  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cdfc943a-f5fb-36e5-b593-d73755ba3729",
      "dc:description": {
        "de": [
          "Das Bowlingcenter von Pontivy bietet 1850 m² Freizeitmöglichkeiten und liegt an der Ausfahrt von Pontivy in Richtung Vannes.\nEin Privatparkplatz mit 100 Plätzen, klimatisierte Räume und verschiedene Freizeitsportarten...\nBowling, Laser-Game, Bar, Billards.\n\nSchließzeiten je nach Besucheraufkommen."
        ],
        "en": [
          "The Pontivy bowling alley offers 1,850 m² of leisure facilities, located just outside Pontivy in the direction of Vannes.\nPrivate parking for around a hundred cars, air-conditioned rooms and a range of leisure sports...\nBowling, Laser-Game, Bar, Billiards.\n\nClosing times according to attendance."
        ],
        "it": [
          "Il bowling di Pontivy offre 1850 m² di strutture per il tempo libero, alle porte di Pontivy, sulla strada per Vannes.\nUn parcheggio privato con un centinaio di posti, sale climatizzate e vari sport per il tempo libero...\nBowling, Laser-Game, Bar, Biliardo.\n\nOrari di chiusura in base all'affluenza."
        ],
        "fr": [
          "Le bowling de Pontivy c'est 1850 m² de loisirs, situé à la sortie de Pontivy, direction de Vannes. \nUn parking privé d'une centaine de places, des salles climatisées et différents sports de loisirs.. \nBowling, Laser-Game, Bar, Billards.\n\nHoraires de fermeture selon affluence."
        ],
        "es": [
          "La bolera de Pontivy ofrece 1850 m² de instalaciones de ocio, a las afueras de Pontivy, camino de Vannes.\nUn aparcamiento privado con un centenar de plazas, salas climatizadas y diversos deportes de ocio...\nBolera, Laser-Game, Bar, Billar.\n\nHorarios de cierre en función de la afluencia."
        ],
        "nl": [
          "De bowlingbaan van Pontivy biedt 1850 m² aan recreatiemogelijkheden, net buiten Pontivy op de weg naar Vannes.\nEen privéparkeerplaats met ongeveer honderd plaatsen, zalen met airconditioning en verschillende recreatieve sporten...\nBowling, Lasergame, Bar, Biljart.\n\nSluitingstijden afhankelijk van de opkomst."
        ]
      },
