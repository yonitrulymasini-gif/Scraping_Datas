  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/38e67907-8139-339e-ab41-d1abfa28612b",
      "dc:description": {
        "de": [
          "Parkplatz am Ortseingang, Slipanlage, Erste-Hilfe-Station, Fahrrinne für Boote, bewachter Badebereich im Sommer (Juli und August).\r\n\r\nRollstuhl für Behinderte am Strand, Plattform mit Sprungbrett, Beachvolleyballfeld, Bootsverleih. Öffentliche Toiletten."
        ],
        "en": [
          "Parking at the entrance to the village, slipway, first-aid post, channel for boats, supervised bathing area in summer (July and August).\r\n\r\nWheelchair beach access, diving platform, beach volleyball court, boat hire. Public toilets."
        ],
        "it": [
          "Parcheggio all'ingresso del villaggio, scivolo, posto di primo soccorso, canale per le imbarcazioni, zona balneare sorvegliata in estate (luglio e agosto).\r\n\r\nAccesso alla spiaggia per sedie a rotelle, piattaforma per immersioni, campo da beach volley, noleggio barche. Servizi igienici pubblici."
        ],
        "fr": [
          "Parking à l’entrée du bourg, cale de mise à l’eau, poste de secours, chenal pour les bateaux, zone de baignade surveillée en été juillet et août. \r\n\r\nFauteuil handi-plage, plate-forme avec plongeoir, terrain de beach volley, location de bateaux. Toilettes publiques."
        ],
        "nl": [
          "Parkeerplaats bij de ingang van het dorp, scheepshelling, eerstehulppost, kanaal voor boten, bewaakt zwemgedeelte in de zomer (juli en augustus).\r\n\r\nToegang tot het strand voor rolstoelgebruikers, duikplatform, beachvolleybalveld, bootverhuur. Openbare toiletten."
        ],
        "es": [
          "Aparcamiento a la entrada del pueblo, varadero, puesto de socorro, canal para embarcaciones, zona de baño vigilada en verano (julio y agosto).\r\n\r\nAcceso a la playa en silla de ruedas, plataforma de buceo, pista de voley playa, alquiler de embarcaciones. Aseos públicos."
        ]
      },
