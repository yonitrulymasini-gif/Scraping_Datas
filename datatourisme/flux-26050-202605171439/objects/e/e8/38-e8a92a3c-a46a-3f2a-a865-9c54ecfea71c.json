  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ab7af3b2-b5e7-32c6-b7de-2a237b07d820",
      "dc:description": {
        "de": [
          "Modernes und gemütliches bretonisches Bauernhaus von 130 m², das 10 Personen beherbergen kann. Das Haus befindet sich in der Nähe von Malestroit. Der Ort ist ideal, um das Herz der Bretagne zu entdecken und gleichzeitig in einem funktionalen Ferienhaus mit allem Komfort zu wohnen."
        ],
        "en": [
          "Warm, modern 130 m² Breton farmhouse for 10 people. The house is located near Malestroit. It's the ideal place to discover the heart of Brittany while staying in a functional, comfortable gîte."
        ],
        "it": [
          "Moderno e accogliente casale bretone di 130 m² per 10 persone. La casa si trova vicino a Malestroit. È il luogo ideale per scoprire il cuore della Bretagna soggiornando in un gîte funzionale e confortevole."
        ],
        "fr": [
          "Longère bretonne moderne et chaleureuse de 130 m² pouvant accueillir 10 personnes. La maison se situe près de Malestroit. L'endroit est idéal pour découvrir le coeur de la Bretagne tout en logeant dans un gîte fonctionnel et tout confort."
        ],
        "nl": [
          "Moderne, gezellige Bretonse boerderij van 130 m² voor 10 personen. Het huis ligt in de buurt van Malestroit. Het is de ideale plek om het hart van Bretagne te ontdekken tijdens een verblijf in een functionele, comfortabele gîte."
        ],
        "es": [
          "Granja bretona moderna y acogedora de 130 m² para 10 personas. La casa está situada cerca de Malestroit. Es el lugar ideal para descubrir el corazón de Bretaña mientras se aloja en una casa rural funcional y confortable."
        ]
      },
