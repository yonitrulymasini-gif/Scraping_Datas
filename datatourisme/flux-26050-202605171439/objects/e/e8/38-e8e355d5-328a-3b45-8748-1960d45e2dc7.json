  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b486e0ea-ceec-3b16-b034-1dac316a12b5",
      "dc:description": {
        "de": [
          "Sie werden die Ruhe und Stille des Ortes mit Blick auf die umliegenden Felder, Wälder und Heideflächen genießen. Der Zigeunerwagen ist mit einer Kochnische, einem Badezimmer und einer Trockentoilette ausgestattet."
        ],
        "en": [
          "You'll appreciate the peace and quiet, with views over the surrounding fields, woods and moors. The caravan is equipped with a kitchenette, shower room and dry toilet."
        ],
        "it": [
          "Vi piacerà la pace e la tranquillità, con vista sui campi, i boschi e le brughiere circostanti. La roulotte è dotata di un angolo cottura, di un bagno con doccia e di una toilette asciutta."
        ],
        "fr": [
          "Vous apprécierez le calme et la tranquillité du lieu avec sa vue sur les champs, les bois et les landes alentour. La roulotte est équipée d’un coin cuisine, d’une salle d’eau et de toilettes sèches."
        ],
        "es": [
          "Le encantará la paz y la tranquilidad, con vistas a los campos, bosques y páramos de los alrededores. La caravana está equipada con cocina americana, cuarto de ducha y aseo seco."
        ],
        "nl": [
          "Je zult genieten van de rust en stilte, met uitzicht over de omliggende velden, bossen en heidevelden. De caravan is uitgerust met een kitchenette, doucheruimte en droogtoilet."
        ]
      },
