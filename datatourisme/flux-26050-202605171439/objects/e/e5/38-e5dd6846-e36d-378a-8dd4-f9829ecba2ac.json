      "@id": "https://data.datatourisme.fr/f975629a-4c5e-3a9e-b3b1-cafcb7298a40",
      "dc:description": {
        "de": [
          "Workshop zur Herstellung einer traditionellen Galette. Lassen Sie uns über Ernährung sprechen und Rezepte rund um die Galette austauschen. Herstellung, Backen auf dem Holzfeuer und Verkostung."
        ],
        "en": [
          "Traditional galette-making workshop. Let's talk about food and exchange recipes around the galette. Production, wood-fired cooking and tasting."
        ],
        "it": [
          "Laboratorio di preparazione di galette tradizionali. Parliamo di cibo e scambiamo ricette intorno alla galette. Preparate la vostra, cuocetela sul fuoco a legna e assaggiatela."
        ],
        "fr": [
          "Atelier fabrication de galette traditionnelle. Parlons de l’alimentation et échangeons nos recettes autour de la galette. Fabrication, cuisson au feu de bois et dégustation."
        ],
        "nl": [
          "Traditionele workshop galette maken. Laten we praten over eten en recepten uitwisselen rond de galette. Maak je eigen galette, kook op houtvuur en proef."
        ],
        "es": [
          "Taller de elaboración de galettes tradicionales. Hablemos de comida e intercambiemos recetas en torno a la galette. Haga la suya, cocínela al fuego de leña y degústela."
        ]
      },
