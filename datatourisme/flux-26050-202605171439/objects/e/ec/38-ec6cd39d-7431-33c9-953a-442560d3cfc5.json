      "dc:description": {
        "de": [
          "Von 19.00 bis 19.45 Uhr: Einführung in die kubanische Salsa (alle Altersgruppen)\nVon 19.45 bis 00.00 Uhr: Tanzabend mit kubanischer Salsa, Bachata und Kizomba SBK\nMojitos und Pizzas werden vor Ort angeboten (Reservierung erforderlich)\nAbend auf Vorbestellung"
        ],
        "en": [
          "7pm to 7:45pm: Cuban Salsa initiation (all ages)\n7.45pm to midnight: SBK Cuban salsa, bachata and kizomba dance party\nMojitos and pizzas available on site (reservation required)\nEvenings on reservation"
        ],
        "it": [
          "Dalle 19.00 alle 19.45: iniziazione alla salsa cubana (per tutte le età)\nDalle 19.45 a mezzanotte: festa di ballo di salsa cubana, bachata e kizomba di SBK\nMojito e pizza disponibili in loco (su prenotazione)\nSerate su prenotazione"
        ],
        "fr": [
          "De 19h à 19h45 : initiation Salsa cubaine (tout public) \nDe 19h45 à 00h : soirée dansante Salsa cubaine, bachata et kizomba SBK\nMojitos et pizzas proposés sur place (sur réservation)\nSoirée sur réservation"
        ],
        "nl": [
          "19.00 tot 19.45 uur: Cubaanse salsa-initiatie (alle leeftijden)\n19.45 tot middernacht: SBK Cubaans salsa-, bachata- en kizomba-dansfeest\nMojito's en pizza's ter plaatse verkrijgbaar (reserveren noodzakelijk)\nS Avonds op reservering"
        ],
        "es": [
          "19.00 a 19.45 h: Iniciación a la salsa cubana (todas las edades)\nDe 19.45 a medianoche: fiesta de salsa cubana, bachata y kizomba SBK\nMojitos y pizzas disponibles in situ (imprescindible reservar)\nNoches previa reserva"
        ]
      },
