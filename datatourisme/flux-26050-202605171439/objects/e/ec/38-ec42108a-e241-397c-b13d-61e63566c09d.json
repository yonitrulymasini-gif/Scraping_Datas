  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/89f25158-8a64-3dcb-9c79-910a5c873378",
      "dc:description": {
        "de": [
          "Diese helle Wohnung befindet sich im 2. Stock, mitten im Stadtzentrum von Gourin, gegenüber dem Rathaus. Genießen Sie einen Zen-Moment und buchen Sie die Option einer privaten Sauna oder/und einer Wellness-Massage!"
        ],
        "en": [
          "This bright apartment is located on the 2nd floor in the center of Gourin, opposite the town hall. Enjoy a moment of zen by booking a private sauna and/or wellness massage!"
        ],
        "it": [
          "Questo luminoso appartamento si trova al 2° piano, proprio nel centro di Gourin, di fronte al municipio. Godetevi un momento di zen prenotando una sauna privata e/o un massaggio benessere!"
        ],
        "fr": [
          "Cet appartement lumineux, est situé au 2e étage, en plein centre-ville de Gourin, face à la mairie. Profitez d'un moment zen en réservant l'option sauna privatisé ou/et le massage bien-être !"
        ],
        "es": [
          "Este luminoso piso se encuentra en la 2ª planta, en pleno centro de Gourin, frente al ayuntamiento. Disfrute de un momento de zen reservando una sauna privada y/o un masaje de bienestar"
        ],
        "nl": [
          "Dit lichte appartement ligt op de 2e verdieping, midden in het centrum van Gourin, tegenover het gemeentehuis. Geniet van een moment van zen door een privésauna en/of een wellnessmassage te boeken!"
        ]
      },
