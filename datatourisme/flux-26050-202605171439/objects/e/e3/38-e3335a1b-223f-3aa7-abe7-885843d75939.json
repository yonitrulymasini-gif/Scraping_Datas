  "COVID19SpecialMeasures": {
    "de": [
      "- max. 10 Personen\n- hydro-alkoholisches Gel vor dem Betreten des Bootes\n- abstände von 1m auf dem Boot\n- desinfektion des Bootes nach jedem Ausflug\n- desinfektion der gemieteten Ausrüstung nach jedem Taucher (Anzug, Maske, Atemregler, Stab, Block...)"
    ],
    "en": [
      "- 10 people max\n- hydro-alcoholic gel before boarding the boat\n- distances of 1m on the boat\n- disinfection of the boat after each outing\n- disinfection of rental equipment after each diver (wetsuit, mask, regulator, stab, block...)"
    ],
    "it": [
      "- 10 persone al massimo\n- gel idroalcolico prima di salire in barca\n- distanze di 1 m sulla barca\n- disinfezione della barca dopo ogni uscita\n- disinfezione dell'attrezzatura noleggiata dopo ogni immersione (muta, maschera, erogatore, stab, blocco, ecc.)"
    ],
    "fr": [
      "- 10 personnes maxi\n- gel hydro-alcoolique avant de monter dans le bateau\n- distances d'1m sur le bateau\n- désinfection du bateau après chaque sortie\n- desinfection du matériel loué après chaque plongeur (combi, masque, détendeur, stab, bloc...)"
    ],
    "nl": [
      "- maximaal 10 personen\n- hydro-alcoholische gel voordat u aan boord gaat\n- afstanden van 1m op de boot\n- desinfectie van de boot na elk uitstapje\n- desinfectie van de gehuurde uitrusting na elke duiker (wetsuit, masker, ademautomaat, stab, blok, enz.)"
    ],
    "es": [
      "- 10 personas máximo\n- gel hidroalcohólico antes de subir al barco\n- distancias de 1 m en el barco\n- desinfección de la embarcación después de cada salida\n- desinfección del equipo alquilado después de cada inmersión (traje de neopreno, máscara, regulador, puñal, bloque, etc.)"
    ]
  },
