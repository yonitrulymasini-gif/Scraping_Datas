  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f2d630e8-0830-3746-83fd-083d6256e9b3",
      "dc:description": {
        "de": [
          "Bretonische Familien-Crêperie seit 1976. Traditionelle Crêperie und Bistro.\nEine der ältesten Crêperien von Erdeven empfängt Sie in einer freundlichen und entspannten Atmosphäre. Ausstellung alter Postkarten von Erdeven."
        ],
        "en": [
          "Family-run creperie in Brittany since 1976. Traditional creperie and bistro.\nOne of Erdeven's oldest crêperies welcomes you in a friendly, relaxed atmosphere. Exhibition of old Erdeven postcards."
        ],
        "it": [
          "Creperia a conduzione familiare in Bretagna dal 1976. Creperia e bistrot tradizionali.\nUna delle più antiche creperie di Erdeven vi accoglie in un'atmosfera amichevole e rilassata. Mostra di vecchie cartoline di Erdeven."
        ],
        "fr": [
          "Crêperie familiale bretonne depuis 1976. Crêperie traditionnelle et bistrot.\nL'une des plus anciennes crêperies d'Erdeven vous accueille dans une ambiance conviviale et décontractée. Exposition de vieilles cartes postales d'Erdeven."
        ],
        "nl": [
          "Familiebedrijf in Bretagne sinds 1976. Traditionele crêperie en bistro.\nEen van de oudste crêperieën van Erdeven heet u welkom in een vriendelijke en ontspannen sfeer. Tentoonstelling van oude ansichtkaarten van Erdeven."
        ],
        "es": [
          "Crepería familiar en Bretaña desde 1976. Crepería tradicional y bistró.\nUna de las creperías más antiguas de Erdeven le da la bienvenida en un ambiente agradable y relajado. Exposición de postales antiguas de Erdeven."
        ]
      },
