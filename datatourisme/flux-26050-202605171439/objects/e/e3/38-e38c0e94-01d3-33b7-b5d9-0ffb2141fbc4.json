      "dc:description": {
        "de": [
          "Kommen Sie und wohnen Sie in unseren 4 Gästezimmern. Wir bieten Ihnen ein Zimmer, das für Personen mit eingeschränkter Mobilität zugänglich ist, mit angrenzendem Badezimmer."
        ],
        "en": [
          "Come and stay in our 4 guest rooms. We offer a room accessible to people with reduced mobility, with an en-suite bathroom."
        ],
        "it": [
          "Venite a soggiornare nelle nostre 4 camere per gli ospiti. Abbiamo una camera accessibile alle persone a mobilità ridotta, con bagno privato."
        ],
        "fr": [
          "Venez résider dans nos 4 chambres d'hôtes. Nous vous proposons une chambre accessible aux personnes à mobilité réduite avec sa salle de bain attenante."
        ],
        "es": [
          "Venga a alojarse en nuestras 4 habitaciones. Disponemos de una habitación accesible para personas con movilidad reducida, con baño en suite."
        ],
        "nl": [
          "Kom overnachten in onze 4 gastenkamers. We hebben een kamer die toegankelijk is voor mensen met beperkte mobiliteit, met een eigen badkamer."
        ]
      },
