  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0b838a75-01ef-392d-9cf4-ae8a135615de",
      "dc:description": {
        "de": [
          "\"Musikalische Poesie im Rhythmus der Liebe und der sie bewegenden Gemütszustände\"\nEine Carte blanche für Adeline Haudiquet, eine Künstlerin, die regelmäßig an den Apéros Klam teilnimmt, und die dieses Mal als Solokünstlerin mit Stimme und Gitarre auftritt."
        ],
        "en": [
          "\"Poetry set to music to the rhythm of love and the moods that drive it\".\nA carte blanche for Adeline Haudiquet, a regular performer at the Apéros Klam, who will be appearing solo this time with voice and guitar."
        ],
        "it": [
          "\"Poesia musicata al ritmo dell'amore e degli stati d'animo che lo animano\"\nUna carta bianca per Adeline Haudiquet, interprete abituale dell'Apéros Klam, che questa volta si presenterà da sola con voce e chitarra."
        ],
        "fr": [
          "\"Poésie mise en musique au rythme de l'Amour et de ses états 'âme qui l'animent\"\nUne carte blanche à Adeline Haudiquet, artiste habituée des Apéros Klam, et qui se représentera cette fois en solo voix et guitare."
        ],
        "es": [
          "\"Poesía musicada al ritmo del amor y de los estados de ánimo que lo impulsan\"\nUna carta blanca para Adeline Haudiquet, intérprete habitual de Apéros Klam, que se presenta esta vez en solitario con voz y guitarra."
        ],
        "nl": [
          "\"Poëzie op muziek op het ritme van de liefde en de stemmingen die haar drijven\"\nEen carte blanche voor Adeline Haudiquet, een vaste artieste in de Apéros Klam, die deze keer solo optreedt met zang en gitaar."
        ]
      },
