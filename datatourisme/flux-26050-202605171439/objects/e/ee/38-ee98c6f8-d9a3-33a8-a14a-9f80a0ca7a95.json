  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e744d8cf-df0d-3c54-ab7b-40606bd69e7b",
      "dc:description": {
        "de": [
          "Bruno und Sylvie bieten Ihnen jeden Mittag von Montag bis Freitag eine traditionelle hausgemachte Küche an (abends, an Wochenenden und Feiertagen auf Reservierung für Gruppen).\nZwischen Weihnachten und dem 31. Dezember geschlossen."
        ],
        "en": [
          "Bruno and Sylvie serve traditional home cooking every lunchtime from Monday to Friday (evenings, weekends and public holidays by prior arrangement for groups).\nClosed between Christmas and December 31st."
        ],
        "it": [
          "Bruno e Sylvie propongono una cucina casalinga tradizionale tutti i pranzi dal lunedì al venerdì (serate, fine settimana e giorni festivi su prenotazione per i gruppi).\nChiuso tra Natale e il 31 dicembre."
        ],
        "fr": [
          "Bruno et Sylvie vous proposent une cuisine traditionnelle maison, tous les midis du lundi au vendredi (soirs, week-ends et jours fériés sur réservation pour les groupes). \nFermé entre Noël et le 31 décembre."
        ],
        "es": [
          "Bruno y Sylvie sirven cocina casera tradicional todos los mediodías de lunes a viernes (noches, fines de semana y festivos previa concertación para grupos).\nCerrado entre Navidad y el 31 de diciembre."
        ],
        "nl": [
          "Bruno en Sylvie serveren traditionele huisgemaakte gerechten elke lunch van maandag tot vrijdag (avonden, weekenden en feestdagen op afspraak voor groepen).\nGesloten tussen Kerstmis en 31 december."
        ]
      },
