      "dc:description": {
        "de": [
          "Von 16:30 bis 17:00 Uhr - Auditorium.\nEntdecken Sie Filmmusik, die vom Kammermusikensemble der interkommunalen Musikschule Dan ar Braz neu interpretiert wird.\nDer Eintritt ist frei. Für alle Altersgruppen"
        ],
        "en": [
          "4:30 pm to 5 pm - auditorium.\nDiscover film music revisited by the Dan ar Braz chamber music ensemble.\nFree admission. Open to all"
        ],
        "it": [
          "Dalle 16.30 alle 17.00 - auditorium.\nScoprite la musica da film rivisitata dall'ensemble di musica da camera della Scuola intercomunale di musica Dan ar Braz.\nIngresso libero. Aperto a tutti"
        ],
        "fr": [
          "De 16h30 à 17h - auditorium.\nDécouvrez des musiques de films revisitées par l’ensemble de musique de chambre de l'École de musique intercommunale Dan ar Braz. \nEntrée libre. Tout public"
        ],
        "nl": [
          "16.30 tot 17.00 uur - auditorium.\nOntdek opnieuw bekeken filmmuziek door het kamermuziekensemble van de Intercommunale Muziekschool Dan ar Braz.\nGratis toegang. Voor iedereen toegankelijk"
        ],
        "es": [
          "16.30 a 17.00 h - auditorio.\nDescubra la música de cine revisitada por el conjunto de música de cámara de la Escuela Intercomunal de Música Dan ar Braz.\nEntrada gratuita. Abierto a todos"
        ]
      },
