  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cbed4288-0870-3877-ae4a-6b7058eaf5e1",
      "dc:description": {
        "de": [
          "In einer gemütlichen Atmosphäre empfängt Sie Dam?Oui mit saisonal wechselnden Speisen, frischen Produkten und Inspirationen von hier und anderswo."
        ],
        "en": [
          "In a warm setting, Dam?Oui welcomes you to a restaurant that changes with the seasons, using fresh produce and inspiration from near and far."
        ],
        "it": [
          "In un ambiente caldo e accogliente, Dam?Oui vi dà il benvenuto in un ristorante che cambia con le stagioni, utilizzando prodotti freschi e ispirazioni da vicino e da lontano."
        ],
        "fr": [
          "Dans un cadre chaleureux Dam’Oui  vous accueille pour une restauration qui varie au gré des saisons avec des produits frais et des inspirations d’ici et d’ailleurs."
        ],
        "nl": [
          "In een warme en gastvrije omgeving verwelkomt Dam Oui je in een restaurant dat met de seizoenen mee verandert, met verse producten en inspiratie van heinde en verre."
        ],
        "es": [
          "En un ambiente cálido y acogedor, Dam?Oui le da la bienvenida a un restaurante que cambia con las estaciones, utilizando productos frescos e inspiración de cerca y de lejos."
        ]
      },
      "@type": [
        "Description"
