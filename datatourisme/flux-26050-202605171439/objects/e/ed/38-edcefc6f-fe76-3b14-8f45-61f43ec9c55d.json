      "dc:description": {
        "de": [
          "Im Land von Planturlure erforschen wir das Geheimnis von Gewürzen, Pflanzen und Blumen, um Farben entstehen zu lassen? Komm und male deinen natürlichen Regenbogen! Um 14 Uhr."
        ],
        "en": [
          "In the land of Planturlure, we explore the secret of using spices, plants and flowers to bring colors to life? Come and paint your own natural rainbow! 2pm."
        ],
        "it": [
          "Nella terra di Planturlure, esploriamo il segreto dell'uso di spezie, piante e fiori per creare colori? Venite a dipingere il vostro arcobaleno naturale! Ore 14.00."
        ],
        "fr": [
          "En contrée de Planturlure, on explore le secret des épices, des plantes et des fleurs pour faire naître des couleurs… Viens peindre ton arc-en-ciel naturel ! A 14h."
        ],
        "nl": [
          "In het land van Planturlure onderzoeken we het geheim van het gebruik van kruiden, planten en bloemen om kleuren te creëren? Kom en schilder je eigen natuurlijke regenboog! 14.00 uur."
        ],
        "es": [
          "En la tierra de Planturlure, exploramos el secreto de utilizar especias, plantas y flores para crear colores.. ¡Ven a pintar tu propio arco iris natural! A las 14 horas."
        ]
      },
