      "dc:description": {
        "de": [
          "Die Workshops\nZahlreiche Workshops werden vom Patiau zum Modellieren, Dekorieren auf Steingut für jedes Publikum (Erwachsene und Kinder) angeboten."
        ],
        "en": [
          "Workshops\nLe Patiau offers a wide range of workshops in earthenware modeling and decoration for adults and children alike."
        ],
        "it": [
          "Laboratori\nLe Patiau offre una serie di laboratori di modellazione e decorazione della terracotta per adulti e bambini."
        ],
        "fr": [
          "Les Ateliers\nDe nombreux ateliers sont proposés par le Patiau de modelage, de décoration sur faïence pour tout public (adultes et enfants)."
        ],
        "nl": [
          "Workshops\nLe Patiau biedt een reeks workshops boetseren en aardewerk decoreren voor zowel volwassenen als kinderen."
        ],
        "es": [
          "Talleres\nLe Patiau ofrece diversos talleres de modelado y decoración en barro para adultos y niños."
        ]
      },
