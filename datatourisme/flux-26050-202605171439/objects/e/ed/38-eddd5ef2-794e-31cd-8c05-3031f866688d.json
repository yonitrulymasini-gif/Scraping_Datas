  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6cb87da9-d00d-3e9c-a0a7-ee0dfbd2b980",
      "dc:description": {
        "de": [
          "Hübsches, gemütliches Zimmer in einer ruhigen Umgebung in Langonnet im Herzen des Pays du Roi Morvan. Hausgemachtes Frühstück, das von Françoise zusammengestellt wurde."
        ],
        "en": [
          "Lovely, warm room in a quiet setting in Langonnet, in the heart of the Pays du Roi Morvan. Home-made breakfast concocted by Françoise."
        ],
        "it": [
          "Camera graziosa e accogliente in un ambiente tranquillo a Langonnet, nel cuore del Pays du Roi Morvan. Colazione fatta in casa da Françoise."
        ],
        "fr": [
          "Jolie chambre chaleureuse dans un environnement calme à Langonnet au cœur du Pays du Roi Morvan. Petit déjeuner maison concocté par Françoise."
        ],
        "nl": [
          "Mooie, gezellige kamer in een rustige omgeving in Langonnet, in het hart van het Pays du Roi Morvan. Zelfgemaakt ontbijt samengesteld door Françoise."
        ],
        "es": [
          "Bonita y acogedora habitación en un entorno tranquilo en Langonnet, en el corazón del Pays du Roi Morvan. Desayuno casero preparado por Françoise."
        ]
      },
