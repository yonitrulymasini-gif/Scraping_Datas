  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cf76fab9-9799-3956-85a5-baa386db8e11",
      "dc:description": {
        "de": [
          "Käse, Wurstwaren, Aperitifbretter, Sahneprodukte, Geschenksets, Weinkeller (Auswahl an Bioweinen), Bier, Tee, Kaffee und Feinkost.\nGeöffnet dienstags von 15 bis 19 Uhr, mittwochs bis samstags von 9:30 bis 12:30 Uhr und von 15 bis 19 Uhr."
        ],
        "en": [
          "Cheeses, charcuterie, aperitif boards, creamery, gift sets, wine cellar (selection of organic wines), beers, teas, coffees and delicatessen.\nOpen Tuesdays from 3pm to 7pm, Wednesdays to Saturdays from 9:30am to 12:30pm and from 3pm to 7pm."
        ],
        "it": [
          "Formaggi, salumi, aperitivi, cremeria, confezioni regalo, cantina (selezione di vini biologici), birre, tè, caffè e gastronomia.\nAperto il martedì dalle 15.00 alle 19.00, dal mercoledì al sabato dalle 9.30 alle 12.30 e dalle 15.00 alle 19.00."
        ],
        "fr": [
          "Fromages, charcuteries, planches apéritives, crémerie, coffrets cadeaux, cave à vins (sélection de vins bio), bières, thés, cafés et épicerie fine.\nOuvert le mardi de 15h à 19h, du mercredi au samedi de 9h30 à 12h30 et de 15h à 19h."
        ],
        "es": [
          "Quesos, embutidos, platos de aperitivo, cremería, cajas de regalo, bodega (selección de vinos ecológicos), cervezas, tés, cafés y delicatessen.\nAbierto los martes de 15.00 a 19.00 h, de miércoles a sábado de 9.30 a 12.30 h y de 15.00 a 19.00 h."
        ],
        "nl": [
          "Kazen, vleeswaren, aperitiefschotels, room, geschenkdozen, wijnkelder (selectie biologische wijnen), bieren, thee, koffie en delicatessen.\nGeopend op dinsdag van 15.00 tot 19.00 uur, van woensdag tot zaterdag van 9.30 tot 12.30 uur en van 15.00 tot 19.00 uur."
        ]
      },
