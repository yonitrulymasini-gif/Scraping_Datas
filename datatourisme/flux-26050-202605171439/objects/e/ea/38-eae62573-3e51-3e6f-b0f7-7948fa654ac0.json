      "dc:description": {
        "de": [
          "Ländliche Unterkunft von 91 m², an eine andere Unterkunft angrenzend, mit traditionellen Möbeln ausgestattet, im Körper eines alten Bauernhofs aus dem Jahr 1850 enthalten, auf einem 2 ha großen Grundstück."
        ],
        "en": [
          "91 m² rural gîte, adjoining another gîte, equipped with traditional furniture, set in the body of an old 1850 farmhouse, on 2 ha of land."
        ],
        "it": [
          "Alloggio rurale di 91 m², adiacente a un altro alloggio, arredato con mobili tradizionali, nell'edificio principale di un'antica fattoria del 1850, su un terreno di 2 ettari."
        ],
        "fr": [
          "Gîte rural de 91 m², mitoyen à un autre gîte, équipé de meubles traditionnels, compris dans le corps d'une ancienne ferme de 1850, sur un terrain de 2 ha."
        ],
        "nl": [
          "Landelijke gîte van 91 m², grenzend aan een andere gîte, ingericht met traditioneel meubilair, in het hoofdgebouw van een oude boerderij uit 1850, op een terrein van 2 ha."
        ],
        "es": [
          "Casa rural de 91 m², contigua a otra casa rural, equipada con mobiliario tradicional, en el edificio principal de una antigua granja de 1850, situada en 2 ha de terreno."
        ]
      },
