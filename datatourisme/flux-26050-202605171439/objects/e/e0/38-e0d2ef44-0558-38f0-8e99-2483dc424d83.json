  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7ab86615-e246-32f4-94e9-f56676d8ff72",
      "dc:description": {
        "de": [
          "Ruhe und Charme entfalten sich im Clos de Cogrenne. Das klassische bretonische Haus in der Ortschaft Beignon liegt inmitten eines wunderschönen Blumengartens."
        ],
        "en": [
          "Tranquillity and charm blossom at Clos de Cogrenne. In the village of Beignon, this classic Breton house nestles in the heart of a superb flower garden."
        ],
        "it": [
          "Tranquillità e fascino sbocciano al Clos de Cogrenne. Nella città di Beignon, questa classica casa bretone è immersa nel cuore di un superbo giardino fiorito."
        ],
        "fr": [
          "Tranquillité et charme s'épanouissent au Clos de Cogrenne. Dans le bourg de Beignon, la maison bretonne de facture classique se niche au cœur d'un superbe jardin fleuri."
        ],
        "es": [
          "Tranquilidad y encanto florecen en Clos de Cogrenne. En la ciudad de Beignon, esta clásica casa bretona se encuentra en el corazón de un magnífico jardín de flores."
        ],
        "nl": [
          "Rust en charme bloeien op in Clos de Cogrenne. In het marktstadje Beignon ligt dit klassieke Bretonse huis in het hart van een prachtige bloementuin."
        ]
      },
