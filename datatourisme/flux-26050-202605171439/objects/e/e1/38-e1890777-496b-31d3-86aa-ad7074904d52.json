  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c77ed0fe-245b-33db-9cf9-e47fe1f71e66",
      "dc:description": {
        "de": [
          "MAISON CLEME ET LUMINEUSE - Das 2019 renovierte Haus liegt mitten auf dem Land, 5 km von La Gacilly entfernt. Terrasse, großer Garten, Hof/Parkplatz, Grill, 2 Küchen...Ruhige und grüne Umgebung."
        ],
        "en": [
          "QUIET AND BRIGHT HOUSE - Renovated house 2019 located in the heart of the countryside, 5 km from La Gacilly. Terrace, large garden, courtyard/parking area, barbecue, 2 kitchens...Quiet, leafy setting."
        ],
        "it": [
          "CASA SILENZIOSA E LUMINOSA - Casa ristrutturata 2019 situata nel cuore della campagna, a 5 km da La Gacilly. Terrazza, ampio giardino, cortile/parcheggio, barbecue, 2 cucine, ecc. Ambiente tranquillo e verdeggiante."
        ],
        "fr": [
          "MAISON CALME ET LUMINEUSE - Maison rénovée 2019 située en plein coeur de la campagne, à 5 km de La Gacilly. Terrasse, grand jardin, cour/parking, barbecue, 2 cuisines...Environnement calme et verdoyant."
        ],
        "nl": [
          "STIL EN BRIGHT HUIS - Gerenoveerd huis 2019 gelegen in het hart van het platteland, op 5 km van La Gacilly. Terras, grote tuin, binnenplaats/parkeerplaats, barbecue, 2 keukens, enz. Rustige, groene omgeving."
        ],
        "es": [
          "CASA TRANQUILA Y BRILLANTE - Casa renovada 2019 situada en el corazón del campo, a 5 km de La Gacilly. Terraza, gran jardín, patio/aparcamiento, barbacoa, 2 cocinas, etc. Entorno tranquilo y frondoso."
        ]
      },
