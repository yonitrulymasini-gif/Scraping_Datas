  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f9d1fcf0-6401-3925-88a4-626e8e09c8a7",
      "dc:description": {
        "de": [
          "200 m von der Freizeitanlage des Lac de Bel Air entfernt, Ausgangspunkt für Wanderrouten. 30 Minuten von Lorient entfernt ... Entdecken Sie die Bretagne, ihr reiches Kulturerbe, ihre authentischen und wilden Landschaften. Über ein ruhiges und komfortables Zimmer verfügen. Reichhaltiges Frühstück zu einer von Ihnen gewünschten Uhrzeit."
        ],
        "en": [
          "200 m from the Lac de Bel Air leisure center, starting point for hiking trails. 30 min from Lorient ... Discover Brittany, its rich heritage and authentic, unspoilt landscapes. Enjoy a quiet, comfortable room. Hearty breakfast at the time of your choosing."
        ],
        "it": [
          "A 200 m dal centro ricreativo Lac de Bel Air, punto di partenza di numerosi sentieri escursionistici. A 30 minuti da Lorient ... Scoprite la Bretagna, il suo ricco patrimonio e i suoi paesaggi autentici e incontaminati. Una camera tranquilla e confortevole. Colazione abbondante all'ora che preferite."
        ],
        "fr": [
          "A 200 m de la base de loisirs du lac de Bel Air, point de départ de circuits de randonnée. A 30 min de Lorient ... Découvrir la Bretagne, son riche patrimoine, ses paysages authentiques et sauvages. Disposer d'une chambre calme et confortable. Petit déjeuner copieux à l'heure que vous souhaitez."
        ],
        "nl": [
          "Op 200 m van het recreatiecentrum Lac de Bel Air, vertrekpunt van een aantal wandelroutes. 30 minuten van Lorient ... Ontdek Bretagne, zijn rijke erfgoed en authentieke, ongerepte landschappen. Een rustige, comfortabele kamer. Uitgebreid ontbijt op een moment dat het u schikt."
        ],
        "es": [
          "A 200 m del centro de ocio Lac de Bel Air, punto de partida de numerosas rutas de senderismo. A 30 minutos de Lorient ... Descubra Bretaña, su rico patrimonio y sus paisajes auténticos y vírgenes. Una habitación tranquila y confortable. Desayuno abundante a la hora que más le convenga."
        ]
      },
      "@type": [
        "Description"
      ],
