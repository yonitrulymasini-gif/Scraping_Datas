      "dc:description": {
        "de": [
          "Entdecken Sie eine Sammlung von Pop'up-Märchenbüchern und -Alben, die von Julien Laparade, einem Pop'Up-Spezialisten und -Liebhaber, ausgeliehen wurden. Zu sehen während der Öffnungszeiten der Mediathek. Kostenlos."
        ],
        "en": [
          "Discover a collection of Pop'up storybooks and albums, on loan from Julien Laparade, Pop'Up specialist and enthusiast. On display during library opening hours. Free admission."
        ],
        "it": [
          "Scoprite una collezione di libri e album di storie Pop'up, prestati da Julien Laparade, specialista e appassionato di Pop'up. In mostra durante gli orari di apertura della biblioteca. Ingresso libero."
        ],
        "fr": [
          "Découvrez une collection de livres et albums de contes Pop'up, prêtée par Julien Laparade, spécialiste et passionné de Pop'Up. Visible aux horaires d'ouverture de la médiathèque. Gratuit."
        ],
        "nl": [
          "Ontdek een verzameling Pop'up-verhalenboeken en -albums, uitgeleend door Julien Laparade, een Pop'Up-specialist en -liefhebber. Te bezichtigen tijdens openingsuren van de bibliotheek. Gratis toegang."
        ],
        "es": [
          "Descubra una colección de libros y álbumes de cuentos Pop'up, prestados por Julien Laparade, especialista y entusiasta del Pop'Up. Expuesta durante las horas de apertura de la biblioteca. Entrada gratuita."
        ]
      },
