      "@id": "https://data.datatourisme.fr/2e02c82b-e8d7-373c-b034-e2851ea46b58",
      "dc:description": {
        "de": [
          "Armelle Farrell Fremdenführer Dolmetscher (Englisch) Natur und Kulturerbe. Geführte Besichtigungen der Halbinsel Rhuys und ihrer Umgebung für Gruppen und Einzelpersonen, ganzjährig geöffnet, Gruppentarif ab 10 Personen: 150 €/Halbtag, 280 €/Tag."
        ],
        "en": [
          "Armelle Farrell Guide Interpreter (English) Nature and Heritage. Guided tours of the Rhuys Peninsula and its region, for groups and individuals. Open all year round. Group rates from 10 people: 150 €/half day, 280 €/day."
        ],
        "it": [
          "Armelle Farrell Interprete di guida (inglese) Natura e patrimonio. Visite guidate alla penisola di Rhuys e alla sua regione, per gruppi e singoli, aperte tutto l'anno. Tariffe per gruppi a partire da 10 persone: 150 €/mezza giornata, 280 €/giorno."
        ],
        "fr": [
          "Armelle Farrell Guide Interprète (Anglais) Nature et Patrimoine. Visites guidées sur la Presqu'île de Rhuys et sa région, pour les groupes et individuels.Ouvert toute l'année.Tartif groupe à partir de 10 personnes : 150 €/demi- journée, 280 €/journée."
        ],
        "es": [
          "Armelle Farrell Guía Intérprete (inglés) Naturaleza y Patrimonio. Visitas guiadas a la península de Rhuys y su región, para grupos y particulares. Abierto todo el año. Tarifas para grupos a partir de 10 personas: 150€/medio día, 280€/día."
        ],
        "nl": [
          "Armelle Farrell Gids Tolk (Engels) Natuur en Erfgoed. Rondleidingen op het schiereiland Rhuys en zijn regio, voor groepen en individuen. Het hele jaar geopend. Groepstarieven vanaf 10 personen: 150 €/halve dag, 280 €/dag."
        ]
      },
