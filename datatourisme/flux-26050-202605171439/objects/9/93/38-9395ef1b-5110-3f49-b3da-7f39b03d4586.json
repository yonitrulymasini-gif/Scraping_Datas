  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/661dce2f-542a-3187-9b05-b43f3d088518",
      "dc:description": {
        "de": [
          "Domäne, die auf mehr als 2 Hektar Grün und Authentizität mit Ruhe und Gelassenheit angesiedelt ist. Die Miete ermöglicht Ihnen den Zugang zu verschiedenen Bereichen: beheiztes Hallenbad, Spielzimmer, Tierpark..."
        ],
        "en": [
          "Estate set in more than 2 hectares of greenery and authenticity with calm and serenity. Rentals include access to a heated indoor swimming pool, games room, animal park..."
        ],
        "it": [
          "Una tenuta immersa in oltre 2 ettari di verde e autenticità, che offre pace e tranquillità. Il noleggio dà accesso a una serie di strutture: piscina interna riscaldata, sala giochi, parco animali, ecc."
        ],
        "fr": [
          "Domaine implanté sur plus de 2 hectares de verdure et d'authenticité avec calme et sérénité. La location vous donne accès à différents espaces : piscine couverte et chauffée, salle de jeux, parc animalier..."
        ],
        "es": [
          "Una finca situada en más de 2 hectáreas de verdor y autenticidad, que ofrece paz y tranquilidad. El alquiler le da acceso a una serie de instalaciones: piscina cubierta climatizada, sala de juegos, parque de animales, etc."
        ],
        "nl": [
          "Een landgoed in meer dan 2 hectare groen en authenticiteit, dat rust en stilte biedt. De huur geeft je toegang tot verschillende faciliteiten: verwarmd overdekt zwembad, speelzaal, dierenpark, enz."
        ]
      },
      "@type": [
        "Description"
