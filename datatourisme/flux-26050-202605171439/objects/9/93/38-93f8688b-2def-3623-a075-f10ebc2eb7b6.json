  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ca6b9405-f310-3de4-a618-02d51e05859e",
      "dc:description": {
        "de": [
          "Jeden Freitagabend gibt es Live-Musik im Restaurant des Kasino.\n\nFormel für 30 ? (Hauptgericht + Dessert) + 7 ? als Spielschein geschenkt.\nEntdecken Sie die Band des Tages auf der Website des Kasino: https://quiberon.kasino.bzh/diners-music-live-n768.html\n\nGlücksspiele sind für Personen unter 18 Jahren verboten."
        ],
        "en": [
          "Every Friday evening, live music in the Kasino restaurant.\n\nSet menu at 30? (main course + dessert) + 7? game ticket.\nDiscover the band of the day on the Kasino website: https://quiberon.kasino.bzh/diners-music-live-n768.html\n\nGambling is prohibited for under-18s."
        ],
        "it": [
          "Ogni venerdì sera, musica dal vivo nel ristorante Kasino.\n\nMenù fisso a € 30 (piatto principale + dessert) + € 7 di biglietto gratuito per il gioco.\nScoprite la band del giorno sul sito web di Kasino: https://quiberon.kasino.bzh/diners-music-live-n768.html\n\nIl gioco d'azzardo è vietato ai minori di 18 anni."
        ],
        "fr": [
          "Tous les vendredis soirs, ambiance musicale en Live au restaurant du Kasino. \n\nFormule à  30 € (Plat + Dessert) +  7€ offerts en ticket de jeu. \nDécouvrez le groupe du jour sur le site du Kasino  : https://quiberon.kasino.bzh/diners-music-live-n768.html\n\nLes jeux d'argent sont interdits au moins de 18 ans."
        ],
        "es": [
          "Todos los viernes por la noche, música en directo en el restaurante Kasino.\n\nMenú del día por 30€ (Plato principal + Postre) + 7€ entrada de juego gratis.\nDescubre el grupo del día en la página web de Kasino: https://quiberon.kasino.bzh/diners-music-live-n768.html\n\nEl juego está prohibido para los menores de 18 años."
        ],
        "nl": [
          "Elke vrijdagavond livemuziek in restaurant Kasino.\n\nVast menu voor ? 30 (Hoofdgerecht + Dessert) + ? 7 gratis game ticket.\nOntdek de band van de dag op de Kasino website: https://quiberon.kasino.bzh/diners-music-live-n768.html\n\nGokken is verboden voor jongeren onder de 18 jaar."
        ]
      },
