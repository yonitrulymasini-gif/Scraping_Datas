  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8df77f95-3817-3a05-9dc5-208e86321555",
      "dc:description": {
        "de": [
          "Traditionelle und großzügige Küche. Alle unsere Gerichte sind hausgemacht und bestehen aus hochwertigen Produkten. Angeboten werden traditionelle Gerichte, Burger, vegane Gerichte, Muscheln in der Saison. Pommes frites aus eigener Herstellung. Freitags und samstags Sauerkraut aus dem Meer. Sonnige Terrasse im Innenbereich. Kaminfeuer in der kühleren Jahreszeit."
        ],
        "en": [
          "Generous, traditional cuisine. All our dishes are homemade from quality ingredients. Traditional dishes, burgers, vegan dishes, mussels in season. Home-made fries. Fridays and Saturdays, sauerkraut from the sea. Sunny indoor terrace. Open fire in cooler months."
        ],
        "it": [
          "Cucina generosa e tradizionale. Tutti i nostri piatti sono fatti in casa con prodotti di qualità. Offriamo piatti tradizionali, hamburger, piatti vegani e cozze di stagione. Patatine fritte. Venerdì e sabato, crauti di mare. Terrazza interna soleggiata. Fuoco aperto nei mesi più freddi."
        ],
        "fr": [
          "Cuisine traditionnelle et généreuse. Tous nos plats sont fait maison à partir de produits de qualité. Sont proposés plats traditionnels, burgers, plat végan, moules en saison. Frites maison. Vendredis et samedis, choucroute de la mer. Terrasse intérieure ensoleillée. Feu de cheminée en saison fraiche."
        ],
        "nl": [
          "Genereuze, traditionele keuken. Al onze gerechten zijn huisgemaakt van kwaliteitsproducten. We bieden traditionele gerechten, hamburgers, veganistische gerechten en mosselen in het seizoen. Friet van het huis. Op vrijdag en zaterdag zuurkool uit de zee. Zonnig overdekt terras. Open haard in de koelere maanden."
        ],
        "es": [
          "Cocina generosa y tradicional. Todos nuestros platos son caseros y elaborados con productos de calidad. Ofrecemos platos tradicionales, hamburguesas, platos veganos y mejillones en temporada. Patatas fritas caseras. Viernes y sábados, chucrut del mar. Terraza interior soleada. Chimenea abierta en los meses más fríos."
        ]
      },
