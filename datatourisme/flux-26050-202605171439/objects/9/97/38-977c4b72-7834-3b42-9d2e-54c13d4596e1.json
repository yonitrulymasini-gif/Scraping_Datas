  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/da5784c8-220c-3805-adeb-b5da9ad64a52",
      "dc:description": {
        "de": [
          "Teesalon im Stil eines Flohmarktes.\nKleine Snacks, heiße Schokolade, Tee, Kaffee, Gebäck, Feinschmeckerpausen in einem warmen und gemütlichen Rahmen.\nDas Menü ist à la carte (Getränke, Gerichte und Gebäck von 2,00 Euro bis 9,60 Euro pro Stück)\nVon Dienstag bis Sonntag geöffnet!"
        ],
        "en": [
          "Brocante-style tea room.\nSnacks, hot chocolates, teas, coffees, pastries, gourmet breaks in a warm and cosy setting.\nThe menu is à la carte (drinks, dishes and pastries from 2.00 euros to 9.60 euros each)\nOpen Tuesday to Sunday!"
        ],
        "it": [
          "Sala da tè in stile brocante.\nSpuntini, cioccolate calde, tè, caffè, pasticcini, pause gourmet in un ambiente caldo e accogliente.\nIl menu è à la carte (bevande, piatti e dolci da 2,00 a 9,60 euro ciascuno)\nAperto da martedì a domenica!"
        ],
        "fr": [
          "Salon de thé esprit brocante.\nPetite restauration, chocolats chauds, thés, cafés, pâtisseries, pauses gourmandes dans un cadre chaleureux et cosy.\nLe menu est à la carte (boissons, plats et pâtisseries de 2.00 euros à 9.60 euros l'unité)\nOuvert  du mardi au dimanche !"
        ],
        "nl": [
          "Theesalon in Brocante-stijl.\nSnacks, warme chocolademelk, thee, koffie, gebak, gastronomische breaks in een warme en gezellige omgeving.\nHet menu is à la carte (drankjes, gerechten en gebak van €2,00 tot €9,60 per stuk)\nGeopend van dinsdag tot zondag!"
        ],
        "es": [
          "Salón de té estilo brocante.\nAperitivos, chocolates calientes, tés, cafés, bollería, pausas gastronómicas en un ambiente cálido y acogedor.\nEl menú es a la carta (bebidas, platos y pasteles de 2,00 a 9,60 euros cada uno)\nAbierto de martes a domingo"
        ]
      },
