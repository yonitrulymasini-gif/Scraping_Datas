      "@id": "https://data.datatourisme.fr/a82e6ed1-5c74-3869-b9c5-157514eb7e62",
      "dc:description": {
        "de": [
          "Für Ihren Urlaub mieten Sie ein kleines Haus in der Nähe von Malestroit (petite cité de caractère). Sie können den Kanal von Nantes nach Brest sowie den Grünen Weg genießen."
        ],
        "en": [
          "For your vacations, rent a small house near Malestroit (small town of character). You'll be able to take advantage of the Nantes-Brest canal, as well as the greenway."
        ],
        "it": [
          "Per le vostre vacanze, affittate una piccola casa vicino a Malestroit (una cittadina piena di carattere). Potrete approfittare del canale Nantes-Brest e della greenway."
        ],
        "fr": [
          "Pour vos vacances, location d'une petite maison près de Malestroit (petite cité de caractère). Vous pourrez profiter du canal de Nantes à Brest, ainsi que de la voie verte."
        ],
        "es": [
          "Para sus vacaciones, alquile una casita cerca de Malestroit (una pequeña ciudad llena de carácter). Podrás aprovechar el canal Nantes-Brest y la vía verde."
        ],
        "nl": [
          "Huur voor je vakantie een huisje in de buurt van Malestroit (een karaktervol stadje). Je kunt profiteren van het kanaal Nantes-Brest en de groene weg."
        ]
      },
