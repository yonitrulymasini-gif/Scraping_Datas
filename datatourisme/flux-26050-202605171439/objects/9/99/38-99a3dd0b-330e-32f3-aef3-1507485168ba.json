  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f178fd24-7fde-3d33-90c2-e7a520854f7e",
      "dc:description": {
        "de": [
          "Le Narval empfängt Sie jeden Tag ab 7:30 Uhr und serviert Ihnen Kaffee, Zeitungen und Frühstück. Mittags werden Brasserie und Crêperie serviert. Es werden verschiedene Menüs angeboten, die von 10.50 bis 14.00 Uhr reichen. Le Narval Brasserie - Bar - Tabac - Presse in Carentoir.\nAn Feiertagen geschlossen."
        ],
        "en": [
          "Le Narval welcomes you every day from 7:30 a.m. for coffee, newspapers and breakfast. Lunchtime brasserie and crêperie service. Various formulas from10?50 to 14? Le Narval Brasserie - Bar - Tabac - Presse in Carentoir.\nClosed on public holidays."
        ],
        "it": [
          "Le Narval vi accoglie ogni giorno dalle 7.30 per servirvi caffè, giornali e colazione. Servizio di brasserie e crêperie a pranzo. Sono disponibili varie formule dalle 10.50 alle 14.00. Le Narval Brasserie - Bar - Tabac - Presse a Carentoir.\nChiuso nei giorni festivi."
        ],
        "fr": [
          "Le Narval vous accueille tous les jours dès 7h30 pour vous servir café, journaux, petit déjeuner. Le midi service brasserie et crêperie. Différentes formules proposées qui vont de10€50 à 14€. Le Narval Brasserie - Bar - Tabac - Presse à Carentoir.\nFermé les jours fériés."
        ],
        "nl": [
          "Le Narval verwelkomt je elke dag vanaf 7.30 uur voor koffie, kranten en ontbijt. Brasserie en crêperie service tijdens de lunch. Verschillende formules zijn beschikbaar van 10?50 tot 14? Le Narval Brasserie - Bar - Tabac - Presse in Carentoir.\nGesloten op feestdagen."
        ],
        "es": [
          "Le Narval le recibe todos los días a partir de las 7.30 h para servirle café, prensa y desayuno. Servicio de brasserie y crêperie al mediodía. Varias fórmulas disponibles de 10?50 a 14? Le Narval Brasserie - Bar - Tabac - Presse en Carentoir.\nCerrado los días festivos."
        ]
      },
