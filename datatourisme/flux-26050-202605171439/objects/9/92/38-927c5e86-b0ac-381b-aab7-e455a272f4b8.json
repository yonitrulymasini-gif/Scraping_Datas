  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5a7801f8-730f-3c4c-ae38-398a1dc7a77e",
      "dc:description": {
        "de": [
          "Der Gou-Run-Zik ist ein Lauf im Format eines städtischen Stierkampfs im Stadtzentrum von Gourin, in einer Atmosphäre, die an ein Musikfest erinnert! Es werden verschiedene Lauf- und Walkingstrecken für Erwachsene und Kinder angeboten. Diese 5. Ausgabe wird mit einem Konzert mit Rital-Polak und einem DJ-Abend abgeschlossen. Kleine Speisen und Getränke vor Ort."
        ],
        "en": [
          "The Gou-Run-Zik is an urban corrida-style race in downtown Gourin, with a music festival atmosphere! Different running and walking routes are proposed for adults and children. This 5th edition will close with a concert by Rital-Polak and a DJ party. Light refreshments on site."
        ],
        "it": [
          "La Gou-Run-Zik è una corsa urbana in stile corrida nel centro di Gourin, con un'atmosfera da festival musicale! Sono previsti diversi percorsi di corsa e camminata per adulti e bambini. Questa quinta edizione si concluderà con un concerto di Rital-Polak e una serata con DJ. Rinfreschi leggeri disponibili sul posto."
        ],
        "fr": [
          "La Gou-Run-Zik, c'est une course au format corrida urbaine au centre ville de Gourin, dans une ambiance fête de la musique ! Différents parcours de courses et de marches sont proposés pour les adultes et les enfants. Cette 5e édition sera clôturée par un concert avec Rital-Polak et une soirée DJ. Petite restauration sur place."
        ],
        "es": [
          "La Gou-Run-Zik es una carrera urbana en el centro de Gourin, con ambiente de festival de música Hay diferentes recorridos a pie y a pie para adultos y niños. Esta 5ª edición se clausurará con un concierto de Rital-Polak y una noche de DJ. Habrá refrescos en el lugar."
        ],
        "nl": [
          "De Gou-Run-Zik is een stadsloop in het centrum van Gourin, met de sfeer van een muziekfestival! Er zijn verschillende hardloop- en wandelroutes voor volwassenen en kinderen. Deze 5e editie wordt afgesloten met een concert van Rital-Polak en een DJ-avond. Lichte versnaperingen zijn ter plaatse verkrijgbaar."
        ]
      },
