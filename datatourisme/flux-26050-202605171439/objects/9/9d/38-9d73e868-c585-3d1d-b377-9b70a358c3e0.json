  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/95e02ffe-b46c-35f4-853b-470c9d61db48",
      "dc:description": {
        "de": [
          "4. Ausgabe!\n\nAuf dem Programm stehen:\nVerpflegung vor Ort\nKonzerte und Unterhaltung; Konservatorium für Musik und Tanz der PontivyCommunauté, Apito Batucada und Zadig Bellony (https://www.facebook.com/p/Zadig-Bellony-100052648908782)\nGetränkeausschank\nGute Laune ist garantiert!\nKommen Sie mit Ihrer Familie oder Ihren Freunden und genießen Sie diesen schönen Sommerabend in Neulliac. Wir erwarten Sie zahlreich! Merken Sie sich das Datum in Ihrem Terminkalender vor."
        ],
        "en": [
          "4th edition!\n\nOn the program:\nOn-site catering\nConcerts and entertainment; Conservatoire de musique et de danse de PontivyCommunauté, Apito Batucada and Zadig Bellony (https://www.facebook.com/p/Zadig-Bellony-100052648908782)\nRefreshment bar\nGood mood guaranteed!\nCome and enjoy this summer evening in Neulliac with family and friends. We look forward to seeing you there! Make a note of the date in your diaries."
        ],
        "it": [
          "quarta edizione!\n\nIn programma:\nRistorazione in loco\nConcerti e intrattenimento; Conservatorio di musica e danza di PontivyCommunauté, Apito Batucada e Zadig Bellony (https://www.facebook.com/p/Zadig-Bellony-100052648908782)\nBar di ristoro\nBuon umore garantito!\nVenite con la vostra famiglia o i vostri amici e godetevi una bella serata estiva a Neulliac. Non vediamo l'ora di vedervi! Segnatevi la data in agenda."
        ],
        "fr": [
          "4ème édition !\n\nAu programme :\nRestauration sur place\nConcerts et animations ; Conservatoire de musique et de danse de PontivyCommunauté, Apito Batucada et Zadig Bellony (https://www.facebook.com/p/Zadig-Bellony-100052648908782)\nBuvette\nBonne humeur garantie !\nVenez en famille ou entre amis profiter de cette belle soirée estivale à Neulliac. On vous attend nombreux ! Notez bien la date sur vos agendas."
        ],
        "nl": [
          "4e editie!\n\nOp het programma:\nCatering ter plaatse\nConcerten en entertainment; Conservatoire de musique et de danse de PontivyCommunauté, Apito Batucada en Zadig Bellony (https://www.facebook.com/p/Zadig-Bellony-100052648908782)\nBar\nHumor gegarandeerd!\nKom langs met je familie of vrienden en geniet van een heerlijke zomeravond in Neulliac. We kijken uit naar je komst! Noteer de datum alvast in je agenda."
        ],
        "es": [
          "4ª edición\n\nEn el programa:\nRestauración in situ\nConciertos y espectáculos: Conservatoire de musique et de danse de PontivyCommunauté, Apito Batucada y Zadig Bellony (https://www.facebook.com/p/Zadig-Bellony-100052648908782)\nBar de refrescos\nBuen humor garantizado\nVenga con su familia o sus amigos y disfrute de una agradable velada estival en Neulliac. ¡Le esperamos! Anote la fecha en su agenda."
        ]
      },
