      "@id": "https://data.datatourisme.fr/82d585dc-ab56-3d64-b4ad-24e8d76301ef",
      "dc:description": {
        "de": [
          "\"Die Zen-Haltung, jodhaltige Länge!\"\r\nTaoistisches Qi Gong, Meditation und Energiewanderungen, dynamische Entspannungsübungen und Sophrologie. Energie, Entspannung, Harmonie.\r\nPraktika und Sitzungen für Einzelpersonen oder Gruppen."
        ],
        "en": [
          "\"Zen attitude, iodized longitude!\"\r\nTaoist Qi Gong, meditation and energy walks, dynamic relaxation and sophrology. Energy, relaxation, harmony.\r\nCourses and individual or group sessions."
        ],
        "it": [
          "\"L'atteggiamento Zen, la longitudine iodata!\r\nQi Gong taoista, meditazione e passeggiate energetiche, rilassamento dinamico e sofrologia. Energia, rilassamento, armonia.\r\nCorsi e sessioni individuali o di gruppo."
        ],
        "fr": [
          "\"L'attitude zen, longitude iodée !\"\r\nQi Gong taoïstes, méditation et marches énergétiques, relaxations dynamiques et sophrologie. Energie, détente, harmonie. \r\nStages et séances individuelles ou en groupe."
        ],
        "es": [
          "\"La actitud zen, ¡longitud yodada!\r\nQi Gong taoísta, meditación y paseos energéticos, relajación dinámica y sofrología. Energía, relajación, armonía.\r\nCursos y sesiones individuales o en grupo."
        ],
        "nl": [
          "\"De Zen-houding, gejodeerde lengte!\r\nTaoïstische Qi Gong, meditatie en energiewandelingen, dynamische ontspanning en sofrologie. Energie, ontspanning, harmonie.\r\nCursussen en individuele of groepssessies."
        ]
      },
