  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d7b94ce5-efea-32e9-bf85-d4ac29e8a387",
      "dc:description": {
        "de": [
          "Ronan und Sandrine heißen Sie in diesem wunderschönen Steinhaus herzlich willkommen.\nSchon bei Ihrer Ankunft werden Sie von dem wunderschönen Garten und den mehrfach preisgekrönten Tieren begeistert sein."
        ],
        "en": [
          "Ronan and Sandrine welcome you to this magnificent stone residence.\nAs soon as you arrive, you'll be seduced by the magnificent garden and its prize-winning animals."
        ],
        "it": [
          "Ronan e Sandrine vi danno il benvenuto in questa magnifica residenza in pietra.\nAppena arrivati, sarete sedotti dal magnifico giardino e dai suoi animali premiati."
        ],
        "fr": [
          "Ronan et Sandrine vous accueillent dans cette magnifique demeure en pierre.\nDès votre arrivée, vous serez séduit par ce magnifique jardin et ses animaux, plusieurs fois primés."
        ],
        "es": [
          "Ronan y Sandrine le dan la bienvenida a esta magnífica residencia de piedra.\nNada más llegar, le seducirán el magnífico jardín y sus animales premiados."
        ],
        "nl": [
          "Ronan en Sandrine heten je welkom in dit prachtige stenen huis.\nZodra je aankomt, word je verleid door de prachtige tuin en de bekroonde dieren."
        ]
      },
