  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/776607dd-1308-3004-b1d3-f78428c08c4f",
      "dc:description": {
        "de": [
          "Eingebettet in Saint Philibert zwischen La Trinité sur Mer und dem Golf von Morbihan liegt die Villa Bel Ange, ein charmantes, intimes Hotel mit Meerblick. Elegante Suiten, private Jacuzzis, direkter Zugang zum Wanderweg GR34.\nAlles ist darauf ausgerichtet, Komfort, Ruhe und Diskretion zu bieten."
        ],
        "en": [
          "Nestled in Saint Philibert between La Trinité sur Mer and the Gulf of Morbihan, Villa Bel Ange is a charming, intimate hotel with a sea view. Elegant suites, private Jacuzzis and direct access to the GR34 footpath.\nEverything is designed to offer comfort, calm and discretion."
        ],
        "it": [
          "Situata a Saint Philibert, tra La Trinité sur Mer e il Golfo di Morbihan, Villa Bel Ange è un hotel intimo e affascinante con vista sul mare. Suite eleganti, vasche idromassaggio private e accesso diretto al sentiero GR34.\nTutto è pensato per offrire comfort, calma e discrezione."
        ],
        "fr": [
          "Niché à Saint Philibert entre la Trinité sur Mer et le Golfe du Morbihan, la Villa Bel Ange est un hôtel de charme intimiste avec vue mer. Suites élégantes, jacuzzi privatifs, accès direct au sentier GR34.\nTout est pensé pour offrir confort calme et discrétion."
        ],
        "nl": [
          "Villa Bel Ange, genesteld in Saint Philibert tussen La Trinité sur Mer en de Golf van Morbihan, is een charmant, intiem hotel met uitzicht op zee. Elegante suites, privé jacuzzi's en directe toegang tot het wandelpad GR34.\nAlles is ontworpen om comfort, rust en discretie te bieden."
        ],
        "es": [
          "Enclavado en Saint Philibert, entre La Trinité sur Mer y el golfo de Morbihan, Villa Bel Ange es un hotel íntimo y encantador con vistas al mar. Elegantes suites, jacuzzis privados y acceso directo al sendero GR34.\nTodo está pensado para ofrecer confort, calma y discreción."
        ]
      },
      "@type": [
        "Description"
