  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f8eb0c39-456e-34d1-bf5e-d81298691b22",
      "dc:description": {
        "de": [
          "Dieses helle und geräumige (65 m²) traditionelle bretonische Haus befindet sich am Ende unseres Stein-Langhauses und teilt sich einen gemeinsamen Eingang mit unserem anderen Ferienhaus \"La Petite Grange\"."
        ],
        "en": [
          "Bright and spacious traditional Breton house (65 m²), located at the end of our stone farmhouse and sharing a common entrance with our other gîte \"La Petite Grange\"."
        ],
        "it": [
          "Luminosa e spaziosa casa tradizionale bretone (65 m²), situata all'estremità della nostra casa colonica in pietra e con ingresso comune all'altro gîte \"La Petite Grange\"."
        ],
        "fr": [
          "Maison bretonne traditionnelle lumineuse et spacieuse (65 m²), située à l'extrémité de notre longère en pierre  et partage une entrée commune avec notre autre gîte \"La Petite Grange\"."
        ],
        "es": [
          "Luminosa y espaciosa casa tradicional bretona (65 m²), situada al final de nuestra granja de piedra y que comparte una entrada común con nuestra otra casa rural \"La Petite Grange\"."
        ],
        "nl": [
          "Licht en ruim traditioneel Bretons huis (65 m²), gelegen aan het einde van onze stenen boerderij en met een gemeenschappelijke ingang met onze andere gîte \"La Petite Grange\"."
        ]
      },
