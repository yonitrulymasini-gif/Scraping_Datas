  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0b40ed2f-a8ec-3d49-bfab-f75d7a8b5e94",
      "dc:description": {
        "de": [
          "Gemütliche Wohnung im Herzen der handwerklichen Animationen, des Festivals, der Illuminationen, der Besichtigungen... Diese 40 m² große Wohnung befindet sich im 1. Stock eines Hauses aus Schieferstein und ist für 4 Personen geeignet."
        ],
        "en": [
          "Cosy apartment, located in the heart of craft activities, festivals, illuminations, visits... Located on the 1st floor of a slate stone house, this 40 m² apartment sleeps 4."
        ],
        "it": [
          "Appartamento accogliente, situato nel cuore dell'artigianato locale, delle feste, delle luminarie, delle visite... Situato al 1° piano di una casa in pietra di ardesia, questo appartamento di 40 m² può ospitare 4 persone."
        ],
        "fr": [
          "Appartement cosy, situé au coeur des animations artisanales, festival, illuminations, visites... Situé au 1er étage d'une maison en pierre d'ardoise, cet appartement de 40 m² convient pour 4 personnes."
        ],
        "es": [
          "Piso acogedor, situado en el corazón de la artesanía local, fiestas, iluminaciones, visitas... Situado en la 1ª planta de una casa de piedra de pizarra, este piso de 40 m² tiene capacidad para 4 personas."
        ],
        "nl": [
          "Gezellig appartement, gelegen in het hart van de lokale ambachten, festivals, verlichtingen, bezoeken... Dit appartement van 40 m² bevindt zich op de 1e verdieping van een huis in leisteen en is geschikt voor 4 personen."
        ]
      },
