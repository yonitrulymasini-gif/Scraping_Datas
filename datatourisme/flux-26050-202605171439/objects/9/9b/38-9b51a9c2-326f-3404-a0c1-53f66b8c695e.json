  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/85721418-d902-3916-9f1d-50769b3d238a",
      "dc:description": {
        "de": [
          "Für eine entspannende Pause und ein leckeres Vergnügen ist Sucré et Salé montags bis samstags von 8:30 bis 18:30 Uhr geöffnet. Hier können Sie zu jeder Tageszeit einen Snack zu sich nehmen: Sandwiches, Salate, Paninis, Kuchen, Snacks oder süßes Vergnügen. Dazu wird ein warmes oder kaltes Getränk gereicht."
        ],
        "en": [
          "For a relaxing break and gourmet pleasure, Sucré et Salé is open Monday to Saturday from 8:30am to 6:30pm for a snack at any time of day: sandwiches, salads, paninis, tarts, snacks or sweet treats. All accompanied by a hot or cold drink."
        ],
        "it": [
          "Sucré et Salé è aperto dal lunedì al sabato dalle 8.30 alle 18.30 per uno spuntino in qualsiasi momento della giornata: panini, insalate, panini, crostate, snack o dolci. Il tutto servito con una bevanda calda o fredda."
        ],
        "fr": [
          "Pour une pause détente et plaisir gourmand, Sucré et Salé est ouvert du lundi au samedi de 8h30 à 18h30 pour un encas à toute heure de la journée : sandwichs, salades, paninis, tartes, snack ou plaisir sucré. Le tout accompagné d'une boisson chaude ou froide."
        ],
        "nl": [
          "Sucré et Salé is geopend van maandag tot zaterdag van 8.30 tot 18.30 uur voor een snack op elk moment van de dag: sandwiches, salades, panini's, taartjes, snacks of zoete lekkernijen. Alles geserveerd met een warm of koud drankje."
        ],
        "es": [
          "Sucré et Salé abre de lunes a sábado de 8.30 a 18.30 h para tomar un tentempié a cualquier hora del día: sándwiches, ensaladas, paninis, tartas, bocadillos o dulces. Todo ello servido con una bebida caliente o fría."
        ]
      },
