  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5ff4db51-a2b2-3128-a1ff-516e928aab2c",
      "dc:description": {
        "de": [
          "Das Festival der Legenden kehrt für die dritte Ausgabe zurück! Die Compagnie du Val Morgane lädt Sie am 12., 13. und 14. Juni zu einem Veranstaltungswochenende mit Kunsthandwerkermarkt und bretonischer Zauberei ein!\nFreitag: Keltisches Rockkonzert mit Son ar Dan\nSamstag: mittelalterliches Bankett\nSamstag und Sonntag: Kunsthandwerkermarkt, Autoren- und Illustratorenpol, Vorträge und Animationen!\nDetailliertes Programm folgt."
        ],
        "en": [
          "The Festival of Legends returns for its third edition! The Val Morgane company invites you to a weekend of entertainment on June 12, 13 and 14, with a craft market and Breton enchantment!\nFriday: Celtic rock concert with Son ar Dan\nSaturday: medieval banquet\nSaturday and Sunday: artisans' market, authors' and illustrators' hub, conferences and entertainment!\nDetailed program to follow."
        ],
        "it": [
          "Il Festival delle Leggende torna per la sua terza edizione! L'azienda Val Morgane vi invita a un weekend di intrattenimento il 12, 13 e 14 giugno, con un mercatino dell'artigianato e una fiaba bretone!\nVenerdì: concerto rock celtico con Son ar Dan\nSabato: banchetto medievale\nSabato e domenica: mercatino dell'artigianato, centro autori e illustratori, conferenze e intrattenimento!\nProgramma dettagliato a breve."
        ],
        "fr": [
          "Le Festival des légendes revient pour la troisième édition ! La compagnie du Val Morgane vous invite les 12, 13 et 14 juin pour un weekend d'animations avec marché artisanal et féerie bretonne ! \nVendredi : concert de rock celtique avec Son ar Dan\nSamedi : banquet médiéval\nSamedi et dimanche : marché des artisans, pôle d'auteurs et illustrateurs, conférences et animations !\nProgramme détaillé à venir."
        ],
        "es": [
          "¡Vuelve el Festival de Leyendas en su tercera edición! La compañía Val Morgane le invita a un fin de semana de entretenimiento los días 12, 13 y 14 de junio, con un mercado de artesanía y ¡un cuento de hadas bretón!\nViernes: concierto de rock celta con Son ar Dan\nSábado: banquete medieval\nSábado y domingo: mercado de artesanía, centro de autores e ilustradores, conferencias y animaciones\nPrograma detallado próximamente."
        ],
        "nl": [
          "Het Festival van de Legenden is terug voor zijn derde editie! Het bedrijf Val Morgane nodigt u uit voor een weekend vol entertainment op 12, 13 en 14 juni, met een ambachtelijke markt en een Bretons sprookje!\nVrijdag: Keltisch rockconcert met Son ar Dan\nZaterdag: middeleeuws banket\nZaterdag en zondag: ambachtsmarkt, auteurs- en illustratorencentrum, lezingen en amusement!\nGedetailleerd programma volgt."
        ]
      },
