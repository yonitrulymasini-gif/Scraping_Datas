  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/86ad2cd9-dd5c-3d75-967d-7a2ff61bc5e4",
      "dc:description": {
        "de": [
          "Le Jardin des Chênes empfängt Sie zu einer Reise ins Herz der Landschaft des Morbihan. Inmitten einer grünen Oase voller Ruhe und Gelassenheit erwartet Sie das Gästezimmer für einen Moment des Komforts und der Entspannung. Wir sprechen Englisch und Spanisch."
        ],
        "en": [
          "Le Jardin des Chênes welcomes you on a journey to the heart of the Morbihan countryside. Nestled in a green setting full of calm and serenity, the bed and breakfast awaits you for a moment of comfort and relaxation. We speak English and Spanish."
        ],
        "it": [
          "Le Jardin des Chênes vi accoglie in un viaggio nel cuore della campagna del Morbihan. Immersa in un ambiente verde e ricco di calma e serenità, la camera degli ospiti vi attende per un momento di comfort e relax. Parliamo inglese e spagnolo."
        ],
        "fr": [
          "Le Jardin des Chênes vous accueille pour un voyage au cœur de la campagne morbihannaise. Posée au milieu d'un écrin de verdure rempli de calme et de sérénité, la chambre d'hôtes vous attend pour un moment de confort et de détente. Nous parlons anglais et espagnol."
        ],
        "nl": [
          "Le Jardin des Chênes verwelkomt je op een reis naar het hart van het platteland van Morbihan. Midden in een groene omgeving vol rust en sereniteit, wacht de gastenkamer op je voor een moment van comfort en ontspanning. We spreken Engels en Spaans."
        ],
        "es": [
          "Le Jardin des Chênes le da la bienvenida en un viaje al corazón de la campiña de Morbihan. En medio de un entorno verde lleno de calma y serenidad, la habitación de huéspedes le espera para un momento de confort y relajación. Hablamos inglés y español."
        ]
      },
      "@type": [
