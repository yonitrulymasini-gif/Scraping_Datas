  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b44f63c7-2560-3c50-9205-7ce68f9a7fa5",
      "dc:description": {
        "de": [
          "An Ti Gwenn, La Maison Blanche auf Bretonisch, ist ein charmantes kleines Hotel mit 10 Zimmern, das Sie in seiner grünen Umgebung zwischen den Alignements und dem Meer empfängt. Die Zimmer sind geräumig und verfügen über einen guten Komfort. Der schattige und ruhige Garten erwartet Sie mit seinen Liegestühlen."
        ],
        "en": [
          "An Ti Gwenn, or La Maison Blanche in Breton, is a charming little 10-room hotel that welcomes you to its green setting between the Alignements and the sea. The rooms are spacious and comfortable. The calm, shady garden awaits you with its deckchairs."
        ],
        "it": [
          "An Ti Gwenn, o La Maison Blanche in bretone, è un piccolo hotel di charme con 10 camere, immerso nel verde tra gli Alignements e il mare. Le camere sono spaziose e confortevoli. Il giardino, ombreggiato e tranquillo, vi aspetta con le sue sedie a sdraio."
        ],
        "fr": [
          "An Ti Gwenn, La Maison Blanche, en Breton, est un charmant petit hôtel de 10 chambres qui vous accueille dans son cadre de verdure entre les alignements et la mer. Les chambres, spacieuses, bénéficient d'un bon confort. Le jardin, ombragé et calme, vous attend avec ses transats."
        ],
        "nl": [
          "An Ti Gwenn, of La Maison Blanche in het Bretons, is een charmant klein hotel met 10 kamers, gelegen in weelderig groen tussen de Alignements en de zee. De kamers zijn ruim en comfortabel. De tuin, schaduwrijk en rustig, wacht op je met zijn ligstoelen."
        ],
        "es": [
          "An Ti Gwenn, o La Maison Blanche en bretón, es un pequeño y encantador hotel de 10 habitaciones, situado en una exuberante vegetación entre los Alignements y el mar. Las habitaciones son espaciosas y confortables. El jardín, sombreado y tranquilo, le espera con sus tumbonas."
        ]
      },
      "@type": [
        "Description"
      ],
