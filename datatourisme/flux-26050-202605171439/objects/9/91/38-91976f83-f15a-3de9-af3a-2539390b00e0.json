  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/136a33ec-93a8-391f-bbf6-c4feb5d1ce60",
      "dc:description": {
        "de": [
          "Geräumige und helle Unterkunft in einem traditionellen Bauernhaus aus Stein. Es wurde modernisiert und verfügt über eine elegante Einrichtung, aber es sind noch viele Originalmerkmale der alten Molkerei erhalten."
        ],
        "en": [
          "Spacious, bright gîte in a traditional stone farmhouse. It has been modernized and stylishly furnished, but still retains many of the original features of the former dairy."
        ],
        "it": [
          "Gîte spazioso e luminoso in una tradizionale casa colonica in pietra. È stato modernizzato e arredato con stile, ma conserva ancora molte delle caratteristiche originali dell'antico caseificio."
        ],
        "fr": [
          "Gîte spacieux et lumineux  dans une longère traditionnelle en pierre. Il a été modernisé et dispose d'un aménagement élégant, mais il conserve encore de nombreuses caractéristiques originales de l'ancienne laiterie."
        ],
        "nl": [
          "Ruime, lichte gîte in een traditionele stenen boerderij. Het is gemoderniseerd en stijlvol ingericht, maar heeft nog steeds veel van de originele kenmerken van de voormalige melkerij."
        ],
        "es": [
          "Casa rural espaciosa y luminosa situada en una granja tradicional de piedra. Se ha modernizado y amueblado con estilo, pero conserva muchas de las características originales de la antigua lechería."
        ]
      },
