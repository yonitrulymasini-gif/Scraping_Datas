      "@id": "https://data.datatourisme.fr/0c34f215-173f-3a94-ae8c-a5fd794b7c72",
      "dc:description": {
        "de": [
          "Wir bieten eine traditionelle Küche mit einem Tagesmenü, das nur zum Mittagessen erhältlich ist. Jeden Mittag können Sie frische Gerichte genießen."
        ],
        "en": [
          "We offer traditional cuisine with a daily menu available for lunch only. Every lunchtime, we serve freshly prepared dishes."
        ],
        "it": [
          "Offriamo una cucina tradizionale con un menu giornaliero disponibile solo a pranzo. Ogni pranzo potrete gustare piatti preparati al momento."
        ],
        "fr": [
          "Nous proposons une cuisine traditionnelle avec un menu du jour disponible uniquement pour le déjeuner. Chaque midi, vous pourrez déguster des plats frais."
        ],
        "nl": [
          "We bieden een traditionele keuken met een dagmenu dat alleen voor de lunch beschikbaar is. Elke lunch kun je genieten van vers bereide gerechten."
        ],
        "es": [
          "Ofrecemos cocina tradicional con un menú diario disponible sólo para el almuerzo. Cada mediodía podrá disfrutar de platos recién preparados."
        ]
      },
