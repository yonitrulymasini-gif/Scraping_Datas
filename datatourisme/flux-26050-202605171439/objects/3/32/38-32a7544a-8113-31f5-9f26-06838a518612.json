  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e1507b72-3ef6-3c7b-af3f-0ca679474686",
      "dc:description": {
        "de": [
          "Abgelegenes Ferienhaus ohne Gegenüber, das sich zum Wandern und Angeln eignet: Wanderweg vor Ort, GR 347 in 750 m Entfernung, Canal de Nantes à Brest in 1,5 km Entfernung und der grüne Radweg."
        ],
        "en": [
          "Isolated, unoverlooked gîte ideal for hiking and fishing: hiking trails on site, GR 347 at 750 m, Nantes-Brest Canal at 1.5 km and green cycling path."
        ],
        "it": [
          "Gîte isolato senza vicini, ideale per escursioni e pesca: sentieri escursionistici in loco, GR 347 a 750 m, Canal de Nantes à Brest a 1,5 km e pista ciclabile verde."
        ],
        "fr": [
          "Gîte isolé sans vis-à-vis, propice à la randonnée et à la pêche : chemin de randonnée sur place, GR 347 à 750 m, Canal de Nantes à Brest à 1,5 km et la voie verte cyclable."
        ],
        "nl": [
          "Geïsoleerde gîte zonder buren, ideaal om te wandelen en te vissen: wandelpaden ter plaatse, GR 347 op 750 m, Canal de Nantes à Brest op 1,5 km en groene fietsroute."
        ],
        "es": [
          "Casa rural aislada, sin vecinos, ideal para practicar senderismo y pesca: rutas de senderismo in situ, GR 347 a 750 m, Canal de Nantes à Brest a 1,5 km y ruta verde ciclista."
        ]
      },
