      "dc:description": {
        "de": [
          "Er findet jeden Dienstag- und Samstagmorgen von 9 bis 13 Uhr statt :\n\n- Centre Bourg von September bis Mai.\n- Place De Gaulle von Juni bis August."
        ],
        "en": [
          "It takes place every Tuesday and Saturday morning from 9am to 1pm:\n\n- Centre Bourg from September to May.\n- Place De Gaulle from June to August."
        ],
        "it": [
          "Si svolge ogni martedì e sabato mattina, dalle 9.00 alle 13.00:\n\n- Centre Bourg da settembre a maggio.\n- Place De Gaulle da giugno ad agosto."
        ],
        "fr": [
          "Il se déroule tous les mardis et samedis matin de 9h à 13h :\n\n- Centre Bourg de septembre à mai.\n- Place De Gaulle de juin à août."
        ],
        "es": [
          "Tiene lugar todos los martes y sábados por la mañana, de 9.00 a 13.00 horas:\n\n- Centre Bourg de septiembre a mayo.\n- Place De Gaulle de junio a agosto."
        ],
        "nl": [
          "Het vindt elke dinsdag- en zaterdagochtend plaats van 9.00 tot 13.00 uur:\n\n- Centre Bourg van september tot mei.\n- Place De Gaulle van juni tot augustus."
        ]
      },
