  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/171a1439-9d8c-31fb-ba0c-0e238b39426c",
      "dc:description": {
        "de": [
          "Inmitten einer wohltuenden Natur, oberhalb des Dorfes La Gacilly, öffnet Ihnen La Grée des Landes, das Yves Rocher Eco-Hotel Spa, den Weg zu Ihrem Wohlbefinden. Behandlungen und Schönheitsrituale, Spaziergänge auf Waldwegen..."
        ],
        "en": [
          "La Grée des Landes , Eco-Hotel Spa Yves Rocher, nestled in the heart of nature, on the heights of the village of La Gacilly, opens the way to well-being. Beauty rituals, walks along forest paths..."
        ],
        "it": [
          "Immerso nella natura, sulle alture del villaggio di La Gacilly, La Grée des Landes, l'Eco-Hôtel Spa Yves Rocher apre la strada al benessere. Rituali di bellezza, passeggiate lungo i sentieri della foresta..."
        ],
        "fr": [
          "Lové au cœur d'une nature bienfaisante, sur les hauteurs du village de La Gacilly, La Grée des Landes , Eco- Hôtel Spa Yves Rocher  vous ouvre la voie vers le bien-être. Soin en rituel de beauté, balade par les chemins forestiers..."
        ],
        "nl": [
          "Genesteld in het hart van de natuur, op de hoogten van het dorpje La Gacilly, La Grée des Landes , effent Eco-Hôtel Spa Yves Rocher het pad naar welzijn. Schoonheidsrituelen, wandelingen langs bospaden..."
        ],
        "es": [
          "En plena naturaleza, en las alturas del pueblo de La Gacilly, en La Grée des Landes, el Eco-Hôtel Spa Yves Rocher allana el camino hacia el bienestar. Rituales de belleza, paseos por los senderos del bosque..."
        ]
      },
      "@type": [
        "Description"
