  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e33b1a95-2000-33a2-a63c-96d26ec2b7dd",
      "dc:description": {
        "de": [
          "Restaurant mit Garen am offenen Kamin.\nVon den Geschmäckern der Welt inspirierte Küche, zubereitet mit lokalen Produkten in einem gemütlichen Rahmen.\nTeestube am Sonntag mit hausgemachtem Gebäck.\nReservierung empfohlen."
        ],
        "en": [
          "Fireplace restaurant.\nCuisine inspired by the flavors of the world, prepared with local produce in a warm setting.\nSunday tea room with home-made pastries.\nReservations recommended."
        ],
        "it": [
          "Ristorante Camino.\nCucina ispirata ai sapori del mondo, preparata con prodotti locali in un ambiente accogliente.\nLa domenica sala da tè con dolci fatti in casa.\nSi consiglia la prenotazione."
        ],
        "fr": [
          "Restaurant avec cuissons à la cheminée.\nCuisine inspirée des saveurs du monde, préparée avec des produits locaux dans un cadre chaleureux.\nSalon de thé le dimanche avec pâtisseries maison.\nRéservation conseillée."
        ],
        "es": [
          "Restaurante Chimenea.\nCocina inspirada en los sabores del mundo, elaborada con productos locales en un ambiente cálido.\nSalón de té los domingos con repostería casera.\nSe recomienda reservar."
        ],
        "nl": [
          "Restaurant Fireplace.\nKeuken geïnspireerd door de smaken van de wereld, bereid met lokale producten in een warme omgeving.\nTearoom op zondag met huisgemaakt gebak.\nReserveren aanbevolen."
        ]
      },
      "@type": [
        "Description"
      ],
