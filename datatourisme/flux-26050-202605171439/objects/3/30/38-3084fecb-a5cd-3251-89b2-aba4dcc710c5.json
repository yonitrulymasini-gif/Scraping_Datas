  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/710ab8ec-fec8-342a-8cc2-3bead96374fa",
      "dc:description": {
        "de": [
          "La Cabane à Jo lädt Sie zu dem einfachen Glück ein, Austern zu genießen, die Füße im Wasser zu vergraben und dabei den Blick auf die Austernparks des Po zu genießen."
        ],
        "en": [
          "La Cabane à Jo invites you to enjoy the simple pleasure of tasting oysters, with your feet in the water and a view over the oyster beds of the Po."
        ],
        "it": [
          "La Cabane à Jo vi invita a godere del semplice piacere di degustare ostriche, con i piedi nell'acqua e la vista sui banchi di ostriche del Po."
        ],
        "fr": [
          "La Cabane à Jo vous invite au bonheur simple de déguster des huîtres, les pieds dans l'eau en profitant d'une vue sur les parcs à huîtres du Pô."
        ],
        "nl": [
          "La Cabane à Jo nodigt je uit om te genieten van het eenvoudige plezier van oesters proeven, met je voeten in het water en uitzicht over de oesterbanken van de Po."
        ],
        "es": [
          "La Cabane à Jo le invita a disfrutar del sencillo placer de degustar ostras, con los pies en el agua y vistas a los criaderos de ostras del Po."
        ]
      },
      "@type": [
        "Description"
