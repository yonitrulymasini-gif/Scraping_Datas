  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d1aade5d-c18d-302f-85a9-41dfa4315186",
      "dc:description": {
        "de": [
          "Entdecken Sie die bretonische Kultur durch ihre Sprache!\n\nSie sprechen Bretonisch und suchen Sprecher, mit denen Sie es üben können? Möchten Sie Ihr Bretonisch lernen oder verbessern?\n\nDie Gruppe des Bretonischen Cafés freut sich, Sie zu empfangen und mit Ihnen die bretonische Sprache zu leben!"
        ],
        "en": [
          "Discover Breton culture through language!\n\nDo you speak Breton and are you looking for speakers to practice with? Would you like to learn or improve your Breton?\n\nThe Café Breton group will be delighted to welcome you and bring Breton to life with you!"
        ],
        "it": [
          "Venite a scoprire la cultura bretone attraverso la sua lingua!\n\nParlate il bretone e cercate persone con cui praticarlo? Volete imparare o migliorare il vostro bretone?\n\nIl gruppo del Café Breton sarà lieto di aiutarvi a far vivere il bretone!"
        ],
        "fr": [
          "Venez découvrir la culture bretonne par son langage!\n\nVous parlez breton et chercher des locuteurs avec qui le pratiquer? Vous souhaitez apprendre ou améliorer votre breton?\n\nLe groupe du café breton vous accueille avec plaisir pour faire vivre le breton avec vous!"
        ],
        "es": [
          "Venga a descubrir la cultura bretona a través de su lengua\n\n¿Habla bretón y busca gente con quien practicarlo? ¿Le gustaría aprender o mejorar su bretón?\n\nEl grupo del Café Bretón estará encantado de ayudarle a dar vida al bretón"
        ],
        "nl": [
          "Kom en ontdek de Bretonse cultuur via de taal!\n\nSpreek je Bretons en zoek je mensen om het mee te oefenen? Wil je Bretons leren of je Bretonse taal verbeteren?\n\nDe groep Café Breton helpt je graag om het Bretons tot leven te brengen!"
        ]
      },
