  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b4588357-dc87-3e20-8bd3-3b5629f314e7",
      "dc:description": {
        "de": [
          "La Bâtisse liegt 600 m vom mittelalterlichen Zentrum entfernt. Sie können auch den nahe gelegenen Kanal von Nantes nach Brest nutzen. Die Studios haben ein Schlafzimmer, ein Badezimmer mit Dusche und WC, eine Küchenecke und ein Wohnzimmer."
        ],
        "en": [
          "La Bâtisse is 600 m from the medieval center. You can also take advantage of the nearby Nantes-Brest canal. Studios have a bedroom, shower room and toilet, kitchenette and living room."
        ],
        "it": [
          "La Bâtisse dista 600 m dal centro medievale. Potrete anche approfittare del vicino canale Nantes-Brest. I monolocali sono dotati di camera da letto, doccia e servizi igienici, angolo cottura e soggiorno."
        ],
        "fr": [
          "La Bâtisse est située à 600 m du centre médiéval. Vous pourrez aussi profiter du canal de Nantes à Brest à proximité. Les studios ont une chambre, salle d'eau et wc, coin cuisine et salon."
        ],
        "nl": [
          "La Bâtisse ligt op 600 m van het middeleeuwse centrum. Je kunt ook profiteren van het nabijgelegen kanaal Nantes-Brest. De studio's hebben een slaapkamer, doucheruimte en toilet, kitchenette en woonkamer."
        ],
        "es": [
          "La Bâtisse está a 600 m del centro medieval. También puede disfrutar del cercano canal de Nantes-Brest. Los estudios disponen de dormitorio, cuarto de ducha y aseo, cocina americana y salón."
        ]
      },
