  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/69734953-17b9-392c-aed5-45d0d92a1f7f",
      "dc:description": {
        "de": [
          "La Calèche ist ein Restaurant, eine Bar und ein Tabakladen in Cournon. Wir bieten eine traditionelle, herzhafte Küche. In einer familiären Atmosphäre.\nWir freuen uns darauf, Sie zu empfangen."
        ],
        "en": [
          "La Calèche is a Restaurant, Bar, Tabac located in Cournon. We offer traditional, hearty cuisine. In a family atmosphere.\nWe look forward to welcoming you."
        ],
        "it": [
          "La Calèche è un ristorante, bar e tabaccheria situato a Cournon. Offriamo una cucina tradizionale e sostanziosa. In un'atmosfera familiare.\nSaremo lieti di darvi il benvenuto."
        ],
        "fr": [
          "La Calèche est un Restaurant, Bar, Tabac situé à Cournon. Nous proposons une cuisine traditionnelle, copieuse. Dans une ambiance familiale.\nAu plaisir de vous recevoir."
        ],
        "nl": [
          "La Calèche is een restaurant, bar en tabakswinkel in Cournon. Wij bieden een traditionele, stevige keuken. In een familiale sfeer.\nWe kijken ernaar uit u te verwelkomen."
        ],
        "es": [
          "La Calèche es un restaurante, bar y estanco situado en Cournon. Ofrecemos una cocina tradicional y abundante. En un ambiente familiar.\nEstaremos encantados de recibirle."
        ]
      },
