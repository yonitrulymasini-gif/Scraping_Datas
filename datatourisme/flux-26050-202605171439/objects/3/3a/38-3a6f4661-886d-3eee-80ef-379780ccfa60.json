      "dc:description": {
        "de": [
          "Lehrgang, Verleih, Raid, Kreuzfahrtschule. Katamaran, Jolle, Windsurfen. Unterricht für Einzelpersonen. Parkplatz für Boote. Lagerung von Windsurfbrettern. Ecole Française de Voile (Französische Segelschule) - angeschlossen an den Französischen Segelverband."
        ],
        "en": [
          "Training course, rental, raid, cruising school. Catamaran, dinghy, windsurfing. Private lessons. Boat parking. Storage of windsurfing boards. French Sailing School - affiliated to the French Sailing Federation."
        ],
        "it": [
          "Formazione, noleggio, raid, scuola di crociera. Catamarano, gommone, windsurf. Lezioni private. Parcheggio per le barche. Deposito di tavole da windsurf. Scuola di vela francese - affiliata alla Federazione Francese di Vela."
        ],
        "fr": [
          "Stage, location, raid, école de croisière. Catamaran, dériveur, planche à voile. Cours particuliers. Parking à bateau. Stockage de planche à voile. Ecole Française de Voile - affiliée à la Fédération Française de Voile."
        ],
        "nl": [
          "Opleiding, verhuur, inval, vaarschool. Catamaran, rubberboot, windsurfen. Privélessen. Parkeerplaats voor boten. Opslag van windsurfplanken. Franse Zeilschool - aangesloten bij de Franse Zeil Federatie."
        ],
        "es": [
          "Formación, alquiler, raid, escuela de cruceros. Catamarán, embarcación auxiliar, windsurf. Clases particulares. Aparcamiento para barcos. Almacenamiento de tablas de windsurf. Escuela de Vela Francesa - afiliada a la Federación Francesa de Vela."
        ]
      },
