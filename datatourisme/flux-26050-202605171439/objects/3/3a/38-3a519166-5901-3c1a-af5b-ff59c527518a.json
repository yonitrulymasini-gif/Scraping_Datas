  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d952263b-ac8b-33be-b340-e45c9ac1e4b0",
      "dc:description": {
        "de": [
          "Lage im Herzen des Dorfes und in der Nähe aller Geschäfte. Sie können den Golf von Morbihan in 30 Minuten Entfernung und hübsche Städte mit Charakter (Malestroit...) entdecken"
        ],
        "en": [
          "Located in the heart of the village, close to all amenities. You can discover the Gulf of Morbihan 30 minutes away, as well as pretty character towns (Malestroit...)"
        ],
        "it": [
          "Situato nel cuore del villaggio e vicino a tutti i servizi. Il Golfo di Morbihan è a 30 minuti di distanza, così come le graziose cittadine di carattere (Malestroit, ecc.)"
        ],
        "fr": [
          "Situation en plein coeur du bourg et à proximité de tous les commerces. Vous pourrez découvrir le Golfe du Morbihan à 30 mn et de jolies cités de caractère ( Malestroit...)"
        ],
        "es": [
          "Situado en el corazón del pueblo y cerca de todos los servicios. El golfo de Morbihan está a 30 minutos, así como las bonitas ciudades de carácter (Malestroit, etc.)"
        ],
        "nl": [
          "Gelegen in het hart van het dorp en dicht bij alle voorzieningen. De Golf van Morbihan ligt op 30 minuten afstand, net als de mooie karakteristieke stadjes (Malestroit, etc.)"
        ]
      },
