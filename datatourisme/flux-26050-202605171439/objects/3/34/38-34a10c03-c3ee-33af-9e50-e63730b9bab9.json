  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/24eb6118-38f7-303d-aac1-906569bd66e7",
      "dc:description": {
        "de": [
          "Die in der Zentralbretagne gelegene Biscuiterie Artisanale Guillemot führt seit drei Generationen die Tradition der bretonischen Kekse, bretonischen Kuchen, bretonischen Galettes und Viervierteltörtchen fort. Um die Authentizität unserer reinen Butterkekse zu erhalten, werden keine Konservierungsstoffe verwendet. Die Rohstoffe stammen aus der lokalen Region."
        ],
        "en": [
          "Located in Central Brittany, Biscuiterie Artisanale Guillemot has been perpetuating the tradition of Breton cookies, Breton cakes, Breton galettes and pound cakes for three generations. To ensure the authenticity of our pure-butter cookies, no preservatives are used. Raw materials are sourced locally."
        ],
        "it": [
          "Situata nella Bretagna centrale, la Biscuiterie Artisanale Guillemot perpetua da tre generazioni la tradizione dei biscotti bretoni, delle torte bretoni, delle galettes bretoni e dei plumcake. Per garantire l'autenticità dei nostri biscotti al burro puro, non vengono utilizzati conservanti. Le materie prime sono di provenienza locale."
        ],
        "fr": [
          "Située en Centre Bretagne, la Biscuiterie Artisanale Guillemot perpétue la tradition des biscuits bretons, gâteau breton, galettes bretonnes et quatre-quarts depuis trois générations. Pour avoir l'authenticité de nos biscuits pur beurre, aucun conservateur n'est utilisé. Les matières premières sont issues du terroir local."
        ],
        "es": [
          "Situada en Bretaña Central, la Biscuiterie Artisanale Guillemot perpetúa desde hace tres generaciones la tradición de las galletas, pasteles, galettes y bizcochos bretones. Para garantizar la autenticidad de nuestras galletas de mantequilla pura, no se utilizan conservantes. Las materias primas se obtienen localmente."
        ],
        "nl": [
          "Biscuiterie Artisanale Guillemot, gevestigd in Midden-Bretagne, zet al drie generaties lang de traditie van Bretonse koekjes, Bretonse cakes, Bretonse galettes en pondgebak voort. Om de authenticiteit van onze pure boterkoekjes te garanderen, worden er geen conserveringsmiddelen gebruikt. De grondstoffen zijn afkomstig uit de streek."
        ]
      },
