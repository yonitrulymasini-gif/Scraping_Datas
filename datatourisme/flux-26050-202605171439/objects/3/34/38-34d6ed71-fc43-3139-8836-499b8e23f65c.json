  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e2e06bce-0cae-3119-8be5-b5592cb8b6d4",
      "dc:description": {
        "de": [
          "Im Stadtzentrum, im Herzen des Fotofestivals und der Kunsthandwerker.  Jeden Sonntagabend geschlossen.  Möglichkeit eines Zimmers im Gartengeschoss, in ruhiger Lage."
        ],
        "en": [
          "In the center of town, in the heart of the Photo Festival and arts & crafts.  Closed every Sunday evening.  Rooms available on garden level, in a quiet location."
        ],
        "it": [
          "Nel centro della città, nel cuore del Photo Festival e dell'artigianato.  Chiuso ogni domenica sera.  Possibilità di camera al piano terra, in posizione tranquilla."
        ],
        "fr": [
          "En centre ville, au cœur du Festival Photo et des artisans d'art.  Fermé  tous les dimanches soirs.  Possibilité de chambre en rez de jardin, au calme."
        ],
        "nl": [
          "In het centrum van de stad, in het hart van het fotofestival en de kunstnijverheid.  Elke zondagavond gesloten.  Mogelijkheid voor een kamer op de begane grond, op een rustige locatie."
        ],
        "es": [
          "En el centro de la ciudad, en pleno Festival de Fotografía y artesanía.  Cierra todos los domingos por la noche.  Posibilidad de habitación en la planta baja, en un lugar tranquilo."
        ]
      },
