  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f70269c3-eea5-3de0-a89a-570cf00a955f",
      "dc:description": {
        "de": [
          "Hübsche Wohnung im Hyperzentrum von La Gacilly. \"Le cocon\" ist eine komfortable und liebevoll eingerichtete 1-Zimmer-Wohnung. Parkplätze befinden sich in der Nähe und die Lage im Hyperzentrum ermöglicht es Ihnen, dieses schöne Dorf zu Fuß zu erkunden."
        ],
        "en": [
          "Lovely apartment in the center of La Gacilly, \"Le cocon\" is a comfortable T1 apartment decorated with care. There's plenty of parking nearby, and its position in the center means you can visit this beautiful village on foot."
        ],
        "it": [
          "Grazioso appartamento nel centro di La Gacilly, \"Le Cocon\" è un appartamento T1 confortevole e arredato con gusto. C'è un ampio parcheggio nelle vicinanze e la sua posizione nel centro della città permette di visitare questo bellissimo villaggio a piedi."
        ],
        "fr": [
          "Joli appartement situé dans l'hyper centre de La Gacilly. \"Le cocon\" est un logement T1 confortable et décoré avec soin. Des parkings se situent à proximité et sa position dans l'hyper centre vous permet de visiter ce beau village à pied."
        ],
        "nl": [
          "Le Cocon\" is een mooi appartement in het centrum van La Gacilly. Het is een comfortabel, smaakvol ingericht T1 appartement. Er is voldoende parkeergelegenheid in de buurt en de ligging in het centrum betekent dat je dit prachtige dorp te voet kunt bezoeken."
        ],
        "es": [
          "Le Cocon\" es un bonito apartamento situado en el centro de La Gacilly. Se trata de un apartamento T1 confortable y decorado con gusto. Dispone de aparcamiento en las inmediaciones y, gracias a su situación en el centro de la ciudad, podrá visitar este bonito pueblo a pie."
        ]
      },
      "@type": [
        "Description"
      ],
