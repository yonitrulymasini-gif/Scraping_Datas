  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/fbf46c7c-54c8-38aa-81ef-22412f9e5484",
      "dc:description": {
        "de": [
          "Charmantes Hotel im Herzen des Badeortes, 50 m vom Großen Strand und 150 m von der Anlegestelle entfernt.\nZimmer zur Meerseite mit Balkon oder zur Landseite."
        ],
        "en": [
          "Charming hotel in the heart of the seaside resort, 50 m from the Grande Plage and 150 m from the pier.\nRooms on the sea side with balcony or on the country side."
        ],
        "it": [
          "Hotel di charme nel cuore della località balneare, a 50 m dalla Grande Plage e a 150 m dal molo.\nCamere sul lato mare con balcone o sul lato campagna."
        ],
        "fr": [
          "Hôtel de charme, situé au cœur de la station balnéaire, à 50m de la Grande Plage et 150m de l'embarcadère. \nChambre coté mer avec balcon ou coté pays."
        ],
        "es": [
          "Hotel con encanto en el corazón de la estación balnearia, a 50 m de la Grande Plage y a 150 m del muelle.\nHabitaciones en el lado del mar con balcón o en el lado del campo."
        ],
        "nl": [
          "Charmant hotel in het hart van de badplaats, op 50 m van het Grande Plage en 150 m van de pier.\nKamers aan de zeezijde met balkon of op het platteland."
        ]
      },
      "@type": [
        "Description"
