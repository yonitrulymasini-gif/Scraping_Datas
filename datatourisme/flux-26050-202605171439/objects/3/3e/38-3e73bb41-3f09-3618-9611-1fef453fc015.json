  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7086f87c-a433-339f-b94d-cd23471d73a4",
      "dc:description": {
        "de": [
          "Am Rande des Waldes von Brocéliande und in der Nähe der Militärschulen von St-Cyr Coëtquidan wohnen Sie in diesem schönen Landhaus aus Stein mit einer raffinierten Dekoration."
        ],
        "en": [
          "On the edge of the Brocéliande forest, near the St-Cyr Coëtquidan military academy, stay in this beautifully decorated stone country house."
        ],
        "it": [
          "Ai margini della foresta di Brocéliande, vicino all'accademia militare di St-Cyr Coëtquidan, soggiornate in questa casa di campagna in pietra splendidamente decorata."
        ],
        "fr": [
          "A l’orée de la forêt de Brocéliande, et près des Écoles Militaires de St-Cyr Coëtquidan, séjournez dans cette belle maison de campagne en pierre, à la décoration raffinée."
        ],
        "es": [
          "Al borde del bosque de Brocéliande, cerca de la academia militar de St-Cyr Coëtquidan, alójese en esta casa de campo de piedra bellamente decorada."
        ],
        "nl": [
          "Aan de rand van het bos van Brocéliande, dicht bij de militaire academie van St-Cyr Coëtquidan, verblijf in dit prachtig ingerichte stenen landhuis."
        ]
      },
      "@type": [
        "Description"
