  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bd76cbc5-ad7c-3828-a7ba-262f840e35e8",
      "dc:description": {
        "de": [
          "Restaurant, Weinbar, Tapas. Entdecken Sie unsere hausgemachte Schiefertafelküche: aktuelle Vorschläge, hochwertiges Fleisch, Fisch, Desserts, Salate.\nEine große Auswahl an Weinen aus Frankreich und der Welt."
        ],
        "en": [
          "Restaurant, wine bar, tapas. Discover our home cooking on the slate: suggestions of the moment, quality meats, fish, desserts, salads.\nA wide selection of wines from France and around the world."
        ],
        "it": [
          "Ristorante, enoteca, tapas. Scoprite la nostra cucina casalinga alla lavagna: proposte del momento, carni di qualità, pesce, dessert, insalate.\nUn'ampia selezione di vini francesi e di tutto il mondo."
        ],
        "fr": [
          "Restaurant, bar à vins, tapas. Découvrez notre cuisine maison à l'ardoise : suggestion du moment, viandes de qualité, poissons, desserts, salades. \nUne grande sélection de vins de France et du monde."
        ],
        "es": [
          "Restaurante, bar de vinos, tapas. Descubra nuestra cocina casera en la pizarra: sugerencias del momento, carnes de calidad, pescados, postres, ensaladas.\nAmplia selección de vinos de Francia y del mundo."
        ],
        "nl": [
          "Restaurant, wijnbar, tapas. Ontdek onze thuiskeuken op de lei: suggesties van het moment, kwaliteitsvlees, vis, desserts, salades.\nEen brede selectie wijnen uit Frankrijk en de rest van de wereld."
        ]
      },
