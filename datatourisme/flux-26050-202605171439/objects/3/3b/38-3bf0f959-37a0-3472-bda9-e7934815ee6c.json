  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/67eefa75-19d6-3c30-943c-9479a4c747f1",
      "dc:description": {
        "de": [
          "Hervé Gaultier lädt Sie ein, seine Werke zu entdecken: Farbige Reisen\n\n?? Ein Termin voller Farben\nzögern Sie nicht, durch die Türen der Kapelle zu gehen\n\n? Kommen Sie zahlreich und sagen Sie es weiter!"
        ],
        "en": [
          "Hervé Gaultier invites you to discover his works: Colorful journeys\n\n?? A colorful rendez-vous\nfeel free to come and visit the chapel\n\n? Come one, come all, and spread the word!"
        ],
        "it": [
          "Hervé Gaultier vi invita a scoprire le sue opere: Viaggi colorati\n\n?? Un appuntamento colorato\nnon esitate a venire e a varcare le porte della cappella\n\n? Venite uno, venite tutti, e diffondete la parola!"
        ],
        "fr": [
          "Hervé Gaultier vous invite à découvrir ses œuvres : Voyages colorés\n\n🕰️ Un rendez-vous plein de couleurs\n✨N’hésitez pas à venir passer les portes de la chapelle\n\n📸 Venez nombreux et faites passer le mot !"
        ],
        "es": [
          "Hervé Gaultier te invita a descubrir sus obras: Viajes llenos de color\n\n?? Una cita llena de color\nno dude en venir y atravesar las puertas de la capilla\n\n? Venga uno, vengan todos, ¡y corran la voz!"
        ],
        "nl": [
          "Hervé Gaultier nodigt je uit om zijn werken te ontdekken: Kleurrijke reizen\n\n?? Een kleurrijk rendez-vous\naarzel niet om langs de deuren van de kapel te komen\n\n? Kom allen en vertel het verder!"
        ]
      },
