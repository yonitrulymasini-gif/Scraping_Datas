      "dc:description": {
        "de": [
          "Die Compagnie ARTEMUSIE bietet ein Konzert mit spanischer Musik aus dem Mittelalter und der Renaissance,: La conviviencia\nEva Fogelgesang: Gesang, Harfen, Viola, Saz\nChristophe Deslignes: Gesang, Organetto, Flöten"
        ],
        "en": [
          "Compagnie ARTEMUSIE presents a concert of Spanish music from the Middle Ages and the Renaissance: La conviviencia\nEva Fogelgesang: vocals, harps, fiddle, saz\nChristophe Deslignes: vocals, organetto, flutes"
        ],
        "it": [
          "La Compagnia ARTEMUSIE presenta un concerto di musica spagnola del Medioevo e del Rinascimento: La conviviencia\nEva Fogelgesang: voce, arpe, violino, saz\nChristophe Deslignes: voce, organetto, flauti"
        ],
        "fr": [
          "La Compagnie ARTEMUSIE propose un concert de musiques espagnoles du Moyen-Age et de la Renaissance, : La conviviencia\nEva Fogelgesang : chant, harpes, vièle, saz \nChristophe Deslignes : chant, organetto, flûtes"
        ],
        "es": [
          "La compañía ARTEMUSIE presenta un concierto de música española de la Edad Media y el Renacimiento: La conviviencia\nEva Fogelgesang: canto, arpas, violín, saz\nChristophe Deslignes: canto, organetto, flautas"
        ],
        "nl": [
          "Het gezelschap ARTEMUSIE presenteert een concert met Spaanse muziek uit de Middeleeuwen en de Renaissance: La conviviencia\nEva Fogelgesang: zang, harpen, viool, saz\nChristophe Deslignes: zang, organetto, fluiten"
        ]
      },
