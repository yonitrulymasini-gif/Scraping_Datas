  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e704de4e-4a38-32f1-ac1b-0ca2fe418fa0",
      "dc:description": {
        "de": [
          "Das Restaurant Le Kerchoch befindet sich in der Landschaft von Le Croisty, im Herzen des Pays du Roi Morvan. Das Restaurant ist seit 1987 geöffnet und bietet traditionelle und familiäre Küche in einer freundlichen und herzlichen Atmosphäre. Es gibt Tagesmenüs, Mahlzeiten für Arbeiter und Gruppen. Couscous jeden dritten Donnerstag im Monat."
        ],
        "en": [
          "Restaurant Le Kerchoch is located in the countryside of Le Croisty, in the heart of the Pays du Roi Morvan. The restaurant, open since 1987, offers traditional, family-style cuisine in a warm, friendly atmosphere, with daily menus, worker's meals and group meals. Couscous every 3rd Thursday of the month."
        ],
        "it": [
          "Il ristorante Le Kerchoch si trova nella campagna di Le Croisty, nel cuore della regione del Roi Morvan. Il ristorante, aperto nel 1987, offre una cucina tradizionale e familiare in un'atmosfera calda e accogliente, con menù del giorno, pasti dei lavoratori e pasti di gruppo. Couscous ogni 3° giovedì del mese."
        ],
        "fr": [
          "Le restaurant Le Kerchoch est situé dans la campagne du Croisty, au cœur du Pays du Roi Morvan. Ce restaurant, ouvert depuis 1987, propose une cuisine traditionnelle et familiale dans une ambiance sympathique et chaleureuse en formule menu du jour, repas ouvrier, de groupe. Couscous tous les 3e jeudi du mois."
        ],
        "nl": [
          "Restaurant Le Kerchoch ligt op het platteland van Le Croisty, in het hart van de regio Roi Morvan. Het in 1987 geopende restaurant biedt een traditionele, familiale keuken in een warme en gezellige sfeer, met een dagmenu, arbeidersmaaltijden en groepsmaaltijden. Couscous elke 3e donderdag van de maand."
        ],
        "es": [
          "El restaurante Le Kerchoch está situado en el campo de Le Croisty, en el corazón de la región de Roi Morvan. El restaurante, abierto en 1987, ofrece una cocina tradicional y familiar en un ambiente cálido y acogedor, con menú del día, comidas para trabajadores y comidas para grupos. Cuscús todos los terceros jueves de mes."
        ]
      },
