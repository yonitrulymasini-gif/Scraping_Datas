  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/98361a19-12d0-3b54-963a-3ec641a60b6b",
      "dc:description": {
        "de": [
          "Entdecken Sie dieses Restaurant, das eine traditionelle, hausgemachte Küche aus lokalen Produkten anbietet.\nFeinschmecker finden hier ihr Glück mit den Menüs \"Plaisir\" oder \"Gourmand\"."
        ],
        "en": [
          "Discover this restaurant offering traditional, homemade cuisine based on local produce.\nGourmets will be delighted with the \"Plaisir\" or \"Gourmand\" menus."
        ],
        "it": [
          "Scoprite questo ristorante che offre una cucina tradizionale e casalinga a base di prodotti locali.\nI buongustai saranno deliziati dai menu \"Plaisir\" o \"Gourmand\"."
        ],
        "fr": [
          "Découvrez ce restaurant proposant une cuisine traditionnelle  fait maison à base de produits locaux. \nLes fins gourmets trouveront leur bonheur avec les menus \"Plaisir\" ou \"Gourmand\"."
        ],
        "nl": [
          "Ontdek dit restaurant met een traditionele, huisgemaakte keuken op basis van lokale producten.\nFijnproevers kunnen hun hart ophalen met de menu's \"Plaisir\" of \"Gourmand\"."
        ],
        "es": [
          "Descubra este restaurante de cocina tradicional y casera basada en productos locales.\nLos gourmets quedarán encantados con los menús \"Plaisir\" o \"Gourmand\"."
        ]
      },
