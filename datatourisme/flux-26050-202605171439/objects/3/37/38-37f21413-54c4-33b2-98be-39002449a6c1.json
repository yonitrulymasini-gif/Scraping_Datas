      "@id": "https://data.datatourisme.fr/347939d1-950b-3000-9d3b-1f4f85abfc9f",
      "dc:description": {
        "de": [
          "Im Erdgeschoss eines Bauernhauses, 2-Zimmer-Wohnung, auf dem Bauernhof gelegen.\nIn der Nähe von Stränden- Wochenenden außerhalb der Schulzeit akzeptiert"
        ],
        "en": [
          "Ground floor of a farmhouse, 2-bedroom apartment.\nClose to beaches - Weekends accepted outside school holidays"
        ],
        "it": [
          "Piano terra di una casa colonica, appartamento con 2 camere da letto.\nVicino alle spiagge - Si accettano weekend al di fuori delle vacanze scolastiche"
        ],
        "fr": [
          "Au rdc d'une longère appartement 2 chambres, situé à la ferme.\nProche plages- Week-ends acceptés hors périodes scolaires"
        ],
        "es": [
          "Planta baja de una granja, piso de 2 habitaciones.\nCerca de las playas - Se aceptan fines de semana fuera de vacaciones escolares"
        ],
        "nl": [
          "Begane grond van een boerderij, appartement met 2 slaapkamers.\nDichtbij stranden - Weekenden geaccepteerd buiten schoolvakanties"
        ]
      },
