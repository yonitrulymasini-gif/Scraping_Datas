  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5fb0c649-cc00-36ee-8bc7-5dc98a67db36",
      "dc:description": {
        "de": [
          "Das Restaurant du Casino ist ein idealer Treffpunkt für einen Moment der Entspannung in einer gemütlichen Atmosphäre, in der Ihnen frische lokale und saisonale Produkte angeboten werden.\nDas Restaurant profitiert von einer Außenterrasse mit einem atemberaubenden Blick auf die Salinen von Bréno."
        ],
        "en": [
          "The Restaurant du Casino is the ideal place to relax in a comfortable atmosphere, serving fresh local seasonal produce.\nThe restaurant boasts an outdoor terrace with a breathtaking view of the Bréno salt flats."
        ],
        "it": [
          "Il Restaurant du Casino è il luogo ideale per rilassarsi in un'atmosfera accogliente e serve prodotti freschi locali di stagione.\nIl ristorante dispone di una terrazza esterna con vista mozzafiato sulle saline di Bréno."
        ],
        "fr": [
          "Le Restaurant du Casino est un lieu de rendez-vous idéal pour un moment de détente dans une atmosphère confortable qui vous propose des produits frais locaux et de saison.\nLe restaurant bénéfice d'une terrasse extérieure avec une vue imprenable sur les salines du Bréno."
        ],
        "nl": [
          "Het Restaurant du Casino is de ideale plek om te ontspannen in een gezellige sfeer en serveert verse lokale seizoensproducten.\nHet restaurant heeft een buitenterras met een adembenemend uitzicht op de Bréno zoutpannen."
        ],
        "es": [
          "El Restaurant du Casino es el lugar ideal para relajarse en un ambiente acogedor, sirviendo productos locales frescos de temporada.\nEl restaurante cuenta con una terraza al aire libre con impresionantes vistas a las salinas de Bréno."
        ]
      },
      "@type": [
        "Description"
      ],
