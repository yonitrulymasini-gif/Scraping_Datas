      "dc:description": {
        "de": [
          "? dienstags 9, 16 und 23: Konversation auf Englisch\ndienstag, 23. um 14:30 Uhr: Kaffeeklatsch\nfreitag, 26. um 12:30 Uhr: Musikalische Siesta\nsamstag, den 27. um 11 Uhr: Croc'en bulles ?\n? bis zum 2. Juni: Entdecken Sie das immaterielle Kulturerbe der Bretagne!\n? 20. Mai bis 6. Juni Ausstellung von Janis Aussel, Illustratorin und Regisseurin von Animationsfilmen.\nKostenlos nach Anmeldung. Das gesamte Programm online."
        ],
        "en": [
          "tuesdays 9, 16 and 23: English conversation\ntuesday 23 at 2:30 pm: coffee chat\nfriday 26 at 12:30 pm: musical siesta\nsaturday 27 at 11am: croc'en bulles\nexhibition until June 2: discovering Brittany's intangible cultural heritage\nexhibition from May 20 to June 6 by Janis Aussel, illustrator and animator.\nFree with registration. Full program on line."
        ],
        "it": [
          "martedì 9, 16 e 23: conversazione in inglese\nmartedì 23 alle 14.30: chiacchierata al caffè\nvenerdì 26 alle 12.30: siesta musicale\nsabato 27 alle 11.00: croc'en bulles\nmostra fino al 2 giugno: alla scoperta del patrimonio culturale immateriale della Bretagna\nmostra dal 20 maggio al 6 giugno di Janis Aussel, illustratrice e animatrice.\nGratuito con registrazione. Programma completo online."
        ],
        "fr": [
          "•\tMardis 9, 16 et 23 : conversation en anglais \n•\tMardi 23 à 14h30 : café-causerie\n•\tVendredi 26 à 12h30 : sieste musicale\n•\tSamedi 27 à 11h : croc'en bulles\n•\tExposition jusqu'au 2 juin : à la découverte du patrimoine culturel immatériel en Bretagne\n•\tExposition du 20 mai au 6 juin de Janis Aussel illustratrice et réalisatrice de films d'animation.\nGratuit sur inscription. Tout le programme en ligne."
        ],
        "es": [
          "martes 9, 16 y 23: conversación en inglés\nmartes 23 a las 14.30 h: café tertulia\nviernes 26 a las 12.30 h: siesta musical\n? sábado 27 a las 11h: croc'en bulles\nexposición hasta el 2 de junio: Descubrir el patrimonio cultural inmaterial de Bretaña\nexposición del 20 de mayo al 6 de junio de Janis Aussel, ilustradora y animadora.\nGratuita previa inscripción. Programa completo en línea."
        ],
        "nl": [
          "dinsdag 9, 16 en 23: Engels gesprek\ndinsdag 23 om 14.30 uur: koffiepraatje\nvrijdag 26 om 12.30 uur: muzikale siësta\nzaterdag 27 om 11.00 uur: croc'en bulles\ntentoonstelling tot 2 juni: Ontdekking van het immaterieel cultureel erfgoed van Bretagne\ntentoonstelling van 20 mei tot 6 juni door Janis Aussel, illustrator en animator.\nGratis bij inschrijving. Volledig programma online."
        ]
