  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/24d65432-ae8f-3bb6-96d9-43ad22c89f33",
      "dc:description": {
        "de": [
          "Um der bretonischen Sonne alle Ehre zu machen, ist das Ferienhaus Jaune Bonbon ein kleines, farbenfrohes Haus. Es ist typisch für Morbihan und wurde von uns vollständig renoviert, wobei wir unsere Werte respektiert haben."
        ],
        "en": [
          "In honor of the Breton sun, the gîte Jaune Bonbon is a colorful little house. Typical of the Morbihan region, it has been entirely renovated by us in keeping with our values."
        ],
        "it": [
          "In onore del sole bretone, la gîte Jaune Bonbon è una casetta colorata. Tipica della regione del Morbihan, è stata completamente ristrutturata da noi nel rispetto dei nostri valori."
        ],
        "fr": [
          "Afin de faire honneur au soleil Breton, le gîte Jaune Bonbon est une petite maison haute en couleurs. Typique du Morbihan, elle a été entièrement rénovée par nos soins dans le respect de nos valeurs."
        ],
        "nl": [
          "Ter ere van de Bretonse zon is de gîte Jaune Bonbon een kleurrijk huisje. Typisch voor de regio Morbihan, is het volledig door ons gerenoveerd in overeenstemming met onze waarden."
        ],
        "es": [
          "En honor al sol bretón, la casa rural Jaune Bonbon es una casita colorida. Típica de la región de Morbihan, ha sido completamente renovada por nosotros respetando nuestros valores."
        ]
      },
