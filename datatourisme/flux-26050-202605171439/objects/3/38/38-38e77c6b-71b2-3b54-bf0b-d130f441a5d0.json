  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0fb94c18-98ac-382f-842b-be8a2b5886b1",
      "dc:description": {
        "de": [
          "Ein Markt für Designer zum Thema Märchen und Hexerei in einer ländlichen Umgebung mit abendlicher Beleuchtung. Unterholz, Hohlwege, märchenhafte Dekorationen und Kreative, die Sie in das Land der Legenden entführen werden!"
        ],
        "en": [
          "Fairy-tale and witchcraft-themed creators' market, in a rural setting, with evening illuminations. Undergrowth, sunken lanes, fairy-tale decorations and creators who will take you on a journey to the land of legends!"
        ],
        "it": [
          "Un mercatino dei creatori a tema fiabesco e stregonesco in un ambiente rurale, con illuminazione serale. Sottobosco, vicoli sommersi, decorazioni magiche e designer che vi porteranno in un viaggio nel paese delle leggende!"
        ],
        "fr": [
          "Marché de créateurs sur le thème féérique et sorcellerie, dans un cadre champêtre, avec illuminations en soirée. Sous bois, chemins creux, décorations féériques et créateurs qui sauront vous faire voyager au pays des légendes !"
        ],
        "es": [
          "Un mercado de creadores de cuentos de hadas y brujería en un entorno rural, con iluminación nocturna. Sotobosque, callejuelas hundidas, decoraciones mágicas y diseñadores que le harán viajar al país de las leyendas"
        ],
        "nl": [
          "Een sprookjes- en heksenmarkt in een landelijke omgeving, met avondverlichting. Ondergroei, holle wegen, magische decoraties en ontwerpers die je meenemen op reis naar het land van de legendes!"
        ]
      },
