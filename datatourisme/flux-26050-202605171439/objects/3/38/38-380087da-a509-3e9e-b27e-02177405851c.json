  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/dc269294-6581-3b73-8a33-c7ab68e6824b",
      "dc:description": {
        "de": [
          "Freie Besichtigung des Jardin du Roc'h: Ein Landschaftsraum, der um das Bauernhaus herum strukturiert ist, Staudengarten, die bemerkenswerte alte Eiche, die allein schon einen Umweg wert ist, Palmengarten, kleine Heide mit Blick auf das Evel-Tal, Schiefersteinbruch.\n10-18 Uhr. 4 ? Eintritt. Kostenlos für Kinder unter 14 Jahren."
        ],
        "en": [
          "Free visit of the Jardin du Roc'h: a landscaped area structured around the farmhouse, a perennial garden, the remarkable old oak which alone is worth the detour, the palm grove, the small moor overlooking the Evel valley, the schist quarry.\nopen 10am-6pm. 4? admission. Free for children under 14."
        ],
        "it": [
          "Visita gratuita del Jardin du Roc'h: un'area paesaggistica strutturata intorno alla fattoria, un giardino perenne, la straordinaria quercia secolare che da sola vale la deviazione, il palmeto, la piccola brughiera che domina la valle dell'Evel, la cava di scisto.\naperto dalle 10 alle 18. ingresso 4. Gratuito per i bambini sotto i 14 anni."
        ],
        "fr": [
          "Visite libre du Jardin du Roc'h : un espace paysager structuré autour de la longère, jardin de vivaces, le vieux chêne remarquable qui a lui seul vaut le détour, la palmeraie, la petite lande surplombant la vallée de l'Evel, la carrière de schiste.\n10h-18h. 4€ l'entrée. Gratuit pour le moins de 14 ans."
        ],
        "es": [
          "Visita libre del Jardin du Roc'h: un espacio paisajístico estructurado en torno a la granja, un jardín perenne, el notable roble viejo que por sí solo merece las diversiones, el palmeral, el pequeño páramo que domina el valle de Evel, la cantera de esquisto.\nabierto de 10.00 a 18.00 h. entrada: 4 ¤. Gratuita para menores de 14 años."
        ],
        "nl": [
          "Gratis bezoek aan de Jardin du Roc'h: een aangelegd gebied rond de boerderij, een vaste plantentuin, de opmerkelijke oude eik die alleen al de moeite waard is, het palmbos, de kleine heide met uitzicht op de Evel-vallei, de leisteengroeve.\nopen van 10.00 tot 18.00 uur. 4 entree. Gratis voor kinderen onder de 14 jaar."
        ]
      },
