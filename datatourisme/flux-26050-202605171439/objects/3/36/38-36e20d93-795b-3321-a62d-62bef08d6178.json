  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d2599ead-df3f-340e-a039-f875fd386828",
      "dc:description": {
        "de": [
          "Praxis des Gespannfahrens mit bretonischen Pferden, Kurse für Freizeit oder Wettkampf. Einzel-, Paar- und Vierspännerfahren auf Grasbahn 80mx40m oder auf Wanderwegen. Betreuung BPJPS Gespannfahren."
        ],
        "en": [
          "Driving with Breton horses, lessons for leisure or competition. Single, pair and four-horse hitching on 80mx40m grass quarry or trail. BPJPS harnessing supervision."
        ],
        "it": [
          "Guida con cavalli bretoni, lezioni per il tempo libero o per le competizioni. Guida in carrozza singola, in coppia e a quattro cavalli su un'arena in erba di 80mx40m o su sentieri. Supervisione della bardatura BPJPS."
        ],
        "fr": [
          "Pratique de l'attelage avec des chevaux bretons, cours pour le loisir ou la compétition. Atteler en simple, en paire et à quatre chevaux sur carrière en herbe 80mx40m ou sur chemins de randonnée. Encadrement BPJPS attelage."
        ],
        "nl": [
          "Mennen met Bretonse paarden, lessen voor recreatie of competitie. Enkelspan, tweespan en vierspan mennen op een grasbak van 80mx40m of op wandelpaden. BPJPS-tuigbegeleiding."
        ],
        "es": [
          "Conducción con caballos bretones, clases de ocio o competición. Conducción de carruajes de uno, dos y cuatro caballos en una pista de hierba de 80mx40m o en senderos. Supervisión de enjaezamiento BPJPS."
        ]
      },
