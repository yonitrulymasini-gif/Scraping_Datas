  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/057f2fc6-f269-3585-9c1e-32cb6cd61f6b",
      "dc:description": {
        "de": [
          "Entdecken Sie Ihre Oase der Ruhe im Herzen eines charmanten, authentischen und sehr lebendigen bretonischen Dorfes. Dieses gemütliche und komfortable T2-Apartment, das sich in den ersten Stock eines atypischen baskischen Hauses schmiegt, lädt Sie zu einem einzigartigen Erlebnis ein."
        ],
        "en": [
          "Discover your haven of peace in the heart of a charming, authentic and lively Breton village. This cozy, comfortable T2 apartment, nestled on the second floor of an atypical Basque house, invites you to enjoy a unique experience."
        ],
        "it": [
          "Scoprite la vostra oasi di pace nel cuore di un villaggio bretone affascinante, autentico e vivace. Questo appartamento T2, accogliente e confortevole, situato al primo piano di una casa basca atipica, vi invita a vivere un'esperienza unica."
        ],
        "fr": [
          "Découvrez votre havre de paix au coeur d'un charmant village breton authentique et très vivant. Cet appartement T2 cosy et confortable, niché au premier étage d'une maison atypique basque, vous invite à vivre une expérience unique."
        ],
        "nl": [
          "Ontdek je oase van rust in het hart van een charmant, authentiek en levendig Bretons dorp. Dit gezellige, comfortabele T2-appartement, genesteld op de eerste verdieping van een atypisch Baskisch huis, nodigt je uit voor een unieke ervaring."
        ],
        "es": [
          "Descubra su remanso de paz en el corazón de un encantador, auténtico y animado pueblo bretón. Este acogedor y confortable apartamento T2, ubicado en la primera planta de una atípica casa vasca, le invita a disfrutar de una experiencia única."
        ]
      },
      "@type": [
        "Description"
      ],
