      "@id": "https://data.datatourisme.fr/7dfbb60b-e245-3b8f-ae19-94c2aa5f67db",
      "dc:description": {
        "de": [
          "Um 9 Uhr Geführte Wanderung \"Geschichte des Ortskerns vom 19. Jahrhundert bis heute, Tumulus Saint Michel und die Landschaft von Carnac\". Preis: 6 ?, 3 ? für Mitglieder des Vereins. Dauer: 3 Stunden, ca. 4 km.\nDie Anmeldung muss im Voraus per Telefon erfolgen: 02 97 52 13 52."
        ],
        "en": [
          "9am Guided tour \"History of the town center from the 19th century to the present day, Tumulus Saint Michel and the Carnac countryside\". Price 6? 3? for association members. Duration 3h, approx. 4 km.\nAdvance registration required by telephone: 02 97 52 13 52."
        ],
        "it": [
          "Ore 9 Visita guidata \"Storia del centro città dal XIX secolo a oggi, Tumulo Saint Michel e campagna di Carnac\". Costo: 6 euro, 3 euro per i membri dell'associazione. Durata: 3 ore, circa 4 km.\nÈ necessario iscriversi in anticipo per telefono: 02 97 52 13 52."
        ],
        "fr": [
          "À 9h Sortie commentée «Histoire du centre-bourg du 19ème siècle à nos jours, Tumulus saint Michel et campagne carnacoise ». Tarif 6€, 3€ pour les adhérents de l’association. Durée 3h, environ 4 km. \nL'inscription se fait obligatoirement à l'avance par téléphone : 02 97 52 13 52."
        ],
        "nl": [
          "9 uur Rondleiding \"Geschiedenis van het stadscentrum van de 19e eeuw tot nu, Tumulus Saint Michel en het platteland van Carnac\". Kosten: € 6, € 3 voor leden van de vereniging. Duur: 3 uur, ongeveer 4 km.\nVooraf aanmelden per telefoon: 02 97 52 13 52."
        ],
        "es": [
          "9 h Visita guiada \"Historia del centro de la ciudad desde el siglo XIX hasta nuestros días, Túmulo Saint Michel y paisajes de Carnac\". Coste: 6 euros, 3 euros para los miembros de la asociación. Duración: 3 horas, aprox. 4 km.\nInscripción previa por teléfono: 02 97 52 13 52."
        ]
      },
