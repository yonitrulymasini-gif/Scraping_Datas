  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4b42898f-16bc-323d-b0ab-9845a40228b9",
      "dc:description": {
        "de": [
          "10:30 Uhr: Geführte Besichtigung der Hirschzucht von Kerfulus.\nGeführte Besichtigung des Parks, in dem sich Hirsche, Hirschkühe, Hirschkälber, Damhirsche, Wildschweine... frei bewegen können.  \n\n12.00 Uhr: Mittagessen in einem Partnerrestaurant in Cléguérec.\n\n15 Uhr: Bootsfahrt auf dem Lac de Guerlédan.\nEinschiffung an Bord der Duc de Guerlédan für eine Kreuzfahrt auf dem größten See der Bretagne.  \n\n16.30 Uhr: Ende des Tages."
        ],
        "en": [
          "10:30 am: Guided tour of the Kerfulus deer farm.\nGuided tour of the park, where stags, hinds, fawns, fallow deer, wild boars and more roam freely...  \n\n12pm: Lunch at a partner restaurant in Cléguérec.\n\n3pm: Cruise on Lac de Guerlédan.\nBoard the Duc de Guerlédan for a cruise on Brittany's largest lake.  \n\n4:30pm: End of the day."
        ],
        "it": [
          "10:30: Visita guidata all'allevamento di cervi di Kerfulus.\nVisita guidata del parco, dove cervi, cerbiatti, cerbiatti, daini e cinghiali vagano liberamente...  \n\n12:00: Pranzo in un ristorante convenzionato a Cléguérec.\n\n15.00: Crociera sul Lac de Guerlédan.\nImbarco sulla nave Duc de Guerlédan per una crociera sul lago più grande della Bretagna.  \n\n16.30: Fine della giornata."
        ],
        "fr": [
          "10h30 : Visite Guidée de l’élevage des cerfs de Kerfulus. \nVisite guidée du parc où gambadent en toute liberté : cerfs, biches, faons, daims, sangliers...  \n\n12h : Déjeuner dans un restaurant partenaire à Cléguérec.\n\n15h : Croisière sur le Lac de Guerlédan.\nEmbarquement à bord du Duc de Guerlédan pour une croisière sur le plus grand lac de Bretagne.  \n\n16h30 : Fin de la journée."
        ],
        "nl": [
          "10:30: Rondleiding door de hertenboerderij Kerfulus.\nRondleiding door het park, waar herten, hinden, reekalfjes, damherten en wilde zwijnen vrij rondlopen...  \n\n12.00 uur: Lunch in een partnerrestaurant in Cléguérec.\n\n15.00 uur: Boottocht over het meer van Guerlédan.\nStap aan boord van de Duc de Guerlédan voor een cruise op het grootste meer van Bretagne.  \n\n16.30 uur: Einde van de dag."
        ],
        "es": [
          "10:30 h: Visita guiada de la granja de ciervos de Kerfulus.\nVisita guiada al parque, donde ciervos, ciervas, cervatillos, gamos y jabalíes campan a sus anchas...  \n\n12h: Almuerzo en un restaurante asociado de Cléguérec.\n\n15h: Crucero por el lago de Guerlédan.\nEmbarque en el Duc de Guerlédan para un crucero por el lago más grande de Bretaña.  \n\n16h30: Fin de la jornada."
        ]
      },
