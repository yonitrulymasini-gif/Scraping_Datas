  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c8d59e6f-e7b5-3ab5-930d-9d4eaa3e4d0f",
      "dc:description": {
        "de": [
          "Ideal gelegenes Haus in einem hübschen Dorf, das als Wiege der Marke Yves Rocher und als touristisches Ziel bekannt ist! Gegenüber dem Flusshafen, in der Nähe des Fremdenverkehrsamtes, des Hauses Yves Rocher und aller Geschäfte."
        ],
        "en": [
          "Ideally located in a pretty village, cradle of the Yves Rocher brand and recognized as a tourist destination! Opposite the river port, close to the Tourist Office, Maison Yves Rocher and all amenities."
        ],
        "it": [
          "Situato in posizione ideale in un grazioso villaggio, luogo di nascita del marchio Yves Rocher e riconosciuto come destinazione turistica! Di fronte al porto fluviale, vicino all'Ufficio del Turismo, alla Casa Yves Rocher e a tutti i negozi."
        ],
        "fr": [
          "Maison idéalement située dans  très un joli village, berceau de la Marque Yves Rocher et reconnue comme destination touristique! En face du port fluvial, à proximité de l'Office de Tourisme,  de la Maison Yves Rocher et de tous les commerces."
        ],
        "es": [
          "Idealmente situado en un bonito pueblo, cuna de la marca Yves Rocher y reconocido como destino turístico Frente al puerto fluvial, cerca de la Oficina de Turismo, de la Casa Yves Rocher y de todos los comercios."
        ],
        "nl": [
          "Ideaal gelegen in een mooi dorp, de geboorteplaats van het merk Yves Rocher en erkend als toeristische bestemming! Tegenover de rivierhaven, dicht bij het VVV-kantoor, het Yves Rocher-huis en alle winkels."
        ]
      },
