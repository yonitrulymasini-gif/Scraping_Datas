      "dc:description": {
        "de": [
          "Ausstellung \"Chemin faisant 2000/2026\" von Thierry Le Saëc: Malerei, Zeichnung, Druckgrafik und Künstlerbuch. Vernissage am Samstag, den 9. Mai um 18 Uhr. Treffen mit dem Künstler am Samstag, den 6. Juni nachmittags. Geöffnet von Dienstag bis Samstag von 14:30 bis 18:30 Uhr. Freier Eintritt."
        ],
        "en": [
          "Exhibition \"Chemin faisant 2000/2026\" by Thierry Le Saëc: painting, drawing, print and artist?s book. Opening Saturday, May 9, 6pm. Meet the artist Saturday afternoon, June 6. Open Tuesday to Saturday, 2.30 pm to 6.30 pm. Free admission."
        ],
        "it": [
          "Mostra \"Chemin faisant 2000/2026\" di Thierry Le Saëc: pittura, disegno, stampa e libro d'artista. Inaugurazione sabato 9 maggio alle 18.00. Incontro con l'artista nel pomeriggio di sabato 6 giugno. Aperto da martedì a sabato, dalle 14.30 alle 18.30. Ingresso libero."
        ],
        "fr": [
          "Exposition \"Chemin faisant 2000/2026\" de Thierry Le Saëc : peinture, dessin, estampe et livre d’artiste. Vernissage samedi 9 mai à 18h. Rencontre avec l'artiste samedi 6 juin après-midi. Ouvert du mardi au samedi de 14h30 à 18h30. Entrée libre."
        ],
        "nl": [
          "Tentoonstelling \"Chemin faisant 2000/2026\" van Thierry Le Saëc: schilderij, tekening, prent en kunstenaarsboek. Opening op zaterdag 9 mei om 18.00 uur. Ontmoet de kunstenaar op zaterdagmiddag 6 juni. Geopend van dinsdag t/m zaterdag van 14.30 tot 18.30 uur. Toegang gratis."
        ],
        "es": [
          "Exposición \"Chemin faisant 2000/2026\" de Thierry Le Saëc: pintura, dibujo, grabado y libro de artista. Inauguración el sábado 9 de mayo a las 18.00 h. Encuentro con el artista el sábado 6 de junio por la tarde. Abierto de martes a sábado, de 14.30 a 18.30 h. Entrada gratuita."
        ]
      },
