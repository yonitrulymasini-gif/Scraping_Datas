  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/86b41ded-424a-3035-8d80-fc80cea95136",
      "dc:description": {
        "de": [
          "Rioux Nautique bietet Ihnen eine große Auswahl an Motorbootvermietungen: RIBs und offene Rümpfe der Marken Zodiac und Lomac. Es besteht die Möglichkeit, Wasserskis, Wakeboards und Schleppbojen mit Schnellboot zu mieten."
        ],
        "en": [
          "Rioux Nautique offers a wide range of motorboat rentals: RIBs and open hulls, from Zodiac and Lomac. Possibility of renting water skis, wakeboards and towable buoys with speedboat."
        ],
        "it": [
          "Rioux Nautique offre un'ampia gamma di noleggi di barche a motore: RIB e scafi aperti, Zodiac e Lomac. Possibilità di noleggiare sci d'acqua, wakeboard e boe trainabili con motoscafo."
        ],
        "fr": [
          "Rioux Nautique vous propose un large choix de location de bateaux à moteur : semi-rigides et coques open, des marques Zodiac et Lomac. Possibilité de location de skis nautiques, wakeboards et bouées tractables avec vedette."
        ],
        "es": [
          "Rioux Nautique ofrece una amplia gama de alquiler de embarcaciones a motor: semirrígidas y cascos abiertos, de Zodiac y Lomac. Posibilidad de alquilar esquís acuáticos, wakeboards y boyas remolcables con lancha."
        ],
        "nl": [
          "Rioux Nautique biedt een breed scala aan verhuur van motorboten: RIBs en open rompen, van Zodiac en Lomac. Mogelijkheid tot het huren van waterski's, wakeboards en sleepboeien met speedboot."
        ]
      },
