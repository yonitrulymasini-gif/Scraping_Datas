  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7b2f8fc0-0e46-3ee5-8170-11b01cff25e2",
      "dc:description": {
        "de": [
          "Dieses Cottage mit Steinmauern liegt inmitten eines Gartens in der Landschaft von Carentoir. Sie profitieren von einem Aufstellpool und einem Fahrradverleih, mit dem Sie die Gegend erkunden können."
        ],
        "en": [
          "Stone-walled cottage nestled in a garden in the Carentoir countryside. You'll benefit from an above-ground swimming pool and a bike-lending service to discover the region."
        ],
        "it": [
          "Cottage con pareti in pietra immerso nel cuore di un giardino nella campagna di Carentoir. C'è una piscina fuori terra e un servizio di prestito biciclette per esplorare la regione."
        ],
        "fr": [
          "Cottage aux murs de pierre niché au coeur d'un jardin dans la campagne de Carentoir. Vous bénéficierez d'une piscine hors-sol, d'un service de prêt de vélos pour découvrir la région."
        ],
        "nl": [
          "Natuurstenen huisje genesteld in het hart van een tuin op het platteland van Carentoir. Er is een bovengronds zwembad en je kunt er fietsen lenen om de streek te verkennen."
        ],
        "es": [
          "Casa rural con paredes de piedra situada en el corazón de un jardín en la campiña de Carentoir. Piscina sobre el suelo y servicio de préstamo de bicicletas para descubrir la región."
        ]
      },
