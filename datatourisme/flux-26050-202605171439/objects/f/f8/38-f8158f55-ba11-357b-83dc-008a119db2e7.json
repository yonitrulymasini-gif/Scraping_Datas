      "@id": "https://data.datatourisme.fr/467c5f4c-8aed-39c8-bf90-a3d6ec1ac2d8",
      "dc:description": {
        "de": [
          "Feinkostladen, Gemüse, lokale Produkte, Zusammenstellung von Feinschmeckerkörben, Gartencenter.\nGeöffnet von Montag bis Samstag von 9 bis 12 Uhr und von 14 bis 18.30 Uhr (von März bis Juni von 9 bis 12 Uhr und von 14 bis 19 Uhr)."
        ],
        "en": [
          "Delicatessen, vegetables, local produce, gourmet baskets, garden center.\nOpen Monday to Saturday, 9am to 12pm and 2pm to 6:30pm (March to June, 9am to 12pm and 2pm to 7pm)."
        ],
        "it": [
          "Delicatessen, verdure, prodotti locali, cesti gourmet, garden center.\nAperto dal lunedì al sabato, dalle 9 alle 12 e dalle 14 alle 18.30 (da marzo a giugno, dalle 9 alle 12 e dalle 14 alle 19)."
        ],
        "fr": [
          "Epicerie fine, légumes, produits locaux, composition de paniers gourmands, jardinerie.\nOuvert du lundi au samedi de 9h à 12h et de 14h à 18h30 (de mars à juin de 9h à 12h et de 14h à 19h)."
        ],
        "nl": [
          "Delicatessen, groenten, streekproducten, gourmetmanden, tuincentrum.\nGeopend van maandag tot zaterdag van 9.00 tot 12.00 en van 14.00 tot 18.30 (maart tot juni van 9.00 tot 12.00 en van 14.00 tot 19.00)."
        ],
        "es": [
          "Charcutería, verduras, productos locales, cestas gourmet, centro de jardinería.\nAbierto de lunes a sábado, de 9:00 a 12:00 y de 14:00 a 18:30 (de marzo a junio, de 9:00 a 12:00 y de 14:00 a 19:00)."
        ]
      },
