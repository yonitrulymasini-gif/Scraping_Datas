  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/962de7b3-e2b2-3f3d-a185-92637b6ffbad",
      "dc:description": {
        "de": [
          "Pizzarestaurant in einem gemütlichen und modernen Rahmen mit einer großen Terrasse in der Fußgängerzone. Pizzas auch zum Mitnehmen. Raclette und Savoyer Fondues jedes Wochenende im Winter. In der Nebensaison mittwochs, donnerstags und freitags ganztägig geschlossen. Im Sommer 7 Tage die Woche geöffnet."
        ],
        "en": [
          "Pizzeria-restaurant in warm, modern setting with large terrace on pedestrian street. Takeaway pizzas. Raclettes and Savoyard fondues every weekend in winter. Closed Wednesday, Thursday and Friday all day out of season. Open 7 days a week in summer."
        ],
        "it": [
          "Ristorante pizzeria in un ambiente caldo e moderno con un'ampia terrazza in una strada pedonale. Pizze da asporto. Raclettes e fondute savoiarde ogni fine settimana in inverno. Chiuso mercoledì, giovedì e venerdì tutto il giorno fuori stagione. Aperto 7 giorni su 7 in estate."
        ],
        "fr": [
          "Restaurant pizzéria dans un cadre chaleureux et moderne avec une grande terrasse en rue piétonne. Pizzas à emporter. Raclettes et fondues savoyardes tous les week-ends en hiver. Fermé le mercredi, le jeudi et le vendredi toute la journée hors saison. Ouvert 7 jours sur 7 en été."
        ],
        "nl": [
          "Pizzerierestaurant in een warme, moderne omgeving met een groot terras in een autovrije straat. Pizza's om mee te nemen. Raclettes en Savoyaardse fondues elk weekend in de winter. Buiten het seizoen de hele dag gesloten op woensdag, donderdag en vrijdag. In de zomer 7 dagen per week geopend."
        ],
        "es": [
          "Pizzería restaurante en un ambiente cálido y moderno con una gran terraza en una calle peatonal. Pizzas para llevar. Raclettes y fondues de Saboya todos los fines de semana en invierno. Cerrado miércoles, jueves y viernes todo el día fuera de temporada. Abierto los 7 días de la semana en verano."
        ]
      },
