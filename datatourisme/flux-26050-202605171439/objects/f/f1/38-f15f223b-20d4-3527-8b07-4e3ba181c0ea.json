  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/33e0c8b8-88d5-3c03-9b64-23e20d276032",
      "dc:description": {
        "de": [
          "Die kleine Herrschaft von Lourmel ist vor allem ein Geist, eine Seele und ein Empfang.\nIn unserem großen, prächtigen Gebäude mit einem schönen Turm und einem unbestreitbaren Charme empfangen wir Sie in unseren geräumigen Gästezimmern."
        ],
        "en": [
          "La petite seigneurie de Lourmel is above all a spirit, a soul, a welcome.\nIn our large, magnificent building, with its beautiful tower and undeniable charm, we welcome you to our spacious guest rooms."
        ],
        "it": [
          "La petite seigneurie de Lourmel è soprattutto spirito, anima e accoglienza.\nNel nostro grande e magnifico edificio, con la sua bella torre e il suo innegabile fascino, vi diamo il benvenuto nelle nostre spaziose camere per gli ospiti."
        ],
        "fr": [
          "La petite seigneurie de Lourmel est surtout un esprit, une âme, un accueil.\nDans notre grande et magnifique bâtisse, dotée d'une belle tour et d'un charme incontestable, nous vous recevons dans nos chambres d'hôtes spacieuses."
        ],
        "nl": [
          "La petite seigneurie de Lourmel is vooral een geest, een ziel en een welkom.\nIn ons grote, prachtige gebouw, met zijn prachtige toren en onmiskenbare charme, verwelkomen wij u in onze ruime gastenkamers."
        ],
        "es": [
          "La petite seigneurie de Lourmel es ante todo espíritu, alma y acogida.\nEn nuestro gran y magnífico edificio, con su hermosa torre y su innegable encanto, le damos la bienvenida a nuestras espaciosas habitaciones de huéspedes."
        ]
      },
      "@type": [
        "Description"
      ],
