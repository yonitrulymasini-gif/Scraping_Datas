      "@id": "https://data.datatourisme.fr/212db2bb-9725-33cf-8817-4e8202b4ee47",
      "dc:description": {
        "de": [
          "Der US LA GACILLY CYCLISME organisiert sein erstes halbnächtliches Kriterium in La Gacilly in der Kategorie Open 2/3 Access 1/2. Abfahrt 19:30 Uhr für 32 Runden à 2,78 km. Getränke und Verpflegung vor Ort. Kommen Sie zahlreich."
        ],
        "en": [
          "US LA GACILLY CYCLISME organizes its first semi-nightly criterium in La Gacilly, Open 2/3 Access 1/2 category. Start at 7:30pm for 32 laps of 2.78 km. Refreshments and catering on site. We look forward to seeing you there."
        ],
        "it": [
          "L'US LA GACILLY CYCLISME organizza il suo primo criterium semiserio a La Gacilly nella categoria Open 2/3 Access 1/2. Partenza alle 19.30 per 32 giri di 2,78 km. Ristoro e ristorazione sul posto. Venite e unitevi a noi."
        ],
        "fr": [
          "L'US LA GACILLY CYCLISME organise son premier critérium semi nocturne a la Gacilly catégorie Open 2/3 Access 1/2. Depart 19h30 pour 32 tours de 2,78 km. Buvette et restauration sur place. Venez nombreux."
        ],
        "es": [
          "US LA GACILLY CYCLISME organiza su primer criterium semi-noche en La Gacilly en la categoría Open 2/3 Access 1/2. Salida a las 19h30 para 32 vueltas de 2,78 km. Refrescos y catering in situ. Ven y únete a nosotros."
        ],
        "nl": [
          "US LA GACILLY CYCLISME organiseert zijn eerste semi-nachtelijke criterium in La Gacilly in de categorie Open 2/3 Access 1/2. Start om 19.30 uur voor 32 ronden van 2,78 km. Versnaperingen en catering ter plaatse. Kom en doe mee."
        ]
      },
