  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ce9d3b1c-fd48-3335-ac91-992715058376",
      "dc:description": {
        "de": [
          "Die Crêperie du port liegt an einem charmanten Fußgängerplatz, 150 m vom Grande Plage entfernt, und empfängt Sie im Herzen von Port en Dro.\nHier werden Ihnen Galettes, Crêpes, Muscheln und Salate angeboten. Reservierungen sind im Innenbereich oder auf der Terrasse möglich."
        ],
        "en": [
          "Located on a charming pedestrian square, 150m from the Grande Plage, the Crêperie du Port welcomes you to the heart of Port en Dro.\nGalettes, crêpes, mussels and salads are on offer. Reservations possible indoors or on the terrace."
        ],
        "it": [
          "Situata in un'incantevole piazza pedonale, a 150 metri dalla Grande Plage, la Crêperie du Port vi accoglie nel cuore di Port en Dro.\nVi si trovano galettes, crêpes, cozze e insalate. È possibile prenotare all'interno o sulla terrazza."
        ],
        "fr": [
          "Située sur une charmante place piétonne, à 150m de la Grande Plage, la Crêperie du port vous accueille au cœur de Port en Dro.\nGalettes, crêpes, moules et salades repas vous y seront proposés. Réservation possible en intérieur ou en terrasse."
        ],
        "es": [
          "Situada en una encantadora plaza peatonal, a 150 m de la Grande Plage, la Crêperie du Port le da la bienvenida al corazón de Port en Dro.\nGalettes, crêpes, mejillones y ensaladas. Puede reservar en el interior o en la terraza."
        ],
        "nl": [
          "De Crêperie du Port, gelegen aan een charmant voetgangersplein op 150 meter van het Grande Plage, verwelkomt je in het hart van Port en Dro.\nGalettes, crêpes, mosselen en salades worden hier aangeboden. U kunt binnen of op het terras reserveren."
        ]
      },
      "@type": [
        "Description"
