  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4603273e-5c69-3555-abb9-4249e36de63a",
      "dc:description": {
        "de": [
          "Ein einzigartiges Hotel am Rande des Waldes von Brocéliande, zwischen Landes und Legenden. Eine märchenhafte Umgebung, 10 Zimmer, 1 Apartment, die Natur zum Auftanken und mehr als 800 Spiele, um sich auszupowern..."
        ],
        "en": [
          "A unique hotel on the edge of the Brocéliande forest, between Landes and legends. A magical setting, 10 rooms, 1 apartment, nature to recharge your batteries and over 800 games to keep you active..."
        ],
        "it": [
          "Un hotel unico ai margini della foresta di Brocéliande, tra Landes e leggende. Un ambiente magico, 10 camere, 1 appartamento, la natura per ricaricarsi e oltre 800 giochi per mantenersi attivi..."
        ],
        "fr": [
          "Un hôtel unique à l'orée de la forêt de Brocéliande, entre Landes et légendes. Un cadre féerique, 10 chambres, 1 appartement, la nature pour se ressourcer et plus de 800 jeux pour se dépenser.."
        ],
        "es": [
          "Un hotel único al borde del bosque de Brocéliande, entre Landas y leyendas. Un entorno mágico, 10 habitaciones, 1 apartamento, naturaleza para reponer fuerzas y más de 800 juegos para mantenerse activo..."
        ],
        "nl": [
          "Een uniek hotel aan de rand van het bos van Brocéliande, tussen Landes en legendes. Een magische omgeving, 10 kamers, 1 appartement, natuur om nieuwe energie op te doen en meer dan 800 spelletjes om je actief te houden..."
        ]
      },
      "@type": [
        "Description"
