  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/11e6e051-b168-3391-b2c8-613ef8cdf1a2",
      "dc:description": {
        "de": [
          "Ferienhaus im Zentrum einer charmanten Gemeinde, Einkaufsmöglichkeiten zu Fuß erreichbar. Ideale Lage für zahlreiche Besichtigungen, 20 Minuten von Vannes und dem Golf von Morbihan entfernt."
        ],
        "en": [
          "Gîte located in the center of a charming commune, shops on foot. Ideally located for numerous visits, 20 minutes from Vannes and the Golfe du Morbihan."
        ],
        "it": [
          "Gîte situato nel centro di un incantevole villaggio, con negozi raggiungibili a piedi. In posizione ideale per numerose visite, a 20 minuti da Vannes e dal Golfe du Morbihan."
        ],
        "fr": [
          "Gîte situé dans le centre d'une charmante commune, commerces à pied. Idéalement situé pour de nombreuses visites, à 20 mn de Vannes et du Golfe du Morbihan."
        ],
        "nl": [
          "Gîte gelegen in het centrum van een charmant dorp, met winkels op loopafstand. Ideaal gelegen voor talrijke bezoeken, op 20 minuten van Vannes en de Golfe du Morbihan."
        ],
        "es": [
          "Casa rural situada en el centro de un pueblo encantador, con comercios a poca distancia. Idealmente situado para numerosas visitas, a 20 minutos de Vannes y el Golfe du Morbihan."
        ]
      },
