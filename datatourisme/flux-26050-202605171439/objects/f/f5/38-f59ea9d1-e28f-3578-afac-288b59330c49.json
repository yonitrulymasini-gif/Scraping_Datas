  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4119694a-18ba-30ae-bbfb-98c6a2e4f3c0",
      "dc:description": {
        "de": [
          "Ferienhaus auf dem Land, 5 Min. von Malestroit entfernt, in einem ruhigen Ort in der Nähe des Bauernhofs der Eigentümer. Sie können den Blick auf den Kanal genießen, der nur 20 m entfernt ist."
        ],
        "en": [
          "Country gîte 5 minutes from Malestroit, in a quiet location close to the owners' farm. Enjoy the view of the canal, just 20 m away."
        ],
        "it": [
          "Gîte in campagna a 5 minuti da Malestroit, in posizione tranquilla vicino alla fattoria dei proprietari. Godetevi la vista sul canale, a soli 20 m di distanza."
        ],
        "fr": [
          "Gîte à la campagne à 5 mn de Malestroit, dans un lieu calme à proximité de la ferme des propriétaires. Vous pourrez profiter de la vue sur le canal, qui se trouve à 20 m seulement."
        ],
        "nl": [
          "Gîte op het platteland op 5 minuten van Malestroit, op een rustige locatie dicht bij de boerderij van de eigenaren. Geniet van het uitzicht op het kanaal, op slechts 20 m afstand."
        ],
        "es": [
          "Casa rural en el campo a 5 minutos de Malestroit, en un lugar tranquilo cerca de la granja de los propietarios. Disfrutar de la vista del canal, a sólo 20 m de distancia."
        ]
      },
