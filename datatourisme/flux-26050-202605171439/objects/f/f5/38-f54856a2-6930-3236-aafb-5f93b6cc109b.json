  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c8a3d9b9-b4a5-304a-88d5-3d90a779a89d",
      "dc:description": {
        "de": [
          "Das Ferienhaus Jardin des Chênes nimmt Sie mit auf eine Reise in die Ferne in einer Atmosphäre wie aus Tausendundeiner Nacht. In seiner grünen Umgebung erwartet es Sie für einen magischen Moment voller Ruhe und Gelassenheit. Wir sprechen Englisch und Spanisch."
        ],
        "en": [
          "The Jardin des Chênes gîte takes you on a voyage of discovery in an atmosphere worthy of a thousand and one nights. Surrounded by greenery, it awaits you for a magical moment of calm and serenity. We speak English and Spanish."
        ],
        "it": [
          "Il gîte Jardin des Chênes vi fa viaggiare in un'atmosfera da mille e una notte. Circondata dal verde, vi aspetta per un momento magico pieno di calma e serenità. Parliamo inglese e spagnolo."
        ],
        "fr": [
          "Le gîte du Jardin des Chênes vous emmène voyager loin dans une ambiance digne des mille et une nuits. Dans son écrin de verdure, il vous attend pour un moment magique rempli de calme et de sérénité. Nous parlons anglais et espagnol."
        ],
        "es": [
          "La casa rural Jardin des Chênes le transporta a una atmósfera digna de las mil y una noches. Rodeada de verdor, le espera para un momento mágico lleno de calma y serenidad. Hablamos inglés y español."
        ],
        "nl": [
          "De gîte Jardin des Chênes neemt je mee op een reis door een sfeer die duizend-en-een-nacht waardig is. Omgeven door groen wacht het op je voor een magisch moment vol rust en sereniteit. We spreken Engels en Spaans."
        ]
      },
