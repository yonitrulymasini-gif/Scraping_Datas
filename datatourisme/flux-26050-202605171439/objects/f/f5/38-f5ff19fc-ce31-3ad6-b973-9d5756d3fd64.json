      "dc:description": {
        "de": [
          "Musikalischer Abend, der von den Vereinen der Stadt organisiert und von der Gruppe Diabless moderiert wird.\nSpeisen und Getränke vor Ort.\nAb 19 Uhr rund um den Plan d'eau."
        ],
        "en": [
          "Musical evening organized by the town's associations and hosted by the band Diabless.\nCatering and drinks on site.\nFrom 7pm, around the lake."
        ],
        "it": [
          "Serata musicale organizzata dalle associazioni cittadine e ospitata dal gruppo Diabless.\nCibo e bevande a disposizione.\nDalle 19.00 intorno al lago."
        ],
        "fr": [
          "Soirée musicale organisée par les associations de la ville et animée par le groupe Diabless.\nRestauration et boissons sur place.\nA partir de 19h autour du plan d'eau."
        ],
        "es": [
          "Velada musical organizada por las asociaciones de la ciudad y presentada por el grupo Diabless.\nComida y bebida.\nA partir de las 19.00 h, alrededor del lago."
        ],
        "nl": [
          "Muzikale avond georganiseerd door de verenigingen van de stad en georganiseerd door de groep Diabless.\nEten en drinken verkrijgbaar.\nVanaf 19.00 uur rond het meer."
        ]
