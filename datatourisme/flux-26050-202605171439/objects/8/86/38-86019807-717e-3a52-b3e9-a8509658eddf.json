      "@id": "https://data.datatourisme.fr/183d8228-f377-31aa-bb9b-912ec002b9c1",
      "dc:description": {
        "de": [
          "AFun Fish lädt Sie zu einer spannenden Erfahrung in einer freundlichen Atmosphäre, wunderschönen Kulissen und mit einem erfahrenen Angelführer ein. Sessions von 4 oder 7 Stunden."
        ],
        "en": [
          "AFun Fish invites you to live an exciting experience in a friendly atmosphere, beautiful scenery, with an experienced fishing guide. Sessions of 4 or 7 hours."
        ],
        "it": [
          "AFun Fish vi invita a vivere un'esperienza emozionante in un'atmosfera amichevole, in uno splendido scenario, con una guida di pesca esperta. Sessioni di 4 o 7 ore."
        ],
        "fr": [
          "AFun Fish vous invite à vivre une expérience passionnante dans une ambiance conviviale, des décors magnifiques, avec un guide de pêche expérimenté. Sessions de 4h ou 7h."
        ],
        "nl": [
          "AFun Fish nodigt u uit om te genieten van een spannende ervaring in een vriendelijke sfeer, een prachtig landschap, met een ervaren visgids. Sessies van 4 of 7 uur."
        ],
        "es": [
          "AFun Fish le invita a disfrutar de una experiencia emocionante en un ambiente agradable, un hermoso paisaje, con un guía de pesca experimentado. Sesiones de 4 o 7 horas."
        ]
      },
