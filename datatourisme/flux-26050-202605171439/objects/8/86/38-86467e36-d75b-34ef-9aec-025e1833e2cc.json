  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4da64d66-22a9-3fd5-8265-a0bc723b88a2",
      "dc:description": {
        "de": [
          "Ob zu zweit oder mit Freunden, Maison Eliste ist der unumgängliche Ort, um sich zu treffen, Spaß zu haben, sich zu erholen und Zeit zu zweit zu verbringen."
        ],
        "en": [
          "Whether you're a couple or a group of friends, Maison Eliste is the place to be for fun, relaxation and time together."
        ],
        "it": [
          "Che siate una coppia o un gruppo di amici, la Maison Eliste è il luogo ideale per incontrarsi, divertirsi, rilassarsi e trascorrere del tempo insieme."
        ],
        "fr": [
          "En couple ou entre amis, Maison Eliste est le lieu incontournable pour se retrouver, s'amuser, se reposer et prendre le temps à deux."
        ],
        "es": [
          "Tanto si sois una pareja como un grupo de amigos, Maison Eliste es el lugar perfecto para reunirse, divertirse, relajarse y disfrutar del tiempo juntos."
        ],
        "nl": [
          "Of je nu met z'n tweeën bent of met een groep vrienden, Maison Eliste is de perfecte plek om elkaar te ontmoeten, plezier te maken, te ontspannen en samen te genieten."
        ]
      },
