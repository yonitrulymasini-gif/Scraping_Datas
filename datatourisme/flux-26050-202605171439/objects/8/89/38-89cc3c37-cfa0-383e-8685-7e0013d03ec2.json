  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b08c45b1-cd78-3a43-9243-62b9dc449847",
      "dc:description": {
        "de": [
          "Der Küchenchef Didier Lequitte empfängt Sie im Restaurant des Hotels Saint Marc, wo Sie regionale Gerichte genießen können. Diese semi-gastronomische Küche wird mit den besten Produkten aus der bretonischen Region zubereitet. Täglich mittags und abends geöffnet (außer Sonntagabend)."
        ],
        "en": [
          "Chef Didier Lequitte welcomes you to the Hôtel Saint Marc restaurant to sample regional dishes. This semi-gastronomic cuisine is prepared with the finest Breton produce. Open daily for lunch and dinner (except Sunday evenings)."
        ],
        "it": [
          "Lo chef Didier Lequitte vi dà il benvenuto al ristorante dell'Hôtel Saint Marc per assaggiare i piatti regionali. Questa cucina semi-gastronomica è preparata con i migliori prodotti locali bretoni. Aperto tutti i giorni a pranzo e a cena (tranne la domenica sera)."
        ],
        "fr": [
          "Le chef Didier Lequitte vous accueille au sein du restaurant de l'Hôtel Saint Marc pour déguster des plats régionaux. Cette cuisine semi-gastronomique est confectionnée avec les meilleurs produits du terroir breton. Ouvert tous les jours midi et soir (sauf le dimanche soir)."
        ],
        "es": [
          "El chef Didier Lequitte le da la bienvenida al restaurante del Hôtel Saint Marc para degustar platos regionales. Esta cocina semigastronómica se elabora con los mejores productos locales bretones. Abierto todos los días para el almuerzo y la cena (excepto los domingos por la noche)."
        ],
        "nl": [
          "Chef Didier Lequitte heet je welkom in het restaurant van Hôtel Saint Marc om te proeven van regionale gerechten. Deze semi-gastronomische keuken wordt bereid met de beste lokale Bretonse producten. Dagelijks geopend voor lunch en diner (behalve zondagavond)."
        ]
      },
      "@type": [
        "Description"
      ],
