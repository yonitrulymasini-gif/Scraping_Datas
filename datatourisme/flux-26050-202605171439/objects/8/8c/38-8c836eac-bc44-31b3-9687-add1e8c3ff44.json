      "dc:description": {
        "de": [
          "Folgen Sie in Begleitung von Vermittlern den Fußstapfen der Archäologen und entdecken Sie die Spuren, die die Menschen der Jungsteinzeit auf den Menhiren von Monteneuf hinterlassen haben."
        ],
        "en": [
          "Accompanied by mediators, follow in the footsteps of archaeologists and discover the traces left on Monteneuf's menhirs by Neolithic man."
        ],
        "it": [
          "Seguite le orme degli archeologi e scoprite le tracce lasciate dall'uomo neolitico sui menhir di Monteneuf."
        ],
        "fr": [
          "Accompagnés de médiateurs, suivez les pas des archéologues et découvrez les  traces laissées sur les menhirs de Monteneuf par les Hommes du Néolithique."
        ],
        "nl": [
          "Treed in de voetsporen van archeologen en ontdek de sporen die de neolithische mens heeft achtergelaten op de menhirs van Monteneuf."
        ],
        "es": [
          "Siga los pasos de los arqueólogos y descubra las huellas dejadas por el hombre neolítico en los menhires de Monteneuf."
        ]
      },
