      "@id": "https://data.datatourisme.fr/d560bbfc-52f5-325a-b4fd-e499d6abfc59",
      "dc:description": {
        "de": [
          "Jeanne Guilloux und Maude Grolleau präsentieren ihre Raku- und Tintenskulpturen\n\n?? Ein Termin voller Farben\nzögern Sie nicht, durch die Türen der Kapelle zu gehen\n\n? Kommen Sie zahlreich und sagen Sie es weiter!"
        ],
        "en": [
          "Jeanne Guilloux and Maude Grolleau present their Raku and Ink sculptures\n\n?? A colourful rendez-vous\ndon't hesitate to come and visit the chapel\n\n? Come one, come all, and spread the word!"
        ],
        "it": [
          "Jeanne Guilloux e Maude Grolleau presentano le loro sculture in Raku e inchiostro\n\n?? Un appuntamento pieno di colori\nnon esitate a visitare la cappella\n\n? Venite uno, venite tutti e spargete la voce!"
        ],
        "fr": [
          "Jeanne Guilloux et Maude Grolleau vous présentent ses leurs sculptures Raku et Encres\n\n🕰️ Un rendez-vous plein de couleurs\n✨N’hésitez pas à venir passer les portes de la chapelle\n\n📸 Venez nombreux et faites passer le mot !"
        ],
        "es": [
          "Jeanne Guilloux y Maude Grolleau presentan sus esculturas de Raku y tinta\n\n?? Una cita llena de color\nno dude en venir a visitar la capilla\n\n? Venga uno, vengan todos, ¡y corran la voz!"
        ],
        "nl": [
          "Jeanne Guilloux en Maude Grolleau presenteren hun Raku- en inktsculpturen\n\n?? Een rendez-vous vol kleur\naarzel niet om de kapel te komen bezoeken\n\n? Kom allen en vertel het verder!"
        ]
      },
