  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/16113a72-6ef8-3e99-badd-a746fbc39ab5",
      "dc:description": {
        "de": [
          "Das Hotel les Alignements befindet sich 250 m vom Zentrum von Carnac, 400 m von den berühmten Megalithanlagen und 1700 m von den Stränden entfernt.\n27 Zimmer, darunter 5 Dreibettzimmer, kostenloser WLAN-Zugang, Aufzug, Restaurant-/Frühstücksraum und ruhige Terrasse mit Bäumen. Öffentlicher Parkplatz 30 m entfernt."
        ],
        "en": [
          "Hotel les Alignements is located 250 m from the center of Carnac, 400 m from the famous megalithic sites and 1,700 m from the beaches.\n27 rooms including 5 triples, free Wi-Fi access, elevator, restaurant/breakfast room and quiet terrace planted with trees. Public parking lot 30 m away."
        ],
        "it": [
          "L'hotel les Alignements si trova a 250 m dal centro di Carnac, a 400 m dai famosi siti megalitici e a 1700 m dalle spiagge.\n27 camere di cui 5 triple, connessione Wi-Fi gratuita, ascensore, ristorante/sala colazioni e tranquilla terrazza alberata. Parcheggio pubblico a 30 m."
        ],
        "fr": [
          "L'hôtel les Alignements est situé à 250 m du centre de Carnac, à 400 m des célèbres sites mégalithiques et à 1700 m des plages. \n27 chambres dont 5 triples, accès Wifi gratuit, ascenseur, salle de restaurant/petit déjeuner,  et terrasse arborée au calme. Parking public à 30 m."
        ],
        "nl": [
          "Hotel les Alignements ligt op 250 m van het centrum van Carnac, 400 m van de beroemde megalithische vindplaatsen en 1700 m van de stranden.\n27 kamers waarvan 5 driepersoonskamers, gratis draadloos internet, lift, restaurant/ontbijtzaal en rustig terras met bomen. Openbare parkeerplaats op 30 m."
        ],
        "es": [
          "El hotel les Alignements está situado a 250 m del centro de Carnac, a 400 m de los famosos yacimientos megalíticos y a 1700 m de las playas.\n27 habitaciones, 5 de ellas triples, conexión Wi-Fi gratuita, ascensor, restaurante/sala de desayunos y terraza arbolada y tranquila. Aparcamiento público a 30 m."
        ]
      },
      "@type": [
        "Description"
