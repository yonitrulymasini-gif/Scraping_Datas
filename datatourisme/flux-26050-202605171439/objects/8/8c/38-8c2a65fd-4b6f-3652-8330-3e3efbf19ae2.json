  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5d611144-82ad-3cc3-a762-e71646d2739d",
      "dc:description": {
        "de": [
          "Traditionelle Crêperie in der Nähe der Anlegestelle. Entdecken Sie die von uns ausgewählten lokalen Produkte und Produkte aus unseren Regionen. Gemütlich eingerichtete Säle und eine schöne, ruhige Terrasse."
        ],
        "en": [
          "Traditional creperie near the pier. Come to discover local products and of our regions selected by our care. Warmly decorated rooms as well as a beautiful quiet terrace."
        ],
        "it": [
          "Creperia tradizionale vicino al molo. Venite a scoprire i prodotti locali e regionali selezionati da noi. Camere arredate con calore e una bella e tranquilla terrazza."
        ],
        "fr": [
          "Crêperie traditionnelle proche de l'embarcadère. Venez découvrir des produits locaux et de nos régions sélectionnés par nos soins. Salles au décor chaleureux ainsi qu'une belle terrasse au calme."
        ],
        "nl": [
          "Traditionele crêperie bij de pier. Kom de door ons geselecteerde lokale en regionale producten ontdekken. Warm ingerichte kamers en een mooi, rustig terras."
        ],
        "es": [
          "Crepería tradicional cerca del muelle. Venga a descubrir los productos locales y regionales seleccionados por nosotros. Habitaciones cálidamente decoradas y una hermosa y tranquila terraza."
        ]
      },
