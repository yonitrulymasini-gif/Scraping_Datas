  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cc343864-10fd-39dd-921f-bd755d81505d",
      "dc:description": {
        "de": [
          "Romain und Camille haben große Freude daran, Galettes und Crêpes anzubieten, die aus frischen und lokalen Produkten hergestellt werden.\nIhre Besonderheit: eine köstliche Mischung aus Sch'tis- und bretonischen Rezepten."
        ],
        "en": [
          "Romain and Camille take great pleasure in offering galettes and crêpes made with fresh, local produce.\nTheir speciality: a delicious blend of Ch'tis and Breton recipes."
        ],
        "it": [
          "Romain e Camille sono molto contenti di proporre galettes e crêpes preparate con prodotti freschi e locali.\nLa loro specialità: un delizioso mix di ricette Ch'tis e Bretoni."
        ],
        "fr": [
          "Romain et Camille prennent un grand plaisir à proposer des galettes et des crêpes fabriquées avec des produits frais et locaux.\nLeur particularité : un délicieux mélange de recettes ch'tis et bretonnes."
        ],
        "es": [
          "Romain y Camille se complacen en ofrecer galettes y crêpes elaboradas con productos frescos y locales.\nSu especialidad: una deliciosa mezcla de recetas ch'tis y bretonas."
        ],
        "nl": [
          "Romain en Camille bieden met veel plezier galettes en crêpes gemaakt met verse, lokale producten.\nHun specialiteit: een heerlijke mix van Ch'tis en Bretonse recepten."
        ]
      },
