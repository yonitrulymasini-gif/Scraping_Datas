      "dc:description": {
        "de": [
          "Terrasse mit den Füßen im Wasser. Schöne Tapas-Karte zum Aperitif, einige interessante Rumsorten und arrangierte Rums."
        ],
        "en": [
          "Waterfront terrace. Nice tapas menu to accompany aperitifs, several interesting rum varieties and rhums arrangés."
        ],
        "it": [
          "Terrazza in riva al mare. Bel menu di tapas per accompagnare gli aperitivi, alcune interessanti varietà di rum e rum arrangiati."
        ],
        "fr": [
          "Terrasse les pieds dans l'eau. Jolie carte de tapas pour accompagnés l'apéritif, quelques variétés de rhum intéressants et rhums arrangés."
        ],
        "es": [
          "Terraza al borde del agua. Buena carta de tapas para acompañar los aperitivos, algunas variedades interesantes de ron y rones arreglados."
        ],
        "nl": [
          "Terras aan het water. Mooi menu met tapas voor bij het aperitief, enkele interessante soorten rum en gearrangeerde rum."
        ]
