  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4b94e341-a041-388f-b32f-01bf53d0ca3e",
      "dc:description": {
        "de": [
          "HINWEIS FÜR FEINSCHMECKER UND GOURMETS!\nEs werden Ihnen verschiedene Workshops angeboten, wie z. B:\n100% vegetarischer Workshop\nBretonisches Land-Meer-Atelier\n100% bretonischer Aperitif\nWorkshop 100% vegetarisch\nDauer des Workshops: 2 Stunden\nAb 65 ?\nDas gesamte Programm der angebotenen Workshops finden Sie auf https://labergerieyvesrocher.com/fr/les-ateliers-culinaires/\nBitte kommen Sie 15 Minuten vor Beginn des Workshops an"
        ],
        "en": [
          "GOURMANDS AND GOURMETS BEWARE!\nWe offer a range of workshops:\n100% vegetarian workshop\nBreton land-sea workshop\n100% Breton aperitif\n100% vegetarian workshop\nWorkshop duration: 2 hours\nStarting at 65?\nYou'll find the full program at https://labergerieyvesrocher.com/fr/les-ateliers-culinaires/\nPlease arrive 15 minutes before the start of the workshop"
        ],
        "it": [
          "AMANTI DEL CIBO E BUONGUSTAI ATTENZIONE!\nL'offerta prevede una serie di laboratori, tra cui\nLaboratorio 100% vegetariano\nLaboratorio bretone di terra e mare\nAperitivo 100% bretone\nLaboratorio 100% vegetariano\nDurata del laboratorio: 2 ore\nA partire da 65?\nIl programma completo dei laboratori è disponibile sul sito https://labergerieyvesrocher.com/fr/les-ateliers-culinaires/\nArrivare 15 minuti prima dell'inizio del laboratorio"
        ],
        "fr": [
          "AVIS AUX GOURMANDS ET GOURMETS !\nDifférents ateliers vous sont proposés comme:\nAtelier 100% végétarien\nAtelier breton terre-mer\nApéro 100% breton\nAtelier 100% végétarien\nDurée de l'atelier: 2 heures\nA partir de 65€\nVous retrouverez tout le programme des ateliers proposés sur https://labergerieyvesrocher.com/fr/les-ateliers-culinaires/\nPrévoir d'arriver 15 minutes avant le début de l'atelier"
        ],
        "nl": [
          "FIJNPROEVERS OPGELET!\nEr worden verschillende workshops aangeboden, waaronder\n100% vegetarische workshop\nBretonse land en zee workshop\n100% Bretons aperitief\n100% vegetarische workshop\nDuur workshop: 2 uur\nVanaf 65?\nHet volledige programma van de workshops is beschikbaar op https://labergerieyvesrocher.com/fr/les-ateliers-culinaires/\nZorg dat je 15 minuten voor aanvang van de workshop aanwezig bent"
        ],
        "es": [
          "AMANTES DE LA COMIDA Y GOURMETS, ¡ATENTOS!\nSe ofrecen diversos talleres, entre ellos\nTaller 100% vegetariano\nTaller bretón de mar y tierra\nAperitivo 100% bretón\nTaller 100% vegetariano\nDuración del taller: 2 horas\nA partir de 65?\nEl programa completo de los talleres está disponible en https://labergerieyvesrocher.com/fr/les-ateliers-culinaires/\nPrevea llegar 15 minutos antes del comienzo del taller"
        ]
      },
