      "@id": "https://data.datatourisme.fr/0c44ea66-8d09-3bc9-936f-6884ce5a7857",
      "dc:description": {
        "de": [
          "Ort des Lebens im historischen Gebäude des Bahnhofs von Auray: Eventbar und lokaler Lebensmittelladen.\nDurchgehender Service 7/7\nOhne Reservierung"
        ],
        "en": [
          "A place to live in the historic Gare d'Auray building: events bar and local grocery store.\n7/7 continuous service\nNo reservation required"
        ],
        "it": [
          "Un luogo per godersi la vita nell'edificio storico della stazione di Auray: bar per eventi e negozio di alimentari locale.\nServizio continuo 7/7\nNon è richiesta la prenotazione"
        ],
        "fr": [
          "Lieu de vie dans le bâtiment historique de la  Gare d'Auray : bar à évènements et épicerie locale.\nService continu 7/7\nSans réservation"
        ],
        "es": [
          "Un lugar para disfrutar de la vida en el edificio histórico de la estación de Auray: bar de eventos y tienda de comestibles local.\nServicio continuo 7/7\nNo es necesario reservar"
        ],
        "nl": [
          "Een plek om van het leven te genieten in het historische gebouw van het station van Auray: evenementenbar en plaatselijke kruidenierswinkel.\n7/7 doorlopende service\nGeen reservering nodig"
        ]
      },
