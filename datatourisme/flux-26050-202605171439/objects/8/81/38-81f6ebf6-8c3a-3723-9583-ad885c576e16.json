      "dc:description": {
        "de": [
          "Ein großes und charmantes bretonisches Landhaus aus Stein, das mit edlen und ökologischen Materialien renoviert wurde, erwartet Sie!\nEs besteht die Möglichkeit, das Haus für eine Nacht zu mieten."
        ],
        "en": [
          "A vast and charming Breton stone country house renovated with noble and ecological materials awaits you!\nPossibility of renting by the night."
        ],
        "it": [
          "Una vasta e affascinante casa di campagna bretone in pietra ristrutturata con materiali nobili ed ecologici vi aspetta!\nPossibilità di affitto a notte."
        ],
        "fr": [
          "Une vaste et charmante demeure campagnarde bretonne en pierre rénovée avec des matériaux nobles et écologiques vous attend! \nPossibilité de location à la nuitée."
        ],
        "es": [
          "¡Una vasta y encantadora casa de campo bretona de piedra renovada con materiales nobles y ecológicos le espera!\nPosibilidad de alquiler por noches."
        ],
        "nl": [
          "Een groot en charmant stenen Bretons landhuis gerenoveerd met edele en ecologische materialen wacht op je!\nMogelijkheid tot verhuur per nacht."
        ]
      },
