      "dc:description": {
        "de": [
          "Wanderung entlang der wilden Küste mit Widerstandsstöcken. Bitte denken Sie an eine Kopfbedeckung und ein gutes Paar Turnschuhe oder Wanderschuhe. Dauer: 1,5 Stunden"
        ],
        "en": [
          "Walk on the wild coast with resistance poles, bring a cover and a good pair of sneakers or walking shoes. Duration: 1h30"
        ],
        "it": [
          "Camminate lungo la costa selvaggia con i bastoncini di resistenza, portate un buon paio di scarpe da ginnastica o da trekking e copritevi. Durata: 1h30"
        ],
        "fr": [
          "Marche sur la côte sauvage avec bâtons de résistance , prévoir de se couvrir et une bonne paire de baskets ou chaussures de marche. Durée: 1h30"
        ],
        "nl": [
          "Wandel langs de wilde kust met weerstandstokken, neem een goed paar sportschoenen of wandelschoenen mee en bedek je. Duur: 1u30"
        ],
        "es": [
          "Camine por la costa salvaje con bastones de resistencia, traiga un buen par de zapatillas o zapatos para caminar y cúbrase. Duración: 1h30"
        ]
      },
