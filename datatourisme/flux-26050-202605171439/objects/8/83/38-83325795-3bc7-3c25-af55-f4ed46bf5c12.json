  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ae54c518-e538-3ce8-a004-cb64d6aab029",
      "dc:description": {
        "de": [
          "Unser Restaurant empfängt Sie, um Ihnen unsere Spezialitäten mit Andouille de Guémené vorzustellen: Andouille chaude-purée oder hachis parmandouille... Andere Gerichte stehen ebenfalls auf der Karte, darunter auch vegetarische Gerichte."
        ],
        "en": [
          "Our restaurant welcomes you to discover our Guémené andouille specialities: andouille chaud-purée or hachis parmandouille... Other dishes are also on the menu, including vegetarian dishes."
        ],
        "it": [
          "Il nostro ristorante vi invita a scoprire le nostre specialità a base di salsiccia andouille di Guémené: salsiccia andouille calda con purè o salsiccia parmandouille tritata... Sono disponibili anche altri piatti, compresi quelli vegetariani."
        ],
        "fr": [
          "Notre restaurant vous accueille pour vous faire découvrir nos spécialités à l'andouille de Guémené : andouille chaude-purée ou hachis parmandouille... D'autres plats sont également à la carte dont des plats végétariens."
        ],
        "nl": [
          "Ons restaurant verwelkomt u om onze specialiteiten op basis van Guémené andouilleworst te ontdekken: warme andouilleworst met puree of gehakte parmandouilleworst... Er zijn ook andere gerechten verkrijgbaar, waaronder vegetarische."
        ],
        "es": [
          "Nuestro restaurante le invita a descubrir nuestras especialidades elaboradas con salchicha andouille de Guémené: salchicha andouille picante con puré o salchicha parmandouille picada... También ofrecemos otros platos, incluidos los vegetarianos."
        ]
      },
      "@type": [
        "Description"
      ],
