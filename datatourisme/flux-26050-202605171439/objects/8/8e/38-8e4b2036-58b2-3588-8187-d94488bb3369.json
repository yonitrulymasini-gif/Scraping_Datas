      "dc:description": {
        "de": [
          "Au Crouesty, Vermietung ? Verkauf ? Reparaturen ? Lagerung von Booten ? Neue oder gebrauchte Motoren. Vertragshändler: Yamaha ? Capelli ? Narwhal - Pacific Craft. Vermietung von Motorbooten. Ganzjährig geöffnet, von Montag bis Samstag."
        ],
        "en": [
          "Au Crouesty, Rental ? Sales ? Boat repairs ? Boat storage ? New or used engines. Dealer : Yamaha ? Capelli ? Narwhal - Pacific Craft. Motorboat rental. Open all year round, Monday to Saturday."
        ],
        "it": [
          "Au Crouesty, Noleggio? Vendite? Riparazioni di barche ? Rimessaggio barche ? Motori nuovi o usati. Concessionario : Yamaha ? Capelli ? Narwhal - Pacific Craft. Noleggio barche a motore. Aperto tutto l'anno, dal lunedì al sabato."
        ],
        "fr": [
          "Au Crouesty, Location – Vente – Réparation – Stockage de bateaux – Moteur neuf ou occasion. Concessionnaire : Yamaha – Capelli – Narwhal - Pacific Craft. Location de bateaux à moteur. Ouvert toute l'année, du lundi au samedi."
        ],
        "nl": [
          "Au Crouesty, Verhuur ? Verkoop ? Boot reparatie ? Boot opslag ? Nieuwe of tweedehands motoren. Dealer : Yamaha ? Capelli ? Narwal - Pacific Craft. Verhuur van motorboten. Het hele jaar geopend, van maandag tot zaterdag."
        ],
        "es": [
          "Au Crouesty, Alquiler ? Venta ? Reparaciones ? Almacén de barcos ? Motores nuevos o usados. Concesionario : Yamaha ? Capelli ? Narwhal - Pacific Craft. Alquiler de embarcaciones a motor. Abierto todo el año, de lunes a sábado."
        ]
      },
