  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/503f98f3-b303-31ad-8143-c0d13a2dd982",
      "dc:description": {
        "de": [
          "Die TONNEAU-Hütte vermittelt eine schöne, authentische und warme Atmosphäre. Dieses lustige Fass bietet eine Inneneinrichtung mit einer echten Abwechslung, um sich auszuruhen und neue Energie zu tanken."
        ],
        "en": [
          "The TONNEAU hut creates a warm, authentic atmosphere. This funny barrel offers a real change of scenery for resting and recharging your batteries."
        ],
        "it": [
          "Il rifugio TONNEAU crea un'atmosfera calda e autentica. L'interno di questa insolita casa a botte offre un vero e proprio cambiamento di scenario per riposare e ricaricare le batterie."
        ],
        "fr": [
          "La cabane TONNEAU donne une belle ambiance authentique et chaleureuse. Cette drôle de barrique propose un aménagement intérieur avec un vrai dépaysement pour se reposer et se ressourcer."
        ],
        "es": [
          "La cabaña TONNEAU crea un ambiente cálido y auténtico. El interior de esta insólita casa tonel ofrece un auténtico cambio de aires para descansar y recargar las pilas."
        ],
        "nl": [
          "De TONNEAU hut creëert een warme, authentieke sfeer. Het interieur van deze ongewone vatenhut biedt een echte verandering van omgeving om uit te rusten en je batterijen op te laden."
        ]
      },
      "@type": [
        "Description"
