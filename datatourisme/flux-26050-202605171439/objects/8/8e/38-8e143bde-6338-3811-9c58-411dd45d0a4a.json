  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/1ffa003d-2edd-3b6c-9888-0716f0bed206",
      "dc:description": {
        "de": [
          "Haus 3 Personen. Charakteristisches Ferienhaus in einer geschützten Natur. Einladendes Anwesen auf einem ehemaligen Bauernhof mit Obstgärten, Wiesen und Wäldern auf 20 ha. Angelegter Hof mit Blumen- und Baumgärten. Möglichkeit zu Spaziergängen und Entdeckung der Natur."
        ],
        "en": [
          "House for 3 people. Character gîte set in unspoilt countryside. Welcoming property on a former farm with orchards, meadows and woods covering 20 ha. Landscaped courtyard with flower gardens and trees. Nature walks and discoveries possible."
        ],
        "it": [
          "Casa per 3 persone. Gîte di carattere immerso nella campagna incontaminata. Proprietà accogliente in un'antica fattoria con frutteti, prati e boschi di 20 ettari. Cortile paesaggistico con giardini fioriti e alberi. Possibilità di passeggiate e scoperte naturalistiche."
        ],
        "fr": [
          "Maison 3 personnes. Gîte de caractère dans une nature préservée. Propriété accueillante sur une ancienne ferme avec vergers, prairies, bois sur 20 ha. Cour aménagée avec jardins fleuris et arborés. Possibilité promenades et découverte nature."
        ],
        "nl": [
          "Huis voor 3 personen. Karaktervolle gîte in een ongerept landschap. Gastvrije woning op een oude boerderij met boomgaarden, weiden en bossen van 20 ha. Aangelegde binnenplaats met bloementuinen en bomen. Natuurwandelingen en ontdekkingen mogelijk."
        ],
        "es": [
          "Casa para 3 personas. Casa rural con carácter situada en un entorno rural intacto. Acogedora propiedad en una antigua granja con huertos, prados y bosques de 20 ha. Patio ajardinado con flores y árboles. Paseos y descubrimientos en plena naturaleza."
        ]
      },
      "@type": [
        "Description"
      ],
