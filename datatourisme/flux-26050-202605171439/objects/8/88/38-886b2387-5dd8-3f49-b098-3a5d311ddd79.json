  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2f30a5f6-b8f1-3c0c-9d64-892de423b087",
      "dc:description": {
        "de": [
          "Künstlerhaus - Ungewöhnliche Gästezimmer - Atelier Galerie\n\n2 Gästezimmer in einem kleinen typischen Dorf 200 Meter von den Stränden entfernt.\n1 Zimmer für 2 Personen. 1 Zimmer für 3 Personen.\nKamin. Wi-Fi.\nTable d'hôte außerhalb der Saison.  Vermietung das ganze Jahr über."
        ],
        "en": [
          "Artist's house - Unusual guest rooms - Gallery workshop\n\n2 guest rooms in a typical village 200 meters from the beach.\n1 room for 2 people. 1 room for 3 people.\nFireplace. Wi-Fi access.\nOff-season table d'hôte.  Year-round rental."
        ],
        "it": [
          "Casa dell'artista - Stanze insolite per gli ospiti - Galleria laboratorio\n\n2 camere per gli ospiti in un villaggio tipico a 200 metri dalla spiaggia.\n1 camera per 2 persone. 1 camera per 3 persone.\nCamino. Accesso Wi-Fi.\nTavola d'albergo in bassa stagione.  In affitto tutto l'anno."
        ],
        "fr": [
          "Maison d'artiste - Chambres d'hôtes insolites - Atelier Galerie  \n\n2 chambres d'hôtes dans un petit village typique à 200 mètres des plages. \n1 chambre pour 2 personnes. 1 chambre pour 3 personnes. \nCheminée. Wi-Fi. \nTable d'hôte hors saison.  Location toute l'année."
        ],
        "nl": [
          "Kunstenaarshuis - Ongebruikelijke gastenkamers - Galerijatelier\n\n2 gastenkamers in een typisch dorp op 200 meter van het strand.\n1 kamer voor 2 personen. 1 slaapkamer voor 3 personen.\nOpen haard. Wi-Fi-toegang.\nTable d'hôte in het laagseizoen.  Het hele jaar te huur."
        ],
        "es": [
          "Casa del artista - Habitaciones insólitas - Galería taller\n\n2 habitaciones de huéspedes en un pueblo típico a 200 metros de la playa.\n1 habitación para 2 personas. 1 habitación para 3 personas.\nChimenea. Acceso Wi-Fi.\nTable d'hôte en temporada baja.  Se alquila todo el año."
        ]
      },
