  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f8559ee2-b4b7-3ac6-a7f6-ef4a249da9a7",
      "dc:description": {
        "de": [
          "Unterkunft für 4 bis 6 Personen in einem alten Pavillon aus dem 17. Jahrhundert, authentisch restauriert, mit einem ländlichen Panorama soweit das Auge reicht. Ruhe und Natur garantiert! Privater Tennisplatz. Möglichkeit der Vermietung pro Nacht."
        ],
        "en": [
          "Gîte for 4 to 6 people in an old 17th-century pavilion, authentically restored, with country views as far as the eye can see. Peace and quiet guaranteed! Private tennis court. Possibility of renting by the night."
        ],
        "it": [
          "Gîte per 4-6 persone in un antico padiglione del XVII secolo, autenticamente restaurato, con vista sulla campagna a perdita d'occhio. Pace e natura garantite! Campo da tennis privato. Possibilità di affitto a notte."
        ],
        "fr": [
          "Gîte pour 4 à 6 personnes dans un ancien pavillon du XVIIème siècle, restauré à l'authentique avec un panorama campagnard à perte de vue. Calme et nature assurés! Tennis privé. Possibilité location à la nuitée."
        ],
        "nl": [
          "Gîte voor 4 tot 6 personen in een oud 17e-eeuws paviljoen, authentiek gerestaureerd, met uitzicht zover het oog reikt. Rust en natuur gegarandeerd! Privé tennisbaan. Mogelijkheid tot verhuur per nacht."
        ],
        "es": [
          "Casa rural para 4 a 6 personas en un antiguo pabellón del siglo XVII, auténticamente restaurado, con vistas al campo hasta donde alcanza la vista. Tranquilidad y naturaleza garantizadas Pista de tenis privada. Posibilidad de alquiler por noche."
        ]
      },
