  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/db4e938c-e271-3a52-9667-60794565d866",
      "dc:description": {
        "de": [
          "Haus für 2 Personen. Auf der wilden Seite von Quiberon, 700m vom Stadtzentrum entfernt, bestehend aus Eingang, Wohnzimmer, Küchenzeile mit Geschirrspüler, einem Schlafzimmer mit Doppelbett, Dusche, TV, Garten, Fahrradraum."
        ],
        "en": [
          "House for 2 people. On the wild side of Quiberon, 700m from town center, comprising entrance hall, living room, kitchenette with dishwasher, bedroom with double bed, shower, TV, garden, bike room."
        ],
        "it": [
          "Casa per 2 persone. Sul lato selvaggio di Quiberon, a 700 m dal centro, composta da ingresso, soggiorno, angolo cottura con lavastoviglie, camera con letto matrimoniale, doccia, TV, giardino, rimessa per biciclette."
        ],
        "fr": [
          "Maison 2 personnes. Sur la côté sauvage de Quiberon, situé à 700m du centre ville comprenant entrée, séjour, coin cuisine avec lave-vaisselle, une chambre avec un lit double, douche, TV, jardin, local vélos."
        ],
        "nl": [
          "Huis voor 2 personen. Aan de wilde kant van Quiberon, 700m van het centrum, bestaande uit entree, woonkamer, kitchenette met vaatwasser, slaapkamer met tweepersoonsbed, douche, tv, tuin, fietsenstalling."
        ],
        "es": [
          "Casa para 2 personas. En el lado salvaje de Quiberon, a 700 m del centro de la ciudad, que consta de hall de entrada, sala de estar, cocina americana con lavavajillas, dormitorio con cama doble, ducha, TV, jardín, cobertizo para bicicletas."
        ]
      },
