  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/725ced4e-8196-3664-a3d6-98bc4700f7b7",
      "dc:description": {
        "de": [
          "T1 bis für 2 Personen. Großes Studio mit separater Küche, im 5. Stock mit Aufzug.\nWohnraum mit herrlichem Blick auf das Meer, Port Maria und Belle-Île.\nLoggia, Parkplatz.\nAm Rande des großen Strandes, Stadtzentrum in 10 Minuten zu Fuß erreichbar."
        ],
        "en": [
          "T1 bis for 2 people. Large studio with separate kitchen, on 5th floor with elevator.\nLiving room with magnificent view of the sea, Port Maria and Belle-Île.\nLoggia, parking.\nOn the edge of the Grande Plage, 10-minute walk to town center."
        ],
        "it": [
          "T1 bis per 2 persone. Ampio monolocale con cucina separata, al 5° piano con ascensore.\nSoggiorno con magnifica vista sul mare, su Port Maria e Belle-Île.\nLoggia, parcheggio.\nAi margini della Grande Plage, a 10 minuti a piedi dal centro città."
        ],
        "fr": [
          "T1 bis pour 2 personnes. Grand studio avec cuisine séparée, au 5ème étage avec ascenseur.\nPièce de vie bénéficiant d'une magnifique vue sur la mer, Port Maria et Belle-Île.\nLoggia, parking. \nAu bord de la Grande Plage, centre ville à 10mn à pied."
        ],
        "nl": [
          "T1 bis voor 2 personen. Groot studio-appartement met aparte keuken, op de 5e verdieping met lift.\nWoonkamer met prachtig uitzicht op zee, Port Maria en Belle-Île.\nLoggia, parkeerplaats.\nAan de rand van het Grande Plage, op 10 minuten lopen van het centrum."
        ],
        "es": [
          "T1 bis para 2 personas. Amplio estudio con cocina independiente, en la 5ª planta con ascensor.\nSalón con magníficas vistas al mar, Port Maria y Belle-Île.\nLoggia, parking.\nAl borde de la Grande Plage, a 10 minutos a pie del centro de la ciudad."
        ]
      },
      "@type": [
        "Description"
