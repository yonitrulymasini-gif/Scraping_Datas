  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/797d91c4-2224-37c3-920d-87294a584c86",
      "dc:description": {
        "de": [
          "Das Studio besteht aus einem Schlafzimmer mit einem Doppelbett im Zwischengeschoss, einem Schlafsofa, einer Sitzecke, einer Küchenzeile und einem Badezimmer."
        ],
        "en": [
          "The studio comprises a bedroom with a double mezzanine bed, a sofa bed, a sitting area, a kitchenette and a bathroom."
        ],
        "it": [
          "Il monolocale è composto da una camera da letto con letto matrimoniale soppalcato, un divano letto, un'area salotto, un angolo cottura e un bagno."
        ],
        "fr": [
          "Le studio comprend une chambre avec un lit double en mezzanine, un canapé convertible, un coin salon, une kitchenette et une salle de bain."
        ],
        "es": [
          "El estudio consta de un dormitorio con cama doble en el altillo, un sofá cama, una zona de estar, una cocina americana y un cuarto de baño."
        ],
        "nl": [
          "De studio bestaat uit een slaapkamer met een tweepersoonsbed op de mezzanine, een slaapbank, een zithoek, een kitchenette en een badkamer."
        ]
      },
