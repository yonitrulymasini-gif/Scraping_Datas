  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/50f9343e-f7fe-3276-9bb5-bbcfbdcde578",
      "dc:description": {
        "de": [
          "Dieser ehemalige Pferdestall wird Sie begeistern. Am Abend können Sie das Spielzimmer (ehemalige Scheune) nutzen. Die brandneuen Fahrräder, die Ihnen zur Verfügung stehen, ermöglichen es Ihnen, Ausflüge zu unternehmen."
        ],
        "en": [
          "You'll love this former stable. In the evening, you can enjoy the games room (former barn). Brand-new bicycles are at your disposal for a leisurely ride."
        ],
        "it": [
          "Vi innamorerete di questa ex stalla. La sera potrete divertirvi nella sala giochi (ex fienile). Sono disponibili biciclette nuove di zecca."
        ],
        "fr": [
          "Cette ancienne écurie vous séduira. Le soir, vous profiterez de la salle de jeux (ancienne grange). Des vélos flambants neufs à votre disposition vous permettront de vous balader."
        ],
        "es": [
          "Te encantará este antiguo establo. Por la noche, podrás disfrutar de la sala de juegos (antiguo establo). Hay bicicletas nuevas a su disposición."
        ],
        "nl": [
          "Je zult dol zijn op deze voormalige stal. S Avonds kun je genieten van de speelkamer (voormalige schuur). Er staan gloednieuwe fietsen voor je klaar."
        ]
      },
