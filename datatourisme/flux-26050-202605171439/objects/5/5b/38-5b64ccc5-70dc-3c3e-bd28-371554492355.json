  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/34e52985-9de0-3add-a5b8-09cbc713d340",
      "dc:description": {
        "de": [
          "Restaurant und Feinkostladen, Terre des Sens steht für köstliche kleine hausgemachte Gerichte, leckere Salate, Burger mit lokalen Käsesorten und hausgemachte Pommes frites, zu denen Chloé mit der Eröffnung des frisch renovierten Restaurants auch Galettes hinzufügt. Die Produkte sind frisch und lokal, soweit möglich biologisch, um Ihnen die Qualität der Speisen und Aromen zu garantieren, die Sie nicht gleichgültig lassen werden. Der Service ist durchgehend. Das Restaurant ist ganzjährig von Montag bis Samstag von 8:00 bis 22:00 Uhr geöffnet. Sonntags geschlossen."
        ],
        "en": [
          "Restaurant and caterer, Terre des Sens is all about succulent home-cooked meals, gourmet salads, burgers with local cheeses and home fries, to which Chloé has added galettes with the opening of the newly renovated restaurant. The products are fresh and local, organic wherever possible, to guarantee the quality of the dishes and flavors that will not leave you indifferent. Continuous service. The restaurant is open all year round, Monday to Saturday, 8am to 10pm. Closed on Sundays."
        ],
        "it": [
          "Ristorante e catering, Terre des Sens si occupa di deliziosi piatti fatti in casa, insalate gourmet, hamburger con formaggi locali e patatine fritte, a cui Chloé ha aggiunto le galettes con l'apertura del ristorante appena rinnovato. I prodotti sono freschi e locali, e per quanto possibile biologici, per garantire la qualità dei piatti e dei sapori che non vi lasceranno indifferenti. Servizio continuo. Il ristorante è aperto tutto l'anno, dal lunedì al sabato, dalle 8.00 alle 22.00. Chiuso la domenica."
        ],
        "fr": [
          "Restaurant et traiteur, Terre des Sens c'est de succulents petits plats maison, des salades gourmandes, des burgers aux fromages locaux et des frites maison, auxquels Chloé ajoute des galettes avec l'ouverture du restaurant fraîchement rénové. Les produits sont frais et locaux, bio dans la mesure du possible pour vous garantir la qualité des mets et des saveurs qui ne vous laisseront pas indifférents. Service en continu. Le restaurant est ouvert toute l'année du lundi au samedi de 8h à 22h. Fermeture le dimanche."
        ],
        "es": [
          "Restaurante y servicio de catering, Terre des Sens es todo comida casera deliciosa, ensaladas gourmet, hamburguesas elaboradas con quesos locales y patatas fritas caseras, a las que Chloé ha añadido galettes con la apertura del restaurante recién renovado. Los productos son frescos y locales, y en la medida de lo posible ecológicos, para garantizar la calidad de los platos y sabores que no le dejarán indiferente. Servicio continuo. El restaurante está abierto todo el año, de lunes a sábado, de 8h a 22h. Domingos cerrado."
        ],
        "nl": [
          "Bij restaurant en traiteur Terre des Sens draait alles om heerlijke huisgemaakte maaltijden, gastronomische salades, hamburgers met lokale kazen en huisgemaakte frietjes, waaraan Chloé met de opening van het onlangs gerenoveerde restaurant galettes heeft toegevoegd. De producten zijn vers en lokaal, en zoveel mogelijk biologisch, om de kwaliteit van de gerechten en smaken te garanderen die je niet onverschillig zullen laten. Continue service. Het restaurant is het hele jaar door geopend, van maandag tot zaterdag van 8.00 tot 22.00 uur. Gesloten op zondag."
        ]
      },
