  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3ebc7ee2-1b6d-300a-b5d6-2b1dae2672b4",
      "dc:description": {
        "de": [
          "Verbringen Sie eine schöne Zeit in der zeltähnlichen Hütte. Für einen Moment der Entspannung, der Flucht und des Wohlbefindens, mit Blick auf den Teich, kommen Sie und genießen Sie das FINNISCHE BAD."
        ],
        "en": [
          "Come and have a good time in the tent-like cabin. For a moment of relaxation, escape and well-being, come and enjoy the FINNISH BATH facing the pond."
        ],
        "it": [
          "Venite a divertirvi nella capanna a forma di tenda. Per un momento di relax, evasione e benessere, venite a godervi il BAGNO FINLANDESE con vista sul laghetto."
        ],
        "fr": [
          "Venez passer un bon moment dans la cabane en forme de tente. Pour un moment de détente, d'évasion et de bien-être, face à l'étang, venez profiter du BAIN FINLANDAIS."
        ],
        "es": [
          "Ven a pasar un buen rato en la cabaña con forma de tienda de campaña. Para un momento de relajación, evasión y bienestar, venga a disfrutar del BAÑO FINLANDÉS con vistas al estanque."
        ],
        "nl": [
          "Kom en vermaak je in de tentvormige hut. Voor een moment van ontspanning, ontsnapping en welzijn, kom en geniet van het FINNISH BATH met uitzicht op de vijver."
        ]
      },
