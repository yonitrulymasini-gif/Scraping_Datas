  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bced698e-a433-3b31-801a-f1e43ee62a8a",
      "dc:description": {
        "de": [
          "Das Hotel liegt im Süden von Brocéliande, im Herzen eines regionalen Naturschutzgebiets und 1,5 km von der Megalithanlage Menhirs de Monteneuf entfernt, einer der wichtigsten Megalithanlagen der Bretagne."
        ],
        "en": [
          "Located south of Brocéliande, in the heart of a Regional Nature Reserve and 1.5 km from the Menhirs de Monteneuf megalithic site, one of the most important in Brittany."
        ],
        "it": [
          "Situato a sud di Brocéliande, nel cuore di una Riserva Naturale Regionale e a 1,5 km dal sito megalitico Menhirs de Monteneuf, uno dei più importanti siti megalitici della Bretagna."
        ],
        "fr": [
          "Situé au sud de Brocéliande, au cœur d'une Réserve Naturelle Régionale et à 1,5 km du site mégalithique des Menhirs de Monteneuf, un des plus importants site mégalithique de Bretagne."
        ],
        "es": [
          "Situado al sur de Brocéliande, en el corazón de una Reserva Natural Regional y a 1,5 km del yacimiento megalítico de Menhirs de Monteneuf, uno de los más importantes de Bretaña."
        ],
        "nl": [
          "Gelegen ten zuiden van Brocéliande, in het hart van een Regionaal Natuurreservaat en op 1,5 km van de megalithische vindplaats Menhirs de Monteneuf, een van de belangrijkste megalithische vindplaatsen in Bretagne."
        ]
      },
      "@type": [
        "Description"
