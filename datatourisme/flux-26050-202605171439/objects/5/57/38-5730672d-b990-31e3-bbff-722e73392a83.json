      "dc:description": {
        "de": [
          "Tag der offenen Tür - Musikschule von Auray\n\nEntdecken Sie die Instrumente und die angebotenen Studiengänge in Anwesenheit des pädagogischen Teams!\n\n14h-15h30: nur für Schüler der Früherziehung 2\n15.30-17.00 Uhr: offen für alle ab der Stufe CP/CE1"
        ],
        "en": [
          "Open Day - Auray Music School\n\nDiscover the instruments and courses on offer, in the presence of the teaching staff!\n\n2pm-3.30pm: reserved for Early Years 2 pupils\n3.30-5pm: open to everyone from CP/CE1 level upwards"
        ],
        "it": [
          "Giornata di apertura - Scuola di musica di Auray\n\nScoprite gli strumenti e i corsi offerti, in presenza del personale docente!\n\n14.00-15.30: riservato agli allievi del livello Early Years 2\n15.30-17.00: aperto a tutti a partire dal livello CP/CE1"
        ],
        "fr": [
          "Journée Portes Ouvertes - Ecole de musique d'Auray\n\nDécouvrez les instruments et les parcours proposés, en présence de l’équipe pédagogique !\n\n14h-15h30 : réservé aux élèves d’éveil 2\n15h30-17h : ouvert à tous·tes à partir du niveau CP/CE1"
        ],
        "nl": [
          "Open Dag - Muziekschool Auray\n\nOntdek de instrumenten en cursussen in aanwezigheid van de docenten!\n\n14.00 - 15.30 uur: gereserveerd voor leerlingen van Early Years 2\n15.30-17.00 uur: open voor iedereen vanaf niveau CP/CE1"
        ],
        "es": [
          "Jornada de Puertas Abiertas - Escuela de Música de Auray\n\nDescubra los instrumentos y los cursos propuestos, en presencia del personal docente\n\nde 14:00 a 15:30: reservado a los alumnos de Early Years 2\n15:30-17:00: abierto a todos a partir del nivel CP/CE1"
        ]
      },
