  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/68ad0dc8-91d1-32f2-b10a-6e0c66d25b69",
      "dc:description": {
        "de": [
          "Konservativer und pädagogischer Bauernhof.\n\nBesichtigungen und Animationen, das ganze Jahr über, nach Vereinbarung.\n\nEntdecken Sie die bretonischen Rassen, die geschützt werden sollen, und das Know-how einer Ziegenhirtin, die Käse herstellt, auf einem ethischen Bauernhof, auf dem kein Tier getötet wird."
        ],
        "en": [
          "Conservatory and educational farm.\n\nVisits and events all year round, by appointment.\n\nCome and discover the Breton breeds that are being preserved and the skills of a goatherd cheese-maker on an ethical farm with no animal deaths."
        ],
        "it": [
          "Conservatorio e fattoria didattica.\n\nVisite ed eventi tutto l'anno, su appuntamento.\n\nVenite a scoprire le razze bretoni protette e le abilità di un casaro di capra in una fattoria etica senza morti di animali."
        ],
        "fr": [
          "Ferme conservatoire et pédagogique.\n\nVisites et animations, toute l'année, sur rendez-vous.\n\nVenez découvrir les races Bretonnes en sauvegarde et le savoir-faire d'une chevrière fromagère dans une ferme éthique sans mort animale."
        ],
        "nl": [
          "Conservatorium en educatieve boerderij.\n\nBezoeken en evenementen het hele jaar door, op afspraak.\n\nKom en ontdek de Bretonse rassen die beschermd worden en de vaardigheden van een geitenkaasmaker op een ethische boerderij zonder diersterfte."
        ],
        "es": [
          "Conservatorio y granja educativa.\n\nVisitas y eventos todo el año, con cita previa.\n\nVenga a descubrir las razas bretonas que se protegen y las habilidades de un quesero caprino en una granja ética sin muerte de animales."
        ]
      },
