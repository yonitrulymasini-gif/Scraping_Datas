  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a38a437e-52e9-3f27-ad46-6a445901070d",
      "dc:description": {
        "de": [
          "Zwischen Guer und Malestroit, in einem kleinen ruhigen Weiler, charmantes Steinhaus von 50 m², neben dem Haus der Eigentümer. Kleine Rasenecke vor dem Haus, Privatgrundstück auf der Rückseite. Keine Vermietung pro Nacht."
        ],
        "en": [
          "Between Guer and Malestroit, in a quiet hamlet, charming 50 m² stone house, adjacent to the owners' house. Small lawn area in front of the house, private plot at rear. No overnight rentals."
        ],
        "it": [
          "Tra Guer e Malestroit, in un borgo tranquillo, affascinante casa in pietra di 50 m² adiacente alla casa dei proprietari. Piccolo prato davanti alla casa, giardino privato sul retro. Non si affittano pernottamenti."
        ],
        "fr": [
          "Entre Guer et Malestroit, dans petit hameau calme, maison de charme en pierre de 50 m², voisine de la maison des propriétaires. Petit coin pelouse devant la maison, terrain privatif à l'arrière. Pas de location à la nuitée."
        ],
        "nl": [
          "Tussen Guer en Malestroit, in een rustig gehucht, charmant stenen huis van 50 m² naast het huis van de eigenaren. Klein grasveldje voor het huis, privétuin aan de achterkant. Geen overnachtingen."
        ],
        "es": [
          "Entre Guer y Malestroit, en una aldea tranquila, encantadora casa de piedra de 50 m² contigua a la casa de los propietarios. Pequeña zona de césped delante de la casa, jardín privado detrás. No se alquila por la noche."
        ]
      },
      "@type": [
        "Description"
      ],
