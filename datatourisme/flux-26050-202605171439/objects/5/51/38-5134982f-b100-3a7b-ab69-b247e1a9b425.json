  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/1f7dd8dd-1285-341e-83ee-967a80b968dd",
      "dc:description": {
        "de": [
          "Haus für 10 Personen in Carentoir im Morbihan, ideal gelegen für schöne Spaziergänge (2 Teiche in 10 Minuten zu Fuß), aber auch um die Region zu erkunden: La Gacilly, die Menhire von Monteneuf, Rochefort-en-Terre, der Wald von Brocéliande, das Manoir de l'automobile von Lohéac, usw...."
        ],
        "en": [
          "House for 10 people in Carentoir in Morbihan, ideally located for beautiful walks (2 ponds 10min walk away), but also for exploring the region: La Gacilly, the menhirs of Monteneuf, Rochefort-en-Terre, the Brocéliande forest, the Manoir de l'automobile in Lohéac, etc..."
        ],
        "it": [
          "Casa per 10 persone a Carentoir nel Morbihan situato in posizione ideale per belle passeggiate (2 stagni 10min a piedi), ma anche per attraversare la regione: La Gacilly, i menhir di Monteneuf, Rochefort-en-Terre, la foresta di Brocéliande, il Manoir de l'automobile de Lohéac, ecc ..."
        ],
        "fr": [
          "Maison pour 10 personnes à Carentoir dans le Morbihan idéalement située pour de belles balades (2 étangs à 10min à pied), mais aussi pour sillonner la région: La Gacilly, les menhirs de Monteneuf, Rochefort-en-Terre, la forêt de Brocéliande, le Manoir de l'automobile de Lohéac, etc..."
        ],
        "nl": [
          "Huis voor 10 personen in Carentoir in Morbihan ideaal gelegen voor mooie wandelingen (2 vijvers 10min lopen), maar ook om de regio te doorkruisen: La Gacilly, de menhirs van Monteneuf, Rochefort-en-Terre, het bos van Brocéliande, het Manoir de l'automobile de Lohéac, etc. ..."
        ],
        "es": [
          "Casa para 10 personas en Carentoir en Morbihan idealmente situado para hermosos paseos (2 estanques 10min a pie), sino también para recorrer la región: La Gacilly, los menhires de Monteneuf, Rochefort-en-Terre, el bosque de Brocéliande, el Manoir de l'automobile de Lohéac, etc ..."
        ]
      },
