  "COVID19SpecialMeasures": {
    "de": [
      "Warten auf die letzte Phase der Containment-Entschärfung:\nTragen von Mundschutz am Empfang.\nReduzierte Anzahl von Personen am Empfang und in den Sanitäranlagen.\nEin Abstand von 1,50 m muss eingehalten werden.\nDie Sanitäranlagen werden mehrmals täglich desinfiziert.\nPflicht zur Verwendung des bereitgestellten hydroalkoholischen Gels."
    ],
    "en": [
      "En attendant la dernière phase de dé-confinement:\nPort du masque à l'accueil.\nNombre de personnes réduit à l'accueil et dans les sanitaires.\nDistance d'1m50 à respecter.\nSanitaires désinfectés plusieurs fois par jour.\nObligation d'utiliser le gel hydroalcoolique mis à disposition."
    ],
    "it": [
      "In attesa della fase finale di de-confinamento:\nIndossare maschere alla reception.\nRiduzione del numero di persone alla reception e nei servizi igienici.\nRispetto della distanza di 1m50.\nDisinfezione dei bagni più volte al giorno.\nObbligo di utilizzare il gel idroalcolico in dotazione."
    ],
    "fr": [
      "En attendant la dernière phase de dé-confinement:\nPort du masque à l'accueil.\nNombre de personnes réduit à l'accueil et dans les sanitaires.\nDistance d'1m50 à respecter.\nSanitaires désinfectés plusieurs fois par jour.\nObligation d'utiliser le gel hydroalcoolique mis à disposition."
    ],
    "nl": [
      "In afwachting van de laatste fase van deconfinement:\nHet dragen van maskers bij de receptie.\nMinder mensen bij de receptie en in de toiletten.\nAfstand van 1m50 te respecteren.\nToiletten meerdere keren per dag ontsmet.\nVerplichting om de verstrekte hydroalcoholische gel te gebruiken."
    ],
    "es": [
      "A la espera de la fase final de desconfinamiento:\nUso de mascarillas en recepción.\nReducción del número de personas en recepción y aseos.\nSe respetará la distancia de 1m50.\nLavabos desinfectados varias veces al día.\nObligación de utilizar el gel hidroalcohólico proporcionado."
    ]
  },
