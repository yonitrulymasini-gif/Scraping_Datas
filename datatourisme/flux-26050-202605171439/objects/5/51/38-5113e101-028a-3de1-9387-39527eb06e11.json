  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/1fd80269-28f6-3a7e-b680-b988c5beb842",
      "dc:description": {
        "de": [
          "Die Apparts'Hôtel de La Bergerie Yves Rocher sind ökologisch konzipierte Unterkünfte mit hohem Standard, die die Anspruchsvollsten unter Ihnen - und nach unseren Berechnungen auch alle anderen - begeistern dürften."
        ],
        "en": [
          "The Apparts'Hôtel de La Bergerie Yves Rocher are high-standard, eco-designed accommodations that should delight the most demanding among you - and, by our calculations, all the others."
        ],
        "it": [
          "Gli Apparts'Hôtel de La Bergerie Yves Rocher sono alloggi ecologici e di alto livello che dovrebbero soddisfare i più esigenti e, secondo i nostri calcoli, tutti gli altri."
        ],
        "fr": [
          "Les Apparts'Hôtel de La Bergerie Yves Rocher sont des hébergements éco-conçus de haut standing, qui devraient ravir les plus exigeants d'entre vous - et, selon nos calculs, tous les autres."
        ],
        "nl": [
          "Het Apparts'Hôtel de La Bergerie Yves Rocher is een eco-ontworpen accommodatie van hoge kwaliteit die de meest veeleisende onder jullie - en volgens onze berekeningen, alle anderen - in verrukking zal brengen."
        ],
        "es": [
          "El Apparts'Hôtel de La Bergerie Yves Rocher es un alojamiento ecológico de alto nivel que hará las delicias de los más exigentes y, según nuestros cálculos, de todos los demás."
        ]
      },
