  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/68f2d5e4-0df0-3c11-91ae-f68de2162aed",
      "dc:description": {
        "de": [
          "Das Maison Tiegezh, ein 4-Sterne-Hotel im Land von Brocéliande, befindet sich in einem vollständig renovierten Gebäude mit authentischem Charme im Departement Morbihan, in dem moderne Raffinesse und traditionelle Authentizität aufeinandertreffen."
        ],
        "en": [
          "In the land of Brocéliande, Maison Tiegezh, a 4-star hotel, is housed in a Morbihan-style building of authentic charm, entirely renovated to combine modern refinement and traditional authenticity."
        ],
        "it": [
          "Nella terra di Brocéliande, la Maison Tiegezh, hotel 4 stelle, è ospitata in un edificio del Morbihan dal fascino autentico, completamente ristrutturato, dove si incontrano la raffinatezza moderna e l'autenticità tradizionale."
        ],
        "fr": [
          "En terre de Brocéliande, la Maison Tiegezh, hôtel classé 4 étoiles, s’inscrit dans une bâtisse morbihannaise au charme authentique, entièrement rénovée, où raffinement moderne et authenticité traditionnelle se côtoient."
        ],
        "nl": [
          "In het land van Brocéliande is Maison Tiegezh, een 4-sterrenhotel, gevestigd in een gebouw in Morbihan met authentieke charme, volledig gerenoveerd, waar moderne verfijning en traditionele authenticiteit elkaar ontmoeten."
        ],
        "es": [
          "En la tierra de Brocéliande, la Maison Tiegezh, hotel de 4 estrellas, se encuentra en un edificio de Morbihan de auténtico encanto, completamente renovado, donde se dan cita el refinamiento moderno y la autenticidad tradicional."
        ]
      },
      "@type": [
        "Description"
      ],
