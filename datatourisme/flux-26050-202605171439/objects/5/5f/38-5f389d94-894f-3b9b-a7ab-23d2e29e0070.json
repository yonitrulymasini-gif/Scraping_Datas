  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/980f1a0a-1438-3002-9fab-c6fc53098459",
      "dc:description": {
        "de": [
          "Schöner Landhafen am Ufer der Vilaine.  Duschen, Toiletten und Trinkwasser für Freizeitkapitäne verfügbar. Kai, Anlegestelle, mechanischer Kran, Slipanlage und Trockenwache"
        ],
        "en": [
          "Pretty country port on the banks of the Vilaine.  Showers, toilets and drinking water available for boaters. Quay, mooring, mechanical crane, slipway and dry docking"
        ],
        "it": [
          "Grazioso porto di campagna sulle rive della Vilaine.  Docce, servizi igienici e acqua potabile a disposizione dei diportisti. Banchina, ormeggio, gru meccanica, scivolo e rimessaggio a secco"
        ],
        "fr": [
          "Joli port de campagne sur les rives de la Vilaine.  Douches, toilettes et eau potable disponible pour les plaisanciers. Quai, amarrage, grue mécanique, cale de mise à l'eau et gardiennage à sec"
        ],
        "nl": [
          "Mooie landelijke haven aan de oever van de Vilaine.  Douches, toiletten en drinkwater beschikbaar voor watersporters. Kade, ligplaatsen, mechanische kraan, scheepshelling en droge opslag"
        ],
        "es": [
          "Bonito puerto rural a orillas del Vilaine.  Duchas, aseos y agua potable a disposición de los navegantes. Muelle, amarre, grúa mecánica, varadero y almacén seco"
        ]
      },
