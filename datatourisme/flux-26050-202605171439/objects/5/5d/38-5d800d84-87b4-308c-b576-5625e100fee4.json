  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c8c784da-9409-3ede-9a2e-6f090668c38d",
      "dc:description": {
        "de": [
          "Ferienhaus, das an eine Reihe von Gebäuden und die Wohnung des Eigentümers angrenzt, 4 km von Carentoir entfernt. Sie werden in diesem Bauernhaus aus dem 18. Jh. empfangen, das sorgfältig renoviert und mit Blumen geschmückt wurde."
        ],
        "en": [
          "Gîte adjoining a group of buildings and the owner's home, 4 km from Carentoir. You'll be welcomed into this 18th-century farmhouse, lovingly renovated and decorated with flowers."
        ],
        "it": [
          "Gîte annesso a un gruppo di edifici e alla casa del proprietario, a 4 km da Carentoir. Sarete accolti in questa casa colonica del XVIII secolo, ristrutturata e decorata con fiori."
        ],
        "fr": [
          "Gîte mitoyen à un ensemble de bâtiments et au logement du propriétaire à 4 km de Carentoir. Vous serez accueillis dans ce corps de ferme du 18ème s., rénové et fleuri avec soin."
        ],
        "nl": [
          "Gîte grenzend aan een groep gebouwen en het huis van de eigenaar, op 4 km van Carentoir. Je wordt verwelkomd in deze 18e eeuwse boerderij, gerenoveerd en versierd met bloemen."
        ],
        "es": [
          "Casa rural contigua a un grupo de edificios y a la casa del propietario, a 4 km de Carentoir. Le acogerán en esta granja del siglo XVIII, renovada y decorada con flores."
        ]
      },
