      "dc:description": {
        "de": [
          "Haus zwischen Rochefort-en-Terre und La Gacilly und in der Nähe des Kanals von Nantes nach Brest, wo man angeln, wandern und Rad fahren kann. Geschlossener Garten."
        ],
        "en": [
          "House located between Rochefort-en-Terre and La Gacilly, near the Canal de Nantes à Brest, where you can fish, hike or bike. Enclosed garden."
        ],
        "it": [
          "Casa situata tra Rochefort-en-Terre e La Gacilly e vicina al Canale di Nantes-Brest, dove è possibile pescare, passeggiare o andare in bicicletta. Giardino recintato."
        ],
        "fr": [
          "Maison située entre Rochefort-en-Terre et La Gacilly et à proximité du Canal de Nantes à Brest, où l'on peut pêcher, randonner à pied ou à vélo. Jardin clos."
        ],
        "nl": [
          "Huis gelegen tussen Rochefort-en-Terre en La Gacilly en vlakbij het kanaal Nantes-Brest, waar je kunt vissen, wandelen of fietsen. Omheinde tuin."
        ],
        "es": [
          "Casa situada entre Rochefort-en-Terre y La Gacilly y cerca del canal Nantes-Brest, donde se puede pescar, pasear o ir en bicicleta. Jardín cerrado."
        ]
