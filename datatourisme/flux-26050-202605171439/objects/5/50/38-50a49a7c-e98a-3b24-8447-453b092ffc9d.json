  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bb2b35e1-c5d4-3787-ba2b-0fbb9226d7ff",
      "dc:description": {
        "de": [
          "Café, Bar, Cocktails mit musikalischer Atmosphäre.\n\nGroße Sonnenterrasse, ideal für Aperitifs mit Wurst- und Käseplatten.\nGroßbildleinwand für Sportübertragungen, kostenloses WLAN."
        ],
        "en": [
          "Café, bar, musical cocktails.\n\nLarge sunny terrace ideal for aperitifs accompanied by charcuterie and cheese boards.\nGiant screen for sports broadcasts, free wifi."
        ],
        "it": [
          "Caffè, bar, cocktail e musica.\n\nGrande terrazza soleggiata ideale per aperitivi accompagnati da taglieri di salumi e formaggi.\nSchermo gigante per le trasmissioni sportive, wifi gratuito."
        ],
        "fr": [
          "Café, bar, cocktails à ambiance musicale.\n\nGrande terrasse ensoleillée idéale pour apéros accompagnés de planches de charcuteries et fromages.\nÉcran géant pour retransmission sportives, wifi gratuit."
        ],
        "nl": [
          "Café, bar, cocktails en muziek.\n\nGroot zonnig terras, ideaal voor een aperitief met schotels vleeswaren en kazen.\nGroot scherm voor sportuitzendingen, gratis wifi."
        ],
        "es": [
          "Café, bar, cócteles y música.\n\nGran terraza soleada ideal para aperitivos acompañados de tablas de embutidos y quesos.\nPantalla gigante para retransmisiones deportivas, wifi gratuito."
        ]
      },
