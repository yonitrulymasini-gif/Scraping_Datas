  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/449777f2-9cf4-3aee-9d36-521a3e29e265",
      "dc:description": {
        "de": [
          "Erholen Sie sich im Herzen einer Ranch. In unseren voll ausgestatteten Mobilheimen für 6 Personen ist Abwechslung garantiert. Bitte kontaktieren Sie uns für Preise und Öffnungszeiten."
        ],
        "en": [
          "Come and recharge your batteries in the heart of a ranch. A change of scenery guaranteed in our fully-equipped 6-person mobile homes. Contact us for rates and times."
        ],
        "it": [
          "Venite a fare il pieno di energia nel cuore di un ranch. Un cambio di scenario garantito nelle nostre case mobili da 6 persone completamente attrezzate. Contattateci per conoscere i prezzi e gli orari."
        ],
        "fr": [
          "Venez vous ressourcer au cœur d'un ranch. Dépaysement garanti dans nos mobil-homes 6 personnes tout équipé. Nous contacter pour les tarifs et horaires."
        ],
        "es": [
          "Venga a reponer fuerzas en el corazón de un rancho. Cambio de aires garantizado en nuestras casas móviles para 6 personas totalmente equipadas. Póngase en contacto con nosotros para consultar precios y horarios."
        ],
        "nl": [
          "Kom nieuwe energie opdoen in het hart van een ranch. Een verandering van omgeving gegarandeerd in onze volledig uitgeruste 6-persoons stacaravans. Neem contact met ons op voor prijzen en tijden."
        ]
      },
      "@type": [
        "Description"
