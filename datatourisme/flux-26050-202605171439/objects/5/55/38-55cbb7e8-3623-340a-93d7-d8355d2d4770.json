      "dc:description": {
        "de": [
          "Unabhängiges Ferienhaus in einem Weiler 2 km von Pleucadeuc entfernt. Plan d'eau du Moulin Neuf, der als Wassersportzentrum eingerichtet wurde, 10 km entfernt. GR38 in 3 km Entfernung."
        ],
        "en": [
          "Self-catering cottage located in a hamlet 2 km from Pleucadeuc. Moulin Neuf lake 10 km away. GR38 hiking trail 3 km away."
        ],
        "it": [
          "Gîte indipendente situato in un borgo a 2 km da Pleucadeuc. Lago Moulin Neuf e centro di sport acquatici a 10 km. Sentiero escursionistico GR38 a 3 km."
        ],
        "fr": [
          "Gîte indépendant situé dans un hameau à 2 km de Pleucadeuc. Plan d'eau du Moulin Neuf aménagé en base nautique à 10 km. GR38 à 3 km."
        ],
        "nl": [
          "Onafhankelijke gîte gelegen in een gehucht op 2 km van Pleucadeuc. Meer van Moulin Neuf en watersportcentrum op 10 km. GR38 wandelroute op 3 km."
        ],
        "es": [
          "Casa rural independiente situada en una aldea a 2 km de Pleucadeuc. Lago y centro náutico de Moulin Neuf a 10 km. Ruta de senderismo GR38 a 3 km."
        ]
