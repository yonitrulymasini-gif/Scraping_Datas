  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/597c5b62-aa7e-3d3f-b029-949769c33fc2",
      "dc:description": {
        "de": [
          "Cottage Les Dunes 2/4 Pers. am Ende einer Sackgasse, 500m vom Meer und den Küstenwegen entfernt, entspannen Sie sich am beheizten Hallenbad, Jacuzzi-Bereich, 2 Terrassen, Privatgarten.\nVollständige und kostenlose Babyausstattung, Parkplatz, Eigentümer vor Ort."
        ],
        "en": [
          "Cottage Les Dunes 2/4 pers at the end of a cul-de-sac 500m from the sea and coastal paths, come and relax and unwind by the covered, heated swimming pool, Jacuzzi area, 2 terraces, private garden.\nFree baby equipment, parking, owner on site."
        ],
        "it": [
          "Cottage Les Dunes 2/4 pers alla fine di un vicolo cieco a 500 m dal mare e dai sentieri costieri, venite a rilassarvi e a distendervi presso la piscina coperta e riscaldata, zona jacuzzi, 2 terrazze, giardino privato.\nAttrezzatura per bambini gratuita, parcheggio, proprietario in loco."
        ],
        "fr": [
          "Cottage Les Dunes 2/4 pers au fond d’une impasse à 500m de la mer et des chemins côtiers, venez vous détendre et vous reposer au bord de la piscine couverte et chauffée, espace jacuzzi, 2 terrasses, jardin privé. \nMatériel bébé complet et gratuit, parking, propriétaire sur place."
        ],
        "es": [
          "Cottage Les Dunes 2/4 pers al final de un callejón sin salida 500m del mar y senderos costeros, venga a relajarse y descansar en la piscina cubierta climatizada, zona de jacuzzi, 2 terrazas, jardín privado.\nEquipamiento para bebés gratuito, aparcamiento, propietario in situ."
        ],
        "nl": [
          "Cottage Les Dunes 2/4 pers aan het einde van een doodlopende weg 500m van de zee en de kustpaden, kom ontspannen en tot rust komen bij het overdekte verwarmde zwembad, jacuzzi, 2 terrassen, privé tuin.\nGratis babyspullen, parkeerplaats, eigenaar ter plaatse."
        ]
      },
      "@type": [
        "Description"
