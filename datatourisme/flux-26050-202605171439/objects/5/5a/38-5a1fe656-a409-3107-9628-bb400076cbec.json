  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/da2463aa-c708-3227-bcdf-536f2caf82cc",
      "dc:description": {
        "de": [
          "Vermietung in einem kleinen Dorf in der Nähe aller Geschäfte - 10 Minuten zu Fuß vom Stadtzentrum entfernt - 7 km von den Stränden entfernt - 2 Schlafzimmer (1 Schlafzimmer mit Doppelbett 140 und 1 Schlafzimmer mit 2 Einzelbetten) - Dusche - Küche/Wohnzimmer -BBQ - Mikrowelle - Geschirrspüler - Waschmaschine - Fernseher - Terrasse. Parkplatz - Gartenmöbel."
        ],
        "en": [
          "Rental located in small village close to all amenities - 10 mn walk from town center - 7 km from beaches - 2 bedrooms (1 bedroom double bed 140 and 1 bedroom 2 single beds) - shower - kitchen/living room - BBQ - microwave - dishwasher - washing machine - TV - Terrace. Parking - garden furniture."
        ],
        "it": [
          "Situato in un piccolo villaggio vicino a tutti i servizi - 10 minuti a piedi dal centro - 7 km dalle spiagge - 2 camere (1 camera con letto matrimoniale 140 e 1 camera con 2 letti singoli) - doccia - cucina/soggiorno - barbecue - microonde - lavastoviglie - lavatrice - televisione - terrazza. Parcheggio - mobili da giardino."
        ],
        "fr": [
          "Location située dans petit village  à proximité de tous les commerces - à 10 mn à pied du centre-ville - à 7 km  plages - 2 chambres (1 chambre lit double 140 et 1 chambre 2 lits 1 personne)- douche - cuisine/séjour -BBQ - micro-ondes - Lave-vaisselle - Lave Linge - Télévision -  Terrasse. Parking - salon jardin."
        ],
        "es": [
          "Situado en un pequeño pueblo cerca de todos los servicios - 10 min a pie del centro del pueblo - 7 km de las playas - 2 habitaciones (1 habitación con cama de matrimonio 140 y 1 habitación con 2 camas individuales) - ducha - cocina/sala de estar - barbacoa - microondas - lavavajillas - lavadora - televisión - terraza. Aparcamiento - muebles de jardín."
        ],
        "nl": [
          "Gelegen in een klein dorp dicht bij alle voorzieningen - 10 min lopen van het centrum - 7 km van de stranden - 2 slaapkamers (1 slaapkamer met een tweepersoonsbed 140 en 1 slaapkamer met 2 eenpersoonsbedden) - douche - keuken / woonkamer - BBQ - magnetron - vaatwasser - wasmachine - televisie - terras. Parkeerplaats - tuinmeubilair."
        ]
      },
      "@type": [
        "Description"
      ],
