  "COVID19SpecialMeasures": {
    "de": [
      "Gesundheitsfördernde Maßnahmen: Desinfektion des Geländes, verstärkte Reinigung der Sanitäranlagen und Bereitstellung eines Desinfektionssprays in den Sanitäranlagen\nbereitstellung von hydroalkoholischer Lösung in allen Gemeinschaftsbereichen\nbegrenzte Anzahl von Personen in der Unterkunft\nverfügbare Dienstleistungen: Der Animationsraum bleibt bis zum 22. Juni geschlossen\nschwimmbad in begrenztem Umfang geöffnet, ebenso wie der Fitnessraum"
    ],
    "en": [
      "Démarches sanitaires: désinfection du site, renforcement du nettoyage des sanitaires et mise à disponibilité d'un pulvérisateur désinfectant dans les sanitaires \nmise à disposition de solution hydro-alcoolique dans toutes les parties communes\nnombre limité de personnes dans l'accueil\nservices disponibles: la salle d'animation reste fermée jusqu'au 22 juin\npiscine ouverte, limitée pour le moment, ainsi que pour la salle de fitness"
    ],
    "it": [
      "Misure sanitarie: disinfezione del sito, pulizia rafforzata dei servizi igienici e disponibilità di uno spray disinfettante nei bagni\nsoluzione idroalcolica disponibile in tutte le aree comuni\nnumero limitato di persone nell'area della reception\nservizi disponibili: la sala attività rimane chiusa fino al 22 giugno\npiscina aperta, ma per il momento limitata, così come la sala fitness"
    ],
    "fr": [
      "Démarches sanitaires: désinfection du site, renforcement du nettoyage des sanitaires et mise à disponibilité d'un pulvérisateur désinfectant dans les sanitaires \nmise à disposition de solution hydro-alcoolique dans toutes les parties communes\nnombre limité de personnes dans l'accueil\nservices disponibles: la salle d'animation reste fermée jusqu'au 22 juin\npiscine ouverte, limitée pour le moment, ainsi que pour la salle de fitness"
    ],
    "nl": [
      "Sanitaire maatregelen: desinfectie van het terrein, versterkte reiniging van de sanitaire ruimtes en beschikbaarheid van een desinfecterende spray in de sanitaire ruimtes\nhydro-alcoholische oplossing beschikbaar in alle gemeenschappelijke ruimten\nbeperkt aantal personen bij de receptie\nbeschikbare diensten: de activiteitenruimte blijft gesloten tot 22 juni\nzwembad open, maar voorlopig beperkt, evenals de fitnessruimte"
    ],
    "es": [
      "Medidas sanitarias: desinfección del lugar, limpieza reforzada de los aseos y disponibilidad de un spray desinfectante en los aseos\nsolución hidroalcohólica disponible en todas las zonas comunes\nnúmero limitado de personas en la zona de recepción\nservicios disponibles: la sala de actividades permanece cerrada hasta el 22 de junio\npiscina abierta, pero limitada por el momento, así como la sala de fitness"
    ]
  },
