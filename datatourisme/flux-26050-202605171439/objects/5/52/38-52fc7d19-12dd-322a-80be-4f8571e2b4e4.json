  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/dc0ab69a-52d6-3b92-b323-1c09cb19bf3c",
      "dc:description": {
        "de": [
          "Gehen Sie mit einem Skipper an Bord eines schnellen und komfortablen RIBs. Lassen Sie sich zu einer Fahrt durch die Bucht, den Golf von Morbihan oder einem Ausflug zu den Inseln Houat und Hoëdic treiben."
        ],
        "en": [
          "Come aboard a fast, comfortable RIB with a skipper. Let yourself be carried away for a trip around the Bay, the Gulf of Morbihan, or an excursion to the islands of Houat and Hoëdic."
        ],
        "it": [
          "Salite a bordo di un RIB veloce e confortevole con uno skipper. Lasciatevi trasportare per una passeggiata nella baia, nel Golfo di Morbihan o per un'escursione alle isole di Houat e Hoëdic."
        ],
        "fr": [
          "Embarquez à bord d’un semi-rigide rapide et confortable avec un skipper. Laissez-vous porter pour une balade dans la Baie, le Golfe du Morbihan, ou une Excursions vers les îles de Houat et Hoëdic."
        ],
        "es": [
          "Suba a bordo de una semirrígida rápida y cómoda con patrón. Déjese llevar para dar un paseo por la bahía, el golfo de Morbihan o una excursión a las islas de Houat y Hoëdic."
        ],
        "nl": [
          "Kom aan boord van een snelle, comfortabele RIB met schipper. Laat je meevoeren voor een wandeling in de baai, de Golf van Morbihan of een excursie naar de eilanden Houat en Hoëdic."
        ]
      },
