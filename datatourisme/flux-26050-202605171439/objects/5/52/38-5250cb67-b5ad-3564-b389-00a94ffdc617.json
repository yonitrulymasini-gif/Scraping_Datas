  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/1f6a089d-2945-34d8-bd39-5ca4761a5e40",
      "dc:description": {
        "de": [
          "Doppelhaushälfte in einem Dorf mit Ferienhäusern, 1,2 km von Quelneuc und 11 km von La Gacilly entfernt. Ehemaliges renoviertes Bauernhaus, das von der Ruhe seiner Umgebung profitiert. Kurzaufenthalte ab 2 Nächten."
        ],
        "en": [
          "Semi-detached gîte in a self-catering village 1.2 km from Quelneuc and 11 km from La Gacilly. Renovated farmhouse in peaceful surroundings. Short stays from 2 nights."
        ],
        "it": [
          "Gîte bifamiliare in un villaggio indipendente a 1,2 km da Quelneuc e a 11 km da La Gacilly. Casa colonica ristrutturata in un ambiente tranquillo. Soggiorni brevi a partire da 2 notti."
        ],
        "fr": [
          "Gîte mitoyen dans un village de gîtes à 1,2 km de Quelneuc et 11 km de la Gacilly. Ancien corps de ferme rénové bénéficiant du calme de son environnement. Courts séjours à partir de 2 nuits."
        ],
        "nl": [
          "Halfvrijstaande gîte in een vakantiehuisdorp op 1,2 km van Quelneuc en 11 km van La Gacilly. Gerenoveerde boerderij in een rustige omgeving. Kort verblijf vanaf 2 nachten."
        ],
        "es": [
          "Casa rural adosada situada en un pueblo con cocina a 1,2 km de Quelneuc y a 11 km de La Gacilly. Casa rural renovada en un entorno tranquilo. Estancias cortas a partir de 2 noches."
        ]
      },
