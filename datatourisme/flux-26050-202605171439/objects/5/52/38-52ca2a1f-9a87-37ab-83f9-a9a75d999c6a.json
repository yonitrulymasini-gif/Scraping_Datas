      "dc:description": {
        "de": [
          "Strand mit weißem Sand. Dieser Strand setzt sich in der Gemeinde Quiberon fort und schließt an den Strand von Saint Julien und den Jachthafen Port Haliguen an."
        ],
        "en": [
          "White sandy beach. This beach extends over the commune of Quiberon in continuity with the beach of Saint Julien and the Marina of Port Haliguen."
        ],
        "it": [
          "Spiaggia di sabbia bianca. Questa spiaggia si estende sul comune di Quiberon in continuità con la spiaggia di Saint Julien e il porto turistico di Port Haliguen."
        ],
        "fr": [
          "Plage de sable blanc. Cette plage se prolonge sur la commune de Quiberon en continuité avec la plage de Saint Julien et le Port de Plaisance de Port Haliguen."
        ],
        "nl": [
          "Wit zandstrand. Dit strand strekt zich uit over de gemeente Quiberon in aansluiting op het strand van Saint Julien en de jachthaven van Port Haliguen."
        ],
        "es": [
          "Playa de arena blanca. Esta playa se extiende en el municipio de Quiberon en continuidad con la playa de Saint Julien y el puerto deportivo de Port Haliguen."
        ]
