  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2382d30d-95e8-36ec-b77a-ba3ecd3eb792",
      "dc:description": {
        "de": [
          "Dieses schöne, freistehende Bauernhaus aus lokalem Schieferstein lädt Sie zu einem angenehmen, ruhigen Urlaub in einer schönen grünen Umgebung ein."
        ],
        "en": [
          "This beautiful detached farmhouse built of local schist stone invites you to spend a peaceful vacation in a lovely green setting."
        ],
        "it": [
          "Questa bella casa colonica indipendente, costruita in pietra scistosa locale, vi invita a trascorrere una vacanza tranquilla in un grazioso contesto verde."
        ],
        "fr": [
          "Cette belle longère indépendante en pierre de schiste de pays vous invite à passer d’agréables vacances au calme dans un joli écrin de verdure."
        ],
        "es": [
          "Esta hermosa casa de campo independiente construida con piedra pizarra local le invita a disfrutar de unas vacaciones tranquilas en un bonito entorno verde."
        ],
        "nl": [
          "Deze prachtige vrijstaande boerderij is gebouwd van lokale leisteen en nodigt je uit om te genieten van een rustige vakantie in een mooie groene omgeving."
        ]
      },
      "@type": [
        "Description"
      ],
