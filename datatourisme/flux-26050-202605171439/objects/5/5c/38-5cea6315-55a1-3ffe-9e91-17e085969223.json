  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b4a5186f-1eee-36fc-8b26-4d1cd8e40c7d",
      "dc:description": {
        "de": [
          "Geräumiges, helles, zugängliches Restaurant. Herzliche Atmosphäre.\nDienstags mittags sowie freitags und samstags abends geöffnet. Sonntag und Montag geschlossen."
        ],
        "en": [
          "Spacious, bright, accessible restaurant. Warm atmosphere.\nOpen Tuesday lunchtimes and Friday and Saturday evenings. Closed on Sundays and Mondays."
        ],
        "it": [
          "Ristorante spazioso, luminoso e accessibile. Atmosfera accogliente.\nAperto a pranzo il martedì e a cena il venerdì e il sabato. Chiuso la domenica e il lunedì."
        ],
        "fr": [
          "Restaurant spacieux, lumineux, accessible. Ambiance chaleureuse.\nOuvert les mardis midi et les vendredis et samedis soirs. Fermé le dimanche et  lundi."
        ],
        "nl": [
          "Ruim, licht, toegankelijk restaurant. Warme sfeer.\nGeopend op dinsdagmiddag en vrijdag- en zaterdagavond. Gesloten op zondag en maandag."
        ],
        "es": [
          "Restaurante amplio, luminoso y accesible. Ambiente cálido.\nAbierto los martes al mediodía y los viernes y sábados por la noche. Cerrado domingos y lunes."
        ]
      },
