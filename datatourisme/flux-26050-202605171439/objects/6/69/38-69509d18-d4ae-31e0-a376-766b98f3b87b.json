  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a9b67d32-c9a3-3ea1-b7fd-13f6a53ee6fb",
      "dc:description": {
        "de": [
          "In einem kleinen Weiler, Wohnung in einer Reihe von Ferienunterkünften in ruhiger Lage. Die Landschaft und das Meer in der Nähe. Alles ist da, um sich zu erholen."
        ],
        "en": [
          "In a small hamlet, apartment in a quiet holiday rental complex. The countryside and the sea nearby. Everything you need to recharge your batteries."
        ],
        "it": [
          "In un piccolo borgo, appartamento in un tranquillo complesso di case vacanza. La campagna e il mare nelle vicinanze. Tutto ciò che serve per ricaricare le batterie."
        ],
        "fr": [
          "Dans un petit hameau, appartement dans un ensemble de locations saisonnières au calme. La campagne et la mer à proximité. Tout est là pour vous ressourcer."
        ],
        "nl": [
          "In een klein gehucht, appartement in een rustig vakantiecomplex. Het platteland en de zee vlakbij. Alles wat je nodig hebt om nieuwe energie op te doen."
        ],
        "es": [
          "En una pequeña aldea, piso en un tranquilo complejo de alquiler vacacional. El campo y el mar cerca. Todo lo necesario para recargar las pilas."
        ]
      },
      "@type": [
        "Description"
