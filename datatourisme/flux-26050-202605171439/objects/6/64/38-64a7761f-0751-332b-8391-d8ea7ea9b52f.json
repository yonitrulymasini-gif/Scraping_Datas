  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/891704dc-3ffc-3216-a6f9-455e76437b65",
      "dc:description": {
        "de": [
          "Einfallsreiche Familienküche (3 Vorspeisen, 3 Hauptgerichte, 3 Desserts).\nDie Speisekarte wird jede Woche erneuert.\nBedienung im Saal oder auf der Veranda.\nLokale und saisonale Produkte.\n\nDas ganze Jahr über geöffnet. Kapazität 25 Gedecke."
        ],
        "en": [
          "Inventive family cuisine (3 starters, 3 main courses, 3 desserts).\nThe menu changes weekly.\nService in the dining room or on the veranda.\nLocal, seasonal produce.\n\nOpen all year round. Capacity 25 covers."
        ],
        "it": [
          "Cucina familiare inventiva (3 antipasti, 3 piatti principali, 3 dessert).\nIl menu cambia ogni settimana.\nServizio in sala o in veranda.\nProdotti locali e di stagione.\n\nAperto tutto l'anno. Capacità 25 coperti."
        ],
        "fr": [
          "Cuisine familiale et inventive (3 entrées, 3 plats, 3 desserts).\nLa carte se renouvelle chaque semaine.\nService en salle ou en véranda. \nProduits locaux et de saison.\n\nOuvert toute l'année. Capacité 25 couverts."
        ],
        "nl": [
          "Inventieve familiekeuken (3 voorgerechten, 3 hoofdgerechten, 3 desserts).\nHet menu verandert elke week.\nService in de eetzaal of op de veranda.\nLokale, seizoensgebonden producten.\n\nHet hele jaar geopend. Capaciteit 25 couverts."
        ],
        "es": [
          "Cocina familiar inventiva (3 entrantes, 3 platos principales, 3 postres).\nEl menú cambia cada semana.\nServicio en el comedor o en la terraza.\nProductos locales de temporada.\n\nAbierto todo el año. Capacidad para 25 comensales."
        ]
      },
      "@type": [
        "Description"
      ],
