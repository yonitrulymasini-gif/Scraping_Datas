  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/64665608-09a4-39d2-8a9e-29b4a07ef6b1",
      "dc:description": {
        "de": [
          "Schnellrestaurants vor Ort oder zum Mitnehmen: Pizzas, Paninis, Burger, Tacos, Salate, hausgemachte Desserts. Sie finden eine vielfältige Karte mit Pizzen aus hausgemachtem Teig, aber auch Burger und Paninis, die mit handwerklich hergestelltem Brot zubereitet werden."
        ],
        "en": [
          "Fast food to eat in or take away: pizzas, paninis, burgers, tacos, salads, homemade desserts. You'll find a varied menu of pizzas made with homemade dough, as well as burgers and paninis made with artisan breads."
        ],
        "it": [
          "Fast food da mangiare o da portare via: pizze, panini, hamburger, tacos, insalate e dolci fatti in casa. Troverete un menu vario di pizze preparate con pasta \"fatta in casa\", oltre ad hamburger e panini preparati con pane tradizionale."
        ],
        "fr": [
          "Restauration rapide sur place ou à emporter : pizzas, paninis, burger, tacos, salades, desserts maisons. Vous trouverez une carte variée de pizzas réalisées avec pâte \"fait maison\" mais également des burgers et des paninis réalisés avec des pains artisanaux."
        ],
        "nl": [
          "Fastfood om te eten of mee te nemen: pizza's, panini's, hamburgers, taco's, salades en huisgemaakte desserts. Je vindt hier een gevarieerd menu van pizza's gemaakt met \"huisgemaakt\" deeg, evenals hamburgers en panini's gemaakt met traditioneel brood."
        ],
        "es": [
          "Comida rápida para comer o llevar: pizzas, paninis, hamburguesas, tacos, ensaladas y postres caseros. Encontrarás una variada carta de pizzas elaboradas con masa casera, así como hamburguesas y paninis hechos con pan tradicional."
        ]
      },
