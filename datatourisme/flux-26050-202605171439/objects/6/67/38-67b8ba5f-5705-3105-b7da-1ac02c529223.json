      "dc:description": {
        "de": [
          "Entdecken Sie die Inseln des Golfs mit einem diplomierten Lehrer.Stand up paddle ist ab einem Alter von 10 Jahren möglich.  Wir organisieren \"Gruppen\"-Ausflüge für maximal 30 Personen."
        ],
        "en": [
          "Discover the islands of the Gulf with a qualified instructor.  We organize \"group\" outings for a maximum of thirty people."
        ],
        "it": [
          "Scoprite le isole del Golfo con un istruttore qualificato.  Organizziamo uscite di gruppo per un massimo di 30 persone."
        ],
        "fr": [
          "Découvrir les îles du Golfe avec un moniteur diplômé.Le Stand up paddle est accessible dès l'âge de 10 ans.  Nous organisons des sorties \"groupe\" pour une trentaine de personnes maximum."
        ],
        "nl": [
          "Ontdek de eilanden van de Golf met een gekwalificeerde instructeur.  Wij organiseren groepsuitstapjes voor maximaal dertig personen."
        ],
        "es": [
          "Descubra las islas del Golfo con un instructor cualificado.  Organizamos salidas en grupo para un máximo de 30 personas."
        ]
