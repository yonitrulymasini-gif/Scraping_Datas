  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f9b765e0-402a-39dd-9ba5-fcc041a6fec9",
      "dc:description": {
        "de": [
          "Weißer Sandstrand, familienfreundlich, wohlhabende Villen direkt am Meer.\r\n\r\nStrandclub für Kinder, Badebereich, Sprungturm, schattiger Parkplatz, in der Nähe des Hafens von Orange und der Geschäfte, Bouleplatz, zwei Volleyballfelder am Strandeingang, öffentliche Toiletten."
        ],
        "en": [
          "Family-friendly, white-sand beach, plush beachfront villas.\r\n\r\nBeach club for children, swimming area, diving board, shaded parking, close to the port of Orange and shops, boules pitch, two volleyball courts at the beach entrance, public toilets."
        ],
        "it": [
          "Spiaggia di sabbia bianca, adatta alle famiglie, ville lussuose sul mare.\r\n\r\nBeach club per bambini, zona balneare, trampolino, parcheggio ombreggiato, vicino al porto di Orange e ai negozi, campo da bocce, due campi da pallavolo all'ingresso della spiaggia, servizi igienici pubblici."
        ],
        "fr": [
          "Plage de sable blanc, familiale, villas cossues en front de mer. \r\n\r\nClub de plage pour les enfants, zone de baignade, plongeoir, parking ombragé, à proximité du port d'Orange et des commerces, terrain de boules, deux terrains de volley à l’entrée de la plage, toilettes publiques."
        ],
        "nl": [
          "Wit zandstrand, gezinsvriendelijk, pluche villa's aan zee.\r\n\r\nBeach club voor kinderen, zwemgedeelte, duikplank, schaduwrijke parkeerplaats, dicht bij de haven van Orange en winkels, jeu de boulesbaan, twee volleybalvelden bij de strandopgang, openbare toiletten."
        ],
        "es": [
          "Playa de arena blanca, ideal para familias, lujosas villas frente al mar.\r\n\r\nClub de playa para niños, zona de baño, trampolín, aparcamiento con sombra, cerca del puerto de Orange y de las tiendas, campo de petanca, dos pistas de voleibol a la entrada de la playa, aseos públicos."
        ]
      },
