  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bf9d34cc-12aa-393f-ba53-8e3825d9f697",
      "dc:description": {
        "de": [
          "Mit seinem einzigartigen Blick auf den Hafen bietet Ihnen das Restaurant l'Arrosoir eine raffinierte ozeanische Küche. Fisch, Meeresfrüchte, Tagesgerichte auf der Schiefertafel in einer sympathischen und entspannten Atmosphäre!"
        ],
        "en": [
          "With its unique view of the harbour, the restaurant l'Arrosoir offers refined oceanic cuisine. Fish, seafood, dishes of the day on the slate in a friendly and relaxed atmosphere!"
        ],
        "it": [
          "Con una vista unica sul porto, il ristorante l'Arrosoir offre una raffinata cucina oceanica. Pesce, frutti di mare, specialità del giorno sulla lavagna in un'atmosfera amichevole e rilassata!"
        ],
        "fr": [
          "Avec sa vue unique sur le port, le restaurant l’Arrosoir vous propose une cuisine Océane raffinée. Poissons, fruits de mer, plats du jour à l’ardoise dans une ambiance sympathique et décontractée !"
        ],
        "nl": [
          "Met zijn unieke uitzicht op de haven biedt het restaurant l'Arrosoir verfijnde oceanische gerechten. Vis, zeevruchten, dagschotels op de lei in een vriendelijke en ontspannen sfeer!"
        ],
        "es": [
          "Con una vista única del puerto, el restaurante l'Arrosoir ofrece una refinada cocina oceánica. ¡Pescado, marisco, especialidades del día en la pizarra en un ambiente agradable y relajado!"
        ]
      },
      "@type": [
        "Description"
