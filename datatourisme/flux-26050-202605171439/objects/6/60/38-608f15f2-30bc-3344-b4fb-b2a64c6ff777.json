      "dc:description": {
        "de": [
          "Ich bin professionelle Pastellmalerin und Vorsitzende des Vereins Art du Pastel en France. Ich wohne im Departement Morbihan und habe seit Sommer 2024 mein Atelier / meine Galerie in Sérent eröffnet."
        ],
        "en": [
          "I am a professional pastel painter and president of the Art du Pastel en France association. Based in Morbihan, I opened my studio/gallery in Sérent in the summer of 2024."
        ],
        "it": [
          "Sono un pittore professionista di pastelli e presidente dell'associazione Art du Pastel en France. Vivo nel Morbihan e ho aperto il mio studio/galleria a Sérent nell'estate del 2024."
        ],
        "fr": [
          "Je suis artiste peintre pastelliste professionnelle, présidente de l'association Art du Pastel en France. Domiciliée dans le Morbihan, j'ai ouvert mon atelier / galerie à Sérent depuis l'été 2024."
        ],
        "es": [
          "Soy pintor profesional al pastel y presidente de la asociación Art du Pastel en France. Vivo en Morbihan y abrí mi estudio/galería en Sérent en el verano de 2024."
        ],
        "nl": [
          "Ik ben professioneel pastelschilder en voorzitter van de vereniging Art du Pastel en France. Ik woon in Morbihan en open mijn atelier/galerie in Sérent in de zomer van 2024."
        ]
      },
