      "@id": "https://data.datatourisme.fr/6d4ffa90-b0f1-38ca-8323-02c94f4008f9",
      "dc:description": {
        "de": [
          "Fleisch - Pizzas - Burgers - Tagliatelle\nVerkauf von Pizzas, Burger, Pommes Frites und hausgemachten Muscheln mit Pommes frites.\nHauslieferung* am Strand von Carnac oder in der Stadt, mit mindestens 2 Artikeln - 5?"
        ],
        "en": [
          "Meats - Pizzas - Burgers - Tagliatelle\nTakeaway & Home Delivery* of Pizzas, Burgers, French fries, home-made Moules frites.\nHome delivery* on Carnac plage or bourg, with 2 items minimum - 5?"
        ],
        "it": [
          "Carne - Pizze - Hamburger - Tagliatelle\nPizze, hamburger, patatine e cozze da asporto e consegna a domicilio*.\nConsegna a domicilio* sulla spiaggia o in città di Carnac, con un minimo di 2 pezzi - 5?"
        ],
        "fr": [
          "Viandes - Pizzas - Burgers - Tagliatelles\nVente à Emporter & Livraison à Domicile* de Pizzas, Burgers, Frites, Moules frites maison .\nLivraison à Domicile* sur Carnac plage ou bourg, avec 2 articles minimum - 5€"
        ],
        "nl": [
          "Vlees - Pizza's - Burgers - Tagliatelle\nAfhaalmaaltijden en thuisbezorging* van huisgemaakte pizza's, hamburgers, friet en mosselen.\nThuisbezorging* op het strand of in de stad Carnac, met een minimum van 2 items - 5?"
        ],
        "es": [
          "Carne - Pizzas - Hamburguesas - Tallarines\nComida para llevar y entrega a domicilio* de pizzas, hamburguesas, patatas fritas y mejillones caseros.\nEntrega a domicilio* en la playa de Carnac o en la ciudad, con un mínimo de 2 unidades - 5?"
        ]
      },
