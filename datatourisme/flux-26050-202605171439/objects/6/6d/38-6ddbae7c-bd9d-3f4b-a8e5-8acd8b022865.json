  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ea7855d3-ec1a-345f-acea-2414b18d8fd4",
      "dc:description": {
        "de": [
          "Das Leben in einem Schloss zu genießen ist ein Traum, der in diesem jahrhundertealten Park wahr wird. 2 Gästezimmer wurden im Wohnsitz der Grafen von Guer eingerichtet.  Gästetisch."
        ],
        "en": [
          "Château life is a dream come true in this centuries-old park. 2 guest rooms have been fitted out in the residence of the Counts of Guer.  Table d'hôtes."
        ],
        "it": [
          "La vita di castello è un sogno che diventa realtà in questo parco secolare. 2 camere per gli ospiti sono state allestite nella residenza dei conti di Guer.  Tavola degli ospiti."
        ],
        "fr": [
          "Profiter de la vie de château est un rêve qui devient réalité dans ce parc séculaire. 2 chambres d'hôtes ont été aménagées dans la demeure des comtes de Guer.  Table d'hôtes."
        ],
        "es": [
          "La vida de castillo es un sueño hecho realidad en este parque centenario. se han habilitado 2 habitaciones de huéspedes en la residencia de los condes de Guer.  Mesa de huéspedes."
        ],
        "nl": [
          "Het kasteelleven is een droom die uitkomt in dit eeuwenoude park. er zijn 2 gastenkamers ingericht in de residentie van de graven van Guer.  Table d'hôtes."
        ]
      },
