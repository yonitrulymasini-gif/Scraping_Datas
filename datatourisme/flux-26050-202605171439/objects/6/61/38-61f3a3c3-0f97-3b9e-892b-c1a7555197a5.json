  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d8627bd6-2509-3a35-9180-7833702e677a",
      "dc:description": {
        "de": [
          "Christophe und Jacqueline begrüßen Sie in ihrem Gästezimmer, das auf dem Land ganz in der Nähe der Innenstadt von Ploërmel liegt. Wanderungen, Radtouren und Angeln sind nur einige der Aktivitäten, die sich Ihnen bieten. Entspannung und Ausflüge in die Natur stehen auf dem Programm."
        ],
        "en": [
          "Christophe and Jacqueline welcome you to their bed and breakfast, located in the countryside close to Ploërmel town center. Walking, cycling and fishing are just some of the activities on offer. Relaxation and nature outings are guaranteed."
        ],
        "it": [
          "Christophe e Jacqueline vi danno il benvenuto nel loro bed and breakfast, situato in campagna vicino al centro di Ploërmel. Passeggiate, ciclismo e pesca sono solo alcune delle attività offerte. Il relax e le escursioni nella natura sono garantiti."
        ],
        "fr": [
          "Christophe et Jacqueline vous accueillent dans leur chambre d'hôtes, située à la campagne, tout proche de Ploërmel ville-centre. Les balades à  pied ou à vélo, la pêche sont des activités qui s'offrent à vous. Détente et sortie nature sont au rendez-vous."
        ],
        "es": [
          "Christophe y Jacqueline le dan la bienvenida a su casa de huéspedes, situada en plena naturaleza, cerca del centro de Ploërmel. Podrá practicar senderismo, ciclismo y pesca. La relajación y las excursiones en plena naturaleza están garantizadas."
        ],
        "nl": [
          "Christophe en Jacqueline heten je welkom in hun bed and breakfast, gelegen op het platteland dicht bij het centrum van Ploërmel. Wandelen, fietsen en vissen zijn slechts enkele van de aangeboden activiteiten. Ontspanning en uitstapjes in de natuur zijn gegarandeerd."
        ]
      },
      "@type": [
        "Description"
      ],
