  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bd671946-4e77-3658-8aab-afa5dd3be4f0",
      "dc:description": {
        "de": [
          "Von Morbihan grandeur Nature angebotene Führung - Die Natur aus nächster Nähe beobachten\n\nZwischen Farben, Texturen und Meeresgerüchen lädt Sie diese Animation dazu ein, die Vielfalt der Algen zu entdecken,\nihre Geheimnisse, ihre Verwendung und die Regeln, die für eine verantwortungsvolle Ernte zu beachten sind."
        ],
        "en": [
          "Guided tour offered by Morbihan grandeur Nature - A closer look at nature \n\nWith its colours, textures and marine smells, this activity invites you to discover the diversity of seaweed,\ntheir secrets, their uses and the rules for responsible harvesting."
        ],
        "it": [
          "Visita guidata proposta da Morbihan grandeur Nature - Uno sguardo da vicino alla natura\n\nCon i suoi colori, le sue consistenze e i suoi odori marini, questa attività vi invita a scoprire la diversità delle alghe,\ni loro segreti, i loro usi e le regole per una raccolta responsabile."
        ],
        "fr": [
          "Visite guidée proposée par Morbihan grandeur Nature - Observer la nature de plus près \n\nEntre couleurs, textures et odeurs marines, cette animation vous invite à découvrir la diversité des algues,\nleurs secrets, leurs usages et les règles à respecter pour une récolte responsable."
        ],
        "es": [
          "Visita guiada ofrecida por Morbihan grandeur Nature - Una mirada más cercana a la naturaleza\n\nCon sus colores, texturas y olores marinos, esta actividad le invita a descubrir la diversidad de las algas,\nsus secretos, sus usos y las normas para una recolección responsable."
        ],
        "nl": [
          "Rondleiding aangeboden door Morbihan grandeur Nature - Een kijkje in de natuur\n\nMet zijn kleuren, texturen en zeegeuren nodigt deze activiteit u uit om de diversiteit van zeewier te ontdekken,\nhun geheimen, hun gebruik en de regels voor verantwoord oogsten."
        ]
      },
