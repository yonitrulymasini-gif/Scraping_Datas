  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3aedcfb8-563c-3092-89b8-285d5fa87fa6",
      "dc:description": {
        "de": [
          "Inmitten der bretonischen Landschaft, zwischen Brocéliande, La Gacilly, den Megalithen von Monteneuf und dem Kanal von Nantes nach Brest, haben Sie die Wahl zwischen Spaziergängen und Besichtigungen."
        ],
        "en": [
          "In the heart of the Breton countryside, between Brocéliande, La Gacilly, the Monteneuf megaliths and the Nantes-Brest canal, you'll have a wide choice of walks and visits."
        ],
        "it": [
          "Nel cuore della campagna bretone, tra Brocéliande, La Gacilly, i megaliti di Monteneuf e il canale Nantes-Brest, potrete scegliere tra un'ampia gamma di passeggiate e visite."
        ],
        "fr": [
          "En pleine campagne bretonne, entre Brocéliande, La Gacilly, les Mégalithes de Monteneuf, le canal de Nantes à Brest, vous aurez le choix de ballades, de visites."
        ],
        "nl": [
          "In het hart van het Bretonse platteland, tussen Brocéliande, La Gacilly, de megalieten van Monteneuf en het kanaal Nantes-Brest, kun je kiezen uit een breed scala aan wandelingen en bezoeken."
        ],
        "es": [
          "En plena campiña bretona, entre Brocéliande, La Gacilly, los megalitos de Monteneuf y el canal Nantes-Brest, podrá elegir entre una amplia gama de paseos y visitas."
        ]
      },
