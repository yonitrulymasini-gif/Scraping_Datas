      "dc:description": {
        "de": [
          "Eine einfache und leckere Küche in der Nähe des Grünen Wegs!\nGeöffnet von Dienstag bis Samstag, mittags und abends."
        ],
        "en": [
          "Simple, gourmet cuisine, close to the greenway!\nOpen Tuesday to Saturday, lunch and dinner."
        ],
        "it": [
          "Cucina semplice e gourmet proprio accanto alla greenway!\nAperto da martedì a sabato, a pranzo e a cena."
        ],
        "fr": [
          "Une cuisine simple et gourmande, à proximité de la voie verte !\nOuvert du mardi au samedi, midi et soir."
        ],
        "nl": [
          "Eenvoudige, gastronomische keuken vlak naast de greenway!\nGeopend van dinsdag tot zaterdag, lunch en diner."
        ],
        "es": [
          "Cocina sencilla y gourmet junto a la vía verde\nAbierto de martes a sábado, almuerzo y cena."
        ]
