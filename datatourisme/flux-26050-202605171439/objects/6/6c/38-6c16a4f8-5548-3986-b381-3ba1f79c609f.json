  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/61aa32ce-a573-39b2-b259-34042e35d04f",
      "dc:description": {
        "de": [
          "Restaurant mit Panoramablick auf den Teich. Warme und gemütliche Atmosphäre in einem Holzgebäude, das von einem 3 ha großen Park umgeben ist. Geöffnet von Dienstag bis Sonntag, mittags und abends am Freitag und Samstag. Sonntagabend und Montag geschlossen."
        ],
        "en": [
          "Restaurant with panoramic view of the pond. Warm, cosy atmosphere in a wooden building surrounded by 3 hectares of parkland. Open Tuesday to Sunday, lunch and dinner on Friday and Saturday. Closed Sunday evening and Monday."
        ],
        "it": [
          "Ristorante con vista panoramica sul lago. Atmosfera calda e accogliente in un edificio in legno circondato da 3 ettari di parco. Aperto dal martedì alla domenica, a pranzo e la sera il venerdì e il sabato. Chiuso la domenica sera e il lunedì."
        ],
        "fr": [
          "Restaurant avec vue panoramique sur l'étang. Ambiance chaleureuse et cosy dans un bâtiment en bois entouré d'un parc de 3 ha. Ouvert du mardi au dimanche, le midi et le soir le vendredi et samedi. Fermeture le dimanche soir et le lundi."
        ],
        "es": [
          "Restaurante con vistas panorámicas al lago. Ambiente cálido y acogedor en un edificio de madera rodeado de 3 hectáreas de parque. Abierto de martes a domingo, viernes y sábados al mediodía y por la noche. Cerrado los domingos por la noche y los lunes."
        ],
        "nl": [
          "Restaurant met panoramisch uitzicht over het meer. Warme, gezellige sfeer in een houten gebouw omringd door 3 hectare park. Geopend van dinsdag tot zondag, 's middags en 's avonds op vrijdag en zaterdag. Gesloten op zondagavond en maandag."
        ]
      },
