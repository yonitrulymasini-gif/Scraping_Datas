      "dc:description": {
        "de": [
          "Entdecken Sie die Aktivität Laser Tag , eine Mischung aus Paintball und Laser Game auf einem 7000 m2 großen Außengelände.\n\nSie können diese Aktivität auch auf Wanderschaft entdecken. Direkt bei Ihnen zu Hause."
        ],
        "en": [
          "Discover Laser Tag, a mix between paintball and Laser Game on a 7,000 m2 outdoor field.\n\nYou can also discover this activity on the road. Directly at home."
        ],
        "it": [
          "Scoprite il Laser Tag, un mix tra paintball e Laser Game su un campo all'aperto di 7.000 m2.\n\nPotete scoprire questa attività anche in viaggio. Direttamente a casa vostra."
        ],
        "fr": [
          "Découvrez l'activité Laser Tag , un mix entre paintball et Laser Game sur un terrain extérieur de 7000 m2. \n\nVous pourrez découvrir cet activité également en itinérance. Directement chez vous."
        ],
        "nl": [
          "Ontdek Laser Tag, een mix tussen paintball en lasergame op een buitenveld van 7.000 m2.\n\nJe kunt deze activiteit ook onderweg ontdekken. Direct bij je thuis."
        ],
        "es": [
          "Descubra Laser Tag, una mezcla entre paintball y Laser Game en un campo al aire libre de 7.000 m2.\n\nTambién puede descubrir esta actividad sobre la marcha. Directamente en su casa."
        ]
      },
