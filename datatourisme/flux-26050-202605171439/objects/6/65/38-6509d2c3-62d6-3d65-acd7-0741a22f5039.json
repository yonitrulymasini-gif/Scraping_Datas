  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/aebe90bb-d50f-3c29-9249-900a0f9d23b3",
      "dc:description": {
        "de": [
          "Unabhängige Unterkunft mit offener Küche, Ess- und Wohnzimmer mit Holzofen. 2 Schlafzimmer.  Andere Unterkünfte in der Nähe. Zur gemeinsamen Nutzung: Zugang zum beheizten (29°) und überdachten Schwimmbad, Sauna in einem gemütlichen Raum."
        ],
        "en": [
          "Self-contained gîte with open-plan kitchen, dining/living room with wood-burning stove. 2 bedrooms.  Other gîtes nearby. Shared: access to heated (29°) and covered swimming pool, sauna in a cosy room."
        ],
        "it": [
          "Gîte indipendente con cucina a pianta aperta, sala da pranzo/soggiorno con stufa a legna. 2 camere da letto.  Altri alloggi nelle vicinanze. In comune: accesso alla piscina riscaldata (29°) e coperta, sauna in una stanza accogliente."
        ],
        "fr": [
          "Gîte indépendant avec cuisine ouverte, salle à manger-salon avec poèle à bois. 2 chambres.  Autres gîtes à proximité. En commun: accès piscine chauffée (29°) et couverte, sauna dans une pièce chaleureuse."
        ],
        "nl": [
          "Vrijstaande gîte met open keuken, eet/woonkamer met houtkachel. 2 slaapkamers.  Andere gîtes in de buurt. Gedeeld: toegang tot verwarmd (29°) en overdekt zwembad, sauna in een gezellige ruimte."
        ],
        "es": [
          "Casa rural independiente con cocina americana, comedor/sala de estar con estufa de leña. 2 habitaciones.  Otras casas rurales cerca. Compartido: acceso a piscina climatizada (29°) y cubierta, sauna en una acogedora sala."
        ]
      },
      "@type": [
        "Description"
