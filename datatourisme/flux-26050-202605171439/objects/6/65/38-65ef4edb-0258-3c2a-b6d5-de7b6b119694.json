      "dc:description": {
        "de": [
          "Entdecken Sie die neue Freiluft-Fotoausstellung in Campénéac: Fotograf sein... in der Bretagne. Ein künstlerisches Ereignis, das Sie nicht verpassen sollten!\nAm 16. Mai um 17 Uhr können Sie bei einem gemütlichen Beisammensein an der Vernissage teilnehmen."
        ],
        "en": [
          "Come and discover Campénéac's new open-air photo exhibition: Etre photographe... en Bretagne. An artistic event not to be missed!\nOn May 16, at 5pm, join us for a convivial opening."
        ],
        "it": [
          "Venite a scoprire la nuova mostra fotografica all'aperto di Campénéac: Essere fotografi... in Bretagna. Un evento artistico da non perdere!\nIl 16 maggio, alle ore 17.00, unitevi a noi in una serata conviviale per festeggiare l'inaugurazione della mostra."
        ],
        "fr": [
          "Venez découvrir la nouvelle exposition photos en plein air de Campénéac : Etre photographe... en Bretagne. Un rendez-vous artistique à ne pas manquer !\nLe 16 mai, à 17h, assistez à son vernissage lors d'un moment convivial."
        ],
        "es": [
          "Venga a descubrir la nueva exposición fotográfica al aire libre de Campénéac: Ser fotógrafo... en Bretaña. Un acontecimiento artístico que no se puede perder\nEl 16 de mayo, a las 17:00, participe en una velada de convivencia para celebrar la inauguración de la exposición."
        ],
        "nl": [
          "Kom en ontdek de nieuwe fototentoonstelling van Campénéac in de open lucht: Fotograaf zijn... in Bretagne. Een artistiek evenement dat u niet mag missen!\nKom op 16 mei om 17.00 uur naar een gezellige avond om de opening van de tentoonstelling te vieren."
        ]
      },
