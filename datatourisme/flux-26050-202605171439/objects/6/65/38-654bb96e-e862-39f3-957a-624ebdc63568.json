  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6d3fee05-efe7-365f-b6f8-c409d53978c7",
      "dc:description": {
        "de": [
          "Auf drei Hektar Grünfläche mit Tieren ist der Ort ruhig und erholsam. Das Studio verfügt über eine eigene Terrasse mit Blick auf den Garten, der sowohl wild als auch landschaftlich gestaltet ist."
        ],
        "en": [
          "Set in three hectares of greenery with animals, the location is calm and relaxing. The studio has a private terrace overlooking the wild, landscaped garden."
        ],
        "it": [
          "Immerso in tre ettari di verde con animali, l'ambiente è tranquillo e riposante. Lo studio dispone di una terrazza privata che si affaccia sul giardino selvaggio e paesaggistico."
        ],
        "fr": [
          "Sur trois hectares de verdure avec des animaux, le lieu est calme et reposant. Le studio dispose d'une terrasse privée avec vue sur le jardin, à la fois sauvage et paysager."
        ],
        "es": [
          "Situado en tres hectáreas de vegetación con animales, el entorno es tranquilo y relajante. El estudio dispone de una terraza privada con vistas al jardín salvaje y ajardinado."
        ],
        "nl": [
          "Gelegen in drie hectare groen met dieren, is de omgeving rustig en rustgevend. De studio heeft een privéterras met uitzicht op de wilde, aangelegde tuin."
        ]
      },
      "@type": [
        "Description"
