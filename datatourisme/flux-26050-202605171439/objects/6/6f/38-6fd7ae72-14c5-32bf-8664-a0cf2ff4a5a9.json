  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/57958ba4-3984-3b71-bd3d-fbaa95ff5428",
      "dc:description": {
        "de": [
          "Renoviertes Haus mit zwei Schlafzimmern (mit Einbauschränken), von denen eines mit einem Doppelbett und einem Schreibtisch und das andere mit zwei Einzelbetten ausgestattet ist. Wohnzimmer, voll ausgestattete Küche, Badezimmer mit italienischer Dusche. Separates WC."
        ],
        "en": [
          "Renovated house with two bedrooms (with fitted closets), one with a double bed and desk, the other with two single beds. Living room, fully equipped kitchen, bathroom with walk-in shower. Separate WC."
        ],
        "it": [
          "Casa ristrutturata con due camere da letto (con armadi), una con letto matrimoniale e scrivania e l'altra con due letti singoli. Salone, cucina completamente attrezzata, bagno con cabina doccia. WC separato."
        ],
        "fr": [
          "Maison rénovée avec deux chambres (avec placards) dont une avec un lit double et un bureau et l'autre avec deux lits une personne. Salon, cuisine toute équipée, salle de bains avec douche à l'italienne. WC séparé."
        ],
        "nl": [
          "Gerenoveerd huis met twee slaapkamers (met kasten), een met een tweepersoonsbed en een bureau en de andere met twee eenpersoonsbedden. Zitkamer, volledig uitgeruste keuken, badkamer met inloopdouche. Aparte WC."
        ],
        "es": [
          "Casa reformada con dos dormitorios (con armarios), uno con cama de matrimonio y escritorio y el otro con dos camas individuales. Salón, cocina equipada, cuarto de baño con ducha. WC separado."
        ]
      },
