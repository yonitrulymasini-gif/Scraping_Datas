  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/54454284-a068-3a53-b1a0-b80204d3ecd1",
      "dc:description": {
        "de": [
          "Von 10:00 bis 12:30 Uhr und von 14:00 bis 17:00 Uhr.  Mithilfe von Spielen werden Groß und Klein eingeladen, die Schätze des Museums auf andere Weise zu betrachten.  Es ist keine Reservierung erforderlich. Der Preis ist im Eintrittspreis enthalten"
        ],
        "en": [
          "10.15am - 12.15pm: Enigmatic, poetic... Take inspiration from the \"Lady of Kermené\", a rare example of a Neolithic statue, to model a clay figurine.\n\nFor children aged 6 and over. Bring a container.\n\nOnline booking available."
        ],
        "it": [
          "Dalle 10.00 alle 12.30, poi dalle 14.00 alle 17.00.  Attraverso i giochi, grandi e piccini sono invitati a osservare i tesori del museo in modo diverso.  Non è necessaria la prenotazione. Prezzo incluso nel biglietto d'ingresso"
        ],
        "fr": [
          "De 10h à 12h30 puis de 14h à 17h.  À travers des jeux, petits et grands sont invités à observer autrement les trésors du musée.  Sans réservation. Tarif inclus dans le prix du billet d'entrée"
        ],
        "nl": [
          "Van 10.00 tot 12.30 uur, daarna van 14.00 tot 17.00 uur.  Door middel van spelletjes worden jong en oud uitgenodigd om de schatten van het museum op een andere manier te bekijken.  Reserveren is niet nodig. Prijs inbegrepen in het toegangskaartje"
        ],
        "es": [
          "De 10.00 a 12.30 h. y de 14.00 a 17.00 h.  A través de juegos, se invita a pequeños y mayores a observar los tesoros del museo de una manera diferente.  No es necesario reservar. Precio incluido en la entrada"
        ]
      },
