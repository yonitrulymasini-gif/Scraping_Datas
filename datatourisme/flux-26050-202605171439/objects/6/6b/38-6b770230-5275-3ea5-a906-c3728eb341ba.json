  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/9c2ba8b3-8cf3-32b1-9c6b-ade4e30210c9",
      "dc:description": {
        "de": [
          "Neu Kafé Hoche\nBar - Bistro - Brasserie - PMU - Grattage\nGroße schattige Terrasse mit kleinem Meerblick auf dem Hauptplatz von Quiberon.\nNeues Team, Karten und Formeln mit frischen Produkten.\nGute Entdeckung"
        ],
        "en": [
          "New Kafé Hoche\nBar - Bistro - Brasserie - PMU - Scratch Shop\nLarge shaded terrace with small sea view, on Quiberon's main square.\nNew team, fresh produce menus and formulas.\nGood discovery"
        ],
        "it": [
          "Nuovo Kafé Hoche\nBar - Bistrot - Brasserie - PMU - Bottega del graffio\nGrande terrazza ombreggiata con piccola vista sul mare, sulla piazza principale di Quiberon.\nNuovo team, menu e formule a base di prodotti freschi.\nUna buona scoperta"
        ],
        "fr": [
          "Nouveau Kafé Hoche\nBar - Bistrot -  Brasserie -  PMU - Grattage\nGrande terrasse ombragée avec petite vue mer, sur la place principale de Quiberon.\nNouvelle équipe, cartes et formules de produits frais.\nBonne découverte"
        ],
        "es": [
          "Nuevo Kafé Hoche\nBar - Bistro - Brasserie - PMU - Tienda de raspados\nAmplia terraza sombreada con una pequeña vista al mar, en la plaza principal de Quiberon.\nNuevo equipo, menús y fórmulas con productos frescos.\nBuen descubrimiento"
        ],
        "nl": [
          "Nieuw Kafé Hoche\nBar - Bistro - Brasserie - PMU - Kraswinkel\nGroot schaduwrijk terras met een klein uitzicht op zee, op het hoofdplein van Quiberon.\nNieuw team, menu's en formules met verse producten.\nGoede ontdekking"
        ]
      },
      "@type": [
        "Description"
      ],
