  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8b606073-6af2-3ce0-a286-79c757f4eaae",
      "dc:description": {
        "de": [
          "Nicolas Le Verger, Bademeister seit 2015, biete ich Ihnen mit 2APA, den Activités Aquatiques Pays d?Auray vom Golf von Morbihan bis zur Ria d'Etel, in Saint-Philibert und Carnac, Privatunterricht im Schwimmen, Longe côte und Meeresschwimmen für Dummies an.\n\nLonge côte revisité: 15? pro Sitzung, 120? für 10 Sitzungen. Schwimmen im Meer für Anfänger: 20? pro Sitzung, 170? für 10 Sitzungen.\nEinzelunterricht im Schwimmen 60 Euro pro Stunde. Miete für Neoprenanzug: 5?"
        ],
        "en": [
          "Nicolas Le Verger, lifeguard since 2015, I offer private swimming lessons, longe côte and sea swimming for Dummies with 2APA, les Activités Aquatiques Pays d?Auray from the Golfe du Morbihan to the ria d'Etel, in Saint-Philibert and Carnac.\n\nLonge côte revisited: 15? per session, 120? for 10 sessions. Sea swimming for beginners: 20? per session, 170? for 10 sessions.\nPrivate swimming lessons: 60? per hour. Wetsuit rental: 5?"
        ],
        "it": [
          "Nicolas Le Verger, bagnino dal 2015, offro lezioni private di nuoto, longe côte e nuoto in mare per principianti con 2APA, les Activités Aquatiques Pays d'Auray du Golfe du Morbihan jusqu'à la ria d'Etel, a Saint-Philibert e Carnac.\n\nLonge côte rivisitata: € 15 a sessione, € 120 per 10 sessioni. Nuoto in mare per principianti: 20 € a sessione, 170 € per 10 sessioni.\nLezioni private di nuoto: 60 € all'ora. Noleggio muta: 5 €."
        ],
        "fr": [
          "Nicolas Le Verger, maître nageur depuis 2015, je vous propose des cours particuliers de natation, du longe côte et de la nage en mer pour les Nuls avec 2APA, les Activités Aquatiques Pays d’Auray du Golfe du Morbihan jusqu'à la ria d'Etel, à Saint-Philibert et Carnac.\n\nLonge côte revisité : 15€ la séance, 120€ les 10 séances. Nage en mer pour les nuls: 20€ la séance, 170€ les 10 séances. \nCours particuliers de natation 60€/ l'heure. Location combinaison: 5€."
        ],
        "es": [
          "Nicolas Le Verger, socorrista desde 2015, ofrezco clases particulares de natación, longe côte y natación en el mar para Dummies con 2APA, les Activités Aquatiques Pays d'Auray du Golfe du Morbihan jusqu'à la ria d'Etel, en Saint-Philibert y Carnac.\n\nLonge côte revisited: 15 euros por sesión, 120 euros por 10 sesiones. Natación en el mar para principiantes: 20 euros por sesión, 170 euros por 10 sesiones.\nClases particulares de natación: 60 euros la hora. Alquiler de neopreno: 5 €."
        ],
        "nl": [
          "Nicolas Le Verger, badmeester sinds 2015, ik geef privézwemlessen, longe côte en zeezwemmen voor Dummies met 2APA, les Activités Aquatiques Pays d'Auray du Golfe du Morbihan jusqu'à la ria d'Etel, in Saint-Philibert en Carnac.\n\nLonge côte revisited: € 15 per sessie, € 120 voor 10 sessies. Zeezwemmen voor beginners: € 20 per sessie, € 170 voor 10 sessies.\nPrivézwemlessen: €60 per uur. Huur wetsuit: €5."
        ]
      },
