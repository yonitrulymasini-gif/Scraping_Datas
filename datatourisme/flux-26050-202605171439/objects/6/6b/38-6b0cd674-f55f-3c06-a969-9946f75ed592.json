      "@id": "https://data.datatourisme.fr/97a2683b-044d-377a-9178-0f77b3860549",
      "dc:description": {
        "de": [
          "Kommen Sie zur Kenleur Tour 2026!\n\nAuf dem Programm stehen bretonische Musik und Tänze auf dem Campingplatz von Aleth!\n\nGetränke und kleine Snacks vor Ort\nKostenlos und frei zugänglich für alle, von 19:00 bis 22:20 Uhr am Freitag, den 17. Juli."
        ],
        "en": [
          "Come and take part in the Kenleur Tour 2026!\n\nBreton music and dance at the Aleth campsite!\n\nRefreshments and snacks on site\nFree and open to all, from 7pm to 10:20pm on Friday, July 17."
        ],
        "it": [
          "Venite a partecipare al Kenleur Tour 2026!\n\nIl programma prevede musica e danze bretoni al campeggio Aleth!\n\nRinfreschi e spuntini in loco\nGratuito e aperto a tutti, dalle 19.00 alle 22.20 di venerdì 17 luglio."
        ],
        "fr": [
          "Venez participer au Kenleur Tour 2026 !\n\nAu programme, musiques et danses bretonnes au camping d'Aleth !\n\nBuvette et petite restauration sur place \nGratuit et en accès libre pour tous, de 19h à 22h20 le vendredi 17 juillet."
        ],
        "es": [
          "¡Venga y participe en el Kenleur Tour 2026!\n\nEl programa incluye música y danza bretonas en el camping Aleth\n\nRefrescos y tentempiés in situ\nGratuito y abierto a todos, de 19.00 a 22.20 h el viernes 17 de julio."
        ],
        "nl": [
          "Kom meedoen aan de Kenleur Tour 2026!\n\nOp het programma: Bretonse muziek en dans op camping Aleth!\n\nVersnaperingen en hapjes ter plaatse\nGratis en voor iedereen toegankelijk, van 19.00 tot 22.20 uur op vrijdag 17 juli."
        ]
      },
