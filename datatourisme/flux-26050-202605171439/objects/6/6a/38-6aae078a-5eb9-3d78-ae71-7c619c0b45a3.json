  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/69a7a8c8-34fa-3d70-be12-cb40dc1fa227",
      "dc:description": {
        "de": [
          "Renoviertes Bauernhaus von 135 m² im Wald von St Jean Brévelay. Das Haus bietet Platz für 10 Personen, mit 4 Schlafzimmern und 3 Badezimmern. Außenbereich mit Gartenmöbeln und einem Jacuzzi ausgestattet. Ellie und Florian werden Sie gerne in ihrem kleinen grünen Schmuckkästchen begrüßen."
        ],
        "en": [
          "Renovated 135 m² farmhouse in the forest of St Jean Brévelay. The gîte sleeps 10, with 4 bedrooms and 3 bathrooms. Outside there's garden furniture and a jacuzzi. Ellie and Florian will be delighted to welcome you to their little green bower."
        ],
        "it": [
          "Casale ristrutturato di 135 m² nella foresta di St Jean Brévelay. L'alloggio può ospitare 10 persone, con 4 camere da letto e 3 bagni. All'esterno ci sono mobili da giardino e una vasca idromassaggio. Ellie e Florian saranno lieti di accogliervi nella loro piccola cornice verde."
        ],
        "fr": [
          "Longère rénovée de 135 m² dans la forêt de St Jean Brévelay. Le gîte peut accueillir 10 personnes, avec 4 chambres et 3 salles de bain. Extérieur agrémenté d'un salon de jardin et d'un jacuzzi. Ellie et Florian vous accueilleront avec plaisir dans leur petit écrin de verdure."
        ],
        "nl": [
          "Gerenoveerde boerderij van 135 m² in het bos van St Jean Brévelay. De gîte is geschikt voor 10 personen, met 4 slaapkamers en 3 badkamers. Buiten is er tuinmeubilair en een jacuzzi. Ellie en Florian heten je van harte welkom in hun kleine groene omgeving."
        ],
        "es": [
          "Casa rural renovada de 135 m² en el bosque de St Jean Brévelay. La casa rural tiene capacidad para 10 personas, con 4 dormitorios y 3 baños. En el exterior hay muebles de jardín y un jacuzzi. Ellie y Florian estarán encantados de darle la bienvenida a su pequeño entorno verde."
        ]
      },
