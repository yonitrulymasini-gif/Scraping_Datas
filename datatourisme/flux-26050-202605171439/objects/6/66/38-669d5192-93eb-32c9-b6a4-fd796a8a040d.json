  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/14d75acb-5d65-3ca7-acc0-6d946adb4a08",
      "dc:description": {
        "de": [
          "\"Das Meer in Kästchen\" Illustrationen & Original-Comicstrips von Lucas Vallerie.\nGeschichten von Inseln, nah oder fern, real oder imaginär, beruhigend oder gefährlich; Geschichten vom Wasser, das umgibt, trennt und das man überquert. Das Meer ist in seinen Comic-Kästchen immer präsent."
        ],
        "en": [
          "\"La mer en cases\" Illustrations & original comic strips by Lucas Vallerie.\nStories of islands, near or far, real or imaginary, reassuring or dangerous; stories of waters that surround, separate and cross. The sea is always present in his comics."
        ],
        "it": [
          "\"La mer en cases\" Illustrazioni e fumetti originali di Lucas Vallerie.\nStorie di isole, vicine o lontane, reali o immaginarie, rassicuranti o pericolose; storie di acque che ci circondano, ci separano e ci attraversano. Il mare è sempre presente nei suoi fumetti."
        ],
        "fr": [
          "\"La mer en cases\" Illustrations & planches originales de BD de Lucas Vallerie.\nHistoires d'îles, proches ou lointaines, réelles ou imaginaires, rassurantes ou dangereuses ; histoires d'eaux qui entourent, qui séparent et que l'on traverse. La mer est toujours présente dans ses cases de BD."
        ],
        "es": [
          "\"La mer en cases\" Ilustraciones y cómics originales de Lucas Vallerie.\nHistorias de islas, cercanas o lejanas, reales o imaginarias, tranquilizadoras o peligrosas; historias de las aguas que nos rodean, nos separan y nos atraviesan. El mar siempre está presente en sus cómics."
        ],
        "nl": [
          "\"La mer en cases\" Illustraties & originele stripverhalen door Lucas Vallerie.\nVerhalen over eilanden, dichtbij of ver weg, echt of denkbeeldig, geruststellend of gevaarlijk; verhalen over het water dat ons omringt, scheidt en doorkruist. De zee is altijd aanwezig in zijn stripverhalen."
        ]
      },
