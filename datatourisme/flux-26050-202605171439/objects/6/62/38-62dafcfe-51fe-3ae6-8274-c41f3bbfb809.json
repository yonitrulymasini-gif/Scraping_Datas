  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/17445cd2-9025-3901-9690-b7f7b4eecfda",
      "dc:description": {
        "de": [
          "Samuel Piriou, Geologe, neues Mitglied und Sekretär des Vereins Traditions et Patrimoine en Montagnes Noires wird einen Vortrag über die Geologie des Armorikanischen Massivs in einer allgemein verständlichen und zugänglichen Form anhand von Karten und Geländefotografien halten."
        ],
        "en": [
          "Geologist Samuel Piriou, a new member and secretary of the Traditions et Patrimoine en Montagnes Noires association, will give a talk on the geology of the Armorican Massif, using maps and photographs to make the subject accessible and understandable to all."
        ],
        "it": [
          "Samuel Piriou, geologo, nuovo membro e segretario dell'associazione Traditions et Patrimoine en Montagnes Noires, parlerà della geologia del Massiccio Armoricano in forma accessibile e comprensibile a tutti, utilizzando mappe e fotografie del terreno."
        ],
        "fr": [
          "Samuel Piriou, géologue, nouveau membre et secrétaire de l'association Traditions et Patrimoine en Montagnes Noires donnera une conférence sur la géologie du Massif armoricain sous une forme accessible et compréhensible par tous, à partir de cartes et de photographies de terrains."
        ],
        "nl": [
          "Samuel Piriou, geoloog, nieuw lid en secretaris van de vereniging Traditions et Patrimoine en Montagnes Noires, zal een lezing geven over de geologie van het Armoricaans Massief in een vorm die toegankelijk en begrijpelijk is voor iedereen, aan de hand van kaarten en foto's van het terrein."
        ],
        "es": [
          "Samuel Piriou, geólogo, nuevo miembro y secretario de la asociación Traditions et Patrimoine en Montagnes Noires, ofrecerá una conferencia sobre la geología del Macizo Armoricano de forma accesible y comprensible para todos, utilizando mapas y fotografías del terreno."
        ]
      },
