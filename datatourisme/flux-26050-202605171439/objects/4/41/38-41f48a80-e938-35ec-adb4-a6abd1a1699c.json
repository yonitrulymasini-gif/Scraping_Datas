      "dc:description": {
        "de": [
          "Wir begrüßen Sie in einem unserer 16 Zimmer mit eigenem Bad und Fernseher, von denen sich 4 im Erdgeschoss befinden und eines für Personen mit eingeschränkter Mobilität geeignet ist."
        ],
        "en": [
          "We welcome you to one of our 16 en-suite rooms with TV, including 4 on the first floor and one for disabled guests."
        ],
        "it": [
          "Vi accoglieremo in una delle nostre 16 camere con bagno privato e televisione, di cui 4 al piano terra e una per persone a mobilità ridotta."
        ],
        "fr": [
          "Nous vous accueillerons dans l'une de nos 16 chambres avec salle d'eau privative et télévision, dont 4 au rez-de-chaussée et une pour personne à mobilité réduite."
        ],
        "nl": [
          "We verwelkomen je in een van onze 16 kamers met eigen badkamer en televisie, waarvan 4 op de begane grond en een voor mensen met beperkte mobiliteit."
        ],
        "es": [
          "Le acogeremos en una de nuestras 16 habitaciones con baño privado y televisión, 4 de ellas en la planta baja y una para personas con movilidad reducida."
        ]
