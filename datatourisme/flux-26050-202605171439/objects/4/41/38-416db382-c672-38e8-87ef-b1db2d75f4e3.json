  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5f1d59ef-b068-3c11-9e65-cd65e021b211",
      "dc:description": {
        "de": [
          "Eine von Morbihan Grandeur Nature angebotene Führung - Die Natur aus nächster Nähe beobachten -\n\nEin spannender Besuch der Salzgärten, bei dem Sie die Geheimnisse der Umwandlung von Wasser in Salz entdecken können. Ein lehrreiches und sinnliches Abenteuer wartet auf Sie!\n\nTelefonische Reservierung"
        ],
        "en": [
          "Guided tour offered by Morbihan Grandeur Nature - Observe nature up close -\n\nTake a captivating tour of the salt marshes to discover the secrets of how water is transformed into salt. An educational and sensory adventure awaits you!\n\nBook by phone"
        ],
        "it": [
          "Visita guidata proposta da Morbihan Grandeur Nature - Osservare la natura da vicino\n\nFate un'affascinante visita alle saline per scoprire i segreti della trasformazione dell'acqua in sale. Vi aspetta un'avventura educativa e sensoriale!\n\nPrenota per telefono"
        ],
        "fr": [
          "Visite guidée proposée par Morbihan Grandeur Nature - Observer la nature de plus près -\n\nVisite captivante des marais salants pour découvrir les secrets de la transformation de l’eau en sel. Une aventure éducative et sensorielle vous attend !\n\nRéservation par téléphone"
        ],
        "es": [
          "Visita guiada ofrecida por Morbihan Grandeur Nature - Observar la naturaleza de cerca -\n\nRealice un cautivador recorrido por las salinas para descubrir los secretos de la transformación del agua en sal. Le espera una aventura educativa y sensorial\n\nReservar por teléfono"
        ],
        "nl": [
          "Rondleiding aangeboden door Morbihan Grandeur Nature - Bekijk de natuur van dichtbij\n\nOntdek tijdens een boeiend bezoek aan de zoutmoerassen de geheimen van de omzetting van water in zout. Een educatief en zintuiglijk avontuur!\n\nReserveer per telefoon"
        ]
      },
