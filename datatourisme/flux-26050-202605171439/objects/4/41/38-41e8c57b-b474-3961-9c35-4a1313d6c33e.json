  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/50504254-a4ef-3d67-ab10-5f3173bf4ebd",
      "dc:description": {
        "de": [
          "An der Côte Sauvage, Meeresfrüchte-Restaurant mit Panoramablick auf Belle Ile en mer und einer Südterrasse... Sehr schöner Spaziergang vom Château Turpault zu unserem Lokal, ganz in der Nähe des Radwegs.\nIdeal, um am Nachmittag zum Durstlöschen vorbeizukommen."
        ],
        "en": [
          "On the Côte Sauvage, seafood restaurant with a panoramic view of Belle Ile en mer, and a south-facing terrace... Lovely walk from Château Turpault to our establishment, close to the cycle path.\nIdeal for afternoon refreshments."
        ],
        "it": [
          "Sulla Côte Sauvage, ristorante di pesce con vista panoramica su Belle Ile en mer e terrazza esposta a sud. Bella passeggiata dallo Château Turpault al nostro ristorante, vicino alla pista ciclabile.\nIdeale per un aperitivo pomeridiano."
        ],
        "fr": [
          "Sur la Côte Sauvage,  restaurant de fruits de mer, avec une vue panoramique sur Belle Ile en mer, et une terrasse plein sud.. Très belle balade pédestre du château Turpault à notre établissement, tout proche de la piste cyclable.\nIdéal pour venir se désaltérer l'après-midi."
        ],
        "es": [
          "En la Côte Sauvage, marisquería con vista panorámica de Belle Ile en mer y terraza orientada al sur. Precioso paseo desde Château Turpault hasta nuestro restaurante, cerca del carril bici.\nIdeal para tomar una copa por la tarde."
        ],
        "nl": [
          "Aan de Côte Sauvage, visrestaurant met een panoramisch uitzicht op Belle Ile en mer, en een terras op het zuiden. Mooie wandeling van Château Turpault naar ons restaurant, vlakbij het fietspad.\nIdeaal voor een drankje in de namiddag."
        ]
      },
      "@type": [
        "Description"
