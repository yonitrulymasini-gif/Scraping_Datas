  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/760099d9-2ff1-32aa-963c-2e7b5ce41abc",
      "dc:description": {
        "de": [
          "Entspannen Sie sich in diesem echten kleinen Kokon, der am Ufer des Nantes-Brest-Kanals eingebettet ist. Ideal gelegen an der Velodyssée, der Eingang erfolgt über den Treidelpfad. Das Ferienhaus befindet sich in einem privaten, geschlossenen Hof. Es befindet sich nur 500m vom Zentrum von Josselin und seinen Geschäften entfernt. Radfahrer sind herzlich willkommen."
        ],
        "en": [
          "Come and relax in this little cocoon nestling on the banks of the Nantes-Brest canal. Ideally located on the Velodyssée, the entrance is via the towpath. The gîte is set in a private, enclosed courtyard. It is only 500m from the center of Josselin and its shops. Cyclists are welcome."
        ],
        "it": [
          "Venite a rilassarvi in questo piccolo bozzolo adagiato sulle rive del canale Nantes-Brest. Situato in posizione ideale sulla Velodyssée, l'ingresso avviene attraverso l'alzaia. L'alloggio si trova in un cortile privato e recintato. Si trova a soli 500 metri dal centro di Josselin e dai suoi negozi. I ciclisti sono i benvenuti."
        ],
        "fr": [
          "Venez vous détendre dans ce véritable petit cocon niché au bord du canal de Nantes à Brest. Idéalement situé sur la Velodyssée, l'entrée s'effectue par le chemin de halage. Le gîte se trouve dans une cour privée et fermée. Il est situé à seulement 500m du centre de Josselin et ses commerces. Les cyclistes sont les bienvenus."
        ],
        "es": [
          "Relájese en este pequeño capullo a orillas del canal Nantes-Brest. Idealmente situado en el Velodyssée, la entrada es a través del camino de sirga. La casa rural se encuentra en un patio privado y cerrado. A 500 m del centro de Josselin y de sus comercios. Los ciclistas son bienvenidos."
        ],
        "nl": [
          "Kom tot rust in deze kleine cocon aan de oever van het kanaal Nantes-Brest. Ideaal gelegen aan de Velodyssée, de ingang is via het jaagpad. De gîte ligt op een besloten binnenplaats. Het ligt op slechts 500m van het centrum van Josselin en de winkels. Fietsers zijn welkom."
        ]
      },
