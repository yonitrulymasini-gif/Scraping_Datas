  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2a94b43e-0c0c-3209-a35d-ff305a8f6226",
      "dc:description": {
        "de": [
          "Marion und Christophe heißen Sie in ihrem Familienhaus herzlich willkommen. Inmitten der Wälder in einer ruhigen und erholsamen Umgebung bieten sie Ihnen 4 geräumige Zimmer, in denen Sie eine zeitlose Zeit in unserer schönen Landschaft des Morbihan verbringen können."
        ],
        "en": [
          "Marion and Christophe welcome you to their family home. In the middle of the woods, in a calm and relaxing setting, they offer 4 spacious bedrooms for a timeless stay in our beautiful Morbihan countryside."
        ],
        "it": [
          "Marion e Christophe vi danno il benvenuto nella loro casa di famiglia. In mezzo al bosco, in un ambiente calmo e rilassante, vi offrono 4 camere spaziose per trascorrere un momento senza tempo nella nostra bella campagna del Morbihan."
        ],
        "fr": [
          "Marion et Christophe vous accueillent dans leur maison familiale. Au milieu des bois dans un cadre calme et reposant, ils vous proposent 4 chambres spacieuses pour passer un moment hors du temps dans notre belle campagne morbihannaise."
        ],
        "es": [
          "Marion y Christophe le dan la bienvenida a su casa familiar. En medio del bosque, en un entorno tranquilo y relajante, le ofrecen 4 amplias habitaciones para pasar un momento sin tiempo en nuestra hermosa campiña de Morbihan."
        ],
        "nl": [
          "Marion en Christophe heten je welkom in hun familiehuis. Midden in de bossen, in een rustige en ontspannende omgeving, bieden ze je 4 ruime kamers om een tijdloos moment door te brengen op ons prachtige platteland van Morbihan."
        ]
      },
      "@type": [
        "Description"
