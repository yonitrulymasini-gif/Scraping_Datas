      "dc:description": {
        "de": [
          "Entdecken Sie während des Andouille-Festes das Kulturerbe von Guémené mit Flash-Touren durch das Schlossviertel und die Bains de la Reine. 15 Uhr: Guémené, Cité des Rohan (45 Min.). 16 Uhr: Hygiene im Mittelalter (45 min)."
        ],
        "en": [
          "During the andouille festival, discover Guémené?s heritage with flash visits to the castle district and the Bains de la Reine. 3pm: Guémené, Cité des Rohan (45 min). 4pm: Hygiene in the Middle Ages (45 min)."
        ],
        "it": [
          "Durante la festa dell'andouille, scoprite il patrimonio di Guémené con visite lampo al quartiere del castello e ai Bains de la Reine. 15:00: Guémené, Cité des Rohan (45 minuti). 16:00: L'igiene nel Medioevo (45 minuti)."
        ],
        "fr": [
          "Pendant la fête de l’andouille, découvrez le patrimoine de Guémené à travers des visites flash du quartier du château et des Bains de la Reine. 15h : Guémené, Cité des Rohan (45 min). 16h : l’hygiène au Moyen Âge (45 min)."
        ],
        "nl": [
          "Ontdek tijdens het andouillefestival het erfgoed van Guémené met flitsrondleidingen door de kasteelwijk en de Bains de la Reine. 15u: Guémené, Cité des Rohan (45 min). 16u: Hygiëne in de Middeleeuwen (45 min)."
        ],
        "es": [
          "Durante la fiesta de la andouille, descubra el patrimonio de Guémené con visitas relámpago al barrio del castillo y a los Bains de la Reine. 15.00 h: Guémené, Cité des Rohan (45 min). 16.00 h: La higiene en la Edad Media (45 min)."
        ]
      },
