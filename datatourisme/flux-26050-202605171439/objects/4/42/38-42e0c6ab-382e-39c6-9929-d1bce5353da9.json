  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/488536bc-f6b3-36f9-94cc-21312f2f5ea7",
      "dc:description": {
        "de": [
          "Dait da zevis, da dabutal, da flapañ. Tremenamp amzer vourrus assambl!\nBei einer Tasse Kaffee können Sie unter der Leitung von Andréa Le Gal auf Bretonisch plaudern! Es handelt sich nicht um einen Sprachkurs, Sie sollten also über einige Bretonischkenntnisse verfügen."
        ],
        "en": [
          "Dait da zevis, da dabutal, da flapañ. Tremenamp amzer vourrus assambl!\nAndréa Le Gal invites you to chat in Breton over a cup of coffee! This is not a language course, so you'll need to have some knowledge of Breton."
        ],
        "it": [
          "Dait da zevis, da dabutal, da flapañ. Tremenamp amzer vourrus assambl!\nAndréa Le Gal sarà a disposizione davanti a una tazza di caffè per una chiacchierata amichevole in bretone! Non si tratta di un corso di lingua, quindi è necessario avere una certa conoscenza del bretone."
        ],
        "fr": [
          "Dait da zevis, da dabutal, da flapañ. Tremenamp amzer vourrus assambl!\nAutour d’un café, un moment convivial animé par Andréa Le Gal pour causer en breton ! Il ne s’agit pas de cours de langues, il faut donc posséder quelques notions de breton."
        ],
        "es": [
          "Dait da zevis, da dabutal, da flapañ. ¡Tremenamp amzer vourrus assambl!\nAndréa Le Gal estará a su disposición con una taza de café para charlar amigablemente en bretón No se trata de un curso de idiomas, por lo que es necesario tener conocimientos de bretón."
        ],
        "nl": [
          "Dait da zevis, da dabutal, da flapañ. Tremenamp amzer vourrus assambl!\nAndréa Le Gal staat voor je klaar onder het genot van een kopje koffie voor een gezellig praatje in het Bretons! Dit is geen taalcursus, dus je moet wel enige kennis van het Bretons hebben."
        ]
      },
