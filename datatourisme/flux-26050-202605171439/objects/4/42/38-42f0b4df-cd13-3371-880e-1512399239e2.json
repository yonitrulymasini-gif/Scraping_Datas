  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8b2c45ba-c57e-3999-aa6d-1272be282b9f",
      "dc:description": {
        "de": [
          "Reihenhaus mit Stockwerk für 4 Personen, in der Nähe des Strandes, des Hafens von Port Maria und der Côte Sauvage, bestehend aus: 1 Wohnzimmer - voll ausgestattete Küche; 2 Schlafzimmer mit Betten von 140 cm.\n1 kleiner geschlossener Hof mit Gartenmöbeln. Hunde werden akzeptiert. Ferienschecks werden akzeptiert.\nVermietung das ganze Jahr über (Woche, zwei Wochen, Monat), von Samstag bis Samstag."
        ],
        "en": [
          "Semi-detached house for 4 people, close to the beach, Port Maria harbor and Côte Sauvage, comprising: 1 living room - fully equipped kitchen; 2 bedrooms with 140cm beds.\n1 small enclosed courtyard with garden furniture. Dogs welcome. Vacation vouchers accepted.\nYear-round rental (week - fortnight - month), Saturday to Saturday."
        ],
        "it": [
          "Casa bifamiliare per 4 persone, vicino alla spiaggia, al porto di Port Maria e alla Côte Sauvage, composta da: 1 soggiorno - cucina completamente attrezzata; 2 camere con letti matrimoniali.\n1 piccolo cortile recintato con mobili da giardino. Cani ammessi. Si accettano buoni vacanza.\nAffitto tutto l'anno (settimana - quindicina - mese), da sabato a sabato."
        ],
        "fr": [
          "Maison mitoyenne avec étage pour 4 personnes, à proximité de la plage, du port de Port Maria et de la Côte Sauvage, comprenant : 1 séjour - cuisine tout équipée; 2 chambres avec lits de 140. \n1 petite cour fermée avec son salon de jardin. Chiens acceptés. Chèques vacances acceptés. \nLocation toute l'année  ( semaine -  quinzaine - mois ),  du samedi au samedi."
        ],
        "nl": [
          "Halfvrijstaand huis voor 4 personen, vlakbij het strand, de haven van Port Maria en de Côte Sauvage, bestaande uit: 1 woonkamer - volledig ingerichte keuken; 2 slaapkamers met tweepersoonsbedden.\n1 kleine omheinde binnenplaats met tuinmeubelen. Honden welkom. Vakantie vouchers geaccepteerd.\nVerhuur het hele jaar door (week - twee weken - maand), van zaterdag tot zaterdag."
        ],
        "es": [
          "Casa adosada para 4 personas, cerca de la playa, del puerto de Port Maria y de la Côte Sauvage, compuesta por: 1 salón - cocina totalmente equipada; 2 dormitorios con camas dobles.\n1 pequeño patio cerrado con muebles de jardín. Se admiten perros. Se aceptan cheques vacaciones.\nAlquiler todo el año (semana - quincena - mes), de sábado a sábado."
        ]
      },
      "@type": [
        "Description"
      ],
