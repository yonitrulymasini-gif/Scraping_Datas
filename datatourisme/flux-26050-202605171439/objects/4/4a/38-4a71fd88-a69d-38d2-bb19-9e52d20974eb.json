  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/21a51689-1c9c-3e81-a56a-ce4366bfba63",
      "dc:description": {
        "de": [
          "Am Fuße des Waldes von Brocéliande, nur zwei Schritte vom Camp de Cyr Coëtquidan entfernt, inmitten der bretonischen Landschaft, finden Sie eine Oase der Ruhe, um sich zu erholen und neue Energie zu tanken."
        ],
        "en": [
          "At the foot of the Brocéliande Forest, 2 steps from the Camp de Cyr Coëtquidan, in the middle of the Breton countryside, you'll find a haven of peace in which to relax and recharge your batteries."
        ],
        "it": [
          "Ai piedi della Foresta di Brocéliande, a due passi dal Camp de Cyr Coëtquidan, nel cuore della campagna bretone, troverete un'oasi di pace in cui rilassarvi e fare il pieno di energia."
        ],
        "fr": [
          "Au pied de la Forêt de Brocéliande, à 2 pas du Camp de Cyr Coëtquidan, au milieu de la campagne bretonne, vous trouverez un havre de paix pour vous reposer et vous ressourcer."
        ],
        "es": [
          "Al pie del bosque de Brocéliande, a dos pasos del Camp de Cyr Coëtquidan, en plena campiña bretona, encontrará un remanso de paz en el que relajarse y reponer fuerzas."
        ],
        "nl": [
          "Aan de voet van het bos van Brocéliande, op een steenworp afstand van het Camp de Cyr Coëtquidan, midden op het Bretonse platteland, vind je een oase van rust om te ontspannen en nieuwe energie op te doen."
        ]
      },
      "@type": [
        "Description"
      ],
