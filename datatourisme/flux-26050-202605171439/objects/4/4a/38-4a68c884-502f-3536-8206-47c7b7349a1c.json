  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3a0eb63d-e81a-394b-b99a-8f466b4ca7cc",
      "dc:description": {
        "de": [
          "Dieses charmante Hotel liegt im Herzen des mythischen Waldes von Brocéliande und empfängt Sie in einem privilegierten Rahmen mit gepflegter Dekoration zum Thema \"Baum in Brocéliande\". Restaurant 50 m entfernt."
        ],
        "en": [
          "Located in the heart of the mythical Brocéliande forest, this charming hotel welcomes you in a privileged setting, decorated in keeping with the Brocéliande tree theme. Restaurant 50 m away."
        ],
        "it": [
          "Situato nel cuore della mitica foresta di Brocéliande, questo hotel di charme vi accoglie in un ambiente privilegiato, decorato con cura sul tema degli alberi di Brocéliande. Ristorante a 50 m."
        ],
        "fr": [
          "Situé au coeur de la mythique forêt de Brocéliande, cet hôtel de charme vous accueille dans un cadre privilégié, à la décoration soignée sur le thème de l'arbre en Brocéliande. Restaurant situé à 50 m."
        ],
        "es": [
          "Situado en el corazón del mítico bosque de Brocéliande, este encantador hotel le da la bienvenida en un entorno privilegiado, decorado con esmero sobre el tema de los árboles en Brocéliande. Restaurante a 50 m."
        ],
        "nl": [
          "Dit charmante hotel ligt in het hart van het mythische bos van Brocéliande en verwelkomt u in een bevoorrechte omgeving, met zorg ingericht rond het thema van de bomen in Brocéliande. Restaurant op 50 m."
        ]
      },
      "@type": [
        "Description"
