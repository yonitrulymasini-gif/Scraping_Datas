  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/78c9cae7-d969-3ad7-98dc-f5868d46f41f",
      "dc:description": {
        "de": [
          "Im Herzen des Dorfes St Guyomard, charmantes Haus aus dem 17. Jahrhundert mit Terrasse und Garten mit Bäumen, in ruhiger Lage ohne Gegenüber. 2 gemütliche Gästezimmer mit gepflegter und neuer Dekoration."
        ],
        "en": [
          "In the heart of the village of St Guyomard, charming 17th-century house with terrace and wooded garden, in a quiet, unoverlooked setting. 2 warm, recently decorated guest rooms."
        ],
        "it": [
          "Nel cuore del villaggio di St Guyomard, un'affascinante casa del XVII secolo con terrazza e giardino alberato, in un ambiente tranquillo e senza vicini. 2 accoglienti camere per gli ospiti, recentemente arredate con uno standard molto elevato."
        ],
        "fr": [
          "Au coeur du bourg de St Guyomard, maison de charme du XVIIème avec terrasse et jardin arboré, au calme sans vis-à-vis. 2 chambres d'hôtes chaleureuses à la décoration soignée et récente."
        ],
        "nl": [
          "In het hart van het dorp St Guyomard, een charmant 17e eeuws huis met terras en beboste tuin, in een rustige omgeving zonder buren. 2 warm ingerichte gastenkamers."
        ],
        "es": [
          "En el corazón del pueblo de St Guyomard, una encantadora casa del siglo XVII con terraza y jardín arbolado, en un entorno tranquilo y sin vecinos. 2 acogedoras habitaciones de huéspedes, recientemente decoradas con un nivel muy alto."
        ]
      },
      "@type": [
        "Description"
