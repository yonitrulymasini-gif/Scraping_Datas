      "dc:description": {
        "de": [
          "Flussfahrt entlang des Flusses Oust. Geführte Wanderung auf Elektrobooten. Entdecken Sie die Anekdoten, Erzählungen und Geschichten des Flusses Oust in Ihrem eigenen Tempo."
        ],
        "en": [
          "River trip along the Oust. Guided tour on electric boats. Discover the anecdotes, stories and history of the Oust at your own pace."
        ],
        "it": [
          "Gita fluviale lungo l'Oust. Visita guidata su barche elettriche. Scoprite gli aneddoti, le storie e la storia dell'Oust al vostro ritmo."
        ],
        "fr": [
          "Balade fluviale au fil de l'Oust. Promenade guidée sur bateaux électriques. Découvrez les anecdotes, récits, histoires de l'Oust à votre rythme."
        ],
        "nl": [
          "Riviertocht langs de Oust. Rondleiding met elektrische boten. Ontdek de anekdotes, verhalen en geschiedenis van de Oust op je eigen tempo."
        ],
        "es": [
          "Paseo fluvial por el Oust. Recorrido guiado en embarcaciones eléctricas. Descubre las anécdotas, historias y la historia del Oust a tu ritmo."
        ]
