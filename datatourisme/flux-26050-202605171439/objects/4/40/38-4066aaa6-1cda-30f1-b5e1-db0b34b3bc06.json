  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/767d439b-a1c9-32c8-aded-683ce0133c19",
      "dc:description": {
        "de": [
          "Unabhängiges Ferienhaus in einer Sackgasse im Dorf Caro, zwischen Malestroit und Ploërmel. Küche, Wohnzimmer, 2 Schlafzimmer (1 Doppelbett, 2 Einzelbetten), Badezimmer, WC."
        ],
        "en": [
          "Detached gîte located in a cul-de-sac in the village of Caro, between Malestroit and Ploërmel. Kitchen, living room, 2 bedrooms (1 double bed, 2 single beds), shower room, wc."
        ],
        "it": [
          "Gîte indipendente situato in una strada senza uscita nel villaggio di Caro, tra Malestroit e Ploërmel. Cucina, soggiorno, 2 camere (1 letto matrimoniale, 2 letti singoli), bagno con doccia, WC."
        ],
        "fr": [
          "Gîte indépendant située dans une impasse, dans le bourg de Caro, entre Malestroit et Ploërmel. Cuisine, salon, 2 chambres (1 lit 2 pers., 2 lits 1 pers.,), salle d'eau, wc."
        ],
        "nl": [
          "Vrijstaande gîte gelegen in een doodlopende straat in het dorpje Caro, tussen Malestroit en Ploërmel. Keuken, woonkamer, 2 slaapkamers (1 tweepersoonsbed, 2 eenpersoonsbedden), doucheruimte, wc."
        ],
        "es": [
          "Casa rural independiente situada en una calle sin salida en el pueblo de Caro, entre Malestroit y Ploërmel. Cocina, salón, 2 habitaciones (1 cama doble, 2 camas individuales), cuarto de ducha, wc."
        ]
      },
      "@type": [
        "Description"
