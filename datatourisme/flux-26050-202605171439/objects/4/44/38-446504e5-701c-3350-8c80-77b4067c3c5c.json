  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a0eed75c-2dc4-3c32-91fa-276ad1e45374",
      "dc:description": {
        "de": [
          "Doppelhaushälfte in einem Dorf mit Ferienhäusern, 1,2 km von Quelneuc und 11 km von La Gacilly entfernt. Zur gemeinsamen Nutzung: beheiztes und überdachtes Schwimmbad, Sauna, 5000 m² großer Garten, Teich, Spielzimmer mit Billard und Tischfußball..."
        ],
        "en": [
          "Semi-detached gîte in a self-catering village 1.2 km from Quelneuc and 11 km from La Gacilly. Shared facilities: heated and covered swimming pool, sauna, 5000 m² garden, pond, games room with billiards and table soccer..."
        ],
        "it": [
          "Gîte bifamiliare in un villaggio indipendente a 1,2 km da Quelneuc e a 11 km da La Gacilly. Servizi in comune: piscina interna riscaldata, sauna, giardino di 5000 m², laghetto, sala giochi con tavolo da biliardo e calcio balilla..."
        ],
        "fr": [
          "Gîte mitoyen dans un village de gîtes à 1,2 km de Quelneuc et 11 km de la Gacilly. En commun : piscine chauffée et couverte, sauna, jardin de 5000 m², étang, salle de jeux avec billard et babyfoot..."
        ],
        "nl": [
          "Halfvrijstaande gîte in een vakantiehuisdorp op 1,2 km van Quelneuc en 11 km van La Gacilly. Gemeenschappelijke faciliteiten: verwarmd overdekt zwembad, sauna, tuin van 5000 m², vijver, speelkamer met biljart en tafelvoetbal..."
        ],
        "es": [
          "Casa rural adosada en una aldea con cocina a 1,2 km de Quelneuc y a 11 km de La Gacilly. Instalaciones comunes: piscina cubierta climatizada, sauna, jardín de 5000 m², estanque, sala de juegos con billar y futbolín..."
        ]
      },
