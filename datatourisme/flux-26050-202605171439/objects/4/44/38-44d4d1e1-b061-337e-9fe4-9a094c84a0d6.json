  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/62de2643-6cfa-38a0-b7e4-77827f04697b",
      "dc:description": {
        "de": [
          "35 Gedecke auf der Terrasse möglich.\nGanzjährig geöffnet, außer Sonntagmittag und Montag den ganzen Tag.\nFormula ab 15,30 ?\nGruppen werden akzeptiert, max. 40 Personen.\n120 mögliche Gedecke.\nZugang für Personen mit eingeschränkter Mobilität.\n3 Speisesäle."
        ],
        "en": [
          "35 seats available on the terrace.\nOpen all year round, except Sunday lunchtime and all day Monday.\nFormulas from 15.30?\nGroups accepted, max 40 people.\n120 place settings available.\nDisabled access.\n3 dining rooms."
        ],
        "it": [
          "35 coperti disponibili sulla terrazza.\nAperto tutto l'anno, tranne la domenica a pranzo e il lunedì tutto il giorno.\nFormule a partire dalle 15.30?\nSi accettano gruppi, massimo 40 persone.\n120 coperti disponibili.\nAccesso per persone a mobilità ridotta.\n3 sale ristorante."
        ],
        "fr": [
          "35 couverts possibles en terrasse.\nOuvert toute l'année, sauf dimanche midi et lundi toute la journée.\nFormule à partir de 15,30 €.\nGroupes acceptés, max 40 personnes.\n120 couverts possibles.\nAccès aux personnes à mobilité réduite.\n3 salles de restaurant."
        ],
        "es": [
          "35 cubiertos disponibles en la terraza.\nAbierto todo el año, excepto los domingos al mediodía y los lunes todo el día.\nFórmulas a partir de las 15.30?\nSe aceptan grupos, máximo 40 personas.\n120 cubiertos disponibles.\nAcceso para personas con movilidad reducida.\n3 salas de restaurante."
        ],
        "nl": [
          "35 couverts beschikbaar op het terras.\nHet hele jaar geopend, behalve op zondagmiddag en maandag de hele dag.\nFormules vanaf 15.30?\nGroepen tot 40 personen.\n120 couverts beschikbaar.\nToegang voor personen met beperkte mobiliteit.\n3 restaurantzalen."
        ]
      },
      "@type": [
        "Description"
      ],
