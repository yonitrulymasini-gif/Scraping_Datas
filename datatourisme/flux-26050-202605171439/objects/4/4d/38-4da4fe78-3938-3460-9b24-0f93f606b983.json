      "dc:description": {
        "de": [
          "Brezhoneg en ho tiskouarn!\nHören Sie mit Yaëlle Geschichten und lernen Sie Reime auf Bretonisch.\nFür alle Kinder von 2 bis 7 Jahren. Ein Samstag pro Monat."
        ],
        "en": [
          "Brezhoneg en ho tiskouarn!\nCome and listen to stories and learn nursery rhymes in Breton with Yaëlle.\nFor all children aged 2 to 7. One Saturday a month."
        ],
        "it": [
          "Brezhoneg en ho tiskouarn!\nVenite ad ascoltare storie e a imparare filastrocche in bretone con Yaëlle.\nPer tutti i bambini dai 2 ai 7 anni. Un sabato al mese."
        ],
        "fr": [
          "Brezhoneg en ho tiskouarn !\nVenez écouter des histoires et apprendre des comptines en breton avec Yaëlle. \nPour tous les enfants de 2 à 7 ans. Un samedi par mois."
        ],
        "es": [
          "¡Brezhoneg en ho tiskouarn!\nVen a escuchar cuentos y aprender canciones infantiles en bretón con Yaëlle.\nPara todos los niños de 2 a 7 años. Un sábado al mes."
        ],
        "nl": [
          "Brezhoneg en ho tiskouarn!\nKom luisteren naar verhalen en leer kinderrijmpjes in het Bretons met Yaëlle.\nVoor alle kinderen van 2 tot 7 jaar. Een zaterdag per maand."
        ]
      },
