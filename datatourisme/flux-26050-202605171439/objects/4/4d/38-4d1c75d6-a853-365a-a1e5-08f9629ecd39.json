  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/85df828b-2b6a-3c68-a665-e43474bf7e06",
      "dc:description": {
        "de": [
          "Die 2015 gegründete Fontaine Airmeth ist ein ökologischer Familienbauernhof im Agri-Tourismus, der 5 ha umfasst und Honig und Bienenstockprodukte aus biologischem Anbau produziert. Claire und Thomas Le Glatin bieten ungewöhnliche Unterkünfte an, die den Bienen gewidmet sind, mit der Option, eine Imkertaufe zu machen."
        ],
        "en": [
          "Created in 2015, La Fontaine Airmeth is a 5-hectare family agri-tourism ecological farm, with organic honey and beehive products production. Claire and Thomas Le Glatin offer unusual accommodations dedicated to bees, with beekeeping baptism option."
        ],
        "it": [
          "Creata nel 2015, la Fontaine Airmeth è un'azienda agrituristica ecologica a conduzione familiare di 5 ettari, con produzione biologica di miele e prodotti dell'alveare. Claire e Thomas Le Glatin offrono un alloggio insolito dedicato alle api, con l'opzione di un battesimo di apicoltura."
        ],
        "fr": [
          "Créée en 2015, la Fontaine Airmeth est une ferme écologique familiale en agri-tourisme, de 5 ha, avec production de miel et produits de la ruche, en agriculture biologique. Claire et Thomas Le Glatin proposent des logements insolites dédiées aux abeilles, avec option baptême d'apiculture."
        ],
        "nl": [
          "La Fontaine Airmeth, opgericht in 2015, is een ecologische agrotoeristische familieboerderij van 5 hectare met biologische productie van honing en bijenkorfproducten. Claire en Thomas Le Glatin bieden een ongewone accommodatie gewijd aan bijen, met de mogelijkheid van een bijenteeltdoop."
        ],
        "es": [
          "Creada en 2015, la Fontaine Airmeth es una granja agroturística ecológica familiar de 5 hectáreas, con producción ecológica de miel y productos de la colmena. Claire y Thomas Le Glatin ofrecen un alojamiento insólito dedicado a las abejas, con la opción de un bautismo apícola."
        ]
      },
