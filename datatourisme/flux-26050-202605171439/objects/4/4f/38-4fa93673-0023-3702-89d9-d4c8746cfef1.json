      "dc:description": {
        "de": [
          "Der Abend gewinnt an Schwung mit der Energie der Perkussionisten von Koro Saba, die von ihrem Lehrer Eric Lohier begleitet werden.\nUm 21:30 Uhr bei freiem Eintritt. Dauer 30 Min. - Für alle Altersgruppen."
        ],
        "en": [
          "The evening gains momentum with the energetic percussionists of Koro Saba, accompanied by their teacher Eric Lohier.\nFree admission at 9:30pm. Duration 30mn - All audiences."
        ],
        "it": [
          "La serata prende slancio con l'energia dei percussionisti Koro Saba, accompagnati dal loro maestro Eric Lohier.\nIngresso libero alle 21.30. Durata 30 minuti - Aperto a tutti."
        ],
        "fr": [
          "La soirée prend de l'élan avec l'énergie des percussionnistes de Koro Saba, accompagnés de leur enseignant Eric Lohier.\nÀ 21h30 en accès libre. Durée 30mn - Tout public."
        ],
        "es": [
          "La velada cobra impulso con la energía de los percusionistas Koro Saba, acompañados por su profesor Eric Lohier.\nEntrada gratuita a las 21.30 h. Duración 30 minutos - Abierto a todos."
        ],
        "nl": [
          "De avond krijgt vaart met de energie van percussionisten Koro Saba, begeleid door hun leraar Eric Lohier.\nGratis toegang om 21.30 uur. Duurt 30 minuten - Open voor iedereen."
        ]
      },
