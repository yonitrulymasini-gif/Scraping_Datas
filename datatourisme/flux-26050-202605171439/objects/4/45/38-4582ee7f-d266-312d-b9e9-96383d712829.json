  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c78faeff-0b2f-3601-a5ae-092bd4611e36",
      "dc:description": {
        "de": [
          "Sandwicherie, Croissanterie, Le P'tit Bidon bietet auch Mittagsangebote an. Es ist auch möglich, vor Ort zu essen. Der Imbiss ist montags bis freitags von 7:00 bis 15:00 Uhr geöffnet."
        ],
        "en": [
          "Sandwich and croissant shop, Le P'tit Bidon also offers lunchtime formulas. It is also possible to eat on site. The snack bar is open Monday to Friday from 7am to 3pm."
        ],
        "it": [
          "Paninoteca e croissant, Le P'tit Bidon offre anche menù per il pranzo. È possibile anche mangiare all'interno. Lo snack bar è aperto dal lunedì al venerdì dalle 7:00 alle 15:00."
        ],
        "fr": [
          "Sandwicherie, croissanterie, Le P'tit Bidon propose également des formules le midi. Il est possible de manger sur place. Le snack est ouvert du lundi au vendredi de 7h à 15h."
        ],
        "es": [
          "Tienda de bocadillos y croissants, Le P'tit Bidon también ofrece menús al mediodía. También se puede comer en el restaurante. El bar abre de lunes a viernes de 7:00 a 15:00."
        ],
        "nl": [
          "Broodjes- en croissantwinkel Le P'tit Bidon biedt ook lunchmenu's. Het is ook mogelijk om binnen te eten. De snackbar is geopend van maandag tot vrijdag van 7.00 tot 15.00 uur."
        ]
      },
