      "dc:description": {
        "de": [
          "Ein geselliger Moment rund um das Feuer: Demonstration des Anzündens, Zubereitung und Backen von Apero-Küchlein. Ist es fertig? Lassen Sie es sich schmecken! (ab 6 Jahren - Reservierung unter museedecarnac.fr)"
        ],
        "en": [
          "A convivial moment around the fire: lighting demonstration, preparation and cooking of galettes apéro. Ready to go? Let's enjoy! (from 6 years - booking on museedecarnac.fr)"
        ],
        "it": [
          "Un momento conviviale intorno al fuoco: dimostrazione di accensione, preparazione e cottura di dolci da aperitivo. Pronti a partire? Divertiamoci! (a partire da 6 anni - prenotazione su museedecarnac.fr)"
        ],
        "fr": [
          "Un moment convivial autour du feu : démonstration d'allumage, préparation et cuisson de galettes apéro. C'est prêt ? Dégustons ! (dès 6 ans - réservation sur museedecarnac.fr)"
        ],
        "es": [
          "Un momento de convivencia en torno al fuego: demostración de encendido, preparación y cocción de pasteles de aperitivo. ¿Preparados? ¡A disfrutar! (a partir de 6 años - reserva en museedecarnac.fr)"
        ],
        "nl": [
          "Een gezellig moment rond het vuur: aanmaakdemonstratie, bereiding en bereiding van aperitiefgebakjes. Klaar voor vertrek? Laten we genieten! (vanaf 6 jaar - reserveren op museedecarnac.fr)"
        ]
      },
