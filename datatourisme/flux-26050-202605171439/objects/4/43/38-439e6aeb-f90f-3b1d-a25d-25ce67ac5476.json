  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4bbe2432-fe10-3428-92eb-b24f35a3b570",
      "dc:description": {
        "de": [
          "Charakteristische, unabhängige Unterkunft auf einem Landgut, 2 km von Quelneuc entfernt, in der Orangerie aus dem 17. Jahrhundert mit Blick auf das Herrenhaus. Sonnige und ruhige Umgebung."
        ],
        "en": [
          "Independent, character gîte on a property 2 km from Quelneuc, created in the 17th-century Orangerie overlooking the manor house. Quiet, sunny setting."
        ],
        "it": [
          "Gîte indipendente di carattere, in una proprietà a 2 km da Quelneuc, ricavata nell'Orangerie del XVII secolo con vista sulla casa padronale. Ambiente soleggiato e tranquillo."
        ],
        "fr": [
          "Gîte de caractère, indépendant, sur une propriété, à 2 km de Quelneuc, créé dans l'Orangerie du XVII ème siècle avec vue sur le manoir. Cadre ensoleillé et calme."
        ],
        "nl": [
          "Onafhankelijke gîte met karakter, op een landgoed op 2 km van Quelneuc, gemaakt in de 17e eeuwse Orangerie met uitzicht op het landhuis. Zonnige en rustige omgeving."
        ],
        "es": [
          "Casa rural independiente con carácter, en una propiedad a 2 km de Quelneuc, creada en la Orangerie del siglo XVII con vistas a la casa solariega. Entorno soleado y tranquilo."
        ]
      },
