  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/50059a6c-1752-3e94-87f9-80c02c21f8a3",
      "dc:description": {
        "de": [
          "Erholen Sie sich im Château du Boschet in La Gacilly, inmitten eines 12 Hektar großen Parks. Wir sind Christel und Franck und freuen uns, Sie als Paar, Familie, Freunde oder allein begrüßen zu dürfen."
        ],
        "en": [
          "Come and recharge your batteries at Château du Boschet, in La Gacilly, in the heart of a 12-hectare park. We're Christel and Franck, and we'd be delighted to welcome you as a couple, with your family, friends or on your own."
        ],
        "it": [
          "Venite a fare il pieno di energia allo Château du Boschet, a La Gacilly, nel cuore di 12 ettari di parco. Christel e Franck saranno lieti di accogliervi in coppia, con la famiglia, con gli amici o da soli."
        ],
        "fr": [
          "Venez vous ressourcer au Château du Boschet, à La Gacilly, au coeur d'un parc de 12 hectares. Nous sommes Christel et Franck et nous vous accueillerons avec grand plaisir en couple, en famille, entre amis ou seul.e."
        ],
        "es": [
          "Venga a reponer fuerzas en el Château du Boschet, en La Gacilly, en el corazón de 12 hectáreas de parque. Christel y Franck estarán encantados de recibirle en pareja, en familia, con amigos o solo."
        ],
        "nl": [
          "Kom nieuwe energie opdoen op Château du Boschet, in La Gacilly, in het hart van 12 hectare park. Christel en Franck ontvangen je graag met z'n tweeën, met het gezin, met vrienden of alleen."
        ]
      },
