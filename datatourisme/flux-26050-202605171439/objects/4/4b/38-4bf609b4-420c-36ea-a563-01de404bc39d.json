  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4041eaed-05fa-39b2-9ee6-10c8773f1dd4",
      "dc:description": {
        "de": [
          "Ökologisches Ferienhaus, das 2015 renoviert wurde. Zahlreiche Wanderungen, Rad- und Wandertouren auf dem grünen Weg 400 m von der Unterkunft entfernt. Grünfläche mit einer Fläche von 2000 m²."
        ],
        "en": [
          "Ecological gîte, renovated in 2015. Numerous hiking, biking and walking trails on the voie verte, 400 m from the gîte. Green space of 2000 m²."
        ],
        "it": [
          "Gîte ecologico, ristrutturato nel 2015. Numerose passeggiate, gite in bicicletta ed escursioni sulla via verde a soli 400 m dall'alloggio. Area verde di 2000 m²."
        ],
        "fr": [
          "Gîte écologique, rénové en 2015. Nombreuses randonnées, vélos, pédestres sur la voie verte à 400 m du gîte. Espace vert d'une surface de 2000 m²."
        ],
        "nl": [
          "Milieuvriendelijke gîte, gerenoveerd in 2015. Talrijke wandelingen, fietstochten en trektochten op de groene weg op slechts 400 m van de gîte. Groene zone van 2000 m²."
        ],
        "es": [
          "Casa rural ecológica, renovada en 2015. Numerosos paseos a pie, en bicicleta o a pie por la vía verde a 400 m de la casa rural. Zona verde de 2000 m²."
        ]
      },
