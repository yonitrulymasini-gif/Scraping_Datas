  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e8e508f5-0398-375f-a50f-5ecc14b66140",
      "dc:description": {
        "de": [
          "Die Moulin de la Beraudaie bietet ein charmantes Ferienhaus für Urlauber und Durchreisende. Ein 42 m2 großes Appartement mit 2 Schlafzimmern, Bad, WC, Küchenzeile und Wohnraum, ideal für Angelfreunde!"
        ],
        "en": [
          "The Moulin de la Beraudaie offers a charming gîte for holidaymakers and visiting guests. A 42 m2 apartment with 2 bedrooms, bathroom, toilet, kitchenette and living room, ideal for fishing enthusiasts!"
        ],
        "it": [
          "Il Moulin de la Beraudaie offre un incantevole gîte per i vacanzieri e gli ospiti che pernottano. Un appartamento di 42 m2 con 2 camere da letto, bagno, wc, angolo cottura e soggiorno, ideale per gli amanti della pesca!"
        ],
        "fr": [
          "Le Moulin de la Beraudaie propose son gîte de charme au service des vacanciers et des hôtes de passage. Un gîte appartement de 42 m2 avec 2 chambres, sdb, wc, kitchenette et pièce à vivre idéal pour les amoureux de la pêche!"
        ],
        "es": [
          "El Moulin de la Beraudaie ofrece una casa rural con encanto para los veraneantes y los huéspedes que pernoctan. Un piso de 42 m2 con 2 habitaciones, cuarto de baño, wc, cocina americana y salón ¡ideal para los amantes de la pesca!"
        ],
        "nl": [
          "De Moulin de la Beraudaie biedt een charmante gîte voor vakantiegangers en overnachtende gasten. Een appartement van 42 m2 met 2 slaapkamers, badkamer, wc, kitchenette en woonkamer, ideaal voor visliefhebbers!"
        ]
      },
      "@type": [
        "Description"
      ],
