  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b6196cd6-fbfc-3b04-9aa3-614b3edc241a",
      "dc:description": {
        "de": [
          "Un Jour Ailleurs, \"L'Aff et Zen\", erfüllt Ihren Traum von Wohlbefinden und Abschalten in einer gemütlichen Atmosphäre, ganz in der Nähe des Waldes von Merlin dem Zauberer, 30 Minuten von Rennes und 40 Minuten vom Golf von Morbihan entfernt."
        ],
        "en": [
          "Un Jour Ailleurs, \"L'Aff et Zen\", fulfills your dream of well-being and disconnection in an ultra-cosy atmosphere, just a stone's throw from the forest of Merlin l'Enchanteur; 30' from Rennes and 40' from the Golfe du Morbihan."
        ],
        "it": [
          "Un Jour Ailleurs, \"L'Aff et Zen\", realizza il vostro sogno di benessere e disconnessione in un'atmosfera ultra-accogliente, a due passi dalla foresta di Merlino l'Incantatore; a 30' da Rennes e a 40' dal Golfe du Morbihan."
        ],
        "fr": [
          "Un Jour  Ailleurs, \"L'Aff et Zen\", exauce votre rêve de bien être et de déconnexion dans une ambiance ultra cosy, à deux pas de la forêt de Merlin l'Enchanteur; 30' de Rennes et 40' du Golfe du Morbihan."
        ],
        "nl": [
          "Un Jour Ailleurs, \"L'Aff et Zen\", vervult uw droom van welzijn en ontkoppeling in een ultragezellige sfeer, op een steenworp afstand van het bos van Merlijn de Betoveraar; 30' van Rennes en 40' van de Golfe du Morbihan."
        ],
        "es": [
          "Un Jour Ailleurs, \"L'Aff et Zen\", cumple su sueño de bienestar y desconexión en un ambiente ultra acogedor, a dos pasos del bosque de Merlín el Encantador; a 30' de Rennes y a 40' del Golfe du Morbihan."
        ]
      },
