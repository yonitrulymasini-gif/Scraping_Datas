  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b142c634-4407-3715-b2b8-fd8feab05557",
      "dc:description": {
        "de": [
          "Das Talvern ist ein Restaurant, das Ihnen eine traditionelle Küche aus frischen Zutaten bietet.\nTagesgericht: 12,50?\n Hauptgericht/Dessert oder Vorspeise/Hauptspeise: 15,90?\nVorspeise/Hauptspeise/Dessert: 18,90?\nVeganes oder vegetarisches Menü möglich.\nFreitagabend und Sonntag geschlossen.\nBusparkplatz in der Nähe."
        ],
        "en": [
          "Le Talvern is a restaurant offering traditional cuisine made with fresh produce.\nDish of the day 12.50?\n Main course/dessert or starter/main course: 15.90?\nStarter/main course/dessert: 18.90?\nVegan and vegetarian menus available.\nClosed Friday evenings and Sundays.\nCoach parking nearby."
        ],
        "it": [
          "Il ristorante Le Talvern propone una cucina tradizionale a base di prodotti freschi.\nPiatto del giorno: 12,50 euro\n Piatto principale/dessert o antipasto/piatto principale: 15,90?\nAntipasto/primo piatto/dessert: 18,90?\nDisponibili menu vegani e vegetariani.\nChiuso il venerdì sera e la domenica.\nParcheggio per pullman nelle vicinanze."
        ],
        "fr": [
          "Le Talvern est un restaurant vous proposant une cuisine traditionnelle, élaborée à partir de produits frais.\nPlat du jour 12,50€\n Plat/dessert ou entrée/plat : 15,90€\nEntrée/plat/dessert : 18,90€\nPossibilité de menu vegan ou végétarien.\nFermé le vendredi soir et le dimanche.\nParking autocar à proximité."
        ],
        "nl": [
          "Le Talvern is een restaurant waar traditionele gerechten met verse producten worden geserveerd.\nDagschotel: €12,50\n Hoofdgerecht/dessert of voorgerecht/hoofdgerecht: 15.90?\nVoorgerecht/hoofdgerecht/dessert: 18,90?\nVeganistisch en vegetarisch menu beschikbaar.\nGesloten op vrijdagavond en zondag.\nParkeergelegenheid voor bussen in de buurt."
        ],
        "es": [
          "Le Talvern es un restaurante de cocina tradicional elaborada con productos frescos.\nPlato del día: 12,50\n Plato principal/postre o entrante/plato principal: 15,90?\nEntrante/plato principal/postre: 18,90?\nMenús vegano y vegetariano disponibles.\nCerrado los viernes por la noche y los domingos.\nAparcamiento para autocares en las inmediaciones."
        ]
      },
