      "dc:description": {
        "de": [
          "Um 17 Uhr Entdecken Sie den Beruf des Austernzüchters inmitten einer Baustelle. Kommentare, Film und Austernverkostung mit Weißwein.\nErwachsener: 10? - Kind (4 bis 11 Jahre): 5?"
        ],
        "en": [
          "5pm Discover the oyster-farming trade at the heart of a construction site. Commentary, film and oyster tasting with white wine.\nAdults: 10? - Children (4 to 11 years): 5?"
        ],
        "it": [
          "Alle 17:00 Scoprite il lavoro di un ostricoltore nel cuore di un cantiere. Commento, filmato e degustazione di ostriche con vino bianco.\nAdulti: 10 euro - Bambini (da 4 a 11 anni): 5?"
        ],
        "fr": [
          "À 17h Découvrez le métier d’ostréiculteur au cœur d’un chantier. Commentaires, film et dégustation d’huîtres accompagnée de vin blanc.\nAdulte : 10€ - Enfant (4 à 11 ans) : 5€"
        ],
        "nl": [
          "Om 17u Ontdek het werk van een oesterkweker op een werklocatie. Commentaar, film en oesterproeverij met witte wijn.\nVolwassenen: €10 - Kinderen (van 4 tot 11 jaar): 5?"
        ],
        "es": [
          "A las 17.00 h Descubra el oficio de ostricultor en plena faena. Comentario, película y degustación de ostras con vino blanco.\nAdultos: 10? - Niños (de 4 a 11 años): 5?"
        ]
      },
