  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/831c221d-73b7-33cb-a419-c423674fa47f",
      "dc:description": {
        "de": [
          "Jomei vermischt einen engagierten Rap mit Liedern mit eindringlichen Texten. Getragen von Elektroprods, Klavier und Rhythmusharfe liefert das Duo Jomei und Al' eine intensive Show zwischen Energie und Sensibilität, die von einer starken Komplizenschaft auf der Bühne geprägt ist."
        ],
        "en": [
          "Jomei mixes committed rap and songs with hard-hitting lyrics. Backed by electro prods, piano and rhythmic harp, the duo Jomei et Al' deliver an intense show, between energy and sensitivity, marked by a strong stage complicity."
        ],
        "it": [
          "Jomei mescola un rap impegnato con testi di grande impatto. Con il supporto di electro, pianoforte e arpa ritmica, il duo di Jomei e Al' offre uno spettacolo intenso, un mix di energia e sensibilità, caratterizzato da un forte senso di complicità sul palco."
        ],
        "fr": [
          "Jomei mêle un rap engagé et des chansons avec des textes percutants. Portée par des prods électro, piano et harpe rythmique, le duo Jomei et Al' livre un show intense, entre énergie et sensibilité, marqué par une forte complicité scénique."
        ],
        "nl": [
          "Jomei mixt geëngageerde rap met harde teksten. Ondersteund door electro, piano en ritmeharp levert het duo Jomei en Al' een intense show, een mix van energie en gevoeligheid, gekenmerkt door een sterk gevoel van medeplichtigheid op het podium."
        ],
        "es": [
          "Jomei mezcla un rap comprometido con letras contundentes. Respaldados por electro, piano y arpa rítmica, el dúo formado por Jomei y Al' ofrece un espectáculo intenso, mezcla de energía y sensibilidad, marcado por un fuerte sentido de la complicidad en el escenario."
        ]
      },
