      "dc:description": {
        "de": [
          "Zwischen Guer und Malestroit, 2 km von den Landes de Monteneuf, einem regionalen Naturschutzgebiet, entfernt, wohnen Sie in diesem ebenerdigen, kürzlich renovierten Reihenhaus."
        ],
        "en": [
          "Between Guer and Malestroit, 2 km from the Landes de Monteneuf, a regional nature reserve, you'll be staying in this recently renovated, single-storey terraced house."
        ],
        "it": [
          "Tra Guer e Malestroit, a 2 km dalle Landes de Monteneuf, una riserva naturale regionale, soggiornerete in questa casa a schiera a un piano recentemente ristrutturata."
        ],
        "fr": [
          "Entre Guer et Malestroit, à 2 km des Landes de Monteneuf, réserve naturelle régionale, vous séjournerez dans cette maison mitoyenne de plain-pied, récemment rénovée."
        ],
        "nl": [
          "Tussen Guer en Malestroit, op 2 km van de Landes de Monteneuf, een regionaal natuurreservaat, verblijf je in dit onlangs gerenoveerde rijtjeshuis met één verdieping."
        ],
        "es": [
          "Entre Guer y Malestroit, a 2 km de las Landas de Monteneuf, reserva natural regional, se alojará en esta casa adosada de una sola planta recientemente renovada."
        ]
