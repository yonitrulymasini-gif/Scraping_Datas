      "dc:description": {
        "de": [
          "Der Strand Men er Beleg in der Bucht von Tréhennarvour ist von einem Pinienwald gesäumt und erstreckt sich über 400 Meter und fällt sanft ab."
        ],
        "en": [
          "Men er Beleg beach, located in the Tréhennarvour cove, is bordered by a pine forest and stretches for 400 meters on a gentle slope."
        ],
        "it": [
          "La spiaggia di Men er Beleg, situata nell'insenatura di Tréhennarvour, è delimitata da una pineta e si estende per 400 metri su un dolce pendio."
        ],
        "fr": [
          "La plage de Men er Beleg, située dans l'anse de Tréhennarvour, est bordée d'une pinède et s'étend sur 400 mètres en pente douce."
        ],
        "es": [
          "La playa de Men er Beleg, situada en la ensenada de Tréhennarvour, está bordeada por un pinar y se extiende a lo largo de 400 metros en suave pendiente."
        ],
        "nl": [
          "Het strand Men er Beleg, gelegen in de baai van Tréhennarvour, wordt begrensd door een dennenbos en strekt zich uit over 400 meter op een zachte helling."
        ]
      },
