  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/119620df-c3e9-3785-af56-d09903bc085f",
      "dc:description": {
        "de": [
          "Ein Haus, das um einen Turm herum gewachsen ist, ein überdachtes und beheiztes Schwimmbad, eine Veranda, ein wunderschöner Garten mit vielen kleinen Ecken?"
        ],
        "en": [
          "A house that has grown up around a tower, a covered and heated swimming pool, a veranda, a superb garden where many little corners blossom?"
        ],
        "it": [
          "Una casa cresciuta intorno a una torre, una piscina coperta e riscaldata, una veranda, un giardino superbo con tanti piccoli angoli?"
        ],
        "fr": [
          "Une maison qui a grandi autour d'une tour, une piscine couverte et chauffée, une véranda, un superbe jardin où s'épanouissent de multiples petits coins…"
        ],
        "es": [
          "Una casa que ha crecido alrededor de una torre, una piscina cubierta y climatizada, una veranda, un magnífico jardín con muchos rinconcitos.."
        ],
        "nl": [
          "Een huis dat rond een toren is gebouwd, een overdekt en verwarmd zwembad, een veranda, een prachtige tuin met veel hoekjes?"
        ]
      },
