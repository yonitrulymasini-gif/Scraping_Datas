  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4044f526-5aaa-303d-8ce6-b7805a257853",
      "dc:description": {
        "de": [
          "Lebensmittelmarkt auf dem Platz vor dem alten Hafen von Port-Haliguen.\nHier finden Sie eine große Auswahl an Meeresfrüchten, Käse, Wurstwaren, Obst und Gemüse.\nJeden Mittwoch im Sommer"
        ],
        "en": [
          "Food market in Port-Haliguen's old port square.\nYou'll find a wide selection of seafood, cheeses, charcuterie, fruit and vegetables.\nEvery Wednesday in summer"
        ],
        "it": [
          "Mercato alimentare nella piazza del porto vecchio di Port-Haliguen.\nTroverete un'ampia scelta di frutti di mare, formaggi, salumi, frutta e verdura.\nOgni mercoledì in estate"
        ],
        "fr": [
          "Marché alimentaire sur la place du vieux port de Port-Haliguen. \nVous y trouverez un large choix de fruits de mer, fromages, charcuteries, fruits et légumes.\nTous les mercredis d'été"
        ],
        "es": [
          "Mercado de alimentación en la plaza del puerto viejo de Port-Haliguen.\nEncontrará una gran variedad de mariscos, quesos, embutidos, frutas y verduras.\nTodos los miércoles de verano"
        ],
        "nl": [
          "Levensmiddelenmarkt op het oude havenplein van Port-Haliguen.\nJe vindt er een ruime keuze aan zeevruchten, kazen, vleeswaren, fruit en groenten.\nElke woensdag in de zomer"
        ]
      },
