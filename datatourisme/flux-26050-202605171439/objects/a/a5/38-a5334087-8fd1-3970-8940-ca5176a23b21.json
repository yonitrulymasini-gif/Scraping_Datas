      "dc:description": {
        "de": [
          "Einer der ersten Wettkämpfe für junge Segler aus dem Morbihan auf Optimisten oder Open Skiffs, die von ihren Trainern und Familien angefeuert werden.\nAbfahrt am Strand von Porigo gegen 13:30 Uhr."
        ],
        "en": [
          "One of the first competitions for young Morbihan sailors on Optimist or Open Skiff, encouraged by their coaches and families.\nDeparture from Porigo beach, around 1.30pm."
        ],
        "it": [
          "Una delle prime competizioni per i giovani velisti del Morbihan su Optimist o Open Skiff, incoraggiati dai loro allenatori e dalle loro famiglie.\nPartenza dalla spiaggia di Porigo, intorno alle 13.30."
        ],
        "fr": [
          "Une des premières compétitions pour les jeunes pratiquants morbihannais sur Optimist ou Open Skiff, encouragés par leurs entraineurs et leurs familles.\nDépart de la plage du Porigo, vers 13h30."
        ],
        "es": [
          "Una de las primeras competiciones para los jóvenes regatistas de Morbihan en Optimist u Open Skiff, animados por sus entrenadores y familias.\nSalida desde la playa de Porigo, hacia las 13.30 h."
        ],
        "nl": [
          "Een van de eerste wedstrijden voor jonge zeilers uit Morbihan in Optimist of Open Skiff, aangemoedigd door hun coaches en families.\nStart vanaf het strand van Porigo, rond 13.30 uur."
        ]
      },
