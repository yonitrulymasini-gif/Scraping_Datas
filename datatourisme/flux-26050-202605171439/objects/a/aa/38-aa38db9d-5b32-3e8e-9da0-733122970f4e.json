  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f42f5cbf-c1d0-320d-b424-3ccdf85393d9",
      "dc:description": {
        "de": [
          "2 Schlafzimmer mit Bett 160. Badezimmer mit WC. Einbauschrank. Erdgeschoss: 1 WC, Wohnzimmer mit Tisch, Stühlen, Schlafsofa für 2 Personen, 2 Sesseln und Couchtisch. Kaminofen. Fernseher mit Flachbildschirm. Ausgestattete Küche."
        ],
        "en": [
          "2 bedrooms with 160cm beds. Shower room with WC. Closet. Ground floor: 1 WC, living room with table, chairs, 2-person convertible sofa, 2 armchairs and coffee table. Wood stove. Flat-screen TV. Fully equipped kitchen."
        ],
        "it": [
          "2 camere da letto con letti da 160 cm. Bagno con doccia e WC. Armadio. Piano terra: 1 WC, soggiorno con tavolo, sedie, divano letto a 2 posti, 2 poltrone e tavolino. Stufa a legna. TV a schermo piatto. Cucina attrezzata."
        ],
        "fr": [
          "2 chambres avec lit 160. Salle d'eau avec WC. Placard. RDC : 1 WC, salon avec table, chaises, canapé convertible 2 palce, 2 fauteuils et table basse. Poêle. TV à écran plat. Cuisine équipée."
        ],
        "nl": [
          "2 slaapkamers met bedden van 160 cm. Doucheruimte met WC. Kast. Begane grond: 1 WC, woonkamer met tafel, stoelen, 2-persoons slaapbank, 2 fauteuils en salontafel. Houtkachel. Flatscreen TV. Ingerichte keuken."
        ],
        "es": [
          "2 dormitorios con camas de 160 cm. Cuarto de ducha con WC. Armario. Planta baja: 1 WC, salón con mesa, sillas, sofá cama de 2 plazas, 2 sillones y mesa de centro. Estufa de leña. Televisión de pantalla plana. Cocina equipada."
        ]
      },
      "@type": [
        "Description"
      ],
