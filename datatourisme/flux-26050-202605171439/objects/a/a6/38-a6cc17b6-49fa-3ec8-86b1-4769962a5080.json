      "dc:description": {
        "de": [
          "Träumen Sie mit Ihrer Familie bei Geschichten, Märchen und Liedern für Kinder ab 4 Jahren.\nJeden 2. Mittwoch im Monat."
        ],
        "en": [
          "Come and dream as a family as you listen to stories, tales and songs for children aged 4 and over.\n2nd Wednesday of each month."
        ],
        "it": [
          "Venite a sognare in famiglia ascoltando storie, racconti e canzoni per bambini dai 4 anni in su.\nOgni 2° mercoledì del mese."
        ],
        "fr": [
          "Venez rêver en famille en écoutant des histoires, des contes et des chansons pour les enfants à partir de 4 ans. \nLe 2e mercredi de chaque mois."
        ],
        "es": [
          "Ven a soñar en familia mientras escuchas historias, cuentos y canciones para niños a partir de 4 años.\nTodos los segundos miércoles de mes."
        ],
        "nl": [
          "Kom en droom als gezin terwijl je luistert naar verhalen, vertellingen en liedjes voor kinderen vanaf 4 jaar.\nElke 2e woensdag van de maand."
        ]
      },
