  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6eb38c42-631e-3470-a0a0-0e524d62782f",
      "dc:description": {
        "de": [
          "Kreative und leckere Küche mit hausgemachten Gerichten und Gebäck aus frischen Produkten unserer lokalen Produzenten. Jede Woche wird ein anderes Menü zusammengestellt, um Ihren Gaumen zu verwöhnen!"
        ],
        "en": [
          "Creative, gourmet cuisine featuring homemade dishes and pastries, using fresh produce from local producers. A different menu every week to keep your taste buds tantalized!"
        ],
        "it": [
          "Cucina creativa e gourmet con particolare attenzione ai piatti e ai dolci fatti in casa, utilizzando prodotti freschi provenienti da produttori locali. Ogni settimana un menu diverso per stuzzicare il vostro palato!"
        ],
        "fr": [
          "Cuisine créative & gourmande qui fait la part belle aux petits plats et pâtisseries faits maison, à partir de produits frais de nos producteurs locaux. Un menu différent concocté chaque semaine pour garder vos papilles en éveil!"
        ],
        "nl": [
          "Creatieve, gastronomische keuken met de nadruk op huisgemaakte gerechten en gebak, met verse producten van lokale producenten. Elke week een ander menu om je smaakpapillen te prikkelen!"
        ],
        "es": [
          "Cocina creativa y gastronómica con especial atención a los platos caseros y la repostería, elaborados con productos frescos de productores locales. Un menú diferente cada semana para deleitar su paladar"
        ]
      },
      "@type": [
        "Description"
