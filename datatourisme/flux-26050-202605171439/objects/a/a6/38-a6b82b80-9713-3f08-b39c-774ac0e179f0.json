      "dc:description": {
        "de": [
          "Hausgemachtes japanisches Streetfood mit kurzen Transportwegen. Spezialisiert auf Ramen, Maki und Domburi.Vor Ort, zum Mitnehmen oder per Click and Collect.\nGeöffnet von Mittwoch bis Sonntag."
        ],
        "en": [
          "Homemade Japanese street food. Specializing in ramen, maki and domburi, available to eat in, take away or click and collect.\nOpen Wednesday to Sunday."
        ],
        "it": [
          "Cibo di strada giapponese fatto in casa. Specializzato in ramen, maki e domburi, disponibile per il consumo, l'asporto o il ritiro.\nAperto da mercoledì a domenica."
        ],
        "fr": [
          "Street food japonaise maison et en circuit court. Spécialisé en ramen, maki et domburi.Sur place, à emporter ou en click and collect.\nOuvert du mercredi au dimanche."
        ],
        "nl": [
          "Huisgemaakt Japans streetfood. Gespecialiseerd in ramen, maki en domburi, beschikbaar om te eten, mee te nemen of af te halen.\nGeopend van woensdag tot zondag."
        ],
        "es": [
          "Comida callejera japonesa casera. Especializado en ramen, maki y domburi, disponible para comer en casa, para llevar o para recoger.\nAbierto de miércoles a domingo."
        ]
