  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/9564d57a-14b0-3143-af0a-ea948b4442a5",
      "dc:description": {
        "de": [
          "Das Ciné-Roch ist ein assoziatives Kino und das ganze Jahr über geöffnet. Jeden zweiten Donnerstag im Monat bietet das Team ein Ciné Café an, eine Filmvorführung, gefolgt von einem gemütlichen Moment bei Kaffee oder Tee. Das ganze Jahr über werden verschiedene Animationen organisiert."
        ],
        "en": [
          "Ciné-Roch is a community cinema open all year round. Every second Thursday of the month, the team proposes a ciné café, a screening followed by a warm moment over coffee or tea. Various events are organized throughout the year."
        ],
        "it": [
          "Ciné-Roch è un cinema comunitario aperto tutto l'anno. Ogni secondo giovedì del mese, il team offre un ciné café, una proiezione seguita da un momento di convivialità davanti a un caffè o a un tè. Durante l'anno vengono organizzati vari eventi."
        ],
        "fr": [
          "Le Ciné-Roch est un cinéma associatif et ouvert toute l'année. Chaque deuxième jeudi du mois, l'équipe propose un ciné café, une séance suivi d'un moment chaleureux autour d'un café ou d'un thé. Diverses animations sont organisées tout au long de l'année."
        ],
        "nl": [
          "Ciné-Roch is een gemeenschapsbioscoop die het hele jaar door geopend is. Elke tweede donderdag van de maand biedt het team een ciné café, een vertoning gevolgd door een warm moment bij een kopje koffie of thee. Het hele jaar door worden er verschillende evenementen georganiseerd."
        ],
        "es": [
          "Ciné-Roch es un cine comunitario abierto todo el año. Cada segundo jueves de mes, el equipo ofrece un ciné café, una proyección seguida de un momento cálido tomando un café o un té. A lo largo del año se organizan diversos actos."
        ]
      },
