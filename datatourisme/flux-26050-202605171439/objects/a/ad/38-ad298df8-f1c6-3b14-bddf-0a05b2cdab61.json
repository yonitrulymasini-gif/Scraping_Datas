  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b8e5157f-4c7a-344e-b5c7-b2d19c8af84e",
      "dc:description": {
        "de": [
          "After surf, after beach, after boat, after sex, after work, apéro les pieds dans l'eau. Meeresfrüchte, Tapas und Co. Le Bateau Ivre, ohne Mäßigung zu konsumieren. Täglich außer dienstags geöffnet.Im Juli und August: 7/7 mittags und abends geöffnet."
        ],
        "en": [
          "After surf, after beach, after boat, after sex, after work, aperitif with your feet in the water. Seafood, tapas and co. Le Bateau Ivre, to be consumed without moderation. In July and August: open 7 days a week for lunch and dinner."
        ],
        "it": [
          "Dopo il surf, dopo la spiaggia, dopo la barca, dopo il sesso, dopo il lavoro, dopo la cena. Frutti di mare, tapas e altro. Le Bateau Ivre, da gustare senza moderazione. Aperto tutti i giorni tranne il martedì, in luglio e agosto: aperto 7/7 per pranzo e cena."
        ],
        "fr": [
          "After surf, after beach, after boat, after sex, after work, apéro les pieds dans l'eau. Fruit de mer, tapas and co. Le Bateau Ivre, à consommer sans modération. Ouvert tous les jours sauf le mardi.En juillet et août : ouvert 7/7 midi et soir."
        ],
        "nl": [
          "Na het surfen, na het strand, na de boot, na de seks, na het werk, na het eten. Zeevruchten, tapas en co. Le Bateau Ivre, om met mate van te genieten. Dagelijks geopend behalve dinsdag, in juli en augustus: 7/7 open voor lunch en diner."
        ],
        "es": [
          "Después del surf, de la playa, del barco, del sexo, del trabajo, de la cena. Marisco, tapas y co. Le Bateau Ivre, para disfrutar sin moderación. Abierto todos los días excepto los martes, en julio y agosto: abierto 7/7 para el almuerzo y la cena."
        ]
      },
