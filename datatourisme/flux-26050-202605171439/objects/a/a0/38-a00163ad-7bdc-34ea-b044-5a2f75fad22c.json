  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/eac4a23e-6407-3b7b-967b-a34111ae9919",
      "dc:description": {
        "de": [
          "Dieses Hotel befindet sich direkt gegenüber der Militärakademie S-Cyr Coëtquidan und empfängt Sie in einem raffinierten Rahmen. Es bietet Ihnen alle Annehmlichkeiten eines 3-Sterne-Hotels in idealer Lage im Herzen des Pays de Brocéliande."
        ],
        "en": [
          "This hotel, located just opposite the S-Cyr Coëtquidan military academy, welcomes you to a refined setting. You'll find all the comforts of a 3-star establishment ideally located in the heart of the Pays de Brocéliande."
        ],
        "it": [
          "Questo hotel, situato proprio di fronte all'accademia militare S-Cyr Coëtquidan, vi accoglie in un ambiente raffinato. Troverete tutti i comfort di una struttura a 3 stelle situata in posizione ideale nel cuore della regione di Brocéliande."
        ],
        "fr": [
          "Cet hôtel, situé juste en face de l'académie militaire de S-Cyr Coëtquidan, vous accueille dans un cadre raffiné. Vous y trouverez tout le confort d'un établissement 3 étoiles idéalement situé au cœur du Pays de Brocéliande."
        ],
        "es": [
          "Este hotel, situado justo enfrente de la academia militar S-Cyr Coëtquidan, le da la bienvenida en un ambiente refinado. Encontrará todas las comodidades de un establecimiento de 3 estrellas idealmente situado en el corazón de la región de Brocéliande."
        ],
        "nl": [
          "Dit hotel, gelegen tegenover de militaire academie S-Cyr Coëtquidan, verwelkomt u in een verfijnde omgeving. U vindt er alle comfort van een 3-sterrenhotel, ideaal gelegen in het hart van de regio Brocéliande."
        ]
      },
      "@type": [
        "Description"
      ],
