  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/fe90ddab-7802-3adc-b8fb-46adae7f9497",
      "dc:description": {
        "de": [
          "Frédéric und Béatrice heißen Sie von Donnerstag bis Sonntag abends willkommen: Donnerstag und Sonntag von 18 bis 21.30 Uhr und Freitag und Samstag von 18 bis 22.30 Uhr. Sie bieten Ihnen eine große Auswahl an Pizzas an"
        ],
        "en": [
          "Frédéric and Béatrice welcome you in the evening from Thursday to Sunday: Thursday and Sunday from 6pm to 9:30pm and Friday and Saturday from 6pm to 10:30pm. They offer a wide choice of pizzas"
        ],
        "it": [
          "Frédéric e Béatrice vi accolgono la sera dal giovedì alla domenica: il giovedì e la domenica dalle 18.00 alle 21.30 e il venerdì e il sabato dalle 18.00 alle 22.30. Offrono un'ampia scelta di pizze"
        ],
        "fr": [
          "Frédéric et Béatrice vous accueillent le soir du jeudi au  dimanche : le jeudi et le dimanche de 18h à 21h30 et le vendredi et samedi de 18h à 22h30 . Ils vous proposent un large choix de pizzas"
        ],
        "es": [
          "Frédéric y Béatrice le dan la bienvenida por la noche de jueves a domingo: jueves y domingo de 18:00 a 21:30 y viernes y sábado de 18:00 a 22:30. Ofrecen una amplia selección de pizzas"
        ],
        "nl": [
          "Frédéric en Béatrice verwelkomen je 's avonds van donderdag tot zondag: donderdag en zondag van 18.00 tot 21.30 uur en vrijdag en zaterdag van 18.00 tot 22.30 uur. Ze bieden een ruime keuze aan pizza's"
        ]
      },
