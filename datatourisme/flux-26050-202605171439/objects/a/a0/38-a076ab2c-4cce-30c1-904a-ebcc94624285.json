  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0c4a2bf4-1662-3e2d-9d5c-bb732b52abf6",
      "dc:description": {
        "de": [
          "Das Gästezimmer besteht aus einem Zimmer mit einem Doppelbett (Elternzimmer), einem Zimmer mit einem einfachen Etagenbett (Kinderzimmer), einem Badezimmer, einer Schlafcouch und einer Küchenzeile."
        ],
        "en": [
          "The guest room comprises a bedroom with a double bed (master bedroom), a bedroom with single bunk beds (children's bedroom), a bathroom, a sofa bed and a kitchenette."
        ],
        "it": [
          "La camera degli ospiti comprende una camera con letto matrimoniale (camera matrimoniale), una camera con letti a castello singoli (camera dei bambini), un bagno, un divano letto e un angolo cottura."
        ],
        "fr": [
          "La chambre d'hôtes se compose d'une chambre avec un lit double (chambre parentale), d'une chambre avec lits simples superposés (chambre enfant),  d'une salle de bain, d'un canapé convertible et d'une kitchenette."
        ],
        "es": [
          "La habitación de invitados consta de un dormitorio con cama de matrimonio (dormitorio principal), un dormitorio con literas individuales (dormitorio infantil), un cuarto de baño, un sofá cama y una cocina americana."
        ],
        "nl": [
          "De gastenkamer bestaat uit een slaapkamer met een tweepersoonsbed (ouderslaapkamer), een slaapkamer met een stapelbed (kinderslaapkamer), een badkamer, een slaapbank en een kitchenette."
        ]
      },
      "@type": [
        "Description"
