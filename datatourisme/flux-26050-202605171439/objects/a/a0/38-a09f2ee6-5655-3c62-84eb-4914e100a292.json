  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6ea8fb67-fdcc-3217-bff5-f72e25274e2f",
      "dc:description": {
        "de": [
          "Willkommen in unserem charmanten Ferienhaus im Herzen des legendären Waldes von Brocéliande, am Fuße des Rocher Glissant! Dieses komfortable und voll ausgestattete Studio ist der ideale Ort für einen romantischen Ausflug oder einen erholsamen Aufenthalt in der Natur."
        ],
        "en": [
          "Welcome to our charming gîte nestled in the heart of the legendary Brocéliande forest, at the foot of Rocher Glissant! This comfortable, fully-equipped studio is the ideal place for a romantic getaway or a revitalizing stay in the heart of nature."
        ],
        "it": [
          "Benvenuti nel nostro affascinante gîte immerso nel cuore della leggendaria foresta di Brocéliande, ai piedi del Rocher Glissant! Questo monolocale confortevole e completamente attrezzato è il luogo ideale per una fuga romantica o per un soggiorno rigenerante nel cuore della natura."
        ],
        "fr": [
          "Bienvenue dans notre charmant gîte niché au coeur de la légendaire forêt de Brocéliande, au pied du Rocher Glissant! Ce studio confortable, et entièrement équipé, est l'endroit idéal pour une escapade romantique ou un séjour revitalisant en pleine nature."
        ],
        "nl": [
          "Welkom in onze charmante gîte in het hart van het legendarische bos van Brocéliande, aan de voet van Rocher Glissant! Deze comfortabele, volledig uitgeruste studio is de ideale plek voor een romantisch uitje of een verkwikkend verblijf midden in de natuur."
        ],
        "es": [
          "Bienvenido a nuestra encantadora casa rural situada en el corazón del legendario bosque de Brocéliande, a los pies del Rocher Glissant Este estudio confortable y totalmente equipado es el lugar ideal para una escapada romántica o una estancia revitalizante en plena naturaleza."
        ]
      },
      "@type": [
