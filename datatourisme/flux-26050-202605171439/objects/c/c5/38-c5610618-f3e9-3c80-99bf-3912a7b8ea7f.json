  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d22792ce-ea54-39a0-8a7c-764f822c16b6",
      "dc:description": {
        "de": [
          "Haus mit beheiztem Pool und eingezäuntem Garten.\nAusgestattete US-Küche im Wohn- und Esszimmer mit Zugang zu den Terrassen\nWC. Schlafzimmer mit eigenem Duschbad -\nEin Raum mit Küchenecke WC Wohnzimmer (2 Schlafplätze) angrenzend.\nEtage: 2 Schlafzimmer, ein Mezzanin Schlafzimmer, ein separates WC, ein Duschbad."
        ],
        "en": [
          "House with heated pool and enclosed garden.\nUS fitted kitchen opening onto living room with access to terraces\nWC. bedroom with en-suite shower room\nAdjoining room with kitchenette, WC and lounge (sleeps 2).\nFirst floor: two bedrooms, mezzanine bedroom, separate WC, shower room."
        ],
        "it": [
          "Casa con piscina riscaldata e giardino recintato.\nCucina americana attrezzata che si apre sul soggiorno con accesso alle terrazze\nCamera da letto con bagno privato con doccia\nCamera adiacente con angolo cottura, WC e salotto (2 posti letto).\nPrimo piano: due camere da letto, camera da letto soppalcata, WC separato e bagno con doccia."
        ],
        "fr": [
          "Maison  avec piscine chauffée et jardin clos.\nCuisine équipée US sur séjour-salon accès terrasses\nWC. chambre avec salle d'eau privative -\nUne pièce avec coin cuisine WC salon (2 couchages) contiguë.\nÉtage : deux chambres, une mezzanine chambre, un WC séparé, une salle d'eau."
        ],
        "nl": [
          "Huis met verwarmd zwembad en omheinde tuin.\nAmerikaanse keuken die uitkomt op de woonkamer met toegang tot de terrassen\nWC. Slaapkamer met en-suite badkamer met douche\nAangrenzende kamer met kitchenette, WC en zitkamer (2 slaapplaatsen).\nEerste verdieping: twee slaapkamers, mezzanine slaapkamer, aparte WC en doucheruimte."
        ],
        "es": [
          "Casa con piscina climatizada y jardín cerrado.\nCocina americana abierta al salón con acceso a terrazas\nDormitorio con cuarto de baño con ducha\nHabitación contigua con cocina americana, WC y salón (2 plazas).\nPrimera planta: dos habitaciones, habitación en altillo, WC separado y cuarto de ducha."
        ]
      },
      "@type": [
        "Description"
      ],
