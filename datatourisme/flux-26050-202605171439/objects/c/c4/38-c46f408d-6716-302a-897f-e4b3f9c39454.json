  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/df7e25ae-77e9-3e01-91c9-de5e79aae813",
      "dc:description": {
        "de": [
          "Das Landgut LA BONNE ETOILE ist ein typisch bretonisches, restauriertes Anwesen, das Sie mit mehreren Schlaf- und Unterkunftsmöglichkeiten empfängt. Mit 30 Jahren Erfahrung stehen Ihr Komfort und Ihre Gelassenheit an diesem Ort der Ruhe und der bewaldeten Natur an erster Stelle."
        ],
        "en": [
          "The Domaine LA BONNE ETOILE is a typically restored Breton property offering a wide range of sleeping and accommodation options. With 30 years of experience, your comfort and serenity are our top priorities in this peaceful, wooded setting."
        ],
        "it": [
          "Il Domaine LA BONNE ETOILE è una proprietà bretone tipicamente restaurata che offre una serie di opzioni di pernottamento e alloggio. Con 30 anni di esperienza, il vostro comfort e la vostra tranquillità sono al primo posto in questo ambiente tranquillo e boscoso."
        ],
        "fr": [
          "La domaine LA BONNE ETOILE est une propriété bretonne typique restaurée qui vous accueille avec plusieurs possibilités de couchage et d'hébergement. Avec 30 ans d'expérience, votre confort et votre sérénité sont prioritaires dans ce lieu de calme et de nature boisée."
        ],
        "es": [
          "El Domaine LA BONNE ETOILE es un establecimiento bretón típicamente restaurado que ofrece diversas posibilidades de alojamiento. Con 30 años de experiencia, su comodidad y tranquilidad son lo primero en este entorno tranquilo y arbolado."
        ],
        "nl": [
          "Domaine LA BONNE ETOILE is een typisch gerestaureerd Bretons landgoed dat verschillende slaap- en verblijfsmogelijkheden biedt. Met 30 jaar ervaring komen uw comfort en gemoedsrust op de eerste plaats in deze rustige, bosrijke omgeving."
        ]
      },
      "@type": [
        "Description"
      ],
