  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/9d508f4b-57b7-3e3f-b97f-77fa2ca44e0b",
      "dc:description": {
        "de": [
          "Entspannen Sie sich auf dem Land in Lizio in unserem geschmackvoll renovierten Mini-Ferienhaus, einem kleinen, ruhigen und komfortablen Kokon. Es befindet sich in einem geselligen Weiler ganz aus Stein, nur wenige Schritte vom Museum des Schrottpoeten entfernt."
        ],
        "en": [
          "Come and relax in the Lizio countryside, in our tastefully renovated mini-gîte, a quiet, comfortable little cocoon. Located in a friendly stone hamlet, a stone's throw from the Musée du Poète Ferrailleur."
        ],
        "it": [
          "Venite a rilassarvi nella campagna di Lizio, nella nostra mini-gîte ristrutturata con gusto, un piccolo rifugio tranquillo e accogliente. Situato in un accogliente borgo in pietra, a pochi passi dal Musée du Poète Ferrailleur."
        ],
        "fr": [
          "Venez vous relaxer en campagne de Lizio, dans notre mini-gîte rénové avec goût, un petit cocon calme et confortable. Situé dans un hameau tout en pierre, convivial, à deux pas du Musée du Poète Ferrailleur."
        ],
        "es": [
          "Venga a relajarse en la campiña de Lizio, en nuestra mini casa rural renovada con gusto, un pequeño capullo tranquilo y acogedor. Situada en una acogedora aldea de piedra, a dos pasos del Museo del Poeta Ferrailleur."
        ],
        "nl": [
          "Kom tot rust op het platteland van Lizio, in onze smaakvol gerenoveerde minigîte, een rustig en gezellig coconnetje. Gelegen in een vriendelijk stenen gehucht, op een steenworp afstand van het Musée du Poète Ferrailleur."
        ]
      },
      "@type": [
        "Description"
