  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8ea25c14-a489-3aa9-9128-45f66c611268",
      "dc:description": {
        "de": [
          "Wir empfangen Sie in einer familiären Atmosphäre und bieten Ihnen unsere frischen Crêpes und Galettes aus bretonischem Buchweizen, unsere Pizzen, unsere Brasserie-Karte mit Fleischgerichten, Burgern, Muscheln und Mahlzeitsalaten. Terrasse. Bedienung im Garten. Verkauf zum Mitnehmen."
        ],
        "en": [
          "We welcome you in a family atmosphere, and offer you our fresh Breton buckwheat crêpes and galettes, pizzas, and our brasserie menu of meats, burgers, mussels and lunch salads. Terrace. Garden service. Take-away sales."
        ],
        "it": [
          "Vi accogliamo in un'atmosfera familiare e vi offriamo le nostre fresche crêpes e galettes bretoni di grano saraceno, le nostre pizze e il nostro menu da brasserie con carni, hamburger, cozze e insalate. Terrazza. Servizio in giardino. Vendita da asporto."
        ],
        "fr": [
          "Nous vous accueillons dans une ambiance familiale, et nous vous proposons nos crêpes et galettes fraîches au blé noir breton, nos pizzas, notre carte brasserie composée de viandes, de burgers, de moules et de salades repas. Terrasse. Service au jardin. Vente à emporter."
        ],
        "nl": [
          "We verwelkomen je in een familiale sfeer en bieden je onze verse Bretoense boekweit crêpes en galettes, onze pizza's en ons brasseriemenu met vlees, hamburgers, mosselen en salades. Terras. Tuinservice. Verkoop afhaalmaaltijden."
        ],
        "es": [
          "Le damos la bienvenida en un ambiente familiar y le ofrecemos nuestras crepes y galettes de trigo sarraceno bretonas frescas, nuestras pizzas y nuestra carta de brasserie con carnes, hamburguesas, mejillones y ensaladas. Terraza. Servicio de jardín. Venta para llevar."
        ]
      },
      "@type": [
        "Description"
      ],
