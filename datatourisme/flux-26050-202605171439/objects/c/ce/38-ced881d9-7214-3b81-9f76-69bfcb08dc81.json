      "dc:description": {
        "de": [
          "Neue Ausgabe der großformatigen Naturfotoausstellung im Priorat Saint-Etienne. Entdecken Sie die Fotografien von Isabelle Kervarec.\n\nAusstellung im Freien mit freiem Zugang und kostenlosem Eintritt"
        ],
        "en": [
          "New edition of the large-format nature photo exhibition at Prieuré Saint-Etienne. Come and discover Isabelle Kervarec's photographs.\n\nFree outdoor exhibition"
        ],
        "it": [
          "Una nuova mostra di fotografia naturalistica di grande formato al Prieuré Saint-Etienne. Venite a scoprire le fotografie di Isabelle Kervarec.\n\nMostra all'aperto gratuita"
        ],
        "fr": [
          "Nouvelle édition de l’expo photo nature en grand format au Prieuré Saint-Etienne. Venez découvrir les photographies d'Isabelle Kervarec.\n\nExpo en extérieur en accès libre et gratuit"
        ],
        "es": [
          "Una nueva exposición de fotografía de naturaleza de gran formato en el Prieuré Saint-Etienne. Venga a descubrir las fotografías de Isabelle Kervarec.\n\nExposición gratuita al aire libre"
        ],
        "nl": [
          "Een nieuwe tentoonstelling van natuurfotografie op groot formaat in de Prieuré Saint-Etienne. Kom de foto's van Isabelle Kervarec ontdekken.\n\nGratis openluchttentoonstelling"
        ]
      },
