  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/23850457-7ed4-3d71-8fd1-4f4501acf670",
      "dc:description": {
        "de": [
          "Gästezimmer mit Charme und Charakter im ökologisch-verantwortlichen Tourismus im Herzen von Morbihan. Ruhig und in der Nähe von Stränden und archäologischen Stätten gelegen.\n\nGourmandises au rendez-vous."
        ],
        "en": [
          "Charming, characterful bed & breakfast in eco-responsible tourism, in the heart of Morbihan. Quiet, close to beaches and archaeological sites.\n\nGourmet delights await you."
        ],
        "it": [
          "Un bed and breakfast di charme e di carattere, all'insegna del turismo eco-responsabile, nel cuore del Morbihan. In un ambiente tranquillo, vicino alle spiagge e ai siti archeologici.\n\nVi aspettano delizie gastronomiche."
        ],
        "fr": [
          "Chambres d'hôtes de charme et de caractère en tourisme éco-responsable, au coeur du Morbihan. Au calme et situé à proximité des plages et des sites archéologiques. \n\nGourmandises au rendez-vous."
        ],
        "nl": [
          "Charmante en karaktervolle bed & breakfast in eco-verantwoord toerisme, in het hart van Morbihan. In een rustige omgeving dicht bij stranden en archeologische vindplaatsen.\n\nGastronomische hoogstandjes wachten op u."
        ],
        "es": [
          "Cama y desayuno con encanto y carácter en turismo eco-responsable, en el corazón de Morbihan. En un entorno tranquilo cerca de playas y sitios arqueológicos.\n\nLe esperan delicias gastronómicas."
        ]
      },
      "@type": [
        "Description"
      ],
