  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4f3620df-45e1-3e7a-bdf5-80e02faec752",
      "dc:description": {
        "de": [
          "Zirkusschule: Schnupperkurse im Juli/August im Zirkuszelt - ab 4 Jahren. Jonglieren, Gleichgewicht, Akrobatik, Zauberei, Clown, Luftartistik, Aufführung am Ende des Kurses. Schulen: Januar bis Juni, September bis Dezember, Zelt in Damgan im Juli und August"
        ],
        "en": [
          "Circus school: discovery-courses in July/August under a big top-from 4 years old. Juggling, balance, acrobatics, magic, clowning, aerialists, end of course show. Schools January to June, September to December. Big top installed in Damgan in July and August"
        ],
        "it": [
          "Scuola di circo: corsi di scoperta luglio/agosto sotto un tendone, a partire dai 4 anni. Giocoleria, equilibrismo, acrobazie, magia, clownerie, aerialisti, spettacolo di fine corso. Scuole da gennaio a giugno, da settembre a dicembre. Big top installato a Damgan in luglio e agosto"
        ],
        "fr": [
          "École de cirque : découverte-stages juillet/août sous chapiteau-à partir de 4 ans. Jonglerie, équilibre, acrobaties, magie, clown, aériens, spectacle fin de stage. Établissements scolaires janvier à juin, Septembre à Décembre.Chapiteau installé à Damgan en juillet et août"
        ],
        "es": [
          "Escuela de circo: cursos de descubrimiento en julio/agosto bajo una carpa, a partir de los 4 años. Malabares, equilibrios, acrobacias, magia, payasadas, equilibristas, espectáculo de fin de curso. Colegios de enero a junio y de septiembre a diciembre. Carpa instalada en Damgan en julio y agosto"
        ],
        "nl": [
          "Circusschool: ontdekkingscursussen juli/augustus onder een big top - vanaf 4 jaar. Jongleren, balans, acrobatiek, magie, clownerie, luchtacrobaten, einde show. Scholen van januari tot juni, september tot december. Grote top geïnstalleerd in Damgan in juli en augustus"
        ]
      },
