  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c2c1b034-5679-3ea7-8300-b9940aa34194",
      "dc:description": {
        "de": [
          "Im Freiluftbereich der Peupleraie sind Skulpturen zeitgenössischer Kunst von international renommierten Künstlern versammelt. Dieser Garten ist frei zugänglich und macht so die zeitgenössische Kunst für alle zugänglich.",
          "Kulturelles Erbe"
        ],
        "en": [
          "Cultural Heritage",
          "The Peupleraie open-air garden features contemporary art sculptures by internationally renowned artists. The garden is open to the public, making contemporary art accessible to all."
        ],
        "it": [
          "All'aperto, nell'area della Peupleraie, sono riunite sculture d'arte contemporanea di artisti di fama internazionale. Il giardino è aperto al pubblico, rendendo l'arte contemporanea accessibile a tutti.",
          "Patrimonio culturale"
        ],
        "fr": [
          "En plein air, dans l’espace de la Peupleraie sont réunies des sculptures d’art contemporain réalisées par des artistes de renommée internationale. Ce jardin est en accès libre et rend ainsi l’art contemporain accessible à tous.",
          "Patrimoine culturel"
        ],
        "nl": [
          "Cultureel erfgoed",
          "De Peupleraie is een openluchtruimte met hedendaagse kunstsculpturen van internationaal bekende kunstenaars. De tuin is open voor het publiek en maakt hedendaagse kunst toegankelijk voor iedereen."
        ],
        "es": [
          "Al aire libre, en la zona de Peupleraie, se reúnen esculturas de arte contemporáneo de artistas de renombre internacional. El jardín está abierto al público, lo que pone el arte contemporáneo al alcance de todos.",
          "Patrimonio cultural"
        ]
      },
