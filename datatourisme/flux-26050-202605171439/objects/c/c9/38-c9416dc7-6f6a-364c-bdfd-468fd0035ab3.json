  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4d3c6fab-ede8-3458-a843-c43ffea2df01",
      "dc:description": {
        "de": [
          "Die in Erdeven gelegene Crêperie empfängt Sie in einem geräumigen, gemütlichen Restaurant mit einer Pergola im Freien. Eine hausgemachte Küche: Galettes, bretonische Crêpes und Brasserie (Burger, Salate, Fleischgerichte). Die Crêperie ist seit April 2018 geöffnet. Sie wird hauptsächlich von Frauen betrieben und wir legen Wert auf Qualität vor Quantität."
        ],
        "en": [
          "Located in Erdeven, the crêperie welcomes you to a warm, spacious restaurant with an outdoor pergola. Home cooking: galettes, Breton crepes and brasserie (burgers, salads, meats). The crêperie has been open since April 2018. It's mainly female and we prioritize quality over quantity."
        ],
        "it": [
          "Situata a Erdeven, la crêperie vi accoglie in un ristorante spazioso e accogliente con una pergola all'aperto. Cucina casalinga: galettes, crepes bretoni e brasserie (hamburger, insalate, carni). La crêperie è aperta da aprile 2018. È prevalentemente femminile e privilegiamo la qualità rispetto alla quantità."
        ],
        "fr": [
          "Située à Erdeven, la crêperie vous accueille dans un restaurant spacieux, chaleureux avec sa pergola extérieure. Une cuisine maison : galettes, crêpes bretonnes et brasserie (burgers, salades, viandes). La crêperie est ouverte depuis avril 2018. Elle est essentiellement féminine et nous privilégions la qualité avant la quantité."
        ],
        "es": [
          "Situada en Erdeven, la crêperie le recibe en un restaurante espacioso y acogedor con pérgola exterior. Cocina casera: galettes, crepes bretonas y brasserie (hamburguesas, ensaladas, carnes). La crêperie está abierta desde abril de 2018. Es mayoritariamente femenina y priorizamos la calidad sobre la cantidad."
        ],
        "nl": [
          "De crêperie ligt in Erdeven en verwelkomt je in een ruim, gezellig restaurant met een buitenpergola. Huisgemaakte gerechten: galettes, Bretonse crêpes en brasserie (hamburgers, salades, vleeswaren). De crêperie is open sinds april 2018. Het is voornamelijk vrouwelijk en we geven voorrang aan kwaliteit boven kwantiteit."
        ]
      },
