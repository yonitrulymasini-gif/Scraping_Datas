  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/da8f4d43-4627-31f3-915b-ee84dc50f83a",
      "dc:description": {
        "de": [
          "Hotel aus den 30er Jahren. Der Charme und die Gemütlichkeit eines Familienhauses. 14 Zimmer, davon 10 Familiensuiten mit Meer- oder Gartenblick.\n\nStrand in 30 m Entfernung und Wassersportmöglichkeiten in der Nähe. Vermietung von Fahrrädern."
        ],
        "en": [
          "Hôtel des Années 30. The charm and conviviality of a family home. 14 rooms including 10 family suites with sea or garden views.\n\nBeach 30 m away and water sports activities nearby. Bicycle rental."
        ],
        "it": [
          "Albergo degli anni '30. Il fascino e la cordialità di una casa di famiglia. 14 camere, tra cui 10 suite familiari con vista sul mare o sul giardino.\n\nSpiaggia a 30 metri e attività sportive nelle vicinanze. Noleggio biciclette."
        ],
        "fr": [
          "Hôtel des Années 30. Le charme et la convivialité d'une maison de famille. 14 chambres dont 10 suites familiales avec vue sur mer ou sur jardin. \n\nPlage à 30 mètres et activités nautiques à proximité. Location de vélos."
        ],
        "nl": [
          "Hotel uit de jaren 1930. De charme en vriendelijkheid van een familiehuis. 14 kamers waaronder 10 familiesuites met uitzicht op zee of de tuin.\n\nStrand op 30 meter en watersportactiviteiten in de buurt. Fietsen te huur."
        ],
        "es": [
          "Hotel de los años 30. El encanto y la amabilidad de una casa familiar. 14 habitaciones, 10 de ellas suites familiares con vistas al mar o al jardín.\n\nPlaya a 30 metros y actividades náuticas en las inmediaciones. Alquiler de bicicletas."
        ]
      },
      "@type": [
        "Description"
      ],
