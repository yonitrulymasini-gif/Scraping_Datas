      "dc:description": {
        "de": [
          "Wir bieten Ihnen eine traditionelle französische Küche, die mit Leidenschaft zubereitet wird - Moules frites in der Saison.\nGenießen Sie unsere Gartenterrasse!\nReservierung erwünscht."
        ],
        "en": [
          "We offer traditional French cuisine prepared with passion - Moules frites in season.\nEnjoy our garden terrace!\nReservations required."
        ],
        "it": [
          "Offriamo una cucina tradizionale francese preparata con passione - Moules frites in stagione.\nGodetevi la nostra terrazza con giardino!\nPrenotazione obbligatoria."
        ],
        "fr": [
          "Nous vous proposons une cuisine traditionnelle française préparée avec passion- Moules frites en saison.\nProfitez de notre terrasse sur jardin!\nRéservation souhaitée."
        ],
        "nl": [
          "Wij bieden traditionele Franse gerechten bereid met passie - Moules frites in het seizoen.\nGeniet van ons tuinterras!\nReserveren verplicht."
        ],
        "es": [
          "Ofrecemos cocina tradicional francesa preparada con pasión - Moules frites en temporada.\nDisfrute de nuestra terraza ajardinada\nReserva obligatoria."
        ]
      },
