  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/27f69187-6659-3460-9019-c7d615c9f4eb",
      "dc:description": {
        "de": [
          "Michel, der Eigentümer, empfängt Sie in seinem Ferienhaus, das sich im südlichen Morbihan in Saint Congard befindet, ganz in der Nähe von Malestroit und nur 25 Minuten von Vannes entfernt."
        ],
        "en": [
          "Michel, the owner, welcomes you to his gîte in Saint Congard, South Morbihan, close to Malestroit and just 25 minutes from Vannes."
        ],
        "it": [
          "Michel, il proprietario, vi dà il benvenuto nel suo gîte a Saint Congard, nel Morbihan meridionale, vicino a Malestroit e a soli 25 minuti da Vannes."
        ],
        "fr": [
          "Michel, le propriétaire vous accueille dans son gîte, situé en Morbihan Sud à Saint Congard, tout proche de Malestroit et à seulement 25 mn de Vannes."
        ],
        "es": [
          "Michel, el propietario, le da la bienvenida a su casa rural en Saint Congard, en el sur de Morbihan, cerca de Malestroit y a sólo 25 minutos de Vannes."
        ],
        "nl": [
          "Michel, de eigenaar, heet je welkom in zijn gîte in Saint Congard in het zuiden van Morbihan, vlakbij Malestroit en op slechts 25 minuten van Vannes."
        ]
      },
