  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e86ff285-726e-392f-9c18-03b2ed4892e7",
      "dc:description": {
        "de": [
          "Gönnen Sie Ihren Kindern während der Schulferien oder an einem Wochenende einen Aufenthalt, bei dem sie die ländliche Welt entdecken können.  Maximale Aufnahme von 2 Kindern zwischen 6 und 15 Jahren."
        ],
        "en": [
          "During the school vacations or over a weekend, give your children the chance to discover the rural world.  Maximum 2 children, aged 6 to 15."
        ],
        "it": [
          "Durante le vacanze scolastiche o un fine settimana, date ai vostri figli la possibilità di scoprire il mondo rurale.  Massimo 2 bambini, dai 6 ai 15 anni."
        ],
        "fr": [
          "Pendant les vacances scolaires ou sur un week-end, offrez à vos enfants un séjour à la découverte du monde rural.  Accueil maximum de 2 enfants, de 6 à 15 ans."
        ],
        "nl": [
          "Geef je kinderen tijdens de schoolvakanties of een weekend de kans om de landelijke wereld te ontdekken.  Maximaal 2 kinderen van 6 tot 15 jaar."
        ],
        "es": [
          "Durante las vacaciones escolares o un fin de semana, dé a sus hijos la oportunidad de descubrir el mundo rural.  Máximo 2 niños de 6 a 15 años."
        ]
      },
