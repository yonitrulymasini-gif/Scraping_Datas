  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/838f48e9-9580-34bb-815e-64add53bf3cd",
      "dc:description": {
        "de": [
          "Wohnung im Obergeschoss eines Bauernhauses, das aus einem Schlafzimmer mit einem 160 cm breiten Bett, einem Badezimmer mit WC, einer voll ausgestatteten Küche, Tischen + Stühlen, einem Schlafsofa für 2 Personen und einem Flachbildfernseher besteht."
        ],
        "en": [
          "Apartment on the first floor of a farmhouse comprising 1 bedroom with 160cm bed, shower room + WC, fitted kitchen, tables + chairs, 2-seater sofa bed with flat-screen TV."
        ],
        "it": [
          "Appartamento al primo piano di una casa colonica, composto da 1 camera con letto da 160 cm, bagno con doccia + WC, cucina attrezzata, tavoli e sedie, divano letto a 2 posti con TV a schermo piatto."
        ],
        "fr": [
          "Appartement à l'étage d'une longère qui se compose d'une 1 chambre avec un lit de 160, une salle d'eau+WC, Cuisine équipée, tables +chaises, un canapé convertible 2 places avec TV à écran plat."
        ],
        "es": [
          "Piso en la primera planta de una granja, compuesto por 1 habitación con cama de 160 cm, cuarto de ducha + WC, cocina equipada, mesas y sillas, sofá cama de 2 plazas con TV de pantalla plana."
        ],
        "nl": [
          "Appartement op de eerste verdieping van een boerderij, bestaande uit 1 slaapkamer met bed van 160 cm, doucheruimte + WC, ingerichte keuken, tafels en stoelen, slaapbank voor 2 personen met flatscreentelevisie."
        ]
      },
      "@type": [
        "Description"
      ],
