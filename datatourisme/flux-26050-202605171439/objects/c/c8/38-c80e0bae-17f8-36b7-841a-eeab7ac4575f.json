      "@id": "https://data.datatourisme.fr/b6694ced-ba0c-3273-ad7a-71a7d72c1196",
      "dc:description": {
        "de": [
          "Wenn die Bretagne auf Brasilien trifft!\nMusikalisches und gemischtes Festival Bretagne - Brasilien.\nDas Prinzip ist einfach und gewagt: brasilianische Perkussion und den Atem der traditionellen bretonischen Musik in einen Dialog zu bringen.\nKonzerte und Tanz.\nMusik und Tanz."
        ],
        "en": [
          "Brittany meets Brazil!\nBrittany-Brazil musical festival.\nThe principle is simple and daring: bring together Brazilian percussion and traditional Breton music.\nConcerts and dance.\nMusic and dance."
        ],
        "it": [
          "La Bretagna incontra il Brasile!\nUn festival musicale della Bretagna e del Brasile.\nL'idea è semplice ma audace: far incontrare le percussioni brasiliane con la musica tradizionale bretone.\nConcerti e danza.\nMusica e danza."
        ],
        "fr": [
          "Quand la Bretagne rencontre le Brésil !\nFestival musical et métissé Bretagne - Brésil.\nLe principe est simple et audacieux : faire dialoguer les percussions brésiliennes et le souffle des musiques bretonnes traditionnelles.\nConcerts et danse.\nMusique et bal."
        ],
        "nl": [
          "Bretagne ontmoet Brazilië!\nEen muzikaal festival van Bretagne en Brazilië.\nHet idee is eenvoudig maar gedurfd: Braziliaanse percussie en traditionele Bretonse muziek samenbrengen.\nConcerten en dans.\nMuziek en dans."
        ],
        "es": [
          "Bretaña y Brasil\nUn festival musical de Bretaña y Brasil.\nLa idea es sencilla pero atrevida: reunir la percusión brasileña y la música tradicional bretona.\nConciertos y danza.\nMúsica y danza."
        ]
      },
