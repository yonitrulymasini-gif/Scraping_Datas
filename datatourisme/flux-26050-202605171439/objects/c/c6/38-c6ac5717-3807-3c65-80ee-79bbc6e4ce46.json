      "dc:description": {
        "de": [
          "Globuli-Marsch, organisiert von der Association fédérée pour le don du sang bénévole Brehan, Credin, Pleugriffet, Rohan.\n2 Strecken von 6 km und 12 km mit Verpflegung.\nZugunsten des Vereins Rayon de soleil Mur de Bretagne."
        ],
        "en": [
          "Marche des globules organized by the association fédérée pour le don du sang bénévole Brehan, Credin, Pleugriffet, Rohan.\n2 routes of 6 km and 12 km with refreshments.\nTo benefit the association Rayon de soleil Mur de Bretagne."
        ],
        "it": [
          "Camminata del sangue organizzata dall'associazione di donazione volontaria di sangue di Brehan, Credin, Pleugriffet e Rohan.\n2 percorsi di 6 km e 12 km con ristoro.\nA favore dell'associazione Rayon de soleil Mur de Bretagne."
        ],
        "fr": [
          "Marche des globules organisée par l'association fédérée pour le don du sang bénévole Brehan, Credin, Pleugriffet, Rohan.\n2 parcours de 6 km et 12 km avec ravitaillement.\nAu profit de l'association Rayon de soleil Mur de Bretagne."
        ],
        "es": [
          "Marcha de la sangre organizada por la asociación de donantes voluntarios de sangre de Brehan, Credin, Pleugriffet y Rohan.\n2 recorridos de 6 km y 12 km con avituallamiento.\nA beneficio de la asociación Rayon de soleil Mur de Bretagne."
        ],
        "nl": [
          "Bloedtocht georganiseerd door de vrijwillige bloeddonatievereniging Brehan, Credin, Pleugriffet en Rohan.\n2 routes van 6 km en 12 km met versnaperingen.\nTen voordele van de vereniging Rayon de soleil Mur de Bretagne."
        ]
      },
