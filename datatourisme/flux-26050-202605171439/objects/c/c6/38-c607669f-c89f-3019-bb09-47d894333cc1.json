  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/18a5071d-5c8d-3b12-9ff7-f1b98b4edf3a",
      "dc:description": {
        "de": [
          "Leinen los mit LE BLAN MARINE, die seit 40 Jahren im Herzen des Golfs von Morbihan ansässig ist!\n\nGleiten Sie im Kajak oder Paddelboot über das Wasser - zu zweit, mit Freunden, mit der Familie oder in Gruppen (bis zu 40 Personen), mit Fahrten ab 1 Stunde bis zu mehreren Stunden."
        ],
        "en": [
          "Cast off with LE BLAN MARINE, established in the heart of the Gulf of Morbihan for 40 years!\n\nCome and glide along the water in a kayak or paddle, as a couple, with friends or family, or in a group (up to 40 people), with trips from 1 hour up to several hours' rental."
        ],
        "it": [
          "Salpate con LE BLAN MARINE, da 40 anni nel cuore del Golfo di Morbihan!\n\nVenite a scivolare sull'acqua in kayak o a pagaiare in coppia, con gli amici, in famiglia o anche in gruppo (fino a 40 persone) con gite che vanno da 1 ora fino a diverse ore di noleggio."
        ],
        "fr": [
          "Larguez les amarres avec LE BLAN MARINE, installé au coeur du Golfe du Morbihan depuis 40 ans !\n\nVenez glisser au fil de l'eau en kayak ou en paddle en couple, entre amis, en famille ou encore en groupe (jusqu'à 40 personnes) avec des balades à partir de 1H jusqu'à plusieurs heures de location."
        ],
        "nl": [
          "Vertrek met LE BLAN MARINE, al 40 jaar gevestigd in het hart van de Golf van Morbihan!\n\nKom over het water glijden in een kajak of peddel met z'n tweeën, met vrienden, familie of zelfs met een groep (tot 40 personen) met tochten van 1 uur tot meerdere uren."
        ],
        "es": [
          "Suelte amarras con LE BLAN MARINE, con 40 años de experiencia en el corazón del Golfo de Morbihan\n\nVenga a deslizarse por las aguas en kayak o a remar en pareja, con amigos, en familia o incluso en grupo (hasta 40 personas) con salidas desde 1 hora hasta varias horas de alquiler."
        ]
      },
