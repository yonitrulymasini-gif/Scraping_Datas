  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/550bdabd-0364-3423-9572-1752a5855f8f",
      "dc:description": {
        "de": [
          "Im Stadtzentrum von Malestroit, nur wenige Schritte vom Kanal von Nantes nach Brest entfernt, finden Sie ein einfaches und komfortables Hotel. Sie haben zu Fuß Zugang zum mittelalterlichen Zentrum, zu Restaurants, Geschäften usw."
        ],
        "en": [
          "In the center of Malestroit, a few steps from the Nantes-Brest canal, you'll find a simple, comfortable hotel. You'll be within walking distance of the medieval center, restaurants, shops and more."
        ],
        "it": [
          "Nel centro di Malestroit, a pochi passi dal canale di Nantes-Brest, troverete un hotel semplice e confortevole. Sarete a pochi passi dal centro medievale, dai ristoranti, dai negozi, ecc."
        ],
        "fr": [
          "Dans le centre-ville de Malestroit, à quelques pas du canal de Nantes à Brest, vous trouverez un hôtel simple et confortable. Vous aurez accès à pied au centre médiéval, aux restaurants, commerces, etc."
        ],
        "nl": [
          "In het centrum van Malestroit, op een steenworp afstand van het kanaal Nantes-Brest, ligt een eenvoudig, comfortabel hotel. Je bevindt je op loopafstand van het middeleeuwse centrum, restaurants, winkels, etc."
        ],
        "es": [
          "En el centro de Malestroit, a pocos pasos del canal Nantes-Brest, encontrará un hotel sencillo y confortable. Estará a poca distancia del centro medieval, restaurantes, tiendas, etc."
        ]
      },
      "@type": [
        "Description"
