  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/acba4cd0-248e-3014-92a0-c1248f8e9762",
      "dc:description": {
        "de": [
          "In einer ruhigen Umgebung gelegen, in der Nähe eines Teichs, von Wanderwegen und eines Golfplatzes. In der Nähe des Stadtzentrums und der se commerces."
        ],
        "en": [
          "Situated in a peaceful setting, close to a pond, hiking trails and a golf course. Close to town center and shops."
        ],
        "it": [
          "Situato in un ambiente tranquillo, vicino a uno stagno, a sentieri escursionistici e a un campo da golf. Vicino al centro del paese e ai negozi."
        ],
        "fr": [
          "Située dans un environnement calme, à proximité d'un étang, de sentiers de randonnées et d'un terrain de golf. Proche du centre bourg et des se commerces."
        ],
        "es": [
          "Situado en un entorno tranquilo, cerca de un estanque, rutas de senderismo y un campo de golf. Cerca del centro del pueblo y de las tiendas."
        ],
        "nl": [
          "Rustig gelegen, vlakbij een vijver, wandelpaden en een golfbaan. Dicht bij het dorpscentrum en winkels."
        ]
      },
