  "COVID19SpecialMeasures": {
    "de": [
      "Verstärkte Reinigung und Belüftung der Unterkünfte.\nAnzeige des Prozesses des Händewaschens.\nAnbringung von Schildern zur Gewährleistung der Distanzierung und einer Einbahnstraße in den Sanitäranlagen.\nGlas an der Rezeption, Gel zur Verfügung\nSeife zur Verfügung am Pool und in den Sanitäranlagen"
    ],
    "en": [
      "Renforcement du nettoyage et de la ventilation des hébergements.\nAffichage du processus de lavage des mains. \nMise en place de signalisation pour assurer la distanciation et un sens unique dans les sanitaires.\nVitre à l'accueil, gel à disposition\nSavon à disposition à la piscine et aux sanitaires"
    ],
    "it": [
      "Miglioramento della pulizia e della ventilazione degli alloggi.\nEsposizione delle procedure di lavaggio delle mani.\nSegnaletica per garantire la distanza e il senso unico di circolazione nei bagni.\nVetro alla reception, gel a disposizione\nSapone disponibile in piscina e nei servizi igienici"
    ],
    "fr": [
      "Renforcement du nettoyage et de la ventilation des hébergements.\nAffichage du processus de lavage des mains. \nMise en place de signalisation pour assurer la distanciation et un sens unique dans les sanitaires.\nVitre à l'accueil, gel à disposition\nSavon à disposition à la piscine et aux sanitaires"
    ],
    "nl": [
      "Verbeterde schoonmaak en ventilatie van accommodatie.\nWeergave van procedures voor handen wassen.\nBewegwijzering om afstand en eenrichtingsverkeer in sanitaire ruimtes te garanderen.\nGlas bij de receptie, gel beschikbaar\nZeep beschikbaar in het zwembad en de toiletten"
    ],
    "es": [
      "Mejora de la limpieza y ventilación de los alojamientos.\nExposición de los procedimientos de lavado de manos.\nSeñalización para garantizar la distancia y el sentido único de circulación en los lavabos.\nVidrio en la recepción, gel disponible\nJabón disponible en la piscina y los aseos"
    ]
  },
