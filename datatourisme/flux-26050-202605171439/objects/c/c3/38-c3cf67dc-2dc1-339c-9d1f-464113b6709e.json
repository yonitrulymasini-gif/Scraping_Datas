  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/794bc163-2428-3e41-8878-160fab472411",
      "dc:description": {
        "de": [
          "Bistro- und Meeresfrüchte-Restaurant, Café und Bar.\nWir bieten Ihnen eine Schiefertafel-Küche, die je nach Anlieferung wechselt.\nDie Atmosphäre ist entspannt.\nBei schönem Wetter können Sie von der außergewöhnlichen Terrasse gegenüber dem Strand profitieren."
        ],
        "en": [
          "Bistro and seafood restaurant, café and bar.\nWe offer à la carte cuisine that changes according to what's on the menu.\nRelaxed atmosphere.\nIn fine weather, you can enjoy an exceptional terrace facing the beach."
        ],
        "it": [
          "Ristorante bistrot e di pesce, caffè e bar.\nIl menu si basa su una serie di piatti che cambiano in base alla disponibilità.\nAtmosfera rilassata.\nNella bella stagione, si può godere di un'eccezionale terrazza affacciata sulla spiaggia."
        ],
        "fr": [
          "Restaurant bistrot et fruits de mer, café et bar.\nOn vous propose une cuisine à l'ardoise qui change au gré des arrivages.\nAmbiance décontractée. \nPar beau temps vous pourrez profiter d'une terrasse d'exception face à la plage."
        ],
        "es": [
          "Restaurante bistró y marisquería, cafetería y bar.\nEl menú se basa en una pizarra de platos que cambia según la disponibilidad.\nAmbiente relajado.\nCuando hace buen tiempo, se puede disfrutar de una excepcional terraza frente a la playa."
        ],
        "nl": [
          "Bistro en visrestaurant, café en bar.\nHet menu is gebaseerd op een lei van gerechten die verandert afhankelijk van wat er beschikbaar is.\nOntspannen sfeer.\nBij mooi weer kun je genieten van een uitzonderlijk terras met uitzicht op het strand."
        ]
      },
      "@type": [
        "Description"
      ],
