  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3fd93663-5499-392f-8ae8-7840c04725bf",
      "dc:description": {
        "de": [
          "Tapas-Bar im Stadtzentrum.\nWir bieten Ihnen eine Gourmetküche mit Oktopus, Tacos, Garnelen, Patatas Bravas usw., die Sie mit einer Auswahl an Weinen, Bieren und Cocktails, die Sie auf der Terrasse oder im Innenbereich genießen können, auf Reisen schicken wird."
        ],
        "en": [
          "Tapas bar in the city center.\nWe offer gourmet cuisine with octopus, tacos, shrimp, patatas bravas, etc., and a selection of wines, beers and cocktails to enjoy on the terrace or indoors."
        ],
        "it": [
          "Tapas bar nel centro della città.\nOffriamo una cucina gourmet con polpo, tacos, gamberi, patatas bravas, ecc. e una selezione di vini, birre e cocktail da gustare sulla terrazza o all'interno."
        ],
        "fr": [
          "Bar à tapas dans le centre ville.\nOn vous propose une cuisine gourmande avec poulpe, tacos, crevette, patatas bravas, etc..., qui vous fera voyager avec une sélection de vins, bières, cocktails à déguster en terrasse ou en intérieur."
        ],
        "nl": [
          "Tapasbar in het stadscentrum.\nWe bieden gastronomische gerechten met octopus, taco's, garnalen, patatas bravas, enz., en een selectie wijnen, bieren en cocktails om van te genieten op het terras of binnen."
        ],
        "es": [
          "Bar de tapas en el centro de la ciudad.\nOfrecemos cocina gourmet con pulpo, tacos, gambas, patatas bravas, etc., y una selección de vinos, cervezas y cócteles para disfrutar en la terraza o en el interior."
        ]
      },
