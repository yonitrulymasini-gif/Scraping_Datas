  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/da9bf26c-547a-3371-892f-8eb07425f046",
      "dc:description": {
        "de": [
          "Bewachter Sandstrand mit Rettungsstation, der wegen seiner Morgensonne und der Nähe zur Segelschule ASNQ beliebt ist.\r\n\r\nService von Seepferdchensesseln. Parkplatz. Duschen und WCs in der Nähe."
        ],
        "en": [
          "Supervised sandy beach with lifeguard station, popular for its morning sunshine and proximity to the ASNQ sailing school.\r\n\r\nSeahorse service. Parking lot. Showers and WCs nearby."
        ],
        "it": [
          "Una spiaggia sabbiosa con sorveglianza da parte di un bagnino e un posto di primo soccorso, apprezzata per il sole mattutino e la vicinanza alla scuola di vela ASNQ.\r\n\r\nServizio di cavalluccio marino. Parcheggio. Docce e WC nelle vicinanze."
        ],
        "fr": [
          "Plage de sable fin surveillée avec poste de secours, appréciée pour son soleil matinal et la proximité de l'école de voile ASNQ. \r\n\r\nService de fauteuils hippocampes. Parking. Douches et WC à proximité."
        ],
        "es": [
          "Playa de arena con vigilancia de socorristas y puesto de primeros auxilios, popular por su sol matinal y su proximidad a la escuela de vela ASNQ.\r\n\r\nServicio de caballitos de mar. Aparcamiento. Duchas y WC cercanos."
        ],
        "nl": [
          "Een zandstrand met strandwacht en eerstehulppost, populair vanwege de ochtendzon en de nabijheid van de zeilschool ASNQ.\r\n\r\nSeahorse service. Parkeerplaats. Douches en toiletten in de buurt."
        ]
      },
