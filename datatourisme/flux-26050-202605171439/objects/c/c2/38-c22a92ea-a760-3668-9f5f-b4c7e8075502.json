  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/de7ba87b-368b-30a6-94fb-0087f9fe2091",
      "dc:description": {
        "de": [
          "Die Gîte le Val des fées entstand durch die Sanierung eines alten, für die Region Brocéliande typischen Bauernhauses aus rotem Schiefer. Diese charakteristische Unterkunft liegt am Rande des Waldes von Brocéliande und ist der ideale Urlaubsort für Familien, Wanderer oder Reiter mit ihren Pferden."
        ],
        "en": [
          "Gîte le Val des fées is the result of the restoration of an old, typical Brocéliande farmhouse built of red schist. Situated on the edge of the Brocéliande forest, this character-filled gîte is the ideal vacation destination for families, hikers or riders with their mounts."
        ],
        "it": [
          "Il Gîte le Val des fées è il risultato del restauro di un'antica casa colonica in scisto rosso tipica della regione di Brocéliande. Questo gîte pieno di carattere, ai margini della foresta di Brocéliande, è la destinazione di vacanza ideale per famiglie, escursionisti o cavalieri con le loro cavalcature."
        ],
        "fr": [
          "Le Gîte le Val des fées est né de la réhabilitation d'une ancienne ferme typique de la région de Brocéliande en schiste rouge. Ce gîte de caractère, situé à l'orée de la forêt de Brocéliande, est le lieu de vacances idéal pour les familles, les randonneurs ou les cavaliers avec leurs montures."
        ],
        "nl": [
          "Gîte le Val des fées is het resultaat van de restauratie van een oude boerderij in rode leisteen, typisch voor de streek Brocéliande. Deze karaktervolle gîte, aan de rand van het bos van Brocéliande, is de ideale vakantiebestemming voor gezinnen, wandelaars of ruiters met hun paard."
        ],
        "es": [
          "Gîte le Val des fées es el resultado de la restauración de una antigua granja de esquisto rojo típica de la región de Brocéliande. Esta casa rural llena de carácter, al borde del bosque de Brocéliande, es el destino de vacaciones ideal para familias, senderistas o jinetes con sus monturas."
        ]
      },
