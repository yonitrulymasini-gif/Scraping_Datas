  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/45964ef3-45f7-3727-b27b-af8f9b8554d9",
      "dc:description": {
        "de": [
          "Panoramablick auf den Ozean. Unsere Küchenchefin bietet Ihnen eine raffinierte Küche mit Meeresaromen und regionalen Akzenten. Musikalische Unterhaltung am Freitagabend.\n7 Tage die Woche mittags und abends geöffnet."
        ],
        "en": [
          "Panoramic ocean view. Our chef offers refined cuisine with sea flavors and local accents. Musical entertainment on Friday evenings.\nOpen 7/7 for lunch and dinner."
        ],
        "it": [
          "Vista panoramica sull'oceano. Il nostro chef vi offre una cucina raffinata con sapori di mare e accenti locali. Intrattenimento musicale il venerdì sera.\nAperto 7/7 per pranzo e cena."
        ],
        "fr": [
          "Vue panoramique sur l'océan. Notre cheffe vous propose une cuisine raffinée aux saveurs de la mer et accents du terroir. Animations musicales les vendredis soir.\nOuvert 7/7 midi et soir."
        ],
        "es": [
          "Vistas panorámicas al océano. Nuestro chef le ofrece una cocina refinada con sabores marinos y acentos locales. Animación musical los viernes por la noche.\nAbierto 7/7 para almuerzos y cenas."
        ],
        "nl": [
          "Panoramisch uitzicht op de oceaan. Onze chef biedt u een verfijnde keuken met zeesmaken en lokale accenten. Muzikaal entertainment op vrijdagavond.\n7/7 geopend voor lunch en diner."
        ]
      },
      "@type": [
        "Description"
