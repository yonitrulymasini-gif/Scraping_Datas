  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/093326e8-df43-32fe-b639-8a7eb0d3af6d",
      "dc:description": {
        "de": [
          "Entdecken Sie das Know-how dieses Handwerkers, der geräucherten Lachs, Trockenfisch und andere Meeresprodukte herstellt. Im Juli und August Animationen und Verkostungen am Dienstagmorgen. Kostenlos, auf Reservierung."
        ],
        "en": [
          "Discover the expertise of this artisan producer of smoked salmon, dried fish and other seafood products. In July and August, events and tastings on Tuesday mornings. Free, on reservation."
        ],
        "it": [
          "Scoprite l'esperienza di questo produttore artigianale di salmone affumicato, pesce essiccato e altri prodotti ittici. In luglio e agosto, eventi e degustazioni il martedì mattina. Gratuito, su prenotazione."
        ],
        "fr": [
          "Découvrez le savoir-faire de cet artisan producteur de saumon fumé, poissons séchés et autres produits de la mer. En juillet et août, animations et dégustations le mardi matin. Gratuit, sur réservation."
        ],
        "nl": [
          "Ontdek de expertise van deze ambachtelijke producent van gerookte zalm, gedroogde vis en andere visproducten. In juli en augustus, evenementen en proeverijen op dinsdagochtend. Gratis, reserveren verplicht."
        ],
        "es": [
          "Descubra el saber hacer de este productor artesanal de salmón ahumado, pescado seco y otros productos del mar. En julio y agosto, eventos y degustaciones los martes por la mañana. Gratuito, previa reserva."
        ]
      },
