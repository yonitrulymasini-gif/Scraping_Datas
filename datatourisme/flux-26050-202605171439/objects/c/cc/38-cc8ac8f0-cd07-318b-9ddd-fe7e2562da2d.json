  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/45421390-f0ce-3e4a-949d-1ec66fa1246f",
      "dc:description": {
        "de": [
          "Restaurant mit modernem Rahmen, Terrasse, Kamin, offene Küche, Business-Menü oder Menükarte, saisonale Produkte, je nach Markt und Lust und Laune, Weine von Winzern im sichtbaren Keller im Restaurant. Kommen Sie und genießen Sie wahre Momente der Gaumenfreuden!\n1 Stern im Guide Michelin seit 2019"
        ],
        "en": [
          "Contemporary restaurant, terrace, fireplace, kitchen opening onto the dining room, business menu or à la carte menu, seasonal produce to suit the market and your tastes, winegrowers' wines in the cellar in the restaurant room. Come and share real gourmet moments!\n1 Michelin star since 2019"
        ],
        "it": [
          "Ristorante dall'ambiente contemporaneo, terrazza, camino, cucina a vista, menu business o menu à la carte, prodotti di stagione, a seconda di ciò che c'è sul mercato e di ciò che si desidera, vini dei viticoltori nella cantina della sala ristorante. Venite a condividere momenti da veri gourmet!\n1 stella nella Guida Michelin dal 2019"
        ],
        "fr": [
          "Restaurant au cadre contemporain, terrasse, cheminée, cuisine ouverte sur la salle, menu affaire ou menu carte , produits de saison, au gré du marché et des envies, vins de vignerons en cave apparente située dans la salle du restaurant. Venez partager de vrais moments de gourmandises!\n1 étoile au Guide Michelin depuis 2019"
        ],
        "es": [
          "Restaurante de ambiente contemporáneo, terraza, chimenea, cocina americana, menú de negocios o a la carta, productos de temporada, según el mercado y sus deseos, vinos de viticultores en la bodega de la sala del restaurante. ¡Ven a compartir verdaderos momentos gourmet!\n1 estrella en la Guía Michelin desde 2019"
        ],
        "nl": [
          "Restaurant met een eigentijds decor, terras, open haard, open keuken, businessmenu of à la carte menu, seizoensproducten, afhankelijk van wat er op de markt is en waar je zin in hebt, wijnen van wijnboeren in de kelder in de restaurantzaal. Kom en deel enkele echte gastronomische momenten!\n1 ster in de Michelingids sinds 2019"
        ]
      },
      "@type": [
        "Description"
      ],
