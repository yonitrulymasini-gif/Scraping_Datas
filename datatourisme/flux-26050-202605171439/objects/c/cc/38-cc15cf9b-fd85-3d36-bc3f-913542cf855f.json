  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/205a47a1-dd9c-349c-bb2b-295363f980b6",
      "dc:description": {
        "de": [
          "La Galette Rieuse bietet Ihnen à la carte Galettes mit Buchweizenmehl aus der örtlichen Mühle in Ploërmel, Weizenpfannkuchen, Gegrilltes (Entrecôte-Nuss, Kalbsschnitzel, Andouillettes AAAAA, Kebab-Teller) und gemischte Salate. Lokale Produkte und hausgemachte Zubereitungen."
        ],
        "en": [
          "La Galette Rieuse offers à la carte galettes made with buckwheat flour from the local Ploërmel mill, wheat pancakes, grilled meats (entrecote, veal escalopes, andouillettes AAAAA, kebab platter) and mixed salads. Local products and homemade preparations."
        ],
        "it": [
          "La Galette Rieuse propone un menu à la carte con galette preparate con farina di grano saraceno del mulino locale di Ploërmel, frittelle di grano, carni alla griglia (entrecote steak, scaloppine di vitello, andouillettes AAAAA, piatto di kebab) e insalate miste. Prodotti locali e preparazioni fatte in casa."
        ],
        "fr": [
          "La Galette Rieuse vous propose, à la carte, des galettes à la farine de blé noir issu du moulin local de Ploërmel, crêpes de froment, grillades (noix d'entrecôte, escalopes de veau, andouillettes AAAAA, assiette kebab) et salades composées. Produits locaux et préparations maison."
        ],
        "es": [
          "La Galette Rieuse ofrece un menú a la carta de galettes elaboradas con harina de trigo sarraceno del molino local de Ploërmel, tortitas de trigo, carnes a la parrilla (entrecot, escalopes de ternera, andouillettes AAAAA, tabla de brochetas) y ensaladas mixtas. Productos locales y preparaciones caseras."
        ],
        "nl": [
          "La Galette Rieuse biedt een à la carte menu van galettes gemaakt met boekweitmeel van de plaatselijke molen in Ploërmel, tarwepannenkoeken, gegrild vlees (entrecote steak, kalfsentrecote, andouillettes AAAAA, kebabschotel) en gemengde salades. Lokale producten en huisbereidingen."
        ]
      },
