  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/dd7c9219-0df5-3214-a07f-139a5ceb8bba",
      "dc:description": {
        "de": [
          "Von Oktober bis Mai verwandelt sich die Hütte in eine außergewöhnliche Suite für zwei Personen, ein Zufluchtsort, um dem Alltag zu entfliehen und eine magische Erfahrung im Herzen der Natur zu machen."
        ],
        "en": [
          "From October to May, the Cabane is transformed into an exceptional suite for two, a refuge from everyday life for a magical experience in the heart of nature."
        ],
        "it": [
          "Da ottobre a maggio, la Cabane si trasforma in un'eccezionale suite per due persone, un rifugio dalla quotidianità e un'esperienza magica nel cuore della natura."
        ],
        "fr": [
          "D'octobre à mai, la Cabane se transforme en suite d'exception pour deux personnes, un refuge pour s'échapper du quotidien et vivre une expérience magique au coeur de la nature."
        ],
        "nl": [
          "Van oktober tot mei wordt de Cabane omgetoverd tot een uitzonderlijke suite voor twee, een toevluchtsoord uit het alledaagse en een magische ervaring in het hart van de natuur."
        ],
        "es": [
          "De octubre a mayo, la Cabane se transforma en una suite excepcional para dos personas, un refugio de lo cotidiano y una experiencia mágica en plena naturaleza."
        ]
      },
