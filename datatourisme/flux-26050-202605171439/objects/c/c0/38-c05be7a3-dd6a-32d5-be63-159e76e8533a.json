      "@id": "https://data.datatourisme.fr/e17e206c-7771-322a-89f2-b188573e3589",
      "dc:description": {
        "de": [
          "Die Moulin du Vaulaurent liegt 10 Minuten vom Nantes-Brest-Kanal entfernt zwischen La Gacilly, Rochefort en Terre und Malestroit und bietet Ihnen einen Urlaub, der Natur und Komfort miteinander verbindet."
        ],
        "en": [
          "Located 10 minutes from the Nantes-Brest canal, between La Gacilly, Rochefort en Terre and Malestroit, Le Moulin du Vaulaurent offers a vacation combining nature and comfort."
        ],
        "it": [
          "Situato a 10 minuti dal canale Nantes-Brest, tra La Gacilly, Rochefort en Terre e Malestroit, il Moulin du Vaulaurent offre una vacanza che unisce natura e comfort."
        ],
        "fr": [
          "Situé à 10 minutes du canal de Nantes à Brest, entre La Gacilly, Rochefort en Terre et Malestroit, le Moulin du Vaulaurent vous propose des vacances alliant nature et confort."
        ],
        "es": [
          "Situado a 10 minutos del canal Nantes-Brest, entre La Gacilly, Rochefort en Terre y Malestroit, el Moulin du Vaulaurent ofrece unas vacaciones que combinan naturaleza y confort."
        ],
        "nl": [
          "Moulin du Vaulaurent ligt op 10 minuten van het kanaal Nantes-Brest, tussen La Gacilly, Rochefort en Terre en Malestroit en biedt een vakantie die natuur en comfort combineert."
        ]
      },
