  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/dd9cae7f-af2e-3037-88b4-131858d0c22f",
      "dc:description": {
        "de": [
          "Neben sechs Ferienunterkünften ist die Gîte d'étape de Tronjoly in Gourin in einem ehemaligen Bauernhof untergebracht. Die Farbe der Steine ist spezifisch für die Gegend der Centre Bretagne."
        ],
        "en": [
          "Alongside six vacation rentals, the Tronjoly gîte d'étape in Gourin is housed in an old farmhouse. The color of the stones is specific to the Centre Bretagne region."
        ],
        "it": [
          "Oltre a sei alloggi per le vacanze, il gîte di sosta Tronjoly a Gourin è ospitato in un'antica casa colonica. Il colore delle pietre è specifico della regione del Centre Bretagne."
        ],
        "fr": [
          "À côté de six locations de vacances, le gîte d'étape de Tronjoly à Gourin est aménagé dans une ancienne ferme. La couleur des pierres est spécifique au territoire du Centre Bretagne."
        ],
        "nl": [
          "Naast zes vakantieverblijven is de gîte Tronjoly in Gourin ondergebracht in een oude boerderij. De kleur van de stenen is eigen aan de regio Centre Bretagne."
        ],
        "es": [
          "Además de seis alojamientos vacacionales, la casa rural Tronjoly de Gourin ocupa una antigua granja. El color de las piedras es específico de la región de Centre Bretagne."
        ]
      },
