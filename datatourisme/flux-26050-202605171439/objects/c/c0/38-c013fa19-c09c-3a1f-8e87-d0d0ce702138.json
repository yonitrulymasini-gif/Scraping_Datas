  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ad750332-6672-394f-b1e4-a2565a4715ad",
      "dc:description": {
        "de": [
          "Emmanuel und Anne-Cécile und ihr Team bieten Crêpes und Galettes sowie eine Brasserie mit lokalen Produkten an. Gegenüber der Anlegestelle passt sich L'Hermine Ihren Bedürfnissen an. Durchgehender Service."
        ],
        "en": [
          "Emmanuel and Anne-Cécile and their team offer crêpes and galettes, and a brasserie based on local produce. Facing the pier, l'Hermine adapts to your needs. Continuous service."
        ],
        "it": [
          "Emmanuel e Anne-Cécile e il loro team propongono crêpes e galettes e una brasserie a base di prodotti locali. Di fronte al molo, l'Hermine si adatta alle vostre esigenze. Servizio continuo."
        ],
        "fr": [
          "Emmanuel et Anne-Cécile et leur équipe proposent crêpes et galettes, brasserie à base de produits locaux. Face à l'embarcadère, l'Hermine s'adapte à vos contraintes. Service continu."
        ],
        "es": [
          "Emmanuel y Anne-Cécile y su equipo ofrecen crêpes y galettes, y una brasserie basada en productos locales. Frente al muelle, l'Hermine se adapta a sus necesidades. Servicio continuo."
        ],
        "nl": [
          "Emmanuel en Anne-Cécile en hun team bieden crêpes en galettes, en een brasserie op basis van lokale producten. Met uitzicht op de pier past l'Hermine zich aan uw behoeften aan. Continue service."
        ]
      },
