      "dc:description": {
        "de": [
          "Waschhäuser, Mühlen, Brunnen... Gehen Sie am Scorff entlang und entdecken Sie die Bedeutung des mit dem Wasser verbundenen Kulturerbes in Guémené."
        ],
        "en": [
          "Washhouses, mills, fountains... Walk along the Scorff and discover the importance of Guémené?s water heritage."
        ],
        "it": [
          "Lavatoi, mulini, fontane... Passeggiate lungo lo Scorff e scoprite l'importanza del patrimonio idrico di Guémené."
        ],
        "fr": [
          "Lavoirs, moulins, fontaine... Longez le Scorff et découvrez l’importance du patrimoine lié à l’eau de Guémené."
        ],
        "nl": [
          "Washuizen, molens, fonteinen... Wandel langs de Scorff en ontdek het belang van het watererfgoed van Guémené."
        ],
        "es": [
          "Lavaderos, molinos, fuentes... Pasee por el Scorff y descubra la importancia del patrimonio acuático de Guémené."
        ]
