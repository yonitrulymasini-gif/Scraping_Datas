  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2be4b2fb-c0dc-39a3-b6ed-cf91e873b538",
      "dc:description": {
        "de": [
          "Kleines Haus, kokett und mit gepflegter Dekoration, bietet Ihnen im Erdgeschoss einen Wohnraum mit Küche/Wohnzimmer/Wohnzimmer. Im 1. Stock: ein Schlafzimmer mit Doppelbett, Dusche/WC."
        ],
        "en": [
          "Small, charming, tastefully-decorated house. Ground floor: living room with kitchen/lounge. 1st floor: bedroom with double bed, shower/wc."
        ],
        "it": [
          "Questa piccola casa accogliente e ben arredata offre un soggiorno al piano terra con cucina/salotto. 1° piano: camera con letto matrimoniale, bagno con doccia/wc."
        ],
        "fr": [
          "Petite maison, coquette et à la décoration soignée, vous offre au rdc une pièce de vie avec cuisine/séjour/salon. Au 1er : une chambre avec lit double, sde/wc."
        ],
        "es": [
          "Esta pequeña casa, acogedora y bien decorada, dispone en la planta baja de un salón con cocina/sala de estar. 1ª planta: dormitorio con cama doble, cuarto de ducha/wc."
        ],
        "nl": [
          "Dit kleine, gezellige, goed ingerichte huis biedt een woonkamer op de begane grond met keuken/salon. 1e verdieping: slaapkamer met tweepersoonsbed, doucheruimte/wc."
        ]
      },
