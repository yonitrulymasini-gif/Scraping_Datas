  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bd365404-a14d-3827-bc15-3ab5c4c07a8e",
      "dc:description": {
        "de": [
          "Wohnung in der Nähe des Zentrums von Le Fouët. Ein Schlafzimmer mit Duschbad im Obergeschoss. Im Erdgeschoss, eine Küchenzeile und Toilette. Alle renoviert im Jahr 2022."
        ],
        "en": [
          "Apartment located near the center of Le Faouët. One bedroom with shower room upstairs. On the ground floor, a kitchenette and toilet. all renovated in 2022."
        ],
        "it": [
          "Appartamento vicino al centro di Le Faouët. Una camera da letto con doccia al piano superiore. Al piano terra, angolo cottura e servizi igienici. Tutto ristrutturato nel 2022."
        ],
        "fr": [
          "Appartement situé proche du centre du faouët. Une chambre avec une salle de douche à l'étage. Au rez de chaussée , une kitchenette et toilette. le tout rénové en 2022."
        ],
        "es": [
          "Piso cerca del centro de Le Faouët. Un dormitorio con cuarto de ducha arriba. En la planta baja, una cocina americana y aseo. todo renovado en 2022."
        ],
        "nl": [
          "Flat vlakbij het centrum van Le Faouët. Een slaapkamer met doucheruimte op de bovenverdieping. Op de begane grond een kitchenette en toilet. Alles gerenoveerd in 2022."
        ]
      },
      "@type": [
        "Description"
