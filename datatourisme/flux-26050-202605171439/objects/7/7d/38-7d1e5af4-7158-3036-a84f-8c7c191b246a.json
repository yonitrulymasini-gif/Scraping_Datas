  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6d70a5cb-b0f9-3c14-86fa-1ca038ad4bfc",
      "dc:description": {
        "de": [
          "Landhaus am Ufer des Kanals von Nantes nach Brest in einem kleinen, sehr gemütlichen Dorf. Haus mit allem Komfort. Nacht- und Wochenendvermietung außerhalb von Juli und August möglich."
        ],
        "en": [
          "Country house on the Canal de Nantes à Brest in a pleasant little village. All comforts. Night and weekend rentals available outside july and august."
        ],
        "it": [
          "Casa di campagna sulle rive del canale di Nantes-Brest, in un piccolo e piacevole villaggio. Tutti i comfort. Pernottamenti e weekend disponibili al di fuori di luglio e agosto."
        ],
        "fr": [
          "Maison de campagne au bord du Canal de Nantes à Brest dans un petit village très agréable. Maison tout confort. Location nuit et week-end possibles hors juillet et août."
        ],
        "nl": [
          "Landhuis aan de oever van het kanaal Nantes-Brest in een aangenaam dorpje. Van alle gemakken voorzien. Overnachting en weekendverhuur mogelijk buiten juli en augustus."
        ],
        "es": [
          "Casa de campo a orillas del Canal de Nantes-Brest, en un agradable pueblecito. Todas las comodidades. Pernoctaciones y fines de semana disponibles fuera de julio y agosto."
        ]
      },
      "@type": [
        "Description"
