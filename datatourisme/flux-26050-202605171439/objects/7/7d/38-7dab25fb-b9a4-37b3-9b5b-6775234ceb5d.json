  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/54ebb38b-c6f9-3a94-a494-76b6f393d4b0",
      "dc:description": {
        "de": [
          "L'Hermine gourmande ist eine handwerkliche Kaffeerösterei im Land des Königs Morvan. Wir wählen die besten Arabica-Bohnen aus, die nach Herzenslust geröstet werden, um einen außergewöhnlichen Kaffee zu kreieren. Besuchen Sie unser Geschäft in Gourin oder unsere Website, dort finden Sie eine große Auswahl an Kaffee, Tee und Schokolade."
        ],
        "en": [
          "L'Hermine gourmande an artisanal roastery in the Pays du Roi Morvan. We select the best Arabicas, which are roasted to perfection for an exceptional coffee. Come and visit our store in Gourin or our website, where you'll find a wide range of coffee, tea and chocolate."
        ],
        "it": [
          "L'Hermine gourmande è una torrefazione artigianale nel Pays du Roi Morvan. Selezioniamo i migliori Arabica che vengono tostati alla perfezione per un caffè eccezionale. Venite a visitare il nostro negozio a Gourin o il nostro sito web, dove troverete una vasta gamma di caffè, tè e cioccolato."
        ],
        "fr": [
          "L'Hermine gourmande une torréfaction artisanale au Pays du Roi Morvan. Nous sélectionnons les meilleurs arabicas qui seront torréfiés à cœur pour un café d'exception. Venez découvrir notre magasin à Gourin ou notre site internet, vous y trouverez une large gamme de café, thé, chocolat."
        ],
        "nl": [
          "L'Hermine gourmande is een ambachtelijke branderij gevestigd in het Pays du Roi Morvan. We selecteren de beste arabica's die tot in de perfectie worden gebrand voor een uitzonderlijke koffie. Kom langs in onze winkel in Gourin of op onze website, waar je een ruim assortiment koffie, thee en chocolade vindt."
        ],
        "es": [
          "L'Hermine gourmande es un tostador artesanal del Pays du Roi Morvan. Seleccionamos los mejores arábicas que se tuestan a la perfección para obtener un café excepcional. Venga a visitar nuestra tienda de Gourin o nuestra página web, donde encontrará una amplia gama de café, té y chocolate."
        ]
      },
