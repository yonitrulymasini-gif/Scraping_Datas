  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a9c71b05-1348-3c2e-a270-71be5bbb7980",
      "dc:description": {
        "de": [
          "Haus, kürzlich modernisiert, mit 2 Schlafzimmern und Terrasse, in ruhiger Lage. Privater Parkplatz. Weniger als 10 Minuten zu Fuß vom Zentrum und 5 Minuten vom städtischen Freibad entfernt."
        ],
        "en": [
          "House, recently modernized, with 2 bedrooms and terrace, in a quiet location. Private parking. Less than 10 minutes' walk from the town center and 5 minutes from the municipal outdoor pool."
        ],
        "it": [
          "Casa recentemente ammodernata con 2 camere da letto e terrazza, in posizione tranquilla. Parcheggio privato. A meno di 10 minuti a piedi dal centro e a 5 minuti dalla piscina comunale all'aperto."
        ],
        "fr": [
          "Maison, récemment modernisée, avec 2 chambres  et terrasse, au calme. Parking privé. Située à moins de 10 mn à pied du centre et à 5 mn de la piscine extérieure municipale."
        ],
        "nl": [
          "Onlangs gemoderniseerd huis met 2 slaapkamers en terras, rustig gelegen. Privé parkeerplaats. Op minder dan 10 minuten lopen van het centrum en op 5 minuten van het gemeentelijke buitenzwembad."
        ],
        "es": [
          "Casa recientemente modernizada con 2 dormitorios y terraza, en zona tranquila. Aparcamiento privado. A menos de 10 minutos a pie del centro y a 5 minutos de la piscina municipal al aire libre."
        ]
      },
