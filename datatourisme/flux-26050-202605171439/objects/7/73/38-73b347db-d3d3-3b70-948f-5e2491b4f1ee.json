  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8ef71f71-7944-31ca-b9f9-1842c4add395",
      "dc:description": {
        "de": [
          "Unsere Trapper-Ferienwohnungen liegen in den Wäldern und bieten Ihnen höchsten Komfort in einer geräumigen, warmen und gemütlichen Umgebung mit Zugang zu allen Einrichtungen (Hallenbad, Wasserrutschen, Wellnessbereich extra)."
        ],
        "en": [
          "Nestled in the woods, our trapper gites offer you the utmost comfort in spacious, warm and cosy surroundings, with access to all facilities (indoor pool, waterslides, wellness area not included)."
        ],
        "it": [
          "Immerse nel bosco, le nostre gite per trapper vi offrono il massimo comfort in un ambiente spazioso, caldo e accogliente, con accesso a tutte le strutture (piscina coperta, acquascivoli, area benessere non inclusi)."
        ],
        "fr": [
          "Nichés dans les bois nos gites trappeurs vous offrent le plus grand confort dans un environnement spacieux, chaleureux et cosy avec accès aux équipements (piscine couverte, toboggans aquatiques, espace bien-être en sus)."
        ],
        "nl": [
          "Onze trappersgîtes liggen verscholen in de bossen en bieden je alle comfort in een ruime, warme en gezellige omgeving, met toegang tot alle faciliteiten (overdekt zwembad, waterglijbanen, wellnessruimte niet inbegrepen)."
        ],
        "es": [
          "Enclavadas en el bosque, nuestras casas rurales para tramperos le ofrecen el máximo confort en un entorno espacioso, cálido y acogedor, con acceso a todas las instalaciones (piscina cubierta, toboganes acuáticos, zona de bienestar no incluidos)."
        ]
      },
      "@type": [
        "Description"
      ],
