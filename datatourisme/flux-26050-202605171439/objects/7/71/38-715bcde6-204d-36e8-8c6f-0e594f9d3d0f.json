      "dc:description": {
        "de": [
          "Freizeitanlage mit freiem Zugang :\nTennisplatz, 2,1 km Wanderweg (rund um den Wasserplan), Buckelpiste für Mountainbikes, Seilbahn und Kinderspielplatz, Minigolf (Materialverleih in der Bar du Foyer)"
        ],
        "en": [
          "Free-access leisure facilities:\nTennis court, 2.1km walking trail (around the lake), mogul track for mountain bikes, zip line and children's games, mini-golf (equipment available on loan from the Bar du Foyer)"
        ],
        "it": [
          "Centro ricreativo con accesso gratuito:\nCampo da tennis, percorso a piedi di 2,1 km (intorno al lago), pista per mountain bike, teleferica e giochi per bambini, minigolf (attrezzatura disponibile in prestito presso il Bar du Foyer)"
        ],
        "fr": [
          "Base de loisirs en accès libre : \nTerrain de tennis, 2,1km de sentier pédestre (tour du plan d'eau), piste à bosses pour les VTT, tyrolienne et jeux pour enfant, mini-golf (prêt de matériel au Bar du Foyer)"
        ],
        "nl": [
          "Vrijetijdscentrum met gratis toegang:\nTennisbaan, wandelpad van 2,1 km (rond het meer), buckelpiste voor mountainbikes, tokkelbaan en kinderspelen, minigolf (materiaal te leen bij de Bar du Foyer)"
        ],
        "es": [
          "Centro de ocio de acceso gratuito:\nPista de tenis, ruta de senderismo de 2,1 km (alrededor del lago), pista de mogul para bicicletas de montaña, tirolina y juegos infantiles, minigolf (material disponible en préstamo en el Bar du Foyer)"
        ]
      },
