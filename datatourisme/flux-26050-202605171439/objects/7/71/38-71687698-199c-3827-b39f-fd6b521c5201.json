  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/dece92b9-e57b-3eea-873e-c052f8ca5fee",
      "dc:description": {
        "de": [
          "Westlich des Grande Plage ist der Strand von Ty bihan ein Ort der Entspannung für alle Altersgruppen mit einem atemberaubenden Blick auf die Bucht von Quiberon. Jeden Sommer lässt sich hier der Club des Dauphins nieder und bietet den Kindern zahlreiche Aktivitäten an."
        ],
        "en": [
          "To the west of the Grande Plage, Ty bihan beach is the place to relax for all ages with a breathtaking view over the bay of Quiberon. Every summer, the Dolphin Club settles there and offers many activities for children."
        ],
        "it": [
          "A ovest della Grande Plage, la spiaggia di Ty Bihan è il luogo di relax per tutte le età con una vista mozzafiato sulla baia di Quiberon. Ogni estate, il club Dauphins vi si installa e propone numerose attività per i bambini."
        ],
        "fr": [
          "A l'ouest de la Grande Plage, la plage de Ty bihan est le lieu de détente pour tous les âges avec une vue imprenable sur la baie de Quiberon. Chaque été, le club des Dauphins s'y installe et propose aux enfants de nombreuses activités."
        ],
        "nl": [
          "Ten westen van het Grande Plage is het strand van Ty Bihan de plek om te ontspannen voor alle leeftijden met een adembenemend uitzicht over de baai van Quiberon. Elke zomer vestigt de club Dauphins zich daar en biedt talrijke activiteiten voor kinderen."
        ],
        "es": [
          "Al oeste de la Grande Plage, la playa de Ty Bihan es el lugar de descanso para todas las edades con una vista impresionante sobre la bahía de Quiberon. Cada verano, el club Dauphins se instala allí y ofrece numerosas actividades para los niños."
        ]
      },
