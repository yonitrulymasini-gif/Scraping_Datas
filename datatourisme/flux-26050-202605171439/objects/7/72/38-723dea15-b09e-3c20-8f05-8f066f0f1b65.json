      "@id": "https://data.datatourisme.fr/475829ae-d3d1-35e5-8541-851638ebff59",
      "dc:description": {
        "de": [
          "Obst, Gemüse, Käse, Feinkost, Geschenkkörbe und Aperitifbretter.\nGeöffnet Dienstag bis Samstag von 8:30 bis 13:00 Uhr und von 15:00 bis 19:30 Uhr; Sonntag von 9:30 bis 12:30 Uhr."
        ],
        "en": [
          "Fruits, vegetables, cheeses, delicatessen, gift baskets and aperitif boards.\nOpen Tuesday to Saturday, 8.30am to 1pm and 3pm to 7.30pm; Sunday, 9.30am to 12.30pm."
        ],
        "it": [
          "Frutta, verdura, formaggi, gastronomia, cesti regalo e aperitivi.\nAperto da martedì a sabato, dalle 8.30 alle 13.00 e dalle 15.00 alle 19.30; domenica, dalle 9.30 alle 12.30."
        ],
        "fr": [
          "Fruits, légumes, fromages, épicerie fine, corbeilles cadeaux et planches apéritives.\nOuvert du mardi au samedi de 8h30 à 13h et de 15h à 19h30 ; le dimanche de 9h30 à 12h30."
        ],
        "es": [
          "Frutas, verduras, quesos, delicatessen, cestas de regalo y platos de aperitivo.\nAbierto de martes a sábado, de 8.30 a 13.00 y de 15.00 a 19.30; domingos, de 9.30 a 12.30."
        ],
        "nl": [
          "Fruit, groenten, kaas, delicatessen, geschenkmanden en aperitiefschotels.\nGeopend van dinsdag tot zaterdag van 8.30 tot 13.00 en van 15.00 tot 19.30; zondag van 9.30 tot 12.30."
        ]
      },
