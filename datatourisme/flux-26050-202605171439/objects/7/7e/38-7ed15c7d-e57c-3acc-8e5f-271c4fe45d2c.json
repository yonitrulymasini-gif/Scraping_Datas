  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f7ef664d-0d58-3e04-93cb-6522988145d7",
      "dc:description": {
        "de": [
          "Joëlle und Antoine heißen Sie in ihrem Haus im Herzen des Morbihan herzlich willkommen. Sie werden Ihr geräumiges Zimmer zu schätzen wissen. Der große Garten mit seinen Ouessant-Schafen und dem Border Collie ist perfekt zum Entspannen."
        ],
        "en": [
          "Joëlle and Antoine welcome you to their home in the heart of Morbihan. You'll love your spacious bedroom. The large garden, with its Ouessant sheep and Border Collie, is perfect for relaxing."
        ],
        "it": [
          "Joëlle e Antoine vi danno il benvenuto nella loro casa nel cuore del Morbihan. Apprezzerete la vostra spaziosa camera da letto. L'ampio giardino, con le pecore Ouessant e il Border Collie, è perfetto per rilassarsi."
        ],
        "fr": [
          "Joëlle et Antoine vous souhaite la bienvenue dans leur maison située au coeur du Morbihan. Vous allez apprécier votre chambre spacieuse. Le grand jardin, avec ses moutons d'Ouessant et son Border Collie, est parfait pour se détendre."
        ],
        "es": [
          "Joëlle y Antoine le dan la bienvenida a su casa en el corazón de Morbihan. Usted apreciará su amplio dormitorio. El gran jardín, con sus ovejas Ouessant y Border Collie, es perfecto para relajarse."
        ],
        "nl": [
          "Joëlle en Antoine heten je welkom in hun huis in het hart van Morbihan. Uw ruime slaapkamer zal u zeker bevallen. De grote tuin, met zijn Ouessant schapen en Border Collie, is perfect om te ontspannen."
        ]
      },
