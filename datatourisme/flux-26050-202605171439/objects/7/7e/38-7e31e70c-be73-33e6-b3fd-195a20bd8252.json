  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3286b3aa-c126-3077-898a-fb891874f643",
      "dc:description": {
        "de": [
          "Spi Location bietet Einrumpfboote von 26 bis 50' und Katamarane von 30 bis 55' zum Verleih an. Es besteht auch die Möglichkeit, ein Boot mit Skipper zu mieten, sowie Kreuzfahrt- und Regattatraining, Incentives und Wasserrallyes."
        ],
        "en": [
          "Spi Location offers monohulls from 26 to 50' and catamarans from 30 to 55' for rent. Possibility of renting a boat with skipper. Also, cruising and regatta training, Incentive, and nautical rallies."
        ],
        "it": [
          "Spi Location offre a noleggio monoscafi da 26 a 50' e catamarani da 30 a 55'. Offriamo anche formazione per crociere e regate, incentivi e raduni nautici."
        ],
        "fr": [
          "Spi Location propose à la location des monocoques de 26 à 50' et des catamarans de 30 à 55'. Possibilité de louer un bateau avec skipper.Egalement, formation croisière et régate, Incentive, et rallyes nautiques."
        ],
        "nl": [
          "Spi Location verhuurt monohulls van 26 tot 50' en catamarans van 30 tot 55'. Wij bieden ook cruise- en regattatraining, incentives en nautische rally's."
        ],
        "es": [
          "Spi Location ofrece monocascos de 26 a 50' y catamaranes de 30 a 55' para alquilar. También ofrecemos formación en cruceros y regatas, incentivos y concentraciones náuticas."
        ]
      },
