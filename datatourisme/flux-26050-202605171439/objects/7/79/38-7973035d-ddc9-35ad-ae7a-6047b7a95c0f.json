  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/35443721-f2b2-3b0e-8e38-8245152a1e90",
      "dc:description": {
        "de": [
          "Tacos ist täglich von 11:00 bis 1:00 Uhr geöffnet und bietet Sandwiches, die Sie nach Ihrem Geschmack zusammenstellen können, Burger, Croque Monsieur, Paninis, Pizzas, Teller... für großzügige Mahlzeiten zu jeder Tageszeit. Auch Lieferservice oder zum Mitnehmen."
        ],
        "en": [
          "Tacos is open every day from 11am to 1am, offering sandwiches to suit every taste, burgers, croque-monsieur, paninis, pizzas, plates... for generous meals at any time. Also available for delivery or takeaway."
        ],
        "it": [
          "Tacos è aperto tutti i giorni dalle 11.00 all'1.00 e offre panini per tutti i gusti, hamburger, croque-monsieur, panini, pizze, piatti... per pasti abbondanti a qualsiasi ora. Disponibile anche come servizio d'asporto o di consegna."
        ],
        "fr": [
          "Tacos est ouvert tous les jours de 11h à 1h et propose des sandwichs à composer selon ses goûts, des burgers, croque-monsieur, paninis, pizzas, assiettes... pour des repas généreux à toute heure. Egalement service de livraison ou à emporter."
        ],
        "nl": [
          "Tacos is elke dag geopend van 11.00 tot 01.00 uur en biedt sandwiches naar ieders smaak, hamburgers, croque-monsieur, panini's, pizza's, plates... voor royale maaltijden op elk moment. Ook beschikbaar als afhaal- of bezorgservice."
        ],
        "es": [
          "Tacos abre todos los días de 11 a 1 de la madrugada y ofrece bocadillos para todos los gustos, hamburguesas, croque-monsieur, paninis, pizzas, platos... para comer generosamente a cualquier hora. También disponible para llevar o a domicilio."
        ]
      },
