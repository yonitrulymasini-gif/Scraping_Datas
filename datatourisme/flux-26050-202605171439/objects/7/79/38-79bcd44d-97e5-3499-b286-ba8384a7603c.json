  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bc76d3d5-613d-3af2-802d-509f291a4a24",
      "dc:description": {
        "de": [
          "F3-Wohnung für 6 Personen, bestehend aus einem Wohnzimmer mit Schlafsofa, 2 Schlafzimmern, ausgestatteter Küche, geschlossener Privatterrasse, Privatparkplatz.\nGeschäfte, Arzt, Apotheke, Restaurants in unmittelbarer Nähe, Strand in 40 m Entfernung mit beaufsichtigtem Schwimmen in der Hochsaison."
        ],
        "en": [
          "F3 apartment for 6 people comprising living room with sofa bed, 2 bedrooms, fitted kitchen, private enclosed terrace, private parking.\nShops, doctor, pharmacy, restaurants in the immediate vicinity, beach 40 m away with supervised swimming in high season."
        ],
        "it": [
          "Appartamento F3 per 6 persone composto da soggiorno con divano letto, 2 camere da letto, cucina attrezzata, terrazza privata recintata, parcheggio privato.\nNegozi, medico, farmacia, ristoranti nelle immediate vicinanze, spiaggia a 40 metri con piscina sorvegliata in alta stagione."
        ],
        "fr": [
          "Appartement F3 pour 6 personnes comprenant un séjour avec canapé convertible, 2 chambres, cuisine équipée, terrasse privative close, parking privatif.\nCommerces, médecin, pharmacie, restaurants à proximité immédiate, plage à 40 mètres avec baignade surveillée en haute saison."
        ],
        "es": [
          "Piso F3 para 6 personas compuesto de salón con sofá cama, 2 dormitorios, cocina equipada, terraza privada cerrada, aparcamiento privado.\nComercios, médico, farmacia, restaurantes en las inmediaciones, playa a 40 metros con baño vigilado en temporada alta."
        ],
        "nl": [
          "F3 appartement voor 6 personen bestaande uit woonkamer met slaapbank, 2 slaapkamers, ingerichte keuken, eigen omheind terras, eigen parkeerplaats.\nWinkels, dokter, apotheek, restaurants in de directe omgeving, strand op 40 meter met zwemmen onder toezicht in het hoogseizoen."
        ]
      },
