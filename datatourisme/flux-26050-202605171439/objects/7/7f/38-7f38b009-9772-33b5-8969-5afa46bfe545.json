  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3448f13b-c0de-3b84-b3c6-b22baa84a6f9",
      "dc:description": {
        "de": [
          "Altes Haus, das geschmackvoll restauriert wurde. Gepflegte Möbel und Dekoration. Auf dem Land, 1,6 km vom Zentrum mit allen Geschäften entfernt. Wander- und Mountainbike-Routen ab der Unterkunft."
        ],
        "en": [
          "Tastefully restored old house. Furnished and decorated to a high standard. In the countryside, 1.6 km from the center with all amenities. Hiking and mountain bike trails from the gîte."
        ],
        "it": [
          "Antica casa restaurata con gusto. Arredata e decorata con gusto. In campagna, a 1,6 km dal centro con tutti i servizi. Sentieri per escursioni e mountain bike dalla casa."
        ],
        "fr": [
          "Maison ancienne restaurée avec goût. Mobilier et décoration soignés. En campagne, à 1,6 km du centre avec tous commerces. Circuits randonnées et VTT au départ du gîte."
        ],
        "nl": [
          "Smaakvol gerestaureerd oud huis. Ingericht en gedecoreerd naar een hoge standaard. Op het platteland, 1.6 km van het centrum met alle voorzieningen. Wandel- en mountainbikeroutes vanaf de gîte."
        ],
        "es": [
          "Casa antigua restaurada con gusto. Amueblada y decorada con gusto. En el campo, a 1,6 km del centro con todos los servicios. Rutas de senderismo y bicicleta de montaña desde la casa rural."
        ]
      },
