      "dc:description": {
        "de": [
          "Yves Ferrec stellt Ihnen seine Ölgemälde vor\n\n?? Ein Termin voller Farben\nzögern Sie nicht, durch die Türen der Kapelle zu gehen\n\n? Kommen Sie zahlreich und sagen Sie es weiter!"
        ],
        "en": [
          "Yves Ferrec presents his oil paintings\n\n?? A colorful rendez-vous\n?don't hesitate to pass through the doors of the chapel\n\n? Come one, come all, and spread the word!"
        ],
        "it": [
          "Yves Ferrec presenta i suoi dipinti a olio\n\n?? Un appuntamento pieno di colori\nnon esitate a visitare la cappella\n\n? Venite uno, venite tutti e spargete la voce!"
        ],
        "fr": [
          "Yves Ferrec vous présente ses peintures à l'huile \n\n🕰️ Un rendez-vous plein de couleurs\n✨N’hésitez pas à venir passer les portes de la chapelle\n\n📸 Venez nombreux et faites passer le mot !"
        ],
        "nl": [
          "Yves Ferrec presenteert zijn olieverfschilderijen\n\n?? Een rendez-vous vol kleur\naarzel niet om de kapel te komen bezoeken\n\n? Kom allen en vertel het verder!"
        ],
        "es": [
          "Yves Ferrec presenta sus óleos\n\n?? Una cita llena de color\nno dude en venir a visitar la capilla\n\n? Venga uno, vengan todos, ¡y corran la voz!"
        ]
      },
