  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3a5ed497-6a99-32a5-bb8e-3d1ce9364213",
      "dc:description": {
        "de": [
          "Qualitätszucht für Qualitätsfleisch. Kühe, die im Freien gehalten und mit Gras gefüttert werden! Probieren Sie unser Fleisch. Schmackhaft und zart sind sie!"
        ],
        "en": [
          "Quality breeding for quality meat. Free-range, grass-fed cows! Taste our meat. Tasty and tender!"
        ],
        "it": [
          "Allevamento di qualità per una carne di qualità. Mucche allevate all'aperto e nutrite con erba! Assaggiate la nostra carne. Gustosa e tenera!"
        ],
        "fr": [
          "Un élevage de qualité pour une viande de qualité. Des vaches élevées en plein air et nourrit à l'herbe ! Goûter notre viande. Savoureuse et tendreté sont au rendez-vous !"
        ],
        "nl": [
          "Kwaliteitsfokkerij voor kwaliteitsvlees. Koeien met vrije uitloop en grasgevoerd! Proef ons vlees. Lekker en mals!"
        ],
        "es": [
          "Cría de calidad para carne de calidad. Vacas criadas en libertad y alimentadas con hierba Pruebe nuestra carne. Sabrosa y tierna"
        ]
      },
