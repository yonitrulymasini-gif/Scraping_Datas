      "dc:description": {
        "de": [
          "Konzert von zwei Chören. La Marion du Faouët und der Chorale Agora der Musikschule des Pays du Roi Morvan bieten Ihnen ein reichhaltiges und abwechslungsreiches Repertoire von Klassik bis Pop."
        ],
        "en": [
          "Concert by two choirs. La Marion du Faouët and the Agora Choir from the Pays du Roi Morvan music school offer a rich and varied repertoire ranging from classical to pop."
        ],
        "it": [
          "Concerto di due cori. La Marion du Faouët e il Coro Agora della scuola di musica Pays du Roi Morvan propongono un repertorio ricco e vario che spazia dal classico al pop."
        ],
        "fr": [
          "Concert de deux chorales. La Marion du Faouët et la Chorale Agora de l'école de Musique du Pays du Roi Morvan vous propose un répertoire riche et varié allant du classique à la pop."
        ],
        "es": [
          "Concierto de dos coros. La Marion du Faouët y el Coro Agora, de la escuela de música Pays du Roi Morvan, ofrecen un repertorio rico y variado que va del clásico al pop."
        ],
        "nl": [
          "Concert door twee koren. La Marion du Faouët en het Agora koor van de Pays du Roi Morvan muziekschool bieden een rijk en gevarieerd repertoire, van klassiek tot pop."
        ]
      },
