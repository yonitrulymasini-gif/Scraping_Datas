      "dc:description": {
        "de": [
          "Das Gästezimmer befindet sich im Holzhaus eines Töpfers: Es liegt in Ruffiac zwischen La Gacilly und Malestroit. Die Töpferwerkstatt kann besichtigt werden."
        ],
        "en": [
          "The chambre d'hôte is located in a potter's wooden house in Ruffiac, between La Gacilly and Malestroit. Possibility of visiting the pottery workshop."
        ],
        "it": [
          "Il bed and breakfast si trova in una casa di legno di un vasaio a Ruffiac, tra La Gacilly e Malestroit. È possibile visitare il laboratorio di ceramica."
        ],
        "fr": [
          "La chambre d'hôte se situe dans la maison en bois d'un potier: elle est située à Ruffiac entre La Gacilly et Malestroit. Possibilité de visite de l'atelier de poterie."
        ],
        "es": [
          "El bed and breakfast está situado en una casa de madera de alfarero en Ruffiac, entre La Gacilly y Malestroit. Se puede visitar el taller de alfarería."
        ],
        "nl": [
          "De bed & breakfast is gevestigd in een houten pottenbakkershuis in Ruffiac, tussen La Gacilly en Malestroit. Je kunt het pottenbakkersatelier bezoeken."
        ]
