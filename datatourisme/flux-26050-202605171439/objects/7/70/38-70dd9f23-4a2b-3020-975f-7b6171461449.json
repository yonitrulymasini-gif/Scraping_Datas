  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/01cb0854-613c-33d0-9d60-8932ae4e357b",
      "dc:description": {
        "de": [
          "In der Nähe des Stadtzentrums und der Strände, Wohnung für 4 Personen im ersten Stock eines Hauses.\nWohnzimmer mit einem Schlafsofa, Küchenzeile (Waschmaschine), ein Schlafzimmer mit einem Doppelbett, Dusche, WC.\nTerrasse im Erdgeschoss mit Grill und Gartenmöbeln."
        ],
        "en": [
          "Close to town center and beaches, 4-person apartment on 1st floor of a house.\nLiving room with sofa bed, kitchenette (washing machine), bedroom with double bed, shower, WC.\nGround-floor terrace with barbecue and garden furniture."
        ],
        "it": [
          "Vicino al centro e alle spiagge, appartamento per 4 persone al 1° piano di una casa.\nSoggiorno con divano letto, angolo cottura (lavatrice), camera con letto matrimoniale, doccia, WC.\nTerrazza al piano terra con barbecue e mobili da giardino."
        ],
        "fr": [
          "À proximité du centre ville et des plages, appartement 4 personnes au 1er étage d'une maison. \nSéjour avec un clic-clac, coin cuisine (lave-linge), une chambre avec un lit double, douche, WC. \nTerrasse au rez-de-chaussée avec barbecue et salon de jardin."
        ],
        "nl": [
          "Vlakbij het centrum en de stranden, 4-persoons appartement op de 1e verdieping van een huis.\nWoonkamer met slaapbank, kookhoek (wasmachine), slaapkamer met tweepersoonsbed, douche, WC.\nTerras op de begane grond met barbecue en tuinmeubilair."
        ],
        "es": [
          "Cerca del centro de la ciudad y de las playas, piso para 4 personas en el 1er piso de una casa.\nSalón con sofá cama, cocina americana (lavadora), dormitorio con cama doble, ducha, WC.\nTerraza en la planta baja con barbacoa y muebles de jardín."
        ]
      },
      "@type": [
        "Description"
      ],
