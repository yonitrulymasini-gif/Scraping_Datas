  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6114b93b-c390-3c53-8d5b-4c0b750060da",
      "dc:description": {
        "de": [
          "Etappenunterkunft mit einem großen Gemeinschaftsraum mit eingerichteter Küche, Esszimmer und Wohnzimmer. Hier können Versammlungen (Videomaterial) und Mahlzeiten für etwa 20 Personen abgehalten werden."
        ],
        "en": [
          "Gîte d'étape comprising a large common room with fitted kitchen, dining room and lounge. Possibility of meetings (video equipment) and meals for around twenty people."
        ],
        "it": [
          "Gîte di sosta composto da un'ampia sala comune con cucina attrezzata, sala da pranzo e salotto. Può essere utilizzata per riunioni (attrezzatura video) e pasti per circa venti persone."
        ],
        "fr": [
          "Gîte d'étape comprenant une grande salle commune avec cuisine aménagée, salle à manger et salon. Possibilité d'y faire des réunions (matériel vidéo) et repas pour une vingtaine de personnes."
        ],
        "nl": [
          "Gîte met tussenstop, bestaande uit een grote gemeenschappelijke ruimte met ingerichte keuken, eetkamer en zitkamer. Deze ruimte kan worden gebruikt voor vergaderingen (videoapparatuur) en maaltijden voor ongeveer twintig personen."
        ],
        "es": [
          "Casa rural con una gran sala común con cocina equipada, comedor y salón. Puede utilizarse para reuniones (equipo de vídeo) y comidas para unas veinte personas."
        ]
      },
