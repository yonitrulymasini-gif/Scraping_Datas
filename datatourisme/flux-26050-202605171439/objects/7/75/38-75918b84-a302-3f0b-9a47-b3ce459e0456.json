  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/888c7525-9d62-30fd-bb80-ec8b6944b18d",
      "dc:description": {
        "de": [
          "Willkommen in Les Jardins Sauvages, dem Bio- und Locavore-Gourmet-Restaurant im La Grée des Landes, Yves Rocher Eco-Hotel Spa.\nHier genießen Sie eine multisensorische Bio *-Küche, die zugleich gesund und lecker ist und aus lokalen und saisonalen Produkten kreiert wird."
        ],
        "en": [
          "Welcome to Les Jardins Sauvages, the Bio & Locavore gourmet restaurant at La Grée des Landes, Eco-Hotel Spa Yves Rocher.\nHere, you'll enjoy multi-sensory organic* cuisine created from local, seasonal produce."
        ],
        "it": [
          "Benvenuti a Les Jardins Sauvages, il ristorante gourmet biologico e locavorevole de La Grée des Landes, Eco-Hotel Spa Yves Rocher.\nQui potrete gustare una cucina organica* multisensoriale, sana e deliziosa, creata con prodotti locali e di stagione."
        ],
        "fr": [
          "Bienvenue aux Jardins Sauvages, le restaurant Gastronomique Bio & Locavore de La Grée des Landes, Eco-Hôtel Spa Yves Rocher.\nVous y dégusterez une cuisine multisensorielle  Bio * à la fois saine et gourmande, créée à partir de produits locaux et de saison."
        ],
        "nl": [
          "Welkom bij Les Jardins Sauvages, het biologische en lokale gastronomische restaurant van La Grée des Landes, Eco-Hotel Spa Yves Rocher.\nHier kun je genieten van een gezonde en heerlijke biologische* keuken met lokale seizoensproducten."
        ],
        "es": [
          "Bienvenido a Les Jardins Sauvages, el restaurante gastronómico ecológico y local de La Grée des Landes, Eco-Hotel Spa Yves Rocher.\nAquí podrá disfrutar de una cocina orgánica* multisensorial, saludable y deliciosa, elaborada con productos locales de temporada."
        ]
      },
      "@type": [
        "Description"
