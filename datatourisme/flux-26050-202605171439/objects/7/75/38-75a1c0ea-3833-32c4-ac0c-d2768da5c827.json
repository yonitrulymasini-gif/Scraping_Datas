  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/afc2e99c-e84c-3a77-b1f7-660b5269046d",
      "dc:description": {
        "de": [
          "Charmantes Ferienhaus auf dem Land, sehr gut ausgestattet für 4 Personen oder eine Familie mit 2 Kindern. 1 Dusche und WC im Erdgeschoss, 1 Badezimmer und WC im Obergeschoss, gemütliche Küche und Wohnzimmer, Kamineinsatz (bei Bedarf)."
        ],
        "en": [
          "Charming country gîte, very well equipped for 4 people or family with 2 children. 1 shower and WC on ground floor, 1 shower room and WC upstairs, pleasant kitchen and living room, fireplace insert (if required)."
        ],
        "it": [
          "Incantevole gîte in campagna, molto ben attrezzata per 4 persone o una famiglia con 2 bambini. 1 doccia e WC al piano terra, 1 doccia e WC al piano superiore, cucina e soggiorno accoglienti, inserto per camino (se necessario)."
        ],
        "fr": [
          "Charmant gîte à la campagne, très bien équipé pour 4 personnes ou famille avec 2 enfants. 1 douche  et WC au RDC, 1 salle d'eau et WC à l'étage, cuisine et salon agréables, insert cheminée (si besoin)."
        ],
        "nl": [
          "Charmante gîte op het platteland, zeer goed uitgerust voor 4 personen of een gezin met 2 kinderen. 1 douche en WC op de begane grond, 1 doucheruimte en WC op de verdieping, gezellige keuken en woonkamer, insert open haard (indien nodig)."
        ],
        "es": [
          "Casa rural con encanto en el campo, muy bien equipada para 4 personas o una familia con 2 niños. 1 ducha y WC en la planta baja, 1 ducha y WC arriba, acogedora cocina y sala de estar, chimenea (si es necesario)."
        ]
      },
