      "@id": "https://data.datatourisme.fr/d2f42a34-9004-39f8-9f27-041eb0e7a854",
      "dc:description": {
        "de": [
          "Shuffleboard-Wettbewerb in der Freizeitanlage.\n10? pro Doppel, Bretter werden gestellt.\nAnmeldung vor Ort ab 14 Uhr, Auslosung der Teams um 14.30 Uhr.\nZahlreiche Preise zu gewinnen, Getränke vor Ort."
        ],
        "en": [
          "Shuffleboard competition at the leisure center.\n10? per double, boards supplied.\nOn-site registration from 2pm, teams drawn at 2:30pm.\nLots of prizes to be won, refreshments on site."
        ],
        "it": [
          "Gara di shuffleboard presso il centro ricreativo.\n10 per doppio, tavole fornite.\nIscrizioni sul posto a partire dalle 14.00, sorteggio delle squadre alle 14.30.\nNumerosi premi in palio, rinfresco in loco."
        ],
        "fr": [
          "Concours de palets sur planche à la base de loisirs. \n10€ la doublette, planches fournies. \nInscription sur place dès 14h, tirage des équipes à 14h30. \nDe nombreux lots à gagner, buvette sur place."
        ],
        "nl": [
          "Sjoelbakcompetitie in het recreatiecentrum.\n10 per dubbel, borden inbegrepen.\nRegistratie vanaf 14.00 uur, teams worden om 14.30 uur getrokken.\nVeel prijzen te winnen, drankjes ter plaatse."
        ],
        "es": [
          "Competición de tejo en el centro de ocio.\n10 por pareja, tableros incluidos.\nInscripción in situ a partir de las 14.00 horas, sorteo de equipos a las 14.30 horas.\nMuchos premios para ganar, refrescos en el sitio."
        ]
      },
