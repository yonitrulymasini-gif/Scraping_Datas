  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/e974721e-8205-373c-882f-8fcc70000d78",
      "dc:description": {
        "de": [
          "2 Schlafzimmer: eines mit einem 160 cm breiten Bett und einer BZ-Sitzbank für eine Person; das andere mit einem 140 cm breiten Bett und einem 90 cm breiten Bett.\nBadezimmer mit WC. Büro.\nErdgeschoss: 1 WC, Wohnzimmer mit Tisch und Stühlen, Schlafsofa + 2 Sessel, 3 Couchtische. Ofen. Fernseher mit Flachbildschirm. Ausgestattete Küche."
        ],
        "en": [
          "2 bedrooms: one with 1 x 160cm bed + 1-person BZ sofa; the other with 1 x 140cm bed and 1 x 90cm bed.\nShower room with WC. Office.\nGround floor: 1 WC, living room with table and chairs, sofa bed + 2 armchairs, 3 coffee tables. Stove. Flat-screen TV. Fully equipped kitchen."
        ],
        "it": [
          "2 camere da letto: una con 1 letto da 160 cm + divano BZ per 1 persona; l'altra con 1 letto da 140 cm e 1 letto da 90 cm.\nBagno con doccia e WC. Studio.\nPiano terra: 1 WC, soggiorno con tavolo e sedie, divano letto + 2 poltrone, 3 tavolini. Stufa a legna. TV a schermo piatto. Cucina attrezzata."
        ],
        "fr": [
          "2 chambres : une avec 1 lit de 160 + banquette BZ 1 personne ; l'autre avec 1 lit de140 et 1 lit de 90.  \nSalle d'au avec WC. Bureau. \nRDC : 1 WC, salon avec table et chaises, canapé convertible + 2 fauteuils, 3 tables basses. Poêle. TV à écran plat. Cuisine équipée."
        ],
        "nl": [
          "2 slaapkamers: een met 1 x 160cm bed + 1-persoons BZ bank; de andere met 1 x 140cm bed en 1 x 90cm bed.\nDoucheruimte met WC. Studeerkamer.\nBegane grond: 1 WC, woonkamer met tafel en stoelen, slaapbank + 2 fauteuils, 3 salontafels. Houtkachel. Flatscreen TV. Ingerichte keuken."
        ],
        "es": [
          "2 dormitorios: uno con 1 cama de 160 cm + sofá BZ para 1 persona; el otro con 1 cama de 140 cm y 1 cama de 90 cm.\nCuarto de ducha con WC. Estudio.\nPlanta baja: 1 WC, salón con mesa y sillas, sofá cama + 2 sillones, 3 mesas de centro. Estufa de leña. Televisión de pantalla plana. Cocina equipada."
        ]
      },
