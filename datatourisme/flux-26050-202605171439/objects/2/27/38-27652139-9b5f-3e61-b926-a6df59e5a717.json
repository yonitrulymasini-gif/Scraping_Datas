      "dc:description": {
        "de": [
          "Traditionelle Vergebung ab 10:30 Uhr mit einer Messe und anschließender Prozession zum Brunnen. Von 11:00 bis 14:00 Uhr Essen zum Mitnehmen. Den ganzen Tag über Getränke vor Ort."
        ],
        "en": [
          "Traditional Pardon from 10:30 am with mass followed by the procession to the fountain. From 11 a.m. to 2 p.m., take-away lunch. Refreshment bar on site all day."
        ],
        "it": [
          "Tradizionale perdono dalle 10.30 con la messa seguita dalla processione alla fontana. Pasti da asporto dalle 11.00 alle 14.00. Rinfreschi disponibili tutto il giorno."
        ],
        "fr": [
          "Pardon traditionnel à partir de 10h30 avec une messe suivie de la procession à la fontaine. De 11h à 14h, repas à emporter. Buvette sur place toute la journée."
        ],
        "nl": [
          "Traditioneel pardon vanaf 10.30 uur met de mis gevolgd door de processie naar de fontein. Afhaalmaaltijden van 11.00 tot 14.00 uur. Versnaperingen zijn de hele dag verkrijgbaar."
        ],
        "es": [
          "Indulto tradicional a partir de las 10.30 h con misa seguida de la procesión hasta la fuente. Comidas para llevar de 11.00 a 14.00 horas. Refrescos durante todo el día."
        ]
