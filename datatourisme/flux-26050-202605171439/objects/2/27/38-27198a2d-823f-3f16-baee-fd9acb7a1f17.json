  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d2365488-eb94-3d53-a080-5965f981de79",
      "dc:description": {
        "de": [
          "Das Ziel des Vereins Léz'arts en Mer ist es, die Ausübung künstlerischer Aktivitäten für Kinder und Erwachsene zu fördern. Auf der Ebene der bildenden Künste: Kurse und Praktika in Modellieren, Keramik, Zeichnen und Malen. Auf der Ebene der Literatur: Schreibkurse"
        ],
        "en": [
          "The aim of the association Léz'arts en Mer is to develop artistic activities for children and adults. For the plastic arts: courses and workshops in modeling, ceramics, drawing and painting; for the literary arts: writing workshops"
        ],
        "it": [
          "L'obiettivo dell'associazione Léz'arts en Mer è quello di sviluppare attività artistiche per bambini e adulti. Per le arti plastiche: corsi e laboratori di modellazione, ceramica, disegno e pittura; per la letteratura: laboratori di scrittura"
        ],
        "fr": [
          "Le but de l'association Léz'arts en Mer est de développer la pratique d'activités artistiques en direction des enfants et des adultes. Au niveau arts plastiques : cours et stages de modelage, céramique, dessin et peinture .Au niveau littéraire : stages d'écriture"
        ],
        "nl": [
          "Het doel van de vereniging Léz'arts en Mer is het ontwikkelen van artistieke activiteiten voor kinderen en volwassenen. Voor plastische kunsten: cursussen en workshops boetseren, keramiek, tekenen en schilderen; voor literatuur: schrijfworkshops"
        ],
        "es": [
          "El objetivo de la asociación Léz'arts en Mer es desarrollar actividades artísticas para niños y adultos. Para las artes plásticas: cursos y talleres de modelado, cerámica, dibujo y pintura; para la literatura: talleres de escritura"
        ]
      },
