  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f599a157-9069-3634-bbf8-3869de1d5fbd",
      "dc:description": {
        "de": [
          "Wohnung für 4 Personen, gegenüber dem Meer und in der Nähe des Strandes, bestehend aus einem Eingang, einer offenen Küche mit Geschirrspüler, Kühlschrank, Gefrierschrank, Mikrowelle, Backofen, einem Wohn- und Esszimmer mit einem Schlafsofa, einem Einzelbett, Fernseher, einem Schlafzimmer mit einem Doppelbett, WC, einem Badezimmer mit Waschmaschine und einer Terrasse mit Blick auf einen kleinen Privatgarten. Garage, Parkplatz.\nVermietung das ganze Jahr über."
        ],
        "en": [
          "4-person apartment facing the sea and close to the beach, comprising entrance hall, open kitchen with dishwasher, fridge, freezer, microwave, oven, living room with sofa bed, single bed, TV, bedroom with double bed, toilet, bathroom with washing machine, terrace overlooking small private garden. Garage and parking space.\nYear-round rental."
        ],
        "it": [
          "Appartamento per 4 persone, di fronte al mare e vicino alla spiaggia, composto da ingresso, cucina a vista con lavastoviglie, frigorifero, freezer, microonde, forno, soggiorno con divano letto, letto singolo, televisione, camera con letto matrimoniale, WC, bagno con lavatrice e terrazza con vista su piccolo giardino privato. Garage e posto auto.\nAffitto per tutto l'anno."
        ],
        "fr": [
          "Appartement 4 personnes, face à la mer et à proximité de la plage, comprenant une entrée,  une cuisine ouverte avec lave-vaisselle, réfrigérateur, congélateur, micro-ondes, four, un salon-séjour avec un clic-clac, un lit simple, télévision, une  chambre avec un lit double, WC, une  salle de bain avec lave-linge, et une terrasse avec vue sur petit jardin privatif. Garage, parking.\nLocation toute l'année."
        ],
        "es": [
          "Piso para 4 personas, frente al mar y cerca de la playa, compuesto por hall de entrada, cocina americana con lavavajillas, nevera, congelador, microondas, horno, salón con sofá cama, cama individual, televisión, dormitorio con cama de matrimonio, WC, cuarto de baño con lavadora y terraza con vistas a pequeño jardín privado. Garaje y plaza de aparcamiento.\nAlquiler todo el año."
        ],
        "nl": [
          "4-persoons appartement, met uitzicht op zee en vlakbij het strand, bestaande uit een hal, open keuken met vaatwasser, koelkast, vriezer, magnetron, oven, woonkamer met slaapbank, eenpersoonsbed, televisie, slaapkamer met tweepersoonsbed, toilet, badkamer met wasmachine, en terras met uitzicht op kleine privétuin. Garage en parkeerplaats.\nVerhuur het hele jaar door."
        ]
      },
