      "dc:description": {
        "de": [
          "Angelführer, der auf das Angeln von Wolfsbarsch und anderen Raubfischen mit Ködern vom Boot aus (oder von einem Boot aus) spezialisiert ist.Abfahrt von Quiberon - Port-Haliguen.Tages- oder Halbtagesausflug.Montags geschlossen"
        ],
        "en": [
          "Fishing guide specialized in bass and other carnivorous fishes with lures by boat (or from a boat).departure from Quiberon - Port-Haliguen.day or 1/2 day trip.closed on monday"
        ],
        "it": [
          "Guida di pesca specializzata nella pesca della spigola e di altri carnivori con esche artificiali dalla barca (o da una barca).Partenza da Quiberon - Port-Haliguen.Gita di un giorno o di mezza giornata.Chiuso il lunedì"
        ],
        "fr": [
          "Guide de pêche spécialisé dans la pêche du bar et autres carnassiers aux leurres en bateau (ou à partir d'un bateau).Départ de Quiberon - Port-Haliguen.Sortie journée ou 1/2 journée.Fermé le lundi"
        ],
        "nl": [
          "Visgids gespecialiseerd in het vissen op baars en andere carnivoren met kunstaas vanuit een boot (of vanaf een boot).Vertrek vanuit Quiberon - Port-Haliguen.Dag of halve dag trip.Gesloten op maandag"
        ],
        "es": [
          "Guía de pesca especializado en la pesca de lubinas y otros carnívoros con señuelos desde una embarcación (o desde un barco).Salida desde Quiberon - Port-Haliguen.Salida de un día o de medio día.Cerrado los lunes"
        ]
      },
