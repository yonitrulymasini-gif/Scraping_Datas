  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cf327946-5d97-3658-8e81-c5100d538cd8",
      "dc:description": {
        "de": [
          "Das Restaurant \"Les S?urs Magui\" in Plouray bietet Ihnen die ganze Woche über traditionelle Küche und am Wochenende Spezialitäten. Die Qualität der Mahlzeiten wird Ihre Geschmacksnerven kitzeln und Sie in Staunen versetzen."
        ],
        "en": [
          "Located in Plouray, the \"Les S?urs Magui\" restaurant offers traditional cuisine every day of the week, as well as specialities at weekends. The quality of our meals will tickle your taste buds and leave you amazed."
        ],
        "it": [
          "Situato a Plouray, il ristorante \"Les S?urs Magui\" propone una cucina tradizionale tutti i giorni della settimana e specialità nel fine settimana. La qualità dei piatti solleticherà le vostre papille gustative e vi stupirà."
        ],
        "fr": [
          "Implanté à Plouray, le restaurant « Les Sœurs Magui » propose une cuisine traditionnelle tous les jours de la semaine, ainsi que des spécialités les week-end. La qualité des repas titillera vos papilles gustatives et vous émerveillera."
        ],
        "es": [
          "Situado en Plouray, el restaurante \"Les Sœurs Magui\" sirve cocina tradicional todos los días de la semana, así como especialidades los fines de semana. La calidad de los platos le sorprenderá."
        ],
        "nl": [
          "Het restaurant \"Les S?urs Magui\" in Plouray serveert elke dag van de week traditionele gerechten en in het weekend specialiteiten. De kwaliteit van de maaltijden zal uw smaakpapillen prikkelen en u verbazen."
        ]
      },
      "@type": [
        "Description"
