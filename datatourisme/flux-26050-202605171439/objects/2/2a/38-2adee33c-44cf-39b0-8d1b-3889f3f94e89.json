  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/97d1aaf6-5f13-354e-acd8-36c2ead7fe69",
      "dc:description": {
        "de": [
          "Das gemeinschaftliche Wassersportzentrum Kan an Dour in Le Faouët (bretonisch für \"das Lied des Wassers\") empfängt die Öffentlichkeit auf einer Fläche von 1116 m². Das Schwimmbad verfügt über ein 25m x 10m großes Sportbecken, ein Spielbecken mit Rutsche und einen Entspannungsbereich."
        ],
        "en": [
          "The Kan an Dour community aquatic center in Le Faouët (Breton for \"the song of water\") welcomes the public on a surface area of 1,116 m². The pool features a 25 x 10-meter sports pool, a fun pool with a slide and a relaxation area."
        ],
        "it": [
          "Il centro acquatico comunitario Kan an Dour di Le Faouët (in bretone \"il canto dell'acqua\") ha una superficie di 1.116 m². La piscina dispone di una vasca sportiva di 25 x 10 metri, di una piscina ludica con scivolo e di un'area relax."
        ],
        "fr": [
          "Le centre aquatique communautaire Kan an Dour à Le Faouët (le chant de l’eau en breton) accueille le public sur une surface de 1 116 m². La piscine dispose d'un bassin sportif de 25 mètres sur 10 mètres, un bassin ludique avec un toboggan et un espace de détente."
        ],
        "nl": [
          "Het communautaire zwemparadijs Kan an Dour in Le Faouët (Bretoens voor \"het lied van het water\") heeft een oppervlakte van 1.116 m². Het zwembad heeft een sportbad van 25 x 10 meter, een ludiek bad met een glijbaan en een ontspanningsruimte."
        ],
        "es": [
          "El centro acuático comunitario de Kan an Dour, en Le Faouët (en bretón, \"el canto del agua\"), tiene una superficie de 1.116 m². Cuenta con una piscina deportiva de 25 x 10 metros, una piscina lúdica con tobogán y una zona de relajación."
        ]
      },
