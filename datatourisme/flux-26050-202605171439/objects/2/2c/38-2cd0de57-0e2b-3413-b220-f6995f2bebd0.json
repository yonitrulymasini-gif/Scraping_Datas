  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a175607c-fe9b-3af4-8778-32d5895debbf",
      "dc:description": {
        "de": [
          "Morailh ist ein Solostück für Bombarde, Biniou, bretonischen Gesang und Live-Soundtransformation mit der Software logelloop.\nEin atypischer und kompromissloser Vorschlag, der das populäre bretonische Repertoire mit Elektroakustik in einem zeitgenössischen und immersiven Klangkabinett verbindet."
        ],
        "en": [
          "Morailh is a solo piece for bombard, biniou, singing in Breton and live sound transformation using logelloop software.\nAn atypical and uncompromising proposition, combining the popular Breton repertoire with electroacoustics, in a contemporary and immersive sound setting."
        ],
        "it": [
          "Morailh è un pezzo solista per bombarda, biniou, canto in bretone e trasformazione del suono dal vivo con il software logelloop.\nUna proposta atipica e senza compromessi, che combina il repertorio popolare bretone con l'elettroacustica, in un contesto sonoro contemporaneo e immersivo."
        ],
        "fr": [
          "Morailh est une pièce solo pour bombarde, biniou, chant en breton et transformation du son en direct avec le logiciel logelloop.\nUne proposition atypique et sans concession, alliant le répertoire populaire breton à l'électroacoustique, dans un écrin sonore contemporain et immersif."
        ],
        "nl": [
          "Morailh is een solostuk voor bombard, biniou, zang in het Bretons en live geluidstransformatie met behulp van logelloop-software.\nEen atypisch en compromisloos voorstel, dat het populaire Bretonse repertoire combineert met elektroakoestiek, in een eigentijdse en meeslepende geluidsomgeving."
        ],
        "es": [
          "Morailh es una pieza solista para bombardino, biniou, canto en bretón y transformación sonora en directo mediante el software logelloop.\nUna propuesta atípica y sin concesiones, que combina el repertorio popular bretón con la electroacústica, en un entorno sonoro contemporáneo e inmersivo."
        ]
      },
