      "dc:description": {
        "de": [
          "Yachtcharter:Regatten auf Einheitsklassenyachten Grand Surprise.Kreuzfahrten oder Tagesausflüge, Option Skipper (Grand Surprise, First 36.7, First 31.7, SUN ODYSSEY 36 Perf) für Ausflüge in den Golf und zu den Inseln."
        ],
        "en": [
          "Sailboat rental: Regattas on one-design Grand Surprise, cruises or day trips, skipper option (Grand Surprise, First 36.7, First 31.7, SUN ODYSSEY 36 Perf) for Gulf and island trips."
        ],
        "it": [
          "Noleggio barche a vela: regate sul monotipo Grand Surprise, crociere o escursioni giornaliere, opzione skipper (Grand Surprise, First 36.7, First 31.7, SUN ODYSSEY 36 Perf) per escursioni nel Golfo e sulle isole."
        ],
        "fr": [
          "Location de voiliers :Régates sur monotypes Grand Surprise.Croisières ou sortie à la journée, option skipper (Grand Surprise, First 36.7, First 31.7, SUN ODYSSEY 36 Perf) pour sorties Golfe et îles."
        ],
        "nl": [
          "Verhuur van zeilboten: Regatta's op de Grand Surprise, cruises of dagtochten, optie schipper (Grand Surprise, First 36.7, First 31.7, SUN ODYSSEY 36 Perf) voor tochten in de Golf en op eilanden."
        ],
        "es": [
          "Alquiler de veleros: Regatas en el monodiseño Grand Surprise, cruceros o excursiones de un día, opción de patrón (Grand Surprise, First 36.7, First 31.7, SUN ODYSSEY 36 Perf) para viajes por el Golfo y las islas."
        ]
