  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/1225d900-1614-3fe3-b3a8-aa6159fb24e6",
      "dc:description": {
        "de": [
          "Diese ebenerdige Wohnung befindet sich im Erdgeschoss eines Hauses auf dem Land und liegt inmitten eines 5 Hektar großen Parks. Ihre Terrasse blickt auf die Wälder und den Teich und bietet einen Blick auf den Fluss Ellé."
        ],
        "en": [
          "This single-storey apartment, located on the first floor of a country house, is in the heart of a 5-hectare park. Its terrace overlooks the woods and pond, and offers a view of the Ellé river."
        ],
        "it": [
          "Questo appartamento al piano terra di una casa di campagna è immerso in un parco di 5 ettari. La sua terrazza si affaccia sul bosco e sul lago, con vista sul fiume Ellé."
        ],
        "fr": [
          "Cet appartement de plain-pied, situé au rez-de-chaussée d'une maison en campagne,  est au cœur d'un parc de 5 hectares. Sa terrasse donne sur les bois et le plan d'eau et offre une vue sur la rivière Ellé."
        ],
        "es": [
          "Este apartamento en la planta baja de una casa de campo está situado en un parque de 5 hectáreas. Su terraza da al bosque y al lago, con vistas al río Ellé."
        ],
        "nl": [
          "Dit appartement op de begane grond in een landhuis ligt in 5 hectare park. Het terras kijkt uit over de bossen en het meer, met uitzicht op de rivier de Ellé."
        ]
      },
      "@type": [
        "Description"
