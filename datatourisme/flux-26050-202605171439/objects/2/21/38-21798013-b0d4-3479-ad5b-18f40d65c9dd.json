  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/70e8e49b-24c2-3a2e-87b5-ddad98cd8c92",
      "dc:description": {
        "de": [
          "Bar Pizzeria Restaurant mit Meerblick am Hafen von Etel.\nQualitativ hochwertige Küche.\n\nGenießen Sie den Sonnenuntergang bei einer schönen Auswahl an Bieren vom Fass, Wein im Glas und Cocktails."
        ],
        "en": [
          "Bar Pizzeria Restaurant sea view on Etel harbor.\nQuality cuisine.\n\nEnjoy the sunset with a selection of draught beers, wine by the glass and cocktails."
        ],
        "it": [
          "Bar Pizzeria Ristorante vista mare sul porto di Etel.\nCucina di qualità.\n\nVenite ad ammirare il tramonto con un'ottima selezione di birre alla spina, vini al bicchiere e cocktail."
        ],
        "fr": [
          "Bar Pizzeria Restaurant vue sur mer sur le port d'Etel.\nCuisine de qualité.\n\nVenez admirer le coucher de soleil avec une belle sélection de bières à la pression, de vin au verre et cocktails."
        ],
        "es": [
          "Bar Pizzeria Restaurante con vistas al mar en el puerto de Etel.\nCocina de calidad.\n\nVenga a admirar la puesta de sol con una buena selección de cervezas de barril, vino por copa y cócteles."
        ],
        "nl": [
          "Bar Pizzeria Restaurant met uitzicht op zee aan de haven van Etel.\nKwaliteitskeuken.\n\nKom en bewonder de zonsondergang met een fijne selectie van tapbieren, wijn per glas en cocktails."
        ]
      },
