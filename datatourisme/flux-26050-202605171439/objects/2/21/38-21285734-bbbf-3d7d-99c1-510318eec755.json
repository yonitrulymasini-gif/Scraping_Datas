      "dc:description": {
        "de": [
          "Vide grenier organisé par le L.P.C. (club de pétanque de Locmariaquer) et l'ACCCA (association des chasseurs de Locmariaquer) : 14° édition\n\nMehr als 150 Aussteller erwartet!\n\nVerpflegung und Getränke vor Ort"
        ],
        "en": [
          "Garage sale organized by the L.P.C. (Locmariaquer petanque club) and the ACCCA (Locmariaquer hunters' association): 14th edition\n\nOver 150 exhibitors expected!\n\nCatering and refreshments on site"
        ],
        "it": [
          "Mercatino delle pulci organizzato dal L.P.C. (club di petanque di Locmariaquer) e dall'ACCCA (associazione dei cacciatori di Locmariaquer): 14a edizione\n\nSono attesi oltre 150 espositori!\n\nRistorazione e ristoro in loco"
        ],
        "fr": [
          "Vide grenier organisé par le L.P.C. (club de pétanque de Locmariaquer) et l'ACCCA (association des chasseurs de Locmariaquer) : 14° édition\n\nPlus de 150 exposants attendus !\n\nRestauration et  buvette sur place"
        ],
        "nl": [
          "Vlooienmarkt georganiseerd door de L.P.C. (Locmariaquer petanque club) en de ACCCA (Locmariaquer jagersvereniging): 14e editie\n\nMeer dan 150 standhouders verwacht!\n\nCatering en verfrissingen ter plaatse"
        ],
        "es": [
          "Mercadillo organizado por el L.P.C. (club de petanca de Locmariaquer) y la ACCCA (asociación de cazadores de Locmariaquer): 14ª edición\n\nSe esperan más de 150 expositores\n\nCatering y refrescos in situ"
        ]
