  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0c27f44d-57c5-3bda-aeb8-3672525b659e",
      "dc:description": {
        "de": [
          "Es liegt ganz oben auf einer Wiese mit herrlicher Aussicht und wird als Unterkunft für Wanderer, Radfahrer und Reiter angeboten, mit der Möglichkeit, Tiere zu parken."
        ],
        "en": [
          "Set at the top of a meadow with a superb view, it offers accommodation for hikers, cyclists and horse riders, with the possibility of parking animals."
        ],
        "it": [
          "Situato in cima a un prato con una vista superba, offre alloggi per escursionisti, ciclisti e cavalieri, con la possibilità di parcheggiare gli animali."
        ],
        "fr": [
          "Posée tout en haut d'une prairie avec superbe vue, elle est proposée en hébergement pour randonneurs de passage tels que marcheurs, cyclistes ou cavaliers avec possibilité de parquer les animaux."
        ],
        "es": [
          "Situado en lo alto de un prado con magníficas vistas, ofrece alojamiento a senderistas, ciclistas y jinetes, con la posibilidad de aparcar animales."
        ],
        "nl": [
          "Het ligt op de top van een weiland met een prachtig uitzicht en biedt accommodatie voor wandelaars, fietsers en ruiters, met de mogelijkheid om dieren te parkeren."
        ]
      },
