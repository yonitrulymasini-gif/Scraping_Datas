  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/982602cd-af01-3c12-bfd1-30d6dbf2f737",
      "dc:description": {
        "de": [
          "Im Herzen des Dorfes Saint Martin Sur Oust empfangen wir Sie in der ehemaligen Dorfschule. Entdecken Sie unsere Region, indem Sie den Canal de Nantes à Brest, den Wald von Brocéliande, den Golf von Morbihan..."
        ],
        "en": [
          "In the heart of the village of Saint Martin Sur Oust, we welcome you to the former village school. Come and discover our region, visiting the Canal de Nantes à Brest, the Brocéliande forest, the Golfe du Morbihan..."
        ],
        "it": [
          "Nel cuore del villaggio di Saint Martin Sur Oust, vi diamo il benvenuto nell'antica scuola del villaggio. Venite a scoprire la nostra regione, con il Canale di Nantes a Brest, la foresta di Brocéliande, il Golfo di Morbihan..."
        ],
        "fr": [
          "Au coeur du village de Saint Martin Sur Oust,  nous vous accueillons dans l'ancienne école de village. Venez découvrir notre région en parcourant le Canal de Nantes à Brest, la forêt de Brocéliande, le Golfe du Morbihan..."
        ],
        "nl": [
          "In het hart van het dorp Saint Martin Sur Oust heten we je welkom in de oude dorpsschool. Kom en ontdek onze regio, met het Canal de Nantes à Brest, het bos van Brocéliande, de Golf van Morbihan..."
        ],
        "es": [
          "En el corazón del pueblo de Saint Martin Sur Oust, le damos la bienvenida a la antigua escuela del pueblo. Venga a descubrir nuestra región, pasando por el Canal de Nantes à Brest, el bosque de Brocéliande, el golfo de Morbihan..."
        ]
      },
      "@type": [
        "Description"
      ],
