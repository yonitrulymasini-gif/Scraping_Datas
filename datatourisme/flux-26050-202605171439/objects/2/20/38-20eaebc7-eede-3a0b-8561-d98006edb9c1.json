      "dc:description": {
        "de": [
          "Um 20:30 Uhr \"On a march sur les îles: la Préhistoire à Houat et Hoëdic\" (Wir sind auf den Inseln gewandert: die Vorgeschichte auf Houat und Hoëdic) Von Jean-Marc Large Doktor der Archäologie, Spezialist für Vorgeschichte, assoziierter Forscher an der Universität Rennes . Ohne Reservierung"
        ],
        "en": [
          "At 8:30 pm \"On a marché sur les îles: la Préhistoire à Houat et Hoëdic\" (We walked on the islands: Prehistory on Houat and Hoëdic) By Jean-Marc Large Doctor of Archaeology, specialist in Prehistory, associate researcher at the University of Rennes . Without reservation"
        ],
        "it": [
          "20.30 \"Abbiamo camminato sulle isole: la preistoria di Houat e Hoëdic\" A cura di Jean-Marc Large Dottore in archeologia, specialista in preistoria, ricercatore associato presso l'Università di Rennes. Non è necessaria la prenotazione"
        ],
        "fr": [
          "À 20h30 \"On a marché sur les îles : la Préhistoire à Houat et Hoëdic\" Par Jean-Marc Large Docteur en Archéologie, spécialiste de la Préhistoire, chercheur associé à l’Université Rennes . Sans réservation"
        ],
        "nl": [
          "20.30 uur \"We wandelden op de eilanden: Prehistorie op Houat en Hoëdic\" Door Jean-Marc Large Doctor in de Archeologie, specialist in Prehistorie, geassocieerd onderzoeker aan de Universiteit van Rennes. Geen reservering nodig"
        ],
        "es": [
          "20.30 h \"Caminamos por las islas: la Prehistoria en Houat y Hoëdic\" Por Jean-Marc Large Doctor en arqueología, especialista en Prehistoria, investigador asociado en la Universidad de Rennes. Sin reserva previa"
        ]
