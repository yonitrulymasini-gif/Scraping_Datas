  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5223408d-1549-363e-942d-1e349429da9a",
      "dc:description": {
        "de": [
          "Dieses Ferienhaus bietet Ihnen den Charme einer ländlichen Gegend, die sich für Spaziergänge eignet. Sie liegt 4 km vom Canal de Nantes à Brest und seinen Treidelpfaden entfernt. Grüner Weg, den Sie zu Fuß, mit dem Fahrrad oder auf Inline-Skates erkunden können. GR347 in 5 km Entfernung."
        ],
        "en": [
          "This gîte offers you the charm of the countryside, ideal for walks. Located 4 km from the Nantes-Brest Canal and its towpaths. Greenway to discover on foot, bike or rollerblades. GR347 5 km away."
        ],
        "it": [
          "Questo gîte vi offre il fascino della campagna, ideale per le passeggiate. Situato a 4 km dal Canale di Nantes-Brest e dalle sue alzaie. Greenway da scoprire a piedi, in bicicletta o con i rollerblade. GR347 a 5 km."
        ],
        "fr": [
          "Ce gîte vous offre le charme de la campagne propice aux balades. Situé à 4 km du Canal de Nantes à Brest et de ses chemins de halage. Voie verte à découvrir à pied, vélo, rollers. GR347 à 5 km."
        ],
        "es": [
          "Esta casa rural le ofrece el encanto del campo, ideal para pasear. Situado a 4 km del Canal de Nantes-Brest y sus caminos de sirga. Vía verde para descubrir a pie, en bicicleta o en patines. GR347 a 5 km."
        ],
        "nl": [
          "Deze gîte biedt u de charme van het platteland, ideaal voor wandelingen. Gelegen op 4 km van het kanaal Nantes-Brest en zijn jaagpaden. Groene weg om te voet, op de fiets of op skeelers te ontdekken. GR347 op 5 km."
        ]
      },
      "@type": [
        "Description"
