  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/58b3c3f9-a58a-3044-8136-9438d6ab8642",
      "dc:description": {
        "de": [
          "Kleines renoviertes Haus auf 3 Ebenen, in einer ruhigen Gasse, im historischen Zentrum von Malestroit.\nEs liegt 100 m vom Kanal Nantes-Brest, dem Treidelpfad und dem grünen Weg sowie den lokalen Geschäften entfernt."
        ],
        "en": [
          "Small renovated house on 3 levels, in quiet lane, in historic center of Malestroit.\nSituated 100m from the Nantes-Brest canal, its towpath and greenway, as well as local shops."
        ],
        "it": [
          "Piccola casa ristrutturata su 3 livelli, in un vicolo tranquillo nel centro storico di Malestroit.\nA 100 m dal canale di Nantes-Brest, dalla sua alzaia e dalla via verde, nonché dai negozi locali."
        ],
        "fr": [
          "Petite maison rénovée sur 3 niveaux, dans ruelle calme , dans centre historique de Malestroit.\nSituée à 100m du canal Nantes à Brest, de son halage et de la voie verte, ainsi que des commerces de proximité."
        ],
        "es": [
          "Pequeña casa renovada en 3 niveles, en una calle tranquila del centro histórico de Malestroit.\nSituada a 100 m del canal Nantes-Brest, su camino de sirga y su vía verde, así como de los comercios locales."
        ],
        "nl": [
          "Klein gerenoveerd huis op 3 niveaus, in een rustige laan in het historische centrum van Malestroit.\nOp 100 m van het kanaal Nantes-Brest, het jaagpad en de groene weg, evenals plaatselijke winkels."
        ]
      },
