  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ec8aa6b8-e251-3214-9b68-8e33ca607b15",
      "dc:description": {
        "de": [
          "Herzlich willkommen bei Nanek! Streetfood zum Mitnehmen, das zu 100% hausgemacht und lokal ist, von Gewürzgurken über Saucen bis hin zu Gewürzmischungen, wir machen alles mit Leidenschaft!"
        ],
        "en": [
          "Welcome to Nanek! From 100% homemade and local takeaway streetfood to pickles, sauces and spice blends, we do it all with passion!"
        ],
        "it": [
          "Benvenuti da Nanek! Dallo streetfood 100% artigianale e locale da asporto ai sottaceti, alle salse e alle miscele di spezie, facciamo tutto con passione!"
        ],
        "fr": [
          "Soyez les bienvenus chez Nanek! De la streetfood à emporter 100% fait maison et local, des pickles, aux sauces, en passant par les mélanges d'épices, on fait tout avec passion !"
        ],
        "es": [
          "¡Bienvenido a Nanek! Desde comida callejera 100% casera y local para llevar hasta encurtidos, salsas y mezclas de especias, ¡lo hacemos todo con pasión!"
        ],
        "nl": [
          "Welkom bij Nanek! Van 100% zelfgemaakt en lokaal meeneem streetfood tot augurken, sauzen en kruidenmengsels, we doen het allemaal met passie!"
        ]
      },
      "@type": [
        "Description"
