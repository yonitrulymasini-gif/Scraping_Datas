  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c30035fe-4fcc-3969-aaea-9cf1dcdeba03",
      "dc:description": {
        "de": [
          "Lokale, biologische Küche, vernünftiger Einkauf. Traditionell, vegetarisch, vegan, glutenfrei. Alles wird hausgemacht. Mittags von Dienstag bis Sonntag und abends am Donnerstag, Freitag und Samstag geöffnet."
        ],
        "en": [
          "Local cuisine, organic, sustainable purchasing. Traditional, vegetarian, vegan, gluten-free. All homemade. Open Tuesday to Sunday lunchtimes and evenings on Thursday, Friday and Saturday."
        ],
        "it": [
          "Cucina locale, biologica, acquisti ragionati. Tradizionale, vegetariana, vegana, senza glutine. Tutto fatto in casa. Aperto dal martedì alla domenica a pranzo e la sera il giovedì, venerdì e sabato."
        ],
        "fr": [
          "Cuisine locale, bio, achats raisonnés. Traditionnel, végétarienne, vegan, sans gluten. Tout fait maison. Ouvert du mardi au dimanche les midis et le soir le jeudi, vendredi et samedi."
        ],
        "nl": [
          "Lokale keuken, biologisch, doordachte aankopen. Traditioneel, vegetarisch, veganistisch, glutenvrij. Alles huisgemaakt. Geopend van dinsdag tot zondag tijdens lunchtijd en 's avonds op donderdag, vrijdag en zaterdag."
        ],
        "es": [
          "Cocina local, ecológica, compras razonadas. Tradicional, vegetariana, vegana, sin gluten. Todo casero. Abierto de martes a domingo a mediodía y los jueves, viernes y sábados por la noche."
        ]
      },
      "@type": [
        "Description"
