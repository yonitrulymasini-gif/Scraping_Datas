  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/239ae5a3-2271-3b36-9adc-0f899964d277",
      "dc:description": {
        "de": [
          "Pizzarestaurant, das Rohstoffe von Premium-Qualität verwendet. Von Dienstag bis Sonntag geöffnet. Donnerstagabend, Sonntag und Montag ganztägig geschlossen.\nIn den Sommermonaten auch am Sonntagabend geöffnet.\nDas Angebot an Pizzen liegt zwischen 9,50? und 16?"
        ],
        "en": [
          "Pizzeria restaurant using top-quality ingredients. Open Tuesday to Sunday. Closed Thursday evening, Sunday and Monday all day.\nOpen Sunday evenings in summer.\nPizzas range from 9.50? to 16?"
        ],
        "it": [
          "Ristorante pizzeria con ingredienti di prima qualità. Aperto da martedì a domenica. Chiuso giovedì sera, domenica e lunedì tutto il giorno.\nAperto la domenica sera durante l'estate.\nLe pizze offerte vanno da 9,50 a 16 euro."
        ],
        "fr": [
          "Restaurant pizzéria qui utilise des matières premières de qualités prémium. Ouvert du mardi au dimanche. Fermé le jeudi soir, dimanche et lundi toute la journée.\nPériode estivale ouverture le dimanche soir.\nL'offre sur les pizzas se situe de 9,50€ à 16€."
        ],
        "es": [
          "Restaurante pizzería con ingredientes de primera calidad. Abierto de martes a domingo. Cerrado los jueves por la noche y los domingos y lunes todo el día.\nAbierto los domingos por la noche en verano.\nLa oferta de pizzas oscila entre 9,50 y 16 euros."
        ],
        "nl": [
          "Pizzeria-restaurant met ingrediënten van topkwaliteit. Geopend van dinsdag tot zondag. Gesloten op donderdagavond, zondag en maandag de hele dag.\nIn de zomer geopend op zondagavond.\nDe pizza's variëren van 9,50 euro tot 16 euro."
        ]
      },
