  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/76d734ea-d672-37e1-8934-5255a5cecd69",
      "dc:description": {
        "de": [
          "Genießen Sie eine elegante und zentral gelegene Unterkunft.\nIdeal gelegen im Herzen von La Gacilly, wohnen Sie in unserem komplett renovierten Häuschen (35 m²). Es bietet Platz für bis zu 4 Personen."
        ],
        "en": [
          "Enjoy elegant, central accommodation.\nIdeally located in the heart of La Gacilly, come and stay in our fully renovated maisonette (35 m²). It can accommodate up to 4 people."
        ],
        "it": [
          "Godetevi un alloggio elegante e centrale.\nIn posizione ideale nel cuore di La Gacilly, venite a soggiornare nella nostra maisonette (35 m²) completamente rinnovata. Può ospitare fino a 4 persone."
        ],
        "fr": [
          "Profitez d'un logement élégant et central.\nIdéalement situé au coeur de La Gacilly, venez séjourner dans notre maisonnette entièrement rénovée (35 m²). Elle peut accueillir jusqu'à 4 personnes."
        ],
        "nl": [
          "Geniet van een elegante, centrale accommodatie.\nIdeaal gelegen in het hart van La Gacilly, kom en verblijf in onze volledig gerenoveerde maisonnette (35 m²). Het is geschikt voor maximaal 4 personen."
        ],
        "es": [
          "Disfrute de un alojamiento elegante y céntrico.\nIdealmente situado en el corazón de La Gacilly, venga a alojarse en nuestro dúplex totalmente renovado (35 m²). Puede alojar hasta 4 personas."
        ]
      },
