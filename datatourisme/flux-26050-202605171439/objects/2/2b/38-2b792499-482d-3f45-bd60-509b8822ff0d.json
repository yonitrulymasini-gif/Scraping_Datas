  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7b1a02cb-9a22-3877-8b07-5dc0271c5141",
      "dc:description": {
        "de": [
          "Im Erdgeschoss bestehend aus: einem Schlafzimmer (1 Bett 140-190 cm), einem Wohnzimmer mit Schlafsofa (TV), einer ausgestatteten Küche (Gasherd, klassischer Ofen und Mikrowelle, Kühlschrank, Kaffeemaschine, diverses Geschirr), 1 Badezimmer mit WC. Eine individualisierte Südterrasse mit Markise und direktem Zugang ist mit einem Terrassentisch zugänglich."
        ],
        "en": [
          "First floor: bedroom (1 bed 140-190 cm), living room with sofa bed (TV), fully-equipped kitchen (gas hob, conventional and microwave ovens, fridge, coffee maker, crockery), 1 bathroom with WC. An individualized south-facing terrace with direct-access awning is accessible with terrace table."
        ],
        "it": [
          "Piano terra: camera da letto (1 letto da 140-190 cm), soggiorno con divano letto (TV), cucina attrezzata (piano cottura a gas, forno tradizionale e a microonde, frigorifero, macchina per il caffè, stoviglie), 1 bagno con doccia e WC. Una terrazza individuale esposta a sud con accesso diretto e cieco è accessibile con un tavolo da terrazza."
        ],
        "fr": [
          "En rez-de-chaussée comprenant : une chambre (1 lit 140-190 cm), un salon avec canapé convertible (TV), une cuisine équipée (plaque à gaz, four classique et four micro-ondes, frigidaire, cafetière électrique, vaisselle diverse), 1 salle d'eau avec WC. Une terrasse plein sud individualisée avec store en accès direct est accessible avec table de terrasse."
        ],
        "es": [
          "Planta baja: dormitorio (1 x cama de 140-190 cm), salón con sofá cama (TV), cocina equipada (placa de gas, hornos convencional y microondas, nevera, cafetera, vajilla), 1 cuarto de ducha con WC. Una terraza individual orientada al sur con persiana de acceso directo es accesible con una mesa de terraza."
        ],
        "nl": [
          "Begane grond: slaapkamer (1 x 140-190 cm bed), woonkamer met slaapbank (TV), ingerichte keuken (gasfornuis, conventionele en magnetron ovens, koelkast, koffiezetapparaat, servies), 1 badkamer met douche en WC. Een individueel terras op het zuiden met directe toegang blind is toegankelijk met een terrastafel."
        ]
      },
      "@type": [
        "Description"
      ],
