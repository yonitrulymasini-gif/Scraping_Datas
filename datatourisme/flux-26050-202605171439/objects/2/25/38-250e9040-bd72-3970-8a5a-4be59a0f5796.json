  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2ca223e3-28c3-3b21-8273-03a3cb9e807d",
      "dc:description": {
        "de": [
          "Genießen Sie bei Antoine und Mélanie eine hausgemachte Küche, die von lokalen Produkten inspiriert ist, in einer gemütlichen Umgebung. Dazu gibt es Cocktails, regionale Biere und eine Auswahl an Rum.\nTerrasse mit Meerblick."
        ],
        "en": [
          "At Antoine and Mélanie's, enjoy home cooking inspired by local produce, in a warm setting, with cocktails, regional beers and a selection of rums.\nSea view terrace."
        ],
        "it": [
          "Da Antoine e Mélanie potrete gustare una cucina casalinga ispirata ai prodotti locali, in un ambiente accogliente, con cocktail, birre regionali e una selezione di rum.\nTerrazza con vista sul mare."
        ],
        "fr": [
          "Chez Antoine et Mélanie, profitez d'une cuisnine maison inspirée de produits locaux, dans un cadre chaleureux, avec cocktails, bères régionales et une selection de rhum.\nTerrasse Vue Mer."
        ],
        "es": [
          "En Antoine y Mélanie's, disfrute de una cocina casera inspirada en los productos locales, en un ambiente cálido, con cócteles, cervezas regionales y una selección de ron.\nTerraza con vistas al mar."
        ],
        "nl": [
          "Bij Antoine en Mélanie's kunt u genieten van huisgemaakte gerechten geïnspireerd door lokale producten, in een warme omgeving, met cocktails, regionale bieren en een selectie rum.\nTerras met uitzicht op zee."
        ]
      },
