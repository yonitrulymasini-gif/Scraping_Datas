  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7e43c098-7a85-342b-aec2-5850238abe67",
      "dc:description": {
        "de": [
          "Von Paul Maisonneuve, Erzähler und Schriftsteller. Mit Märchen, Legenden und Glaubensvorstellungen wagt sich die Erzählung um Menhire, Dolmen, Feen und Korporane herum... Humor und Träume, begleitet von einer kleinen Drehorgel. Nur für UTL-Mitglieder, Mitgliedschaft 30 ? pro Jahr. 14.30 Uhr."
        ],
        "en": [
          "By Paul Maisonneuve, storyteller and writer. With tales, legends and beliefs, the story ventures around menhirs, dolmens, fairies and korrigans... Humor and dreams accompanied by a small barrel organ. UTL members only, annual membership 30? At 2.30pm."
        ],
        "it": [
          "Di Paul Maisonneuve, narratore e scrittore. Con racconti, leggende e credenze, la storia si avventura tra menhir, dolmen, fate e korrigan... Umorismo e sogni accompagnati da un organetto. Solo per i soci UTL, iscrizione annuale 30? Alle 14.30."
        ],
        "fr": [
          "Par Paul Maisonneuve, conteur, écrivain. Avec des contes, des légendes, des croyances, la racontée s'aventure autour des menhirs, dolmens, fées et korrigans... De l'humour et du rêve accompagnés par un petit orgue de Barbarie. Réservé aux adhérents UTL, adhésion 30 € par an. A 14h30."
        ],
        "es": [
          "Por Paul Maisonneuve, narrador y escritor. Con cuentos, leyendas y creencias, la historia se aventura alrededor de menhires, dólmenes, hadas y korrigans... Humor y sueños acompañados de un pequeño organillo. Sólo para miembros de UTL, cuota anual 30? A las 14.30 h."
        ],
        "nl": [
          "Door Paul Maisonneuve, verhalenverteller en schrijver. Met verhalen, legendes en geloofsovertuigingen gaat het verhaal rond menhirs, dolmens, feeën en korrigans... Humor en dromen begeleid door een klein draaiorgel. Alleen voor UTL-leden, jaarlijks lidmaatschap 30? Om 14.30 uur."
        ]
      },
