      "dc:description": {
        "de": [
          "Der Club des dauphins bietet: Wassergymnastik im Meer, Paddle :Verleih, Kurse, Wanderungen\r\nFortgeschrittenenkurs Schwimmen im Meer (Kinder/Erwachsene)\r\nAnfängerkurs zur Rettung der Küste\r\nYoga-Paddeln."
        ],
        "en": [
          "Club des dauphins offers: aquagym at sea, Paddle: rental, courses, excursions\r\nAdvanced swimming course at sea (children/adults)\r\nIntroductory coastal rescue course\r\nYoga-paddle."
        ],
        "it": [
          "Il Club des Dauphins propone: aquagym in mare, Paddle: noleggio, lezioni, passeggiate, ecc\r\nCorso di nuoto avanzato in mare (bambini/adulti)\r\nCorso introduttivo di salvataggio costiero\r\nYoga-paddle."
        ],
        "fr": [
          "Le club des dauphins propose: aquagym en mer, Paddle :location, cours, randonnées\r\nStage perfectionnement natation en mer (enfants/adultes)\r\nStage initiation sauvetage côtier \r\nYoga-paddle."
        ],
        "es": [
          "El Club des Dauphins ofrece: aquagym en el mar, Paddle: alquiler, clases, paseos, etc\r\nCurso avanzado de natación en el mar (niños/adultos)\r\nCurso de iniciación al salvamento costero\r\nYoga-pádel."
        ],
        "nl": [
          "De Club des Dauphins biedt: aquagym op zee, peddelen: verhuur, lessen, wandelingen, enz\r\nGevorderde zwemcursus op zee (kinderen/volwassenen)\r\nInleidende kustreddingscursus\r\nYoga peddelen."
        ]
      },
