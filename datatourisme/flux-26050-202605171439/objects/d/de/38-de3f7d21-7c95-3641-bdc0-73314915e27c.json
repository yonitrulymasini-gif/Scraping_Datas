  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6f4d6f18-7a9a-3e8c-8ce9-c4fb2524c667",
      "dc:description": {
        "de": [
          "Lust auf einen kleinen Ausflug in den historischen Stadtkern von Ploërmel? Im gemütlichen Studio des remparts können Sie die Stadt und den nahe gelegenen Lac au Duc erkunden."
        ],
        "en": [
          "Looking for a little getaway in the historic heart of Ploërmel? The cosy studio des remparts is the perfect place to discover the city and its nearby Lac au Duc."
        ],
        "it": [
          "Avete voglia di una breve vacanza nel cuore storico di Ploërmel? Lo studio des remparts è un luogo particolarmente accogliente per scoprire la città e il suo Lac au Duc, a pochi passi."
        ],
        "fr": [
          "Envie d'une petite escapade dans le coeur historique de Ploërmel ? Le studio des remparts, particulièrement cosy, vous permettra de découvrir la cité ainsi que son lac au Duc situé à deux pas."
        ],
        "es": [
          "¿Le apetece una escapada al centro histórico de Ploërmel? El estudio des remparts es un lugar especialmente acogedor para descubrir la ciudad y su Lac au Duc, a dos pasos."
        ],
        "nl": [
          "Zin in een korte vakantie in het historische hart van Ploërmel? De studio des remparts is een bijzonder gezellige plek om de stad en het Lac au Duc te ontdekken, op een steenworp afstand."
        ]
      },
