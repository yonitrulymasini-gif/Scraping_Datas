      "dc:description": {
        "de": [
          "Kleiner Familienstrand an der Bucht von Quiberon. Achtung: Bei Flut ist der Strand vollständig bedeckt! Parkplatz und WC in der Nähe."
        ],
        "en": [
          "Small family beach on the Quiberon Bay side. Beware, at high tide, the beach is completely covered! Parking and WC nearby."
        ],
        "it": [
          "Piccola spiaggia per famiglie, sul lato della baia di Quiberon. Attenzione, con l'alta marea la spiaggia è completamente coperta! Parcheggio e WC nelle vicinanze."
        ],
        "fr": [
          "Petite plage familiale, côté Baie de Quiberon. Attention, à marée haute, la plage est entièrement recouverte! Parking et WC à proximité."
        ],
        "es": [
          "Pequeña playa familiar, en el lado de la Bahía de Quiberon. Cuidado, con la marea alta, la playa está completamente cubierta Aparcamiento y WC cercanos."
        ],
        "nl": [
          "Klein familiestrand, aan de kant van de baai van Quiberon. Pas op, bij vloed is het strand volledig bedekt! Parkeerplaats en WC in de buurt."
        ]
      },
