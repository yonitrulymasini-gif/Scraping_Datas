  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/fd6094b8-1ae4-345a-9281-c014444ffb31",
      "dc:description": {
        "de": [
          "Vollständig renovierter ehemaliger Gutshof, ideal für Liebhaber alter Steine und für Ruhesuchende, inmitten eines Waldgebiets mit bukolischem Charme."
        ],
        "en": [
          "Completely renovated former manor farm, ideal for lovers of old stones and peace and quiet, in the heart of a wooded area with bucolic charm."
        ],
        "it": [
          "Ex casa padronale completamente ristrutturata, ideale per gli amanti della pietra antica e della tranquillità, nel cuore di un'area boschiva dal fascino bucolico."
        ],
        "fr": [
          "Ancienne ferme-manoir entièrement rénovée, idéale pour les amoureux de vieilles pierres et pour les amateurs de calme, au cœur d'un espace boisé au charme bucolique."
        ],
        "nl": [
          "Volledig gerenoveerd voormalig herenhuis, ideaal voor liefhebbers van oude stenen en rust, in het hart van een bosrijke omgeving met bucolische charme."
        ],
        "es": [
          "Antigua casa solariega completamente renovada, ideal para los amantes de la piedra antigua y la tranquilidad, en el corazón de una zona boscosa con encanto bucólico."
        ]
      },
      "@type": [
        "Description"
