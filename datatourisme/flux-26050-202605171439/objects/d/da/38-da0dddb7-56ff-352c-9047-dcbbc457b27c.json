  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/fc4681d5-ae3e-359b-aa86-a860f8dd24c6",
      "dc:description": {
        "de": [
          "Im Stadtzentrum, gegenüber dem großen Strand und in der Nähe des Seebahnhofs, empfängt Sie das Le Corsaire in seinen Räumen und auf seiner Terrasse mit Meerblick. Qualitätsküche, die aus frischen Produkten zubereitet wird."
        ],
        "en": [
          "In the town centre, opposite the large beach and close to the ferry terminal, Le Corsaire welcomes you to its rooms and terrace with a sea view. Quality cuisine made from fresh products."
        ],
        "it": [
          "Nel centro della città, di fronte alla grande spiaggia e vicino al terminal dei traghetti, Le Corsaire vi accoglie nelle sue camere e nella sua terrazza con vista sul mare. Cucina di qualità a base di prodotti freschi."
        ],
        "fr": [
          "En centre ville, face à la grande plage et proche de la gare maritime, le Corsaire vous accueille dans ses salles et sa terrasse, vue mer. Cuisine de qualité élaborée à partir de produits frais."
        ],
        "nl": [
          "In het stadscentrum, tegenover het grote strand en dicht bij de veerbootterminal, verwelkomt Le Corsaire u in zijn kamers en terras met uitzicht op zee. Kwaliteitskeuken gemaakt van verse producten."
        ],
        "es": [
          "En el centro de la ciudad, frente a la gran playa y cerca de la terminal del ferry, Le Corsaire le da la bienvenida a sus habitaciones y a su terraza con vistas al mar. Cocina de calidad elaborada con productos frescos."
        ]
      },
      "@type": [
        "Description"
      ],
