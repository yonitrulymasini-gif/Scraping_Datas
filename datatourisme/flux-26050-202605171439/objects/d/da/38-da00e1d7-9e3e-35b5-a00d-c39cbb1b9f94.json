  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5055f1ed-72ae-3da3-b18f-5c5408f04e14",
      "dc:description": {
        "de": [
          "Café Caillou ist eine Kaffeetheke in Saint-Pierre-Quiberon, die nur wenige Schritte vom Orangenhafen entfernt liegt.\n\nWir sind dienstags bis sonntags von 8:30 bis 18:00 Uhr geöffnet und bieten eine abwechslungsreiche Speisekarte mit Kaffee, süßem und herzhaftem Frühstück sowie selbstgemachten Sandwiches und Kuchen."
        ],
        "en": [
          "Café Caillou is a café counter located in Saint-Pierre-Quiberon, just a few steps from the orange port.\n\nOpen Tuesday to Sunday from 8:30am to 6pm, we offer a varied menu of coffees, sweet and savory breakfasts, cooked sandwiches and cakes."
        ],
        "it": [
          "Il Café Caillou è un banco bar situato a Saint-Pierre-Quiberon, a pochi passi dal Port d'Orange.\n\nAperto dal martedì alla domenica dalle 8.30 alle 18.00, offre un menù vario di caffè, colazioni dolci e salate, panini e torte pronte."
        ],
        "fr": [
          "Café Caillou est un café comptoir situé à Saint-Pierre-Quiberon à quelques pas du port d'orange. \n\nOuvert du mardi au dimanche de 8h30 à 18h, nous proposons une carte variée de cafés, petits-déjeuners sucrés et salés ainsi que des sandwichs cuisinés et des gâteaux."
        ],
        "es": [
          "El Café Caillou es una cafetería situada en Saint-Pierre-Quiberon, a dos pasos del Puerto de Orange.\n\nAbierto de martes a domingo de 8.30 a 18.00 h, ofrecemos una variada carta de cafés, desayunos dulces y salados, así como bocadillos y pasteles preparados."
        ],
        "nl": [
          "Café Caillou is een cafécounter in Saint-Pierre-Quiberon, op een steenworp afstand van de Port d'Orange.\n\nWij zijn geopend van dinsdag tot zondag van 8.30 tot 18.00 uur en bieden een gevarieerd menu met koffie, zoete en hartige ontbijten en kant-en-klare sandwiches en gebak."
        ]
      },
