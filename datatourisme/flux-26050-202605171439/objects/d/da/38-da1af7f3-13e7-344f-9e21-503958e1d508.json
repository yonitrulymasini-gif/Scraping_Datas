  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/21770086-26de-3f27-9dd1-cc27aec6508f",
      "dc:description": {
        "de": [
          "In diesem kleinen Paradies empfangen Sie Thierry und Marie, umgeben von ihren Tieren, für einen Aufenthalt voller Abwechslung. Die Zimmer sind in den Farben der Reisen der Besitzer gehalten."
        ],
        "en": [
          "In this little paradise, Thierry and Marie, surrounded by their animals, welcome you for an exotic stay. The rooms are decorated in the colors of the owners' travels."
        ],
        "it": [
          "In questo piccolo paradiso, Thierry e Marie, circondati dai loro animali, vi accolgono per un cambio di scenario. Le camere sono decorate con i colori dei viaggi dei proprietari."
        ],
        "fr": [
          "Dans ce petit paradis, Thierry et Marie, entourés par leurs animaux, vous accueillent pour un séjour dépaysant. Les chambres sont aux couleurs des voyages des propriétaires."
        ],
        "nl": [
          "In dit kleine paradijs verwelkomen Thierry en Marie, omringd door hun dieren, je voor een verandering van omgeving. De kamers zijn ingericht in de kleuren van de reizen van de eigenaren."
        ],
        "es": [
          "En este pequeño paraíso, Thierry y Marie, rodeados de sus animales, le dan la bienvenida para cambiar de aires. Las habitaciones están decoradas con los colores de los viajes de los propietarios."
        ]
      },
