  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/59e58f08-e068-33d3-80cb-911c8ede3566",
      "dc:description": {
        "de": [
          "In einem 20 ha großen, öffentlich zugänglichen Park, 1,5 km von Erdeven, 3 km von den Stränden entfernt, 8 aneinandergrenzende Unterkünfte für 2 bis 4 Personen: Küche, Wohn-/Esszimmer, Badezimmer, WC. Terrasse."
        ],
        "en": [
          "In a 20ha park open to the public, 1.5km from Erdeven, 3km from the beaches, 8 semi-detached gîtes for 2 to 4 people: kitchen, living room, bathroom, WC. Terrace."
        ],
        "it": [
          "In 20 ettari di parco aperto al pubblico, a 1,5 km da Erdeven, a 3 km dalle spiagge, 8 gîtes bifamiliari per 2-4 persone: cucina, soggiorno/salotto, bagno, WC. Terrazza."
        ],
        "fr": [
          "Dans un parc de 20ha ouvert au public, à 1,5km d'Erdeven, 3km des plages, 8 gîtes mitoyens de 2 à 4 personnes : cuisine, salon/séjour, salle de bain, WC. Terrasse."
        ],
        "nl": [
          "In een openbaar park van 20 ha, op 1,5 km van Erdeven, op 3 km van de stranden, 8 geschakelde gîtes voor 2 tot 4 personen: keuken, salon/woonkamer, badkamer, WC. Terras."
        ],
        "es": [
          "En 20 ha de parque abierto al público, a 1,5 km de Erdeven, a 3 km de las playas, 8 casas rurales adosadas para 2 a 4 personas: cocina, salón/sala de estar, cuarto de baño, WC. Terraza."
        ]
      },
