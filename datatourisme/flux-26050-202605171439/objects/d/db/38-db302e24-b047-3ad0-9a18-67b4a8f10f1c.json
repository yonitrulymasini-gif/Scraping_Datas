  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/74e053a3-f1f7-3a6c-99c9-20c73b60793c",
      "dc:description": {
        "de": [
          "Das Château de la Ville Der öffnet für eine freie Besichtigung der vier Räume im Erdgeschoss. Diese Räume sind die charakteristischsten der Renovierung, die 1892-1895 stattfand. Der Park und der Hof sind das ganze Jahr über geöffnet. Von 14:00 bis 17:00 Uhr."
        ],
        "en": [
          "The Château de la Ville Der is open to visitors for a tour of the 4 rooms on the first floor. These are the most characteristic of the 1892-1895 renovation. The park and courtyard are open all year round. Open from 2pm to 5pm."
        ],
        "it": [
          "Il Château de la Ville Der è aperto per una visita gratuita delle 4 sale al piano terra. Sono le più caratteristiche della ristrutturazione avvenuta nel 1892-1895. Il parco e il cortile sono aperti tutto l'anno. Aperto dalle 14:00 alle 17:00."
        ],
        "fr": [
          "Le Château de la Ville Der ouvre pour une visite libre des 4 pièces du rez-de-chaussée. Celles-ci sont les plus caractéristiques de la rénovation ayant eu lieu en 1892-1895. Le parc et la cour sont quant à eux ouverts toute l'année. De 14h à 17h."
        ],
        "nl": [
          "Het Château de la Ville Der is open voor een gratis rondleiding door de 4 kamers op de begane grond. Deze zijn het meest karakteristiek voor de renovatie die plaatsvond in 1892-1895. Het park en de binnenplaats zijn het hele jaar geopend. Open van 14.00 tot 17.00 uur."
        ],
        "es": [
          "El Château de la Ville Der está abierto para una visita gratuita de las 4 salas de la planta baja. Son las más características de la renovación que tuvo lugar en 1892-1895. El parque y el patio están abiertos todo el año. Abierto de 14:00 a 17:00 h."
        ]
      },
