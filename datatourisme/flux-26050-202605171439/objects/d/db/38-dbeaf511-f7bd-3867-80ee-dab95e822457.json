  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/416dd2b3-a5e2-3f28-96d5-41e99fb113f6",
      "dc:description": {
        "de": [
          "Gäste- und Designerhaus\nIm Herzen des Städtchens Quelneuc, 10 km von La Gacilly entfernt, empfange ich Sie gerne in einer gemütlichen Atmosphäre für ein Bed & Breakfast und warum nicht für eine Tea Time im Garten."
        ],
        "en": [
          "Guest and designer house\nIt's in the heart of the village of Quelneuc, 10km from La Gacilly, that I'll be delighted to welcome you in a cosy atmosphere for a Bed & Breakfast and why not for a Tea Time in the garden."
        ],
        "it": [
          "Pensione e creatori\nÈ nel cuore del villaggio di Quelneuc, a 10 km da La Gacilly, che sarò lieta di accogliervi in un'atmosfera accogliente per un Bed & Breakfast e, perché no, per un Tea Time in giardino."
        ],
        "fr": [
          "Maison d'hôtes et de créateurs\nC'est au coeur du bourg de Quelneuc, à 10km de La Gacilly, que je vous recevrai avec plaisir dans une ambiance cosy pour un Bed & Breakfast et pourquoi pas pour un Tea Time au jardin."
        ],
        "nl": [
          "Pension en makers\nHet is in het hart van het dorp Quelneuc, op 10 km van La Gacilly, dat ik u met veel plezier zal verwelkomen in een gezellige sfeer voor een Bed & Breakfast en waarom niet voor een Tea Time in de tuin."
        ],
        "es": [
          "Casa de huéspedes y creadores\nEs en el corazón del pueblo de Quelneuc, a 10 km de La Gacilly, que estaré encantado de darle la bienvenida en un ambiente acogedor para un Bed & Breakfast y por qué no para una hora del té en el jardín."
        ]
      },
      "@type": [
        "Description"
      ],
