      "@id": "https://data.datatourisme.fr/3b80e4a4-7854-338d-8121-1d6e3ce4918d",
      "dc:description": {
        "de": [
          "Schule für Surfen und Wellenreiten. Angegliedert an die Fédération Française de Surf et de Kite-surf. Anerkannt von Jeunesse et Sports.Club ganzjährig geöffnet. Schule während der Saison. Empfang von Einzelpersonen, Gruppen und Schulen. Einführungskurse, Training und Perfektionierung für Kinder und Erwachsene."
        ],
        "en": [
          "Surf school. Affiliated to the French Federation of Surf and Kite-surf. Club open all year round. Seasonal school. Individuals, groups and schools welcome. Introductory, training and improvement sessions for children and adults."
        ],
        "it": [
          "Scuola di surf. Affiliato alla Federazione Francese di Surf e Kite-surf. Club aperto tutto l'anno. Scuola stagionale. Singoli, gruppi e scuole sono i benvenuti. Sessioni di introduzione, formazione e perfezionamento per bambini e adulti."
        ],
        "fr": [
          "Ecole de surf. Affiliée à la Fédération Française de Surf et de Kite-surf. Agréé Jeunesse et Sports.Club ouvert toute l'année . Ecole saisonnière. Accueil particuliers, groupes, scolaires. Séances d'initiation, d'entraînement et de perfectionnement pour enfants et adultes."
        ],
        "nl": [
          "Surfschool. Aangesloten bij de Franse Surf en Kite-surf Federatie. Club het hele jaar geopend. Seizoensschool. Individuen, groepen en scholen zijn welkom. Kennismakings-, trainings- en verbeteringsessies voor kinderen en volwassenen."
        ],
        "es": [
          "Escuela de surf. Afiliado a la Federación Francesa de Surf y Kite-surf. Club abierto todo el año. Escuela de temporada. Se aceptan individuos, grupos y escuelas. Sesiones de iniciación, formación y perfeccionamiento para niños y adultos."
        ]
      },
