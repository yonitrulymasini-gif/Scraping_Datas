  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/54d94652-c370-3bfe-a6c7-7996a9f7a5b7",
      "dc:description": {
        "de": [
          "Ehemaliges Gasthaus aus dem Jahr 1658. Eine gemütliche Einrichtung und eine Feinschmeckerküche erwarten Sie, im Winter am Kamin und im Sommer auf der Terrasse. Das berühmte Andouille-Purée wird auf Vorbestellung angeboten!"
        ],
        "en": [
          "Former inn dating from 1658. A warm decor and gourmet cuisine await you, by the fireside in winter and on the terrace in summer. The famous andouille-purée is available on reservation!"
        ],
        "it": [
          "Antica locanda del 1658. Vi aspettano un ambiente accogliente e una cucina gourmet, accanto al camino in inverno e sulla terrazza in estate. La famosa andouille-purée è disponibile su prenotazione!"
        ],
        "fr": [
          "Ancienne auberge de 1658. Un décor chaleureux et une cuisine gourmande vous attend, au coin du feu l'hiver et sur la terrasse l'été. La fameuse andouille-purée est proposée sur réservation !"
        ],
        "nl": [
          "Voormalige herberg uit 1658. Een warm kader en een gastronomische keuken wachten op je, bij het haardvuur in de winter en op het terras in de zomer. De beroemde andouille-purée is beschikbaar op reservering!"
        ],
        "es": [
          "Antigua posada de 1658. Un ambiente acogedor y una cocina gastronómica le esperan, junto a la chimenea en invierno y en la terraza en verano. El famoso andouille-purée está disponible previa reserva"
        ]
      },
      "@type": [
        "Description"
      ],
