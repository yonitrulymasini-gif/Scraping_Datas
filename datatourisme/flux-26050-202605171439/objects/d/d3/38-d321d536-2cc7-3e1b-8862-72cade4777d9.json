  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/750b1fbd-f84e-33d4-9ae5-482fbc7fa628",
      "dc:description": {
        "de": [
          "Saint-Philibert, ein kleiner, sehr geselliger Badeort, in dem es sich gut leben lässt. Unser Zigeunerwagen, der in einem Obstgarten in einem kleinen grünen Weiler in ruhiger Lage steht, wird Sie begeistern. Hinweis für Austernliebhaber."
        ],
        "en": [
          "Saint-Philibert, a small, friendly seaside town where life is good. Our gypsy caravan is located in an orchard, in a quiet, leafy hamlet, and is sure to please. Oyster lovers beware."
        ],
        "it": [
          "Saint-Philibert è una piccola e accogliente città di mare dove la vita è bella. La nostra roulotte zingara si trova in un frutteto, nel cuore di un piccolo borgo verde e tranquillo, e vi conquisterà sicuramente. Gli amanti delle ostriche facciano attenzione!"
        ],
        "fr": [
          "Saint-Philibert, petite cité balnéaire très conviviale où il fait bon vivre. Notre roulotte située dans un verger, au sein d'un petit hameau verdoyant, au calme, saura vous séduire. Avis aux amateurs d'huîtres."
        ],
        "nl": [
          "Saint-Philibert is een kleine, vriendelijke badplaats waar het leven goed is. Onze woonwagen staat in een boomgaard in een klein, groen en rustig gehucht. Oesterliefhebbers opgelet!"
        ],
        "es": [
          "Saint-Philibert es una pequeña y acogedora ciudad costera donde se vive bien. Nuestra caravana gitana está situada en un huerto, en una pequeña aldea verde y tranquila. Atención a los amantes de las ostras."
        ]
      },
      "@type": [
        "Description"
      ],
