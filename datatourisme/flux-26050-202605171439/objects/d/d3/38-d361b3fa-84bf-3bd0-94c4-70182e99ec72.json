      "dc:description": {
        "de": [
          "Unser Restaurant befindet sich seit 20 Jahren im Herzen von Gourin und empfängt Sie an 6 Tagen in der Woche. Vor Ort oder zum Mitnehmen."
        ],
        "en": [
          "Located in the heart of Gourin for 20 years, our restaurant welcomes you 6 days a week. On the spot or to take away."
        ],
        "it": [
          "Situato nel cuore di Gourin da 20 anni, il nostro ristorante vi accoglie 6 giorni alla settimana. Sul posto o da asporto."
        ],
        "fr": [
          "Situé en plein cœur de Gourin depuis 20 ans, notre restaurant vous accueille 6 jours/7. Sur place ou à emporter."
        ],
        "es": [
          "Situado en el corazón de Gourin desde hace 20 años, nuestro restaurante le da la bienvenida 6 días a la semana. En el acto o para llevar."
        ],
        "nl": [
          "Ons restaurant ligt al 20 jaar in het hart van Gourin en verwelkomt je 6 dagen per week. Ter plaatse of om mee te nemen."
        ]
