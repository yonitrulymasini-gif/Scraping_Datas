  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b6113546-96b9-3f04-86aa-0cfde1a548a2",
      "dc:description": {
        "de": [
          "Das Restaurant-Bar le Ty Blomen bietet Ihnen eine traditionelle französische Küche mit hochwertigen Produkten der Saison. Alle unsere Gerichte sind hausgemacht. Es gibt ein Tagesmenü. Das Restaurant verfügt über einen großen Saal und eine Veranda."
        ],
        "en": [
          "The Ty Blomen Restaurant-Bar serves traditional French cuisine using quality seasonal produce. All our dishes are home-made. Daily menu. The restaurant has a large dining room and a veranda."
        ],
        "it": [
          "Il ristorante-bar Ty Blomen propone una cucina tradizionale francese a base di prodotti stagionali di qualità. Tutti i nostri piatti sono fatti in casa. Menu del giorno. Il ristorante dispone di un'ampia sala da pranzo e di una veranda."
        ],
        "fr": [
          "Le Restaurant-Bar le Ty Blomen vous fais découvrir sa cuisine traditionnelle française avec des produits de qualités et de saison. Tout nos plats sont fait maison. Menu du jour. Le restaurant dispose d’une grande salle et d’une véranda."
        ],
        "nl": [
          "Restaurant-Bar Ty Blomen serveert traditionele Franse gerechten met seizoensproducten van hoge kwaliteit. Al onze gerechten zijn huisgemaakt. Menu van de dag. Het restaurant heeft een grote eetzaal en een veranda."
        ],
        "es": [
          "El restaurante-bar Ty Blomen sirve cocina tradicional francesa con productos de temporada de calidad. Todos nuestros platos son caseros. Menú del día. El restaurante dispone de un amplio comedor y una veranda."
        ]
      },
      "@type": [
        "Description"
