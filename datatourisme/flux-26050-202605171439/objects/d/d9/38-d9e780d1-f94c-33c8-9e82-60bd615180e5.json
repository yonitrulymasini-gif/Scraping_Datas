  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/1a232fc6-654e-3844-b829-4718897d915a",
      "dc:description": {
        "de": [
          "Crêperie in Carnac, 2 Schritte von den Stränden entfernt.\n\nGalettes aus Buchweizen mit regionalen und handwerklichen Produkten in einem gemütlichen Lokal am Kaminfeuer oder auf der Sonnenterrasse.\n\nCidre und bretonische Getränke.\n\nReservierungen sind möglich."
        ],
        "en": [
          "Crêperie located in Carnac, 2 steps from the beaches.\n\nBuckwheat pancakes with regional and artisanal products in a cosy setting by the fireplace or on the sunny terrace.\n\nCider and Breton drinks.\n\nReservations possible."
        ],
        "it": [
          "Creperia situata a Carnac, a 2 passi dalle spiagge.\n\nFrittelle di grano saraceno preparate con prodotti regionali e tradizionali in un ambiente accogliente accanto al fuoco o sulla terrazza soleggiata.\n\nSidro e bevande bretoni.\n\nPossibilità di prenotazione."
        ],
        "fr": [
          "Crêperie située à Carnac à 2 pas des plages. \n\nGalettes de blé noir avec des produits régionaux et artisanaux dans un lieu chaleureux au coin du feu de cheminée ou en terrasse ensoleillée. \n\nCidre et boissons bretonnes. \n\nRéservation possible."
        ],
        "nl": [
          "Creperie gelegen in Carnac, op 2 stappen van de stranden.\n\nBoekweitpannenkoeken gemaakt met regionale en traditionele producten in een gezellige omgeving bij het vuur of op het zonnige terras.\n\nCider en Bretonse dranken.\n\nReserveren mogelijk."
        ],
        "es": [
          "Crepería situada en Carnac, a 2 pasos de las playas.\n\nTortitas de trigo sarraceno elaboradas con productos regionales y tradicionales en un ambiente acogedor junto al fuego o en la soleada terraza.\n\nSidra y bebidas bretonas.\n\nPosibilidad de reservar."
        ]
      },
      "@type": [
        "Description"
      ],
