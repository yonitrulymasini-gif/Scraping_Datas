  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/14dd6e3a-0694-3188-bdbb-f9b085180bc9",
      "dc:description": {
        "de": [
          "Dieses Restaurant bietet eine traditionelle \"hausgemachte\" Küche. Der Chefkoch kann Ihnen Krustentiere, Fisch und Fleisch anbieten, das vom örtlichen Metzger geliefert wird. Kontaktieren Sie uns für die Organisation Ihrer Geburtstags- oder Familienessen..."
        ],
        "en": [
          "This restaurant offers traditional \"home-made\" cuisine. The chef can offer you shellfish, fish and meat supplied by the local butcher. Contact us to organize your birthday or family meal..."
        ],
        "it": [
          "Questo ristorante offre una cucina tradizionale e casalinga. Lo chef può offrirvi crostacei, pesce e carne forniti dal macellaio locale. Contattateci per organizzare il vostro compleanno o il vostro pranzo in famiglia..."
        ],
        "fr": [
          "Ce restaurant offre une cuisine traditionnelle « faite maison ». Le chef pourra vous proposer des crustacés, des poissons, de la viande fournie par le boucher local. Contactez nous pour l'organisation de vos repas d'anniversaire, de famille..."
        ],
        "es": [
          "Este restaurante ofrece cocina tradicional y casera. El chef puede ofrecerle marisco, pescado y carne suministrados por el carnicero local. Póngase en contacto con nosotros para organizar su cumpleaños o una comida familiar..."
        ],
        "nl": [
          "Dit restaurant biedt traditionele, huisgemaakte gerechten. De chef kan je schelpdieren, vis en vlees van de plaatselijke slager aanbieden. Neem contact met ons op om uw verjaardag of familiediner te organiseren..."
        ]
      },
      "@type": [
        "Description"
