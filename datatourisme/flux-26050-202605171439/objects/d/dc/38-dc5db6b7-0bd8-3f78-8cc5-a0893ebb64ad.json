  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/31cfcc24-0c9b-3593-b2ee-4251d60e65ba",
      "dc:description": {
        "de": [
          "Bar, Restaurant, Cocktails mit den Füßen im Wasser gegenüber der Insel Saint-Cado in Belz.\nMeeresfrüchte, Fisch ... Snacks: Crêpes, handgemachtes Eis...\nMittags und abends geöffnet.\nEntspannte Atmosphäre und DJ-Set in der Sommersaison."
        ],
        "en": [
          "Waterfront bar, restaurant and cocktails on the Ile de Saint-Cado in Belz.\nSeafood, fish... Snack breaks: crêpes, homemade ice creams...\nOpen for lunch and dinner.\nRelaxed atmosphere and DJ set in summer."
        ],
        "it": [
          "Bar, ristorante, cocktail sul lungomare di fronte all'Ile de Saint-Cado a Belz.\nFrutti di mare, pesce... Spuntini: crêpes, gelati artigianali...\nAperto a pranzo e a cena.\nAtmosfera rilassata e DJ set in estate."
        ],
        "fr": [
          "Bar, restaurant, cocktails les pieds dans l'eau situé face à l'Île de Saint-Cado à Belz.\nFruits de mer, poissons... Pause goûter : crêpes, glaces artisanales...\nOuvert midi et soir.\nAmbiance décontractée et DJ set en saison estivale."
        ],
        "es": [
          "Bar, restaurante, cócteles en el paseo marítimo frente a la isla de Saint-Cado en Belz.\nMarisco, pescado... Aperitivos: crepes, helados caseros...\nAbierto para almuerzos y cenas.\nAmbiente relajado y DJ set en verano."
        ],
        "nl": [
          "Bar, restaurant, cocktails aan de waterkant tegenover het Ile de Saint-Cado in Belz.\nZeevruchten, vis... Snackpauzes: crêpes, huisgemaakt ijs...\nOpen voor lunch en diner.\nOntspannen sfeer en dj-set in de zomer."
        ]
      },
      "@type": [
        "Description"
      ],
