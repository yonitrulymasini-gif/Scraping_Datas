      "dc:description": {
        "de": [
          "Der Campingplatz Pont Salmon bietet von Mai bis September einen Fahrradverleih (Mountainbikes für Erwachsene und Kinder), Kinderanhänger und den Verleih von Helmen und Kindersitzen."
        ],
        "en": [
          "The Pont Salmon campsite offers bicycle rental (VTC adults and children), children's trailers and the loan of helmets and baby seats, from May to September."
        ],
        "it": [
          "Il campeggio Pont Salmon offre il noleggio di biciclette (VTC adulti e bambini), rimorchi per bambini e il prestito di caschi e seggiolini, da maggio a settembre."
        ],
        "fr": [
          "Le camping du Pont Salmon propose la location de vélos (VTC adultes et enfants), remorques enfants et le prêt de casques et sièges bébé, de mai à septembre."
        ],
        "es": [
          "El camping Pont Salmon ofrece alquiler de bicicletas (VTC adultos y niños), remolques para niños y préstamo de cascos y sillas para bebés, de mayo a septiembre."
        ],
        "nl": [
          "De camping Pont Salmon biedt fietsverhuur (VTC volwassenen en kinderen), kinderwagens en de uitleen van helmen en babyzitjes, van mei tot september."
        ]
      },
