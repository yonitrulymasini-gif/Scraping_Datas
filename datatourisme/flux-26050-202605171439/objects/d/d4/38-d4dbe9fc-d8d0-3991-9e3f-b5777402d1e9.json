  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2aa9c044-897d-3a95-9ec9-1c83fd2039bd",
      "dc:description": {
        "de": [
          "Anatolie Kebab liegt in der Nähe des historischen Zentrums von Josselin und bietet Ihnen Schnellgerichte an. Auf dem Teller oder als Sandwich, vor Ort oder zum Mitnehmen, können Sie Kebab, Tacos, Panini, Hamburger, Gegrilltes und Salate essen. Geöffnet von Dienstag bis Sonntag von 11:30 bis 14:00 Uhr und von 18:00 bis 22:00 Uhr."
        ],
        "en": [
          "Located near the historic center of Josselin, Anatolie Kebab offers fast food. By the plate or sandwich, on the spot or to take away, you can enjoy kebabs, tacos, paninis, hamburgers, grilled meats and salads. Open Tuesday to Sunday, 11:30am to 2pm and 6pm to 10pm."
        ],
        "it": [
          "Situato vicino al centro storico di Josselin, Anatolie Kebab offre cibo veloce. È possibile mangiare kebab, tacos, panini, hamburger, carne alla griglia e insalate al piatto o come panino, sul posto o da asporto. Aperto dal martedì alla domenica, dalle 11.30 alle 14.00 e dalle 18.00 alle 22.00."
        ],
        "fr": [
          "Situé à proximité du centre historique de Josselin, Anatolie Kebab vous propose une restauration rapide. A l'assiette ou en sandwich, sur place ou à emporter, vous pourrez manger des kebabs, tacos, panini, hamburgers, grillades et salades. Ouvert du mardi au dimanche de 11h30 à 14h et de 18h à 22h."
        ],
        "es": [
          "Situado cerca del centro histórico de Josselin, Anatolie Kebab ofrece comida rápida. Se pueden comer kebabs, tacos, paninis, hamburguesas, carnes a la parrilla y ensaladas por platos o en bocadillo, en el momento o para llevar. Abierto de martes a domingo, de 11.30 a 14.00 y de 18.00 a 22.00."
        ],
        "nl": [
          "Anatolie Kebab ligt vlak bij het historische centrum van Josselin en biedt fastfood. Je kunt er kebab, taco's, panini's, hamburgers, gegrild vlees en salades per bord of als broodje eten, ter plekke of om mee te nemen. Geopend van dinsdag tot zondag van 11.30 tot 14.00 uur en van 18.00 tot 22.00 uur."
        ]
      },
