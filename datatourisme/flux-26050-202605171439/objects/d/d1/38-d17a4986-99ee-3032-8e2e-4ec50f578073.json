  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c7489fbd-63c1-3f0c-87fb-41bf15103116",
      "dc:description": {
        "de": [
          "Das Manoir de Kermain öffnet den ganzen Sommer über wieder seine Außenanlagen mit einer neuen Kreation zum Thema \"Blick\". Öffnen Sie also Ihre Augen weit! Begrüßung durch Carlo Rosolen und Philippe Loyer vom Verein Pour le Patrimoine au Pays du Roi Morvan."
        ],
        "en": [
          "The Manoir de Kermain is once again opening its exteriors throughout the summer with a new creation on the theme of the gaze. So open your eyes wide! Welcome by Carlo Rosolen and Philippe Loyer from the Pour le Patrimoine au Pays du roi Morvan association."
        ],
        "it": [
          "Il Manoir de Kermain apre nuovamente i suoi esterni al pubblico per tutta l'estate con una nuova creazione sul tema dell'occhio. Aprite bene gli occhi! Benvenuto da Carlo Rosolen e Philippe Loyer dell'associazione Pour le Patrimoine au Pays du roi Morvan."
        ],
        "fr": [
          "Le manoir de Kermain ouvre à nouveau ses extérieurs durant tout l’été avec une nouvelle création sur le thème du regard. Alors ouvrez grand les yeux ! Accueil par Carlo Rosolen et Philippe Loyer de l'association Pour le Patrimoine au Pays du roi Morvan."
        ],
        "nl": [
          "Het Manoir de Kermain opent opnieuw zijn exterieur voor het publiek gedurende de zomer met een nieuwe creatie rond het thema van het oog. Dus open je ogen wijd! Welkom door Carlo Rosolen en Philippe Loyer van de vereniging Pour le Patrimoine au Pays du roi Morvan."
        ],
        "es": [
          "El Manoir de Kermain abre de nuevo sus exteriores al público durante todo el verano con una nueva creación sobre el tema de la mirada. ¡Abra bien los ojos! Bienvenida de Carlo Rosolen y Philippe Loyer, de la asociación Pour le Patrimoine au Pays du roi Morvan."
        ]
      },
