  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8fc551c2-5dab-331b-b7f6-f558f0d29a98",
      "dc:description": {
        "de": [
          "Gästezimmer in einer grünen Oase der Ruhe in der Nähe von Malestroit, einer kleinen Stadt mit Charakter, wo die Oust und der Kanal von Nantes nach Brest fließen und sich umarmen."
        ],
        "en": [
          "Bed and breakfast set in a green haven of peace near Malestroit, a small town full of character, where the Oust river and the Nantes-Brest canal flow and intertwine."
        ],
        "it": [
          "Bed and breakfast situato in un'oasi di pace verde vicino a Malestroit, una piccola città piena di carattere, dove scorrono e si intrecciano il fiume Oust e il canale Nantes-Brest."
        ],
        "fr": [
          "Chambres d'hôtes situées dans un havre de paix verdoyant à proximité de Malestroit, petite cité de caractère, où coulent et s'enlacent l'Oust et le canal de Nantes à Brest."
        ],
        "es": [
          "Bed and breakfast situado en un remanso de paz verde cerca de Malestroit, una pequeña ciudad llena de carácter, donde el río Oust y el canal Nantes-Brest fluyen y se entrelazan."
        ],
        "nl": [
          "Bed and breakfast in een oase van groene rust in de buurt van Malestroit, een karaktervol stadje waar de rivier de Oust en het kanaal Nantes-Brest door elkaar stromen."
        ]
      },
