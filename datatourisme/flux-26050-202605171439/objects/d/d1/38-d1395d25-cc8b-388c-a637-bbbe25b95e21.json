  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/689605a3-34fc-3925-ac67-2aa0d2e77561",
      "dc:description": {
        "de": [
          "Charmantes Bauernhaus im Herzen der Bretagne, in der Nähe des buddhistischen Zentrums Drupka Plouray. Es befindet sich in dem grünen Weiler Kerguzul. Das Haus ist komfortabel mit einem Hauptraum, an den sich eine voll ausgestattete Küche anschließt. Das Haus verfügt über eine Terrasse, die sich zu einem großen Garten hin öffnet."
        ],
        "en": [
          "Charming longère in the heart of Brittany, near the Drupka Plouray Buddhist center. It is located in the leafy hamlet of Kerguzul. The house is comfortable, with a main room adjoining a fully-equipped kitchen. It has a terrace opening onto a large garden."
        ],
        "it": [
          "Incantevole casale nel cuore della Bretagna, vicino al centro buddista Drupka Plouray. Si trova nella verdeggiante frazione di Kerguzul. La casa è confortevole, con una sala principale adiacente a una cucina attrezzata. Dispone di una terrazza che si apre su un ampio giardino."
        ],
        "fr": [
          "Charmante longère au coeur de la Bretagne, près du centre bouddhique Drupka Plouray. Elle est située dans le hameau verdoyant de Kerguzul. La maison est confortable avec une pièce principale attenant à une cuisine équipée. Elle dispose d'une terrasse ouvrant sur un grand jardin."
        ],
        "nl": [
          "Charmante boerderij in het hart van Bretagne, vlakbij het boeddhistische centrum Drupka Plouray. Het is gelegen in het lommerrijke gehucht Kerguzul. Het huis is comfortabel, met een grote kamer die grenst aan een ingerichte keuken. Het heeft een terras dat uitkomt op een grote tuin."
        ],
        "es": [
          "Caserío con encanto en el corazón de Bretaña, cerca del centro budista Drupka Plouray. Se encuentra en la frondosa aldea de Kerguzul. La casa es confortable, con una habitación principal contigua a una cocina equipada. Dispone de una terraza que da a un gran jardín."
        ]
      },
      "@type": [
        "Description"
