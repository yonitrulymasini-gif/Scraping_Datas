  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c24bffd6-6f2d-36d3-a599-2e262c04ea89",
      "dc:description": {
        "de": [
          "Unternehmen, das Motor- und Segelboote vermietet.\r\n\r\nMöglichkeit des Empfangs von Gruppen bis zu 250 Personen. Spezialist für maßgeschneiderte Nautik. Aktivitäten für Familien, um die Region zu entdecken.\r\n\r\nVerkauf von neuen und gebrauchten Booten. Verwaltung, Überwinterung, Wartung von Booten von Privatpersonen."
        ],
        "en": [
          "Motorboat and sailboat rental company.\r\n\r\nPossibility of welcoming groups of up to 250 people. Specialized in customized nautical tours. Family activities to discover the region.\r\n\r\nNew and used boat sales. Management, wintering and maintenance of private boats."
        ],
        "it": [
          "Società di noleggio di barche a vela e a motore.\r\n\r\nÈ possibile ospitare gruppi fino a 250 persone. Specialista in attività nautiche su misura. Attività per famiglie alla scoperta della regione.\r\n\r\nVendita di barche nuove e usate. Gestione, invernaggio e manutenzione di imbarcazioni private."
        ],
        "fr": [
          "Société de location de bateau à moteur, à voile.\r\n\r\nPossibilité d'accueil de groupe jusqu'à 250 personnes. Spécialiste du sur-mesure nautique. Activités pour famille, à la découverte de la région. \r\n\r\nVente de bateau neuf et occasion. Gestion, hivernage, entretien de bateau de particulier."
        ],
        "nl": [
          "Verhuurbedrijf van zeil- en motorboten.\r\n\r\nGroepen tot 250 personen kunnen worden ondergebracht. Specialist in nautische activiteiten op maat. Gezinsactiviteiten om de regio te ontdekken.\r\n\r\nVerkoop van nieuwe en gebruikte boten. Beheer, overwintering en onderhoud van privéboten."
        ],
        "es": [
          "Empresa de alquiler de embarcaciones a vela y motor.\r\n\r\nCapacidad para grupos de hasta 250 personas. Especialista en actividades náuticas a medida. Actividades familiares para descubrir la región.\r\n\r\nVenta de embarcaciones nuevas y de ocasión. Gestión, invernaje y mantenimiento de embarcaciones privadas."
        ]
      },
