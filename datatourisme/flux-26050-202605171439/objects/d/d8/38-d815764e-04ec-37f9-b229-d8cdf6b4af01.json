  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8f98592a-989a-370c-8116-d4edb861e12f",
      "dc:description": {
        "de": [
          "Typisches Ferienhaus aus Stein auf dem Land, in ruhiger Lage, für Naturliebhaber. Ein modulierbares Haus für 6 bis 14 Personen mit Garten und Terrasse, ein Ort, um einen angenehmen Aufenthalt mit der Familie oder mit Freunden zu verbringen. Wanderungen und architektonische Sehenswürdigkeiten in der Umgebung, alle Einkaufsmöglichkeiten in 2 km Entfernung."
        ],
        "en": [
          "Typical stone cottage in the countryside, in a peaceful setting, for nature lovers. A modular house for 6 to 14 people with garden and terrace, a place to spend a pleasant stay with family or friends. Hiking and architectural sites nearby, shops 2 km away."
        ],
        "it": [
          "Tipico cottage in pietra in campagna, in un ambiente tranquillo, per gli amanti della natura. Una casa modulare per 6-14 persone con giardino e terrazza, un luogo dove trascorrere un piacevole soggiorno in famiglia o con gli amici. Escursioni e siti architettonici nelle vicinanze, tutti i negozi a 2 km."
        ],
        "fr": [
          "Gîte typique en pierres à la campagne, au calme, pour les amoureux de la nature. Une maison modulable de 6 à 14 personnes avec jardin et terrasse, un lieu pour passer un agréable séjour en famille ou entre amis. Randonnées et sites architecturaux aux alentours, tous commerces à 2 km."
        ],
        "nl": [
          "Typisch stenen huisje op het platteland, in een rustige omgeving, voor natuurliefhebbers. Een moduleerbaar huis voor 6 tot 14 personen met tuin en terras, een plek om een aangenaam verblijf door te brengen met familie of vrienden. Wandel- en architecturale sites in de buurt, alle winkels op 2 km."
        ],
        "es": [
          "Típica casa rural de piedra en el campo, en un entorno tranquilo, para los amantes de la naturaleza. Una casa modulable para 6 a 14 personas con jardín y terraza, un lugar para pasar una agradable estancia en familia o con amigos. Senderismo y sitios arquitectónicos cercanos, todos los comercios a 2 km."
        ]
      },
      "@type": [
        "Description"
