  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d9b0e30c-586b-3ff4-8343-e87437f9c408",
      "dc:description": {
        "de": [
          "Wohnung für 4 Personen. Résidence La Plage, im 1. Stock, Wohnung für 4 Personen, bestehend aus: 1 Wohnzimmer, 1 Schlafzimmer mit 1 Doppelbett, 1 Kabine mit 2 einfachen Etagenbetten sowie 1 ausgestattete Küche.\nTerrasse mit Meerblick. Großer Strand in 25m Entfernung. Einkaufsmöglichkeiten in 100m Entfernung.  \nVermietung das ganze Jahr über."
        ],
        "en": [
          "4-person apartment. Résidence La Plage, 1st floor, 4-person apartment comprising: 1 living room, 1 bedroom with 1 double bed, 1 cabin with 2 single bunk beds and 1 fully-equipped kitchen.\nTerrace with sea view. Large beach 25m away. Shops 100m away.  \nYear-round rental."
        ],
        "it": [
          "Appartamento per 4 persone. Residence La Plage, 1° piano, appartamento per 4 persone composto da: 1 soggiorno, 1 camera con 1 letto matrimoniale, 1 cabina con 2 letti a castello singoli e 1 cucina completamente attrezzata.\nTerrazza con vista mare. Grande spiaggia a 25 m. Negozi a 100 m.  \nAffitto per tutto l'anno."
        ],
        "fr": [
          "Appartement 4 personnes. Résidence La Plage, au 1er étage, appartement 4 personnes comprenant : 1 séjour, 1 chambre avec 1 lit double., 1 cabine avec 2 lits simples superposés. ainsi qu'1 cuisine équipée. \nTerrasse vue mer . Grande Plage à 25m. Commerces à 100m.  \nLocation toute l'année."
        ],
        "es": [
          "Piso para 4 personas. Residencia La Plage, 1er piso, apartamento para 4 personas compuesto por: 1 salón, 1 habitación con 1 cama doble, 1 cabina con 2 literas individuales y 1 cocina equipada.\nTerraza con vistas al mar. Gran playa a 25 m. Comercios a 100 m.  \nAlquiler todo el año."
        ],
        "nl": [
          "4-persoons appartement. Residence La Plage, 1e verdieping, 4-persoons appartement bestaande uit: 1 woonkamer, 1 slaapkamer met 1 tweepersoonsbed, 1 cabine met 2 eenpersoons stapelbedden en 1 volledig ingerichte keuken.\nTerras met uitzicht op zee. Groot strand op 25m. Winkels op 100m.  \nVerhuur het hele jaar door."
        ]
      },
