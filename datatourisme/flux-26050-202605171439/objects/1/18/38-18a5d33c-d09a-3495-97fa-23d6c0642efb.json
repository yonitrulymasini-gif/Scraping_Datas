  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/9834d2d3-7dbc-300f-a4c3-5fdefdbf261a",
      "dc:description": {
        "de": [
          "Entdecken Sie die Ruhe in unserem Haus mit 10 Zimmern, mit allem Komfort, Terrasse und Garten, das 30 Minuten von den Stränden entfernt liegt. Wir bieten Ihnen außerdem eine traditionelle, hausgemachte Küche mit frischen Produkten."
        ],
        "en": [
          "Discover the peace and quiet of our 10-room establishment, with its terrace and garden, located 30 minutes from the beaches. We also offer traditional, home-cooked cuisine based on fresh produce."
        ],
        "it": [
          "Godetevi la pace e la tranquillità della nostra struttura con 10 camere da letto, terrazza e giardino, situata a 30 minuti dalle spiagge. Offriamo anche una cucina tradizionale e casalinga a base di prodotti freschi."
        ],
        "fr": [
          "Découvrez la quiétude dans notre établissement de 10 chambres, tout confort, avec terrasse et jardin, situé à 30 mn des plages. Nous vous proposons également une cuisine traditionnelle faite maison, à base de produits frais."
        ],
        "nl": [
          "Geniet van de rust van ons 10 kamers tellende etablissement, met terras en tuin, gelegen op 30 minuten van de stranden. We bieden ook een traditionele, huisgemaakte keuken op basis van verse producten."
        ],
        "es": [
          "Disfrute de la tranquilidad de nuestro establecimiento de 10 habitaciones, con terraza y jardín, situado a 30 minutos de las playas. También ofrecemos cocina tradicional y casera basada en productos frescos."
        ]
      },
      "@type": [
        "Description"
      ],
