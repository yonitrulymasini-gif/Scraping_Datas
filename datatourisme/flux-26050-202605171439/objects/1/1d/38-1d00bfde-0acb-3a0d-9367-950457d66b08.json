  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/072b54d0-2fa3-3a35-80cd-0f75b218d6f4",
      "dc:description": {
        "de": [
          "Wir begrüßen Sie zu einem entspannten Aufenthalt in der Bretagne in einem unserer 18 Cottages. In der Nähe von La Gacilly, in Carentoir im Departement Morbihan, liegt unser über 3 Hektar großes Anwesen inmitten einer grünen Natur."
        ],
        "en": [
          "We welcome you for a relaxing stay in Brittany in one of our 18 cottages. Near La Gacilly, in Carentoir, Morbihan, our 3-hectare estate is nestled in the heart of lush greenery."
        ],
        "it": [
          "Vi diamo il benvenuto per una pausa rilassante in Bretagna in uno dei nostri 18 cottage. Vicino a La Gacilly, a Carentoir, nel Morbihan, la nostra tenuta di oltre 3 ettari è immersa nel cuore di una vegetazione lussureggiante."
        ],
        "fr": [
          "Nous vous accueillons pour un séjour détente en Bretagne dans l'un de nos 18 cottages. Proche de La Gacilly, à Carentoir, dans le Morbihan, notre domaine de plus de 3 hectares est niché au cœur d'une nature verdoyante."
        ],
        "nl": [
          "We verwelkomen je graag voor een ontspannende vakantie in Bretagne in een van onze 18 cottages. Vlakbij La Gacilly, in Carentoir, in Morbihan, ligt ons landgoed van meer dan 3 hectare midden in het groen."
        ],
        "es": [
          "Le invitamos a disfrutar de un relajante descanso en Bretaña en una de nuestras 18 casas rurales. Cerca de La Gacilly, en Carentoir, en Morbihan, nuestra finca de más de 3 hectáreas está enclavada en el corazón de una exuberante vegetación."
        ]
      },
      "@type": [
        "Description"
      ],
