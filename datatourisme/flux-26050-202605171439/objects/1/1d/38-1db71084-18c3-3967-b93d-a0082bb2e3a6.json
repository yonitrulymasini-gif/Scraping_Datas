      "dc:description": {
        "de": [
          "Besichtigung des ehemaligen herrschaftlichen Gerichtsauditoriums von Priziac, das in seinem ursprünglichen Zustand wunderschön restauriert wurde und eines der wenigen Beispiele ist, die in der Bretagne und in Frankreich erhalten geblieben sind."
        ],
        "en": [
          "Visit the former Auditoire de Justice de Priziac, magnificently restored to its original state and one of the few remaining examples in Brittany and France."
        ],
        "it": [
          "Visitate l'antico Auditoire de justice seigneuriale di Priziac, magnificamente restaurato allo stato originale e uno dei pochi esempi sopravvissuti in Bretagna e in Francia."
        ],
        "fr": [
          "Visite de l'ancien Auditoire de justice seigneuriale de Priziac, magnifiquement restauré dans son état originel et l'un des rares exemples subsistant en Bretagne et en France."
        ],
        "es": [
          "Visite el antiguo Auditoire de justice seigneuriale de Priziac, magníficamente restaurado a su estado original y uno de los pocos ejemplos supervivientes en Bretaña y Francia."
        ],
        "nl": [
          "Bezoek de voormalige Auditoire de justice seigneuriale in Priziac, prachtig gerestaureerd in de oorspronkelijke staat en een van de weinige overgebleven exemplaren in Bretagne en Frankrijk."
        ]
