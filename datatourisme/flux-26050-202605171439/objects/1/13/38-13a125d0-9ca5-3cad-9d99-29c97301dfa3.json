  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/84171447-bb0b-37e9-93e7-78bed7549bd4",
      "dc:description": {
        "de": [
          "In der Nähe des Waldes von Brocéliande und der Schulen von St-Cyr Coëtquidan heißen Sie Yves und Evelyne auf ihrem Bauernhof willkommen und laden Sie ein, das Landleben zu genießen."
        ],
        "en": [
          "Close to the Brocéliande forest and the Écoles de St-Cyr Coëtquidan, Yves and Evelyne welcome you to their farm, and invite you to enjoy life in the country."
        ],
        "it": [
          "Vicino alla foresta di Brocéliande e alle scuole di St-Cyr Coëtquidan, Yves ed Evelyne vi accolgono nella loro fattoria e vi invitano a godervi la vita in campagna."
        ],
        "fr": [
          "A proximité de la forêt de Brocéliande et des Écoles de St-Cyr Coëtquidan, Yves et Evelyne vous accueillent à la ferme, et vous invitent à savourer la vie à la campagne."
        ],
        "nl": [
          "In de buurt van het bos van Brocéliande en de scholen van St-Cyr Coëtquidan heten Yves en Evelyne je welkom op hun boerderij en nodigen ze je uit om te genieten van het leven op het platteland."
        ],
        "es": [
          "Cerca del bosque de Brocéliande y de las escuelas de St-Cyr Coëtquidan, Yves y Evelyne le dan la bienvenida a su granja y le invitan a disfrutar de la vida en el campo."
        ]
      },
      "@type": [
        "Description"
