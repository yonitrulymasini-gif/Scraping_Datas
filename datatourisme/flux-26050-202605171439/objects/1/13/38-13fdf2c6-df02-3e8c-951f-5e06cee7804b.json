      "dc:description": {
        "de": [
          "Der Wochenmarkt findet am Dienstag- und Freitagmorgen von 8 bis 13 Uhr auf dem Place du Voulien statt."
        ],
        "en": [
          "The weekly market is held on Tuesday and Friday mornings from 8am to 1pm on the Place du Voulien."
        ],
        "it": [
          "Il mercato settimanale si tiene il martedì e il venerdì mattina dalle 8 alle 13 in Place du Voulien."
        ],
        "fr": [
          "Le marché hebdomadaire se tient le mardi et le vendredi matin de 8h à 13h sur la place du Voulien."
        ],
        "es": [
          "El mercado semanal se celebra los martes y viernes por la mañana, de 8:00 a 13:00, en la plaza del Voulien."
        ],
        "nl": [
          "De wekelijkse markt wordt gehouden op dinsdag- en vrijdagochtend van 8.00 tot 13.00 uur op het Place du Voulien."
        ]
      },
