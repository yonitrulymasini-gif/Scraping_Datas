  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/38facf66-a8c5-3673-8ef1-5b49dd32e23c",
      "dc:description": {
        "de": [
          "Wohnung in separatem Haus, Einkaufsmöglichkeiten 1 km , Strände 2km, Küstenpfad 300m , Fahrradwege.\n\n55m² in der Nähe des Eigentümers, 2 Schlafzimmer mit 1 Doppelbett, Waschmaschine, Geschirrspüler, TV, Wifi, Parkplatz, geschlossenes Grundstück von 1000m²."
        ],
        "en": [
          "Apartment in detached house, shops 1 km away, beaches 2 km, coastal path 300 m away, cycle paths.\n\n55m² near the owner, 2 bedrooms with 1 double bed, washing machine, dishwasher, TV, wifi, parking, enclosed grounds of 1000m²."
        ],
        "it": [
          "Appartamento in casa indipendente, negozi a 1 km, spiagge a 2 km, sentiero costiero a 300 m, piste ciclabili.\n\n55m² vicino al proprietario, 2 camere con 1 letto matrimoniale, lavatrice, lavastoviglie, TV, wifi, parcheggio, terreno recintato di 1000m²."
        ],
        "fr": [
          "Appartement dans maison indépendante, commerces à 1 km , plages à 2km, sentier côtier à 300m , pistes cyclables. \n\n55m² à proximité du propriétaire, 2 chambres avec 1 lit 2 places, lave-linge, lave-vaisselle, TV, wifi, parking, terrain clos de 1000m²."
        ],
        "es": [
          "Piso en casa unifamiliar, comercios a 1 km, playas a 2 km, camino de ronda a 300 m, carril bici.\n\n55m² cerca del propietario, 2 habitaciones con 1 cama doble, lavadora, lavavajillas, TV, wifi, parking, terreno cerrado de 1000m²."
        ],
        "nl": [
          "Appartement in vrijstaand huis, winkels op 1 km, stranden op 2 km, kustpad op 300 m, fietspaden.\n\n55m² bij de eigenaar, 2 slaapkamers met 1 tweepersoonsbed, wasmachine, vaatwasser, TV, wifi, parkeerplaats, omheind terrein van 1000m²."
        ]
      },
