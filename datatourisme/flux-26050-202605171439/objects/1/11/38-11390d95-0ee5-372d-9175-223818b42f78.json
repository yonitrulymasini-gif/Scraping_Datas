      "dc:description": {
        "de": [
          "Paddeln Sie auf dem größten See der Bretagne\nVerleih von Kanus, Kajaks und Tretbooten auf dem Lac de Guerlédan in Anse de Sordan.\nGeöffnet von April bis Oktober."
        ],
        "en": [
          "Paddle on Brittany's largest lake\nCanoe-kayak and pedal-boat hire on Lac de Guerlédan at l'Anse de Sordan.\nOpen from April to October."
        ],
        "it": [
          "Pagaiare sul più grande lago della Bretagna\nNoleggio di canoe-kayak e pedalò sul Lac de Guerlédan a l'Anse de Sordan.\nAperto da aprile a ottobre."
        ],
        "fr": [
          "Pagayez sur le plus grand lac de Bretagne\nLocation de canoë-kayaks et pédalos sur le Lac de Guerlédan à l'Anse de Sordan.\nOuverture d'avril à octobre."
        ],
        "es": [
          "Remar en el lago más grande de Bretaña\nAlquiler de canoas-kayak y pedalós en el lago de Guerlédan, en l'Anse de Sordan.\nAbierto de abril a octubre."
        ],
        "nl": [
          "Peddel op het grootste meer van Bretagne\nVerhuur van kano's, kajaks en waterfietsen op het Lac de Guerlédan bij l'Anse de Sordan.\nGeopend van april tot oktober."
        ]
      },
