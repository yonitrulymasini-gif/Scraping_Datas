  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/58a551d9-1bbe-32f7-864a-f45ff116edea",
      "dc:description": {
        "de": [
          "La Reposée, zwei kleine Landhäuser aus dem 17. und 18. Jahrhundert, die zu einem einzigen umgebaut wurden, befinden sich in einem kleinen Weiler, der früher um seinen Steinofen und seinen Brunnen herum lebte."
        ],
        "en": [
          "La Reposée, two small country houses from the 17th and 18th centuries converted into one, located in a small hamlet that once revolved around its stone oven and well."
        ],
        "it": [
          "La Reposée, due piccole case di campagna del XVII e XVIII secolo trasformate in una sola, situate in un piccolo borgo che un tempo ruotava intorno al suo forno di pietra e al suo pozzo."
        ],
        "fr": [
          "La Reposée, deux petites maisons de campagne du 17 ème siècle et 18 ème siècle aménagées en une seule, située dans un petit hameau qui vivait autrefois autour de son four en pierres et de son puits."
        ],
        "nl": [
          "La Reposée, twee kleine landhuizen uit de 17e en 18e eeuw omgebouwd tot één geheel, gelegen in een klein gehucht dat ooit draaide om zijn stenen oven en waterput."
        ],
        "es": [
          "La Reposée, dos pequeñas casas de campo de los siglos XVII y XVIII convertidas en una, situadas en una pequeña aldea que antaño giraba en torno a su horno de piedra y su pozo."
        ]
      },
