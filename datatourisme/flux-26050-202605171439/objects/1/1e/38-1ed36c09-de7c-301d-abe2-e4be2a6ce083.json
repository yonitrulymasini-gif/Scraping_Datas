  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/639b9bea-dbfc-39b5-814c-e2c296252941",
      "dc:description": {
        "de": [
          "In einem ehemaligen Bauernhof aus dem 17. Jahrhundert, in der Nähe der kleinen charaktervollen Städte Malestroit, Rochefort-en-Terre und Josselin, des Kanals von Nantes nach Brest und eines grünen Weges."
        ],
        "en": [
          "In an old 17th-century farmhouse, near the small towns of Malestroit, Rochefort-en-Terre and Josselin, the Nantes-Brest canal and a greenway."
        ],
        "it": [
          "In un'antica casa colonica del XVII secolo, vicino alle cittadine di Malestroit, Rochefort-en-Terre e Josselin, al canale Nantes-Brest e a una strada verde."
        ],
        "fr": [
          "Dans une ancienne ferme du XVIIème siècle, près des petites cités de caractère de Malestroit, Rochefort-en-Terre, Josselin, du canal de Nantes à Brest et d'une voie verte."
        ],
        "nl": [
          "In een voormalige boerderij uit de 17e eeuw, vlakbij de stadjes Malestroit, Rochefort-en-Terre en Josselin, het kanaal Nantes-Brest en een groen pad."
        ],
        "es": [
          "En una antigua granja del siglo XVII, cerca de las pequeñas ciudades de Malestroit, Rochefort-en-Terre y Josselin, del canal Nantes-Brest y de una vía verde."
        ]
      },
      "@type": [
        "Description"
