      "dc:description": {
        "de": [
          "Mieten Sie eine 12 Meter lange Segelyacht (Bénéteau First 40.7) mit einem professionellen Skipper ab La Trinité sur Mer und entdecken Sie das Segeln und die bretonischen Inseln in aller Ruhe."
        ],
        "en": [
          "Rent a 12 meters sailboat (Bénéteau First 40.7) with a professional skipper from La Trinité sur Mer and discover the sailing and the Breton islands in all serenity."
        ],
        "it": [
          "Noleggiate una barca a vela di 12 metri (Bénéteau First 40.7) con uno skipper professionista a La Trinité sur Mer e scoprite la vela e le isole Bretoni in tutta tranquillità."
        ],
        "fr": [
          "Louez un voilier de 12 mètres (Bénéteau First 40.7) avec un skipper professionnel au départ de La Trinité sur Mer et découvrez la voile et les îles bretonnes en toute sérénité."
        ],
        "nl": [
          "Huur een zeilboot van 12 meter (Bénéteau First 40.7) met een professionele schipper van La Trinité sur Mer en ontdek in alle rust het zeilen en de Bretonse eilanden."
        ],
        "es": [
          "Alquile un velero de 12 metros (Bénéteau First 40.7) con un patrón profesional en La Trinité sur Mer y descubra la navegación y las islas bretonas con total tranquilidad."
        ]
      },
