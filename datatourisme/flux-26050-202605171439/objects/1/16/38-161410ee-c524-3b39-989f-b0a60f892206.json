  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8da01bfb-9952-3675-a4e8-af7cdf18d9e8",
      "dc:description": {
        "de": [
          "Sapa Restaurant Asian Food in Auray, und Lebensmittelgeschäft durchgehend geöffnet von Montag bis Samstag von 10.00 bis 20.00 Uhr.\n\nWir bieten Ihnen eine Straßengastronomie aus Südostasien, vor Ort oder zum Mitnehmen."
        ],
        "en": [
          "Sapa Asian Food Restaurant in Auray, and grocery store open Monday to Saturday, 10am to 8pm.\n\nWe offer Southeast Asian street food, on the premises or to take away."
        ],
        "it": [
          "Ristorante Sapa Asian Food ad Auray e negozio di alimentari aperto dal lunedì al sabato dalle 10.00 alle 20.00.\n\nOffriamo cibo di strada del Sud-Est asiatico, da mangiare o da portare via."
        ],
        "fr": [
          "Sapa Restaurant Asian Food à Auray, et épicerie ouvert en continu du lundi au samedi de 10h à 20h. \n\nNous vous proposons une gastronomie de rue d'Asie du Sud-Est, sur place ou à emporter."
        ],
        "nl": [
          "Sapa Asian Food Restaurant in Auray, en kruidenierswinkel geopend van maandag tot zaterdag van 10.00 tot 20.00 uur.\n\nWij bieden Zuidoost-Aziatisch straatvoedsel, om te eten of om mee te nemen."
        ],
        "es": [
          "Restaurante de comida asiática Sapa en Auray, y tienda de comestibles abierta de lunes a sábado de 10 a 20 h.\n\nOfrecemos comida callejera del sudeste asiático, para comer en el restaurante o para llevar."
        ]
      },
