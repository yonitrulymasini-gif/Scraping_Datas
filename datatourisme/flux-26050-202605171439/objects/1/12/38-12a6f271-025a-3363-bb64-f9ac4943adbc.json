  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/787e6b05-cbb0-391d-a02d-fa58199dd2e2",
      "dc:description": {
        "de": [
          "Bar Brasserie im Zentrum von La Gacilly, neben Les Halles, ganzjährig geöffnet mit einer sonnigen und ruhigen Terrasse in einer angenehmen Vegetation, die etwa 100 Plätze bieten kann. Wir freuen uns auf Ihren Besuch."
        ],
        "en": [
          "Bar-brasserie in the center of La Gacilly, next to Les Halles, open all year round with its sunny, peaceful terrace in pleasant greenery, seating around 100. We look forward to welcoming you."
        ],
        "it": [
          "Bar-brasserie nel centro di La Gacilly, accanto a Les Halles, aperto tutto l'anno con la sua terrazza soleggiata in un ambiente tranquillo e piacevole con circa 100 posti a sedere. Saremo lieti di darvi il benvenuto."
        ],
        "fr": [
          "Bar brasserie en plein centre de La Gacilly, à côté des Halles, ouverte à l'année avec sa terrasse ensoleillée et au calme dans une végétation agréable pouvant accueillir une centaine de places. Nous  vous accueillerons avec plaisir."
        ],
        "nl": [
          "Bar-brasserie in het centrum van La Gacilly, naast Les Halles, het hele jaar geopend met een zonnig terras in een rustige, aangename omgeving met zitplaatsen voor ongeveer 100 personen. We kijken ernaar uit je te verwelkomen."
        ],
        "es": [
          "Bar-brasserie en el centro de La Gacilly, junto a Les Halles, abierto todo el año con su terraza soleada en un entorno tranquilo y agradable con capacidad para unos 100 comensales. Estaremos encantados de recibirle."
        ]
      },
