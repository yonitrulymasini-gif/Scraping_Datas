  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/af6a4362-a23b-3600-9fac-b0dcdbf1d89f",
      "dc:description": {
        "de": [
          "Traditionelles Restaurant am Ortseingang von La Gacilly. Violaine und Sylvain empfangen Sie jeden Mittag unter der Woche sowie Freitag- und Samstagabend (dienstags geschlossen). Der Maître Restaurateur bietet Ihnen verschiedene frische und saisonal variierende Produkte an."
        ],
        "en": [
          "Traditional restaurant at the entrance to La Gacilly. Violaine and Sylvain welcome you for lunch on weekdays and for dinner on Fridays and Saturdays (closed on Tuesdays). This Master Restaurateur offers you a wide range of fresh seasonal produce."
        ],
        "it": [
          "Ristorante tradizionale situato all'ingresso di La Gacilly. Violaine e Sylvain vi accolgono a pranzo durante la settimana e il venerdì e il sabato sera (chiuso il martedì). Questo maestro ristoratore offre una varietà di prodotti freschi a seconda della stagione."
        ],
        "fr": [
          "Restaurant traditionnel situé à l'entrée de La Gacilly. Violaine et Sylvain vous accueillent tous les midis en semaine et les vendredis et samedis soir (Fermé le Mardi ). Différents produits frais et variés selon les saisons, vous seront proposés, par ce  Maître Restaurateur."
        ],
        "nl": [
          "Traditioneel restaurant bij de ingang van La Gacilly. Violaine en Sylvain heten je welkom voor de lunch doordeweeks en op vrijdag- en zaterdagavond (gesloten op dinsdag). Deze meester-restaurateur biedt een verscheidenheid aan verse producten, afhankelijk van het seizoen."
        ],
        "es": [
          "Restaurante tradicional situado a la entrada de La Gacilly. Violaine y Sylvain le dan la bienvenida para el almuerzo durante la semana y los viernes y sábados por la noche (cerrado los martes). Este maestro restaurador ofrece una gran variedad de productos frescos según la temporada."
        ]
      },
      "@type": [
        "Description"
