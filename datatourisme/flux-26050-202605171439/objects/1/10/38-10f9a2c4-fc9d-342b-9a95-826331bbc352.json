        "de": [
          "Der Wochenmarkt findet jeden Samstagmorgen in der Rue du Ponant statt, das ganze Jahr über von 8:00 bis 13:00 Uhr."
        ],
        "en": [
          "The weekly market takes place every Saturday morning on rue du Ponant, year-round from 8am to 1pm."
        ],
        "it": [
          "Il mercato settimanale si svolge ogni sabato mattina in rue du Ponant, tutto l'anno, dalle 8.00 alle 13.00."
        ],
        "fr": [
          "Le marché hebdomadaire se déroule tous les samedis matins, rue du Ponant, toute l'année de 8h à 13h."
        ],
        "es": [
          "El mercado semanal tiene lugar todos los sábados por la mañana en la rue du Ponant, durante todo el año de 8:00 a 13:00 horas."
        ],
        "nl": [
          "De wekelijkse markt vindt elke zaterdagochtend plaats in de rue du Ponant, het hele jaar door van 8.00 tot 13.00 uur."
        ]
