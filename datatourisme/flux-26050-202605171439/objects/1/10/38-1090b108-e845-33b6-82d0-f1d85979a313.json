  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d750bc45-2772-34e5-bfce-3df33257ff19",
      "dc:description": {
        "de": [
          "Jeden Samstag beherbergen wir im Grand Manger einen Markt mit lokalen Erzeugern:\nbiogemüse, Eier, Milchprodukte, Austern, Honig, Brot, Apfelsaft, Remouleur, ..."
        ],
        "en": [
          "Every Saturday we host a local farmers' market at Le Grand Manger:\norganic vegetables, eggs, dairy products, oysters, honey, bread, apple juice, remouleur, ..."
        ],
        "it": [
          "Ogni sabato ospitiamo un mercato di produttori locali presso Le Grand Manger:\nverdure biologiche, uova, prodotti caseari, ostriche, miele, pane, succo di mela, remouleur, ..."
        ],
        "fr": [
          "Tous les samedis nous accueillons un marché de producteurs locaux au Grand Manger : \nlégumes bio, oeufs, produits laitiers, huîtres, miel, pain, jus de pommes, rémouleur, ..."
        ],
        "es": [
          "Todos los sábados organizamos un mercado de productores locales en Le Grand Manger:\nverduras ecológicas, huevos, productos lácteos, ostras, miel, pan, zumo de manzana, remouleur, ..."
        ],
        "nl": [
          "Elke zaterdag organiseren we een markt van lokale producenten in Le Grand Manger:\nbiologische groenten, eieren, zuivelproducten, oesters, honing, brood, appelsap, remouleur, ..."
        ]
      },
