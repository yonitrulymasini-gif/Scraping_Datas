  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7cd058b8-b4d1-392d-9679-76723057ffcd",
      "dc:description": {
        "de": [
          "Eine von Morbihan Grandeur Nature angebotene Führung - Die Natur aus nächster Nähe beobachten -\n\nEntdecken Sie die erstaunliche Organisation eines Bienenvolkes, indem Sie in aller Sicherheit das Innere eines offenen Bienenstocks beobachten. Ein besonderer Moment, um zu verstehen, wie die Bienen leben, zusammenarbeiten und das Leben der Kolonie sichern."
        ],
        "en": [
          "Guided tour offered by Morbihan Grandeur Nature - Observe nature up close - \n\nDiscover the amazing organisation of a colony by observing the inside of an open beehive in complete safety. A unique opportunity to understand how bees live, cooperate and ensure the life of the colony."
        ],
        "it": [
          "Visita guidata proposta da Morbihan Grandeur Nature - Osservare la natura da vicino\n\nScoprite l'incredibile organizzazione di una colonia osservando l'interno di un alveare aperto in tutta sicurezza. Un'occasione unica per capire come le api vivono, collaborano e garantiscono la vita della colonia."
        ],
        "fr": [
          "Visite guidée proposée par Morbihan Grandeur Nature - Observer la nature de plus près - \n\nDécouvrez l’organisation étonnante d’une colonie en observant l’intérieur d’une ruche ouverte en toute sécurité. Un moment privilégié pour comprendre comment les abeilles vivent, coopèrent et assurent la vie de la colonie."
        ],
        "es": [
          "Visita guiada ofrecida por Morbihan Grandeur Nature - Observar la naturaleza de cerca -\n\nDescubra la sorprendente organización de una colonia observando el interior de una colmena abierta con total seguridad. Una oportunidad única para comprender cómo viven las abejas, cooperan y aseguran la vida de la colonia."
        ],
        "nl": [
          "Rondleiding aangeboden door Morbihan Grandeur Nature - Bekijk de natuur van dichtbij\n\nOntdek de verbazingwekkende organisatie van een bijenkolonie door in alle veiligheid de binnenkant van een open bijenkorf te observeren. Een unieke kans om te begrijpen hoe bijen leven, samenwerken en het leven van de kolonie verzekeren."
        ]
      },
