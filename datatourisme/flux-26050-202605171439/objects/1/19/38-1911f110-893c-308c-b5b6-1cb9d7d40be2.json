  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cb558806-0edc-3cdc-957a-19ae9f0dc320",
      "dc:description": {
        "de": [
          "Villa für 8 Personen, mit den Füßen im Sand, mit allem Komfort ausgestattet, Panoramablick auf den großen Strand und die Anlegestelle der Inseln. In einer entspannten Atmosphäre lädt Sie die Villa Bikini zur Erholung und Geselligkeit ein."
        ],
        "en": [
          "Villa for 8 people, feet in the sand, with every comfort, panoramic view of the large beach and the island pier. In a relaxed atmosphere, Villa Bikini invites you to relax and socialize."
        ],
        "it": [
          "Villa per 8 persone, ai piedi della sabbia, con tutti i comfort, vista panoramica sulla grande spiaggia e sul molo delle isole. In un'atmosfera rilassata, Villa Bikini vi invita a rilassarvi e a socializzare."
        ],
        "fr": [
          "Villa 8 personnes, les pieds dans le sable, dotée de tout le confort, vue panoramique sur la grande plage et sur l'embarcadère des îles. Dans une ambiance décontractée, la Villa Bikini vous invite à la détente et à la convivialité."
        ],
        "nl": [
          "Villa voor 8 personen, voeten in het zand, met alle comfort, panoramisch uitzicht op het grote strand en de pier van het eiland. In een ontspannen sfeer nodigt Villa Bikini je uit om te ontspannen en te socializen."
        ],
        "es": [
          "Villa para 8 personas, pies en la arena, con todas las comodidades, vista panorámica de la gran playa y el muelle de las islas. En un ambiente relajado, Villa Bikini le invita a relajarse y socializar."
        ]
      },
      "@type": [
        "Description"
