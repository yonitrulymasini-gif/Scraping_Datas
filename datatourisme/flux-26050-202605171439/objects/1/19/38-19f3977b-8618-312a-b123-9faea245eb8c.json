  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/d5d225ec-38d1-3fab-a0a9-084204dcb531",
      "dc:description": {
        "de": [
          "Unabhängige Wohnung mit einem großen Wohnraum mit Einbauküche, 2 richtigen Schlafzimmern, 1 Duschbad und einem separaten WC, gegenüber dem Eingang der Militärschule St Cyr Coëtquidan gelegen, in der Nähe von Geschäften und in der Nähe des Waldes von Brocéliande."
        ],
        "en": [
          "Self-contained apartment with large living room with fitted kitchen, 2 bedrooms, 1 shower room and separate toilet, located opposite the entrance to the St Cyr Coëtquidan military academy, close to shops and near the Brocéliande forest."
        ],
        "it": [
          "Appartamento indipendente composto da un ampio soggiorno con cucina attrezzata, 2 camere da letto, 1 bagno con doccia e un WC separato, situato di fronte all'ingresso dell'accademia militare di St Cyr Coëtquidan, vicino ai negozi e alla foresta di Brocéliande."
        ],
        "fr": [
          "Appartement indépendant avec une grande pièce de vie avec cuisine aménagée, 2 vraies chambres, 1 salle de douche et un WC indépendant, situé face à l'entrée de l'école militaire de St Cyr Coëtquidan, proche des commerces et à proximité de la forêt de Brocéliande."
        ],
        "nl": [
          "Zelfstandig appartement met een grote woonkamer met ingerichte keuken, 2 slaapkamers, 1 doucheruimte en een apart toilet, gelegen tegenover de ingang van de militaire academie St Cyr Coëtquidan, dicht bij de winkels en dicht bij het bos van Brocéliande."
        ],
        "es": [
          "Piso independiente con un gran salón con cocina equipada, 2 dormitorios, 1 cuarto de ducha y un aseo separado, situado frente a la entrada de la academia militar St Cyr Coëtquidan, cerca de los comercios y cerca del bosque de Brocéliande."
        ]
      },
