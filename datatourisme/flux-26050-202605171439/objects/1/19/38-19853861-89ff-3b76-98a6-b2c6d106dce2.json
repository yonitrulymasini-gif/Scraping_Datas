  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7e55ca95-4025-3f25-86fe-ffa30a7fb622",
      "dc:description": {
        "de": [
          "Eine hübsche Hütte, die in 6 m Höhe über einem schönen Tal thront, ist ein echtes Nest für eine oder mehrere Nächte! Ideal für maximal drei Personen, einschließlich Kinder."
        ],
        "en": [
          "A pretty cabin perched 6 m high overlooking a beautiful valley, a real nest for one night or more! Ideal for up to three people, including children."
        ],
        "it": [
          "Una graziosa baita arroccata a 6 metri di altezza che domina una splendida valle, un vero e proprio nido per una notte o più! Ideale per un massimo di tre persone, compresi i bambini."
        ],
        "fr": [
          "Une jolie cabane perchée à 6 m de hauteur surplombe une belle vallée, un véritable nid pour une nuit ou plusieurs ! Idéale pour trois personnes maximum, enfants compris."
        ],
        "es": [
          "Una bonita cabaña encaramada a 6 m de altura con vistas a un hermoso valle, ¡un auténtico nido para una noche o más! Ideal para un máximo de tres personas, niños incluidos."
        ],
        "nl": [
          "Een mooie hut op 6 m hoogte met uitzicht op een prachtige vallei, een echt nest voor een nacht of meer! Ideaal voor maximaal drie personen, inclusief kinderen."
        ]
      },
