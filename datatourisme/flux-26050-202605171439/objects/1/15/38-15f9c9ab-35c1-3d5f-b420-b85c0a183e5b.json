  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/76f7a697-076e-3abb-a270-201f9970a4a6",
      "dc:description": {
        "de": [
          "Die Hobbit-Hütte ist eine Art moderne Kapsel, die echten Komfort und eine zeitgemäße Ästhetik bietet.  Diese charmante und intime Unterkunft ist perfekt für 2 Personen.  Im Inneren verbindet sich moderner Komfort mit einem rustikalen Touch. Eine kleine Terrasse lädt zum Entspannen ein."
        ],
        "en": [
          "The Hobbit Cabin is a modern capsule of sorts, offering real comfort with a contemporary aesthetic.  This charming, intimate accommodation is perfect for 2 people.  Inside, modern comfort blends with a rustic touch. A small terrace invites you to relax."
        ],
        "it": [
          "La Cabina Hobbit è una sorta di capsula moderna che offre un vero comfort con un'estetica contemporanea.  Questa sistemazione intima e affascinante è perfetta per 2 persone.  All'interno, i comfort moderni si combinano con un tocco rustico. Una piccola terrazza invita al relax."
        ],
        "fr": [
          "La Cabane Hobbit est une sorte de capsule moderne qui offre un réel confort avec une ésthétique contemporaine.  Cet hébergement charmant et intimiste est parfait pour 2 personnes.  A l'intérieur, le confort moderne se marie avec une touche rustique. Une petite terrasse  invite à la détente."
        ],
        "es": [
          "La Cabaña Hobbit es una especie de cápsula moderna que ofrece auténtico confort con una estética contemporánea.  Este encantador e íntimo alojamiento es perfecto para 2 personas.  En su interior, las comodidades modernas se combinan con un toque rústico. Una pequeña terraza invita a relajarse."
        ],
        "nl": [
          "De Hobbit Cabin is een soort moderne capsule die echt comfort biedt met een eigentijdse esthetiek.  Deze charmante, intieme accommodatie is perfect voor 2 personen.  Binnenin wordt modern comfort gecombineerd met een rustieke toets. Een klein terras nodigt je uit om te ontspannen."
        ]
      },
