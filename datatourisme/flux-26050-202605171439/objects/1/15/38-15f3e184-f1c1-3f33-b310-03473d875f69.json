  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/00cb1c74-7e3d-3e20-8a92-19350f28c5ad",
      "dc:description": {
        "de": [
          "Haus 6 Personen.\n\nCharakteristisches Ferienhaus in einer geschützten Natur.\n\n Einladendes Anwesen auf einem ehemaligen Bauernhof mit Obstgärten, Wiesen und Wäldern auf 20 ha. Der Hof ist mit Blumengärten und Bäumen angelegt.\n\nSchöne Spaziergänge in Aussicht und Entdeckung der Natur."
        ],
        "en": [
          "House sleeps 6.\n\nCharacter gîte in unspoilt countryside.\n\n Welcoming property on an old farm with orchards, meadows and woods on 20 ha. The courtyard is laid out with flower gardens and trees.\n\nNice walks in perspective and discovery of nature."
        ],
        "it": [
          "Casa da 6 posti letto.\n\nGîte di carattere immerso nella campagna incontaminata.\n\n Proprietà accogliente in un'antica fattoria con frutteti, prati e boschi di 20 ettari. Il cortile è circondato da giardini fioriti e alberi.\n\nGrandi passeggiate e scoperta della natura."
        ],
        "fr": [
          "Maison 6 personnes. \n\nGîte de caractère dans une nature préservée.\n\n Propriété accueillante sur une ancienne ferme avec vergers, prairies, bois sur 20 ha. La cour est aménagée de jardins fleuris et arborés. \n\nBelle promenades en perspective et découverte de la nature."
        ],
        "es": [
          "La casa tiene capacidad para 6 personas.\n\nCasa rural de carácter situada en un campo virgen.\n\n Acogedora propiedad en una antigua granja con huertos, prados y bosques que cubren 20 hectáreas. El patio está decorado con jardines de flores y árboles.\n\nGrandes paseos y descubrimiento de la naturaleza."
        ],
        "nl": [
          "Huis voor 6 personen.\n\nKaraktervolle gîte op het ongerepte platteland.\n\n Gastvrij huis op een oude boerderij met boomgaarden, weiden en bossen van 20 hectare. De binnenplaats is aangelegd met bloementuinen en bomen.\n\nPrachtige wandelingen en ontdekking van de natuur."
        ]
      },
