  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f66ba887-81d3-3102-9013-9efea6a0444d",
      "dc:description": {
        "de": [
          "Kostenlose Anmeldung gegen Vorlage des Personalausweises\n- Eine reiche und sich ständig erweiternde Sammlung\n- Für Menschen mit Sehbehinderung geeignete Dokumente\n- Digitale Ressourcen\n- Ein Filmfonds\n- Ein Fonds Belle-Île und Bretagne\n- Ein Fonds für nachhaltige Entwicklung\n- Animationen für alle Altersgruppen\n- Multimedia-Zugang sowie Zugang zu Druckern und Kopierern"
        ],
        "en": [
          "Free registration with proof of identity\n- A rich and constantly evolving collection\n- Documents adapted for the visually impaired\n- Digital resources\n- A film collection\n- A Belle-île and Brittany collection\n- A sustainable development collection\n- Activities for all ages\n- Multimedia, printer and photocopier access"
        ],
        "it": [
          "Registrazione gratuita con un documento d'identità\n- Una collezione ricca e in continua evoluzione\n- Documenti adattati per gli ipovedenti\n- Risorse digitali\n- Una collezione di film\n- Collezione Belle-île e Bretagna\n- Una collezione sullo sviluppo sostenibile\n- Attività per tutte le età\n- Accesso multimediale e accesso a stampanti e fotocopiatrici"
        ],
        "fr": [
          "Inscription gratuite sur présentation de pièce d’identité\n- Une collection riche et en constante évolution\n- Des documents adaptés aux personnes malvoyantes\n- Des ressources numériques\n- Un fonds cinéma\n- Un fonds Belle-île et Bretagne\n- Un fonds développement durable\n- Des animations pour tout les âges\n- Un accès multimédia ainsi qu‘un accès imprimante et photocopieuse"
        ],
        "es": [
          "Inscripción gratuita con documento de identidad\n- Una colección rica y en constante evolución\n- Documentos adaptados a las personas con discapacidad visual\n- Recursos digitales\n- Colección de películas\n- Colección Belle-île y Bretaña\n- Una colección sobre desarrollo sostenible\n- Actividades para todas las edades\n- Acceso multimedia y acceso a impresoras y fotocopiadoras"
        ],
        "nl": [
          "Gratis registratie met identiteitsbewijs\n- Een rijke en voortdurend evoluerende collectie\n- Documenten aangepast voor slechtzienden\n- Digitale bronnen\n- Een filmcollectie\n- Een collectie Belle-île en Bretagne\n- Collectie duurzame ontwikkeling\n- Activiteiten voor alle leeftijden\n- Toegang tot multimedia, printers en kopieerapparaten"
        ]
      },
