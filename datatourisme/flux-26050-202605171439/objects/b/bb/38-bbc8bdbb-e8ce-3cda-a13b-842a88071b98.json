  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8a04a822-f62c-31e3-bb89-53460b110b62",
      "dc:description": {
        "de": [
          "In der Nähe des Waldes von Brocéliande und der Schulen von St-Cyr-Coëtquidan leben Sie den Geist der Bohème in diesen zwei Land-Roulottes im Schutz der großen Eichen!"
        ],
        "en": [
          "Close to the Brocéliande forest and the Écoles de St-Cyr-Coëtquidan, live the bohemian spirit in these two country gypsy caravans, sheltered by large oak trees!"
        ],
        "it": [
          "Vicino alla foresta di Brocéliande e alle scuole di St-Cyr-Coëtquidan, vivete lo spirito bohémien in queste due roulotte gitane di campagna, al riparo di grandi querce!"
        ],
        "fr": [
          "A proximité de la forêt de Brocéliande et des Écoles de St-Cyr-Coëtquidan, vivez l’esprit bohème dans ces deux roulottes de campagne, à l'abri des grands chênes !"
        ],
        "nl": [
          "Dicht bij het bos van Brocéliande en de scholen van St-Cyr-Coëtquidan, ervaar de bohemien geest in deze twee landelijke woonwagens, beschut door grote eiken!"
        ],
        "es": [
          "Cerca del bosque de Brocéliande y de las escuelas de St-Cyr-Coëtquidan, viva el espíritu bohemio en estas dos caravanas gitanas campestres, ¡al abrigo de grandes robles!"
        ]
      },
      "@type": [
        "Description"
