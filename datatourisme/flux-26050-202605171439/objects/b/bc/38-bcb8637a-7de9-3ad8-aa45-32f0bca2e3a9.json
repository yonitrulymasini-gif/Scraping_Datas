      "dc:description": {
        "de": [
          "Pferde, Ponys aller Niveaus - Ausritte in den Sümpfen, am Strand - Für Anfänger geeignet - Baby-Ponys ab 2 Jahren - Horse Ball - Polo - Dressur - CCE - CSO - Praktika - Bundesprüfungen - Pferdepensionen Wiesen/Boxen - Staatlich geprüfte Reitlehrer - Angeschlossen an FFE und Jeunesse et Sport.Vom 1. Juli bis 31. August."
        ],
        "en": [
          "Horses, ponies all levels - Riding in the marshes, on the beach - Accessible to beginners - Baby ponies from 2 years old - Horse ball - Polo - Dressage - CCE - CSO - Training courses - Federal exams - Pensions horses meadows/boxing - State qualified instructors - Affiliated FFE and Youth and Sport.from July 1st to August 31st."
        ],
        "it": [
          "Cavalli, pony a tutti i livelli - Equitazione in palude, sulla spiaggia - Accessibile ai principianti - Baby pony a partire da 2 anni - Horse ball - Polo - Dressage - CCE - CSO - Corsi di formazione - Esami federali - Pensione dei cavalli nei prati/boxing - Istruttori qualificati dallo Stato - Affiliato alla FFE e a Jeunesse et Sport. Dal 1° luglio al 31 agosto."
        ],
        "fr": [
          "Chevaux, poneys tous niveaux - Promenade dans les marais, sur la plage - Accessible aux débutants - Baby poneys à partir de 2 ans - Horse ball - Polo - Dressage - CCE - CSO - Stages - Examens fédéraux - Pensions chevaux prés/boxe - Moniteurs diplômés d'État - Affilié FFE et Jeunesse et Sport.Du 1er Juillet au 31 Août."
        ],
        "nl": [
          "Paarden, pony's alle niveaus - Paardrijden in de moerassen, op het strand - Toegankelijk voor beginners - Baby pony's vanaf 2 jaar - Paardenbal - Polo - Dressuur - CCE - CSO - Opleidingen - Federale examens - Pensionering van paarden in weiden/boxen - Staat gediplomeerde instructeurs - Aangesloten bij FFE en Jeunesse et Sport. 1 juli tot 31 augustus."
        ],
        "es": [
          "Caballos, ponis de todos los niveles - Equitación en las marismas, en la playa - Accesible a los principiantes - Ponis para bebés a partir de 2 años - Horse ball - Polo - Doma - CCE - CSO - Cursos de formación - Exámenes federales - Alojamiento de caballos en prados/boxing - Monitores cualificados por el Estado - Afiliado a la FFE y a Jeunesse et Sport. Del 1 de julio al 31 de agosto."
        ]
      },
