  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/95bff896-4a56-36db-8d63-ab53887df9e2",
      "dc:description": {
        "de": [
          "Kleines Haus auf dem Land, das Sie begeistern wird. Nur wenige Schritte von den Wanderwegen entfernt. Sie werden die Ruhe auf dem Land genießen und können die Reichtümer der Gegend entdecken."
        ],
        "en": [
          "Small country house that will seduce you. A stone's throw from hiking trails. Enjoy the peace and quiet of the countryside and discover the area's many attractions."
        ],
        "it": [
          "Piccola casa di campagna che vi piacerà. A due passi dai sentieri escursionistici. Potrete godere della pace e della tranquillità della campagna e scoprire i tesori della zona."
        ],
        "fr": [
          "Petite maison de campagne qui saura vous séduire. A deux pas des sentiers de randonnées. Vous apprécierez le calme de la campagne et pourrez découvrir les richesses du secteur."
        ],
        "es": [
          "Pequeña casa de campo que le encantará. A un paso de rutas de senderismo. Disfrutará de la tranquilidad del campo y podrá descubrir los tesoros de la zona."
        ],
        "nl": [
          "Klein landhuis waar je van zult houden. Op een steenworp afstand van wandelpaden. Je zult genieten van de rust en stilte van het platteland en de schatten van de streek kunnen ontdekken."
        ]
      },
