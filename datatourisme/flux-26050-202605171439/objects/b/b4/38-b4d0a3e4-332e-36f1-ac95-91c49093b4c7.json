  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c44b325f-bf05-31ed-b516-a47f20b0a48e",
      "dc:description": {
        "de": [
          "Dieses Ferienhaus liegt 10 Minuten zu Fuß vom Ortszentrum entfernt und ist ideal für Naturliebhaber, für einen ruhigen Urlaub mit der Familie oder mit Freunden."
        ],
        "en": [
          "Just a 10-minute walk from the town center, this gîte is ideal for nature lovers, for a peaceful vacation with family or friends."
        ],
        "it": [
          "A soli 10 minuti a piedi dal centro città, questo gîte è ideale per gli amanti della natura, per una vacanza tranquilla in famiglia o con gli amici."
        ],
        "fr": [
          "A 10 mn à pied du centre-bourg, ce gîte est idéal pour les amoureux de la nature, pour des vacances au calme en famille ou entre amis."
        ],
        "nl": [
          "Op slechts 10 minuten lopen van het stadscentrum is deze gîte ideaal voor natuurliefhebbers, voor een rustige vakantie met familie of vrienden."
        ],
        "es": [
          "A sólo 10 minutos a pie del centro de la ciudad, esta casa rural es ideal para los amantes de la naturaleza, para unas vacaciones tranquilas en familia o con amigos."
        ]
      },
