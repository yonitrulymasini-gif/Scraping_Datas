      "dc:description": {
        "de": [
          "Bar mit stimmungsvollem Ambiente.\nKonzerte, Aufführungen, Workshops und Jam Sessions.\nOrt des Austauschs und des Teilens.\nHausgemachte Biere und Cocktails."
        ],
        "en": [
          "Ambiance bar.\nConcerts, shows, workshops and jam sessions.\nA place for exchange and sharing.\nCraft beers and house cocktails."
        ],
        "it": [
          "Bar con atmosfera.\nConcerti, spettacoli, workshop e jam session.\nUn luogo di condivisione e scambio.\nBirre artigianali e cocktail della casa."
        ],
        "fr": [
          "Bar à ambiance.\nConcerts, spectacles, ateliers et jam sessions.\nLieu d'échange et de partage.\nBières artisanales et cocktails maison."
        ],
        "nl": [
          "Sfeervolle bar.\nConcerten, shows, workshops en jamsessies.\nEen plek om te delen en uit te wisselen.\nCraft bieren en huiscocktails."
        ],
        "es": [
          "Bar con ambiente.\nConciertos, espectáculos, talleres y jam sessions.\nUn lugar para compartir e intercambiar.\nCervezas artesanales y cócteles de la casa."
        ]
      },
