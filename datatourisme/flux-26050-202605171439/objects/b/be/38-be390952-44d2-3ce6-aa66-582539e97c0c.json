  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0a1efe18-f612-3be7-a303-8e4b653102fc",
      "dc:description": {
        "de": [
          "Gîte de la Muse für einen entspannenden Aufenthalt zwischen Legenden und Meer!\nDieses hübsche Haus aus dem Jahr 1860, das durch seine durchgehenden Balken im Obergeschoss untypisch ist, liegt im Zentrum von Sérent, in der Nähe von Ploërmel und Vannes."
        ],
        "en": [
          "Gîte de la Muse for a relaxing stay between legends and the sea!\nLovely 1860 house, atypical for its cross-beams upstairs, located in the center of Sérent, near Ploërmel and Vannes."
        ],
        "it": [
          "Gîte de la Muse per una pausa rilassante tra leggende e mare!\nUna graziosa casa del 1860, con travi incrociate atipiche al primo piano, situata nel centro di Sérent, vicino a Ploërmel e Vannes."
        ],
        "fr": [
          "Gîte de la Muse pour un séjour détente entre légendes & mer!\nJolie maison de 1860, atypique par ses poutres traversantes à l'étage, située au centre de Sérent, à proximité de Ploërmel et de Vannes."
        ],
        "nl": [
          "Gîte de la Muse voor een ontspannen vakantie tussen legendes en de zee!\nEen mooi huis uit 1860, met atypische dwarsbalken op de eerste verdieping, gelegen in het centrum van Sérent, vlakbij Ploërmel en Vannes."
        ],
        "es": [
          "Casa rural de la Muse para una escapada relajante entre leyendas y mar\nBonita casa de 1860, con atípicas vigas transversales en el primer piso, situada en el centro de Sérent, cerca de Ploërmel y Vannes."
        ]
      },
