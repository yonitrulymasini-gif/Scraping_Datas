      "dc:description": {
        "de": [
          "Ein Vorzeigeobjekt oder ein ungewöhnliches Objekt der Sammlungen, ein Vermittler / eine Vermittlerin des Museums enthüllt Ihnen seine / ihre Geschichte.\nDer Besuch ist in der freien Besichtigung des Museums inbegriffen."
        ],
        "en": [
          "A museum mediator will tell you all about its history.\nVisit included in the self-guided tour of the museum."
        ],
        "it": [
          "Un oggetto chiave o insolito delle collezioni, un mediatore del museo vi racconterà la sua storia.\nVisita inclusa nel tour autoguidato del museo."
        ],
        "fr": [
          "Objet phare ou insolite des collections, un médiateur / une médiatrice du musée vous dévoile son histoire. \nVisite incluse dans la visite libre du musée."
        ],
        "es": [
          "Un mediador del museo le contará la historia de un objeto clave o insólito de las colecciones.\nVisita incluida en el recorrido autoguiado por el museo."
        ],
        "nl": [
          "Een museummedewerker vertelt je alles over de geschiedenis van een belangrijk of ongewoon object in de collecties.\nBezoek inbegrepen in de rondleiding door het museum."
        ]
      },
