      "dc:description": {
        "de": [
          "12. Ausgabe ! Es werden verschiedene Strecken von 3, 7, 11, 16 und 22 km angeboten, die am Schloss Tronjoly beginnen. Treffpunkt um 9:30 Uhr zum Aufwärmen und kollektiver Start um 10:00 Uhr!"
        ],
        "en": [
          "12th edition! Various circuits of 3, 7, 11, 16 and 22 km are available, starting from the Château de Tronjoly. Meet at 9.30 am for warm-up and a mass start at 10 am!"
        ],
        "it": [
          "12ª edizione! Sono disponibili diversi percorsi di 3, 7, 11, 16 e 22 km, con partenza dal Castello di Tronjoly. Ritrovo alle 9.30 per il riscaldamento e partenza di massa alle 10.00!"
        ],
        "fr": [
          "12e édition ! Différents circuits de 3, 7, 11, 16 et 22 km sont proposés au départ du château de Tronjoly. RDV à 9h30 pour l'échauffement et un départ collectif à 10h !"
        ],
        "es": [
          "¡12ª edición! Varios recorridos de 3, 7, 11, 16 y 22 km con salida desde el castillo de Tronjoly. Cita a las 9.30 h para el calentamiento y salida masiva a las 10 h"
        ],
        "nl": [
          "12e editie! Er zijn verschillende routes beschikbaar van 3, 7, 11, 16 en 22 km, met vertrek vanaf het Château de Tronjoly. Verzamelen om 9.30 uur voor een warming-up en een massastart om 10.00 uur!"
        ]
      },
