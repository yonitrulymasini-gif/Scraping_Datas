  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/314973d0-6be5-3d2e-9ac6-28baa7bea70d",
      "dc:description": {
        "de": [
          "4*-Ferienhaus inmitten einer grünen Oase, in der Sie Ruhe und Erholung finden. Emmanuelle, die Besitzerin des Hauses, bietet Ihnen \"Wellness\"-Leistungen an: ayurvedische Massage und Entspannung durch Neurofeedback"
        ],
        "en": [
          "4* vacation home in the heart of greenery, calm and rejuvenation. Owner Emmanuelle offers a range of wellness services, including Ayurvedic massage and Neurofeedback relaxation"
        ],
        "it": [
          "Casa vacanze 4* nel cuore del verde, della calma e del ringiovanimento. Emmanuelle, la proprietaria, offre una serie di servizi di benessere, tra cui il massaggio ayurvedico e il rilassamento con neurofeedback"
        ],
        "fr": [
          "Maison de vacances 4* au cœur d'un écrin de verdure, calme et ressourcement. Emmanuelle, propriétaire des lieux, vous propose des prestations « bien-être » : massage ayurvédique et relaxation par Neurofeedback"
        ],
        "es": [
          "Casa de vacaciones de 4* en el corazón del verdor, la calma y el rejuvenecimiento. Emmanuelle, la propietaria, ofrece diversos servicios de bienestar, como masajes ayurvédicos y relajación Neurofeedback"
        ],
        "nl": [
          "4* vakantiehuis in het hart van groen, rust en verjonging. Emmanuelle, de eigenaresse, biedt een scala aan wellnessdiensten, waaronder Ayurvedische massage en Neurofeedback-ontspanning"
        ]
      },
      "@type": [
        "Description"
