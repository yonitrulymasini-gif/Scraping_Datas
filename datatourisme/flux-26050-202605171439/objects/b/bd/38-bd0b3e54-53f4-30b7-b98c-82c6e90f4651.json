  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/46f75b68-72e4-3645-9a30-f9749343f622",
      "dc:description": {
        "de": [
          "Restaurant, Crêperie, mit Tagesgerichten, Fleischstücken, Burgern, Fish and Chips? Crêperie mit glutenfreien Galettes aus 100 % Bio-Buchweizen und Weizencrêpes."
        ],
        "en": [
          "Restaurant, crêperie, with daily specials, butcher's cuts, burgers, fish and chips? Crêperie with 100% organic buckwheat, gluten-free galettes and wheat crêpes."
        ],
        "it": [
          "Ristorante, crêperie, con specialità del giorno, tagli di macelleria, hamburger, fish and chips? Crêperie con grano saraceno 100% biologico, galettes senza glutine e crêpes di grano."
        ],
        "fr": [
          "Restaurant, crêperie, avec plats du jour, pièce du boucher, burgers, fish and chips… Crêperie avec du des galettes 100% blé noir bio, sans gluten et crêpes de froment."
        ],
        "es": [
          "Restaurante, crêperie, con platos del día, cortes de carnicería, hamburguesas, fish and chips.. Crêperie con trigo sarraceno 100% ecológico, galettes sin gluten y crêpes de trigo."
        ],
        "nl": [
          "Restaurant, crêperie, met dagschotels, beenhouwerij, hamburgers, fish and chips? Crêperie met 100% biologische boekweit, glutenvrije galettes en tarwe crêpes."
        ]
      },
