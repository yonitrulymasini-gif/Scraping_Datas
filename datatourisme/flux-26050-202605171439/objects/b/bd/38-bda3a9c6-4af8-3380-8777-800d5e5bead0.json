  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/c8785595-a06a-3ca2-ad32-0b593280acdb",
      "dc:description": {
        "de": [
          "Organisierte JET-SKI-Wanderungen von Saint-Philibert aus (gegenüber von La-Trinité-sur-Mer), ohne Führerschein. Entdeckung der Bucht von Quiberon - Golf von Morbihan - Houat & Hoedic - Belle-Ile. Jet-Ski der neuesten Generation. Liebhaber von Nervenkitzel: Probieren Sie das FLYBOARD aus! Schweben Sie dank des Antriebs unter dem Brett über dem Wasser! Für alle ab 16 Jahren zugänglich"
        ],
        "en": [
          "JET-SKI excursions organized from Saint-Philibert (opposite La-Trinité-sur-Mer), without a permit. Discovery of the Bay of Quiberon - Gulf of Morbihan - Houat & Hoedic - Belle-Ile. Jets-ski of last generation. Lovers of strong sensations, come and try the FLYBOARD ! Fly over the water thanks to the propulsion under the board! Accessible to all, from 16 years old"
        ],
        "it": [
          "Escursioni JET-SKI organizzate da Saint-Philibert (di fronte a La-Trinité-sur-Mer), senza licenza. Scoprite la Baia di Quiberon - Golfo di Morbihan - Houat e Hoedic - Belle-Ile. Moto d'acqua di ultima generazione. Per gli amanti del brivido, venite a provare il FLYBOARD! Volate sull'acqua grazie alla propulsione sotto la tavola! Accessibile a tutti, a partire dai 16 anni"
        ],
        "fr": [
          "Randonnées JET-SKI organisées au départ de Saint-Philibert (en face de La-Trinité-sur-Mer), sans permis. Découverte de la Baie de Quiberon - Golfe du Morbihan - Houat & Hoedic - Belle-Ile. Jets-ski de dernière génération. Amateurs de sensations fortes, venez essayer le FLYBOARD ! Envolez-vous au dessus de l'eau grâce à la propulsion sous la planche ! Accessible à tous, à partir de 16 ans"
        ],
        "nl": [
          "JET-SKI excursies georganiseerd vanuit Saint-Philibert (tegenover La-Trinité-sur-Mer), zonder vergunning. Ontdek de Baai van Quiberon - Golf van Morbihan - Houat & Hoedic - Belle-Ile. Nieuwste generatie jetski. Voor sensatiezoekers, kom en probeer het FLYBOARD! Vlieg over het water dankzij de voortstuwing onder het board! Toegankelijk voor iedereen, vanaf 16 jaar"
        ],
        "es": [
          "Excursiones JET-SKI organizadas desde Saint-Philibert (frente a La-Trinité-sur-Mer), sin licencia. Descubra la Bahía de Quiberon - Golfo de Morbihan - Houat y Hoedic - Belle-Ile. Moto acuática de última generación. Para los amantes de las emociones, venga a probar el FLYBOARD ¡Vuela sobre el agua gracias a la propulsión bajo la tabla! Accesible para todos, a partir de 16 años"
        ]
      },
