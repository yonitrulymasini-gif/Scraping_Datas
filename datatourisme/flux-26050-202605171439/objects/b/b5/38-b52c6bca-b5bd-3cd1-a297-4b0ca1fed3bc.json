  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/8247b537-0a1b-35f6-a3b1-98db758752e5",
      "dc:description": {
        "de": [
          "Ob mit der Familie oder mit Freunden, das Schatzamt bietet Ihnen einen geräumigen und gemütlichen Raum, der komplett neu gestaltet wurde, auf Ihren Komfort ausgerichtet, funktional und leicht zu handhaben ist."
        ],
        "en": [
          "Whether you're with family or friends, La Trésorerie offers you a warm, spacious space that's been completely refurbished, designed for your comfort, functionality and ease of use."
        ],
        "it": [
          "Che siate in famiglia o con amici, La Trésorerie vi offre uno spazio caldo e spazioso, completamente rinnovato, progettato pensando al vostro comfort, funzionale e facile da vivere."
        ],
        "fr": [
          "En famille ou entre amis, la Trésorerie vous offre un espace spacieux et chaleureux entièrement refait à neuf, pensé pour votre confort, fonctionnel et facile à vivre."
        ],
        "nl": [
          "Of je nu met je gezin of met vrienden bent, La Trésorerie biedt je een warme, ruime ruimte die volledig is gerenoveerd, ontworpen met jouw comfort in gedachten, functioneel en gemakkelijk om mee te leven."
        ],
        "es": [
          "En familia o entre amigos, La Trésorerie le ofrece un espacio cálido y espacioso, totalmente reformado, diseñado pensando en su comodidad, funcional y fácil de vivir."
        ]
      },
