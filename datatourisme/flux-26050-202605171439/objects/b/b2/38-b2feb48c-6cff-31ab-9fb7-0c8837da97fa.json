  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/f15cd59d-4f04-3cc9-975f-a079098dafbe",
      "dc:description": {
        "de": [
          "Weltküche, Rotisserie, Paellas. Ambiente mit Musik aus aller Welt. Themenküche am Wochenende, Afterwork-Tapas/Platte. Geöffnet von Mittwoch bis Sonntag: Mittwoch und Donnerstag 11:30 15:00, 18:00 21:30. Freitag 11:30 15:00, 18:00 22:30. Samstag 11:30 15:00, 18:00 01:00. Sonntag 11:00 16:00, 18:00 21:30."
        ],
        "en": [
          "World cuisine, rotisserie, paellas. World music atmosphere. Theme cuisine at weekends, tapas/plank afterwork. Open Wednesday to Sunday: Wednesday and Thursday 11:30 15:00, 18:00 21:30. Friday 11:30 15:00, 18:00 22:30. Saturday 11:30 15:00, 18:00 01:00. Sunday 11:00 16:00, 18:00 21:30."
        ],
        "it": [
          "Cucina mondiale, rosticceria, paella. Atmosfera da musica mondiale. Cucina a tema nel fine settimana, tapas/piatti dopo il lavoro. Aperto da mercoledì a domenica: mercoledì e giovedì 11:30 15:00, 18:00 21:30. Venerdì 11:30 15:00, 18:00 22:30. Sabato 11:30 15:00, 18:00 01:00. Domenica 11:00 16:00, 18:00 21:30."
        ],
        "fr": [
          "Cuisine du monde, rôtisserie, paellas. Ambiance musique du monde. Cuisine à thème le week-end, afterwork tapas/planche. Ouvert du mercredi au dimanche : Mercredi et jeudi 11:30 15:00, 18:00 21:30. Vendredi 11:30 15:00, 18:00 22:30. Samedi 11:30 15:00, 18:00 01:00. Dimanche 11:00 16:00, 18:00 21:30."
        ],
        "nl": [
          "Wereldkeuken, rotisserie, paella's. Sfeer van wereldmuziek. Themakeuken in het weekend, tapas/plank na het werk. Geopend van woensdag tot zondag: woensdag en donderdag 11.30 15.00 uur, 18.00 21.30 uur. Vrijdag 11:30 15:00, 18:00 22:30. Zaterdag 11:30 15:00, 18:00 01:00. Zondag 11:00 16:00, 18:00 21:30."
        ],
        "es": [
          "Cocina del mundo, asador, paellas. Ambiente de músicas del mundo. Cocina temática los fines de semana, tapas/tapas afterwork. Abierto de miércoles a domingo: miércoles y jueves 11:30 15:00, 18:00 21:30. Viernes 11:30 15:00, 18:00 22:30. Sábado 11:30 15:00, 18:00 01:00. Domingo 11:00 16:00, 18:00 21:30."
        ]
      },
