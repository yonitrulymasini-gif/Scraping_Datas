  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b005cbe0-7684-3411-9b1b-8c8af08dbed8",
      "dc:description": {
        "de": [
          "Schule für verschiedene Aktivitäten: Surfen, Kajak, Paddeln, Strandsegeln, Longe côte, an der Landenge von Penthièvre gelegen.\nKurse, aber auch Verleih (Kajaks, Surfbretter, Paddles, Riesenpaddle)\nAlle Niveaus ab 8 Jahren.\nDiplomierte Lehrer und der Fédération Française de Surf angegliederte Schule\nUmkleidekabine und Toiletten vor Ort."
        ],
        "en": [
          "Multi-activity school: surfing, kayaking, paddling, sand yachting, longe côte, located on the isthmus of Penthièvre.\nLessons and rentals (kayaks, surfboards, paddles, giant paddle)\nAll levels from age 8.\nQualified instructors and school affiliated with the French Surfing Federation\nChanging room and toilets on site."
        ],
        "it": [
          "Scuola multiattività: surf, kayak, paddling, sand yachting, vela costiera, situata sull'istmo di Penthièvre.\nLezioni e noleggio (kayak, tavole da surf, pagaie, pagaia gigante)\nTutti i livelli dagli 8 anni in su.\nIstruttori qualificati e scuola affiliata alla Federazione Francese di Surf\nSpogliatoio e servizi igienici in loco."
        ],
        "fr": [
          "Ecole multi-activités: surf, kayak, paddle, char à voile, longe côte, située à l'isthme de Penthièvre. \nCours mais aussi location (kayaks, surfs, paddles, paddle géant)\nTous niveaux à partir de 8 ans.\nMoniteurs diplômés et école affiliée à la Fédération Française de Surf \nVestiaire et toilettes sur place."
        ],
        "nl": [
          "Multi-activiteiten school: surfen, kajakken, peddelen, strandzeilen, kustzeilen, gelegen op de landengte van Penthièvre.\nLessen en verhuur (kajaks, surfplanken, peddels, reuzenpeddel)\nAlle niveaus vanaf 8 jaar.\nGekwalificeerde instructeurs en school aangesloten bij de Franse Surf Federatie\nKleedkamer en toiletten ter plaatse."
        ],
        "es": [
          "Escuela multiactividades: surf, kayak, remo, vela de arena, vela costera, situada en el istmo de Penthièvre.\nClases y alquiler (kayaks, tablas de surf, remos, remo gigante)\nTodos los niveles a partir de 8 años.\nMonitores titulados y escuela afiliada a la Federación Francesa de Surf\nVestuarios y aseos in situ."
        ]
      },
