      "dc:description": {
        "de": [
          "Coralie und Anthony bereiten ihre Pizzen und bearbeiteten Gerichte wie Entrecôte und Seelachsrücken mit Sorgfalt aus frischen, lokalen Produkten zu."
        ],
        "en": [
          "Coralie and Anthony carefully prepare pizzas and dishes such as entrecote and saithe, using fresh local produce."
        ],
        "it": [
          "Coralie e Anthony preparano con cura le loro pizze e piatti come la bistecca di entrecote e il merluzzo carbonaro, utilizzando prodotti freschi locali."
        ],
        "fr": [
          "Coralie et Anthony vous préparent avec soin leurs pizzas et plats travaillés comme l'entrecôte et le dos de lieu noir, avec des produits frais et locaux."
        ],
        "es": [
          "Coralie y Anthony preparan con esmero sus pizzas y platos como el entrecot y el carbonero, utilizando productos locales frescos."
        ],
        "nl": [
          "Coralie en Anthony bereiden hun pizza's en gerechten zoals entrecote steak en koolvis zorgvuldig met verse lokale producten."
        ]
