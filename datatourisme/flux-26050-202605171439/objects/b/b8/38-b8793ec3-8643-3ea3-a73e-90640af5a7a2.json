      "dc:description": {
        "de": [
          "Studio, mit Blick auf den Kanal von Nantes nach Brest. Sie können Malestroit entdecken und schöne Spaziergänge am Wasser machen. In der Nähe der Geschäfte von Malestroit."
        ],
        "en": [
          "Studio overlooking the Nantes-Brest canal. You'll be able to discover Malestroit and take lovely walks along the water's edge. Close to Malestroit's shops."
        ],
        "it": [
          "Monolocale con vista sul canale di Nantes-Brest. Potrete scoprire Malestroit e fare belle passeggiate lungo la riva. Vicino ai negozi di Malestroit."
        ],
        "fr": [
          "Studio,  avec vue sur le canal de Nantes à Brest. Vous pourrez découvrir Malestroit et faire de jolies promenades au bord de l'eau. A proximité des commerces de Malestroit."
        ],
        "nl": [
          "Studio met uitzicht op het kanaal Nantes-Brest. Je kunt Malestroit ontdekken en genieten van mooie wandelingen langs het water. Dicht bij de winkels van Malestroit."
        ],
        "es": [
          "Estudio con vistas al canal Nantes-Brest. Podrá descubrir Malestroit y disfrutar de agradables paseos a orillas del agua. Cerca de las tiendas de Malestroit."
        ]
      },
