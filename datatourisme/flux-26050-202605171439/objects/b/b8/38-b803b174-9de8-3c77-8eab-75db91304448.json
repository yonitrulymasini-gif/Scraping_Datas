  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/5a9315ed-4d61-3da1-82aa-c504d8486a4f",
      "dc:description": {
        "de": [
          "Diese Gästezimmer im Schloss bieten Ihnen eine einzigartige Erfahrung, die sowohl modernen Luxus und Komfort als auch den historischen Charakter des Ortes vereint.  2 Suiten und 3 Doppelzimmer."
        ],
        "en": [
          "These guest rooms at the château offer a unique experience, combining modern luxury and comfort with the historic character of the site.  2 suites and 3 double rooms."
        ],
        "it": [
          "Queste camere del castello offrono un'esperienza unica, combinando lusso e comfort moderni con il carattere storico del sito.  2 suite e 3 camere doppie."
        ],
        "fr": [
          "Ces chambres d’hôtes au château vous proposent une expérience unique, alliant à la fois le luxe et le confort moderne, et le caractère historique du site.  2 suites et 3 ch doubles."
        ],
        "es": [
          "Estas habitaciones del castillo ofrecen una experiencia única, combinando el lujo y el confort modernos con el carácter histórico del lugar.  2 suites y 3 habitaciones dobles."
        ],
        "nl": [
          "Deze gastenkamers in het kasteel bieden een unieke ervaring en combineren moderne luxe en comfort met het historische karakter van de locatie.  2 suites en 3 tweepersoonskamers."
        ]
      },
