  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/86e16c1f-30bf-322a-b0a1-578537e08ea5",
      "dc:description": {
        "de": [
          "Geführte Besichtigung in Begleitung eines Mediators.\n\nEntdecken Sie das bäuerliche Leben vor 1950: Wohnraum, Landwirtschaft, Landschaft, Know-how... und erweitern Sie Ihren Blick auf das Pays d'Auray."
        ],
        "en": [
          "Guided tour accompanied by a mediator. \n\nCome and discover peasant life before 1950: housing, agriculture, landscape, skills... and gain a better understanding of the Pays d'Auray."
        ],
        "it": [
          "Visita guidata accompagnata da un mediatore.\n\nVenite a scoprire com'era la vita in campagna prima del 1950: abitazioni, agricoltura, paesaggio, abilità, ecc. e a conoscere meglio il Pays d'Auray."
        ],
        "fr": [
          "Visite guidée accompagnée d’un médiateur. \n\nVenez découvrir la vie paysanne avant 1950 : habitat, agriculture, paysage, savoir-faire… et enrichir votre regard sur le Pays d’Auray."
        ],
        "es": [
          "Visita guiada acompañada por un mediador.\n\nVenga a descubrir cómo era la vida en el campo antes de 1950: vivienda, agricultura, paisaje, oficios, etc., y conozca mejor el Pays d'Auray."
        ],
        "nl": [
          "Rondleiding onder begeleiding van een bemiddelaar.\n\nKom te weten hoe het leven was op het platteland vóór 1950: huisvesting, landbouw, landschap, vaardigheden, enz. en krijg een beter begrip van de Pays d'Auray."
        ]
      },
