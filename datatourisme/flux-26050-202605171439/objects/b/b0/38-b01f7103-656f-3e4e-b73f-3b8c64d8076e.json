      "dc:description": {
        "de": [
          "Atelier und Boutique für Glasmalerei. Originelle Kreationen rund um die Glasmalerei nach traditionellen und zeitgenössischen Methoden. Das ganze Jahr über geöffnet. Geöffnet am Montag, Dienstag, Donnerstag, Freitag und Samstag."
        ],
        "en": [
          "Stained glass workshop. Original creations around the stained glass following traditional and contemporary methods. Open all year round. Open Monday, Tuesday, Thursday, Friday and Saturday."
        ],
        "it": [
          "Laboratorio di vetrate. Creazioni originali su vetro colorato secondo metodi tradizionali e contemporanei. Aperto tutto l'anno. Aperto lunedì, martedì, giovedì, venerdì e sabato."
        ],
        "fr": [
          "Atelier boutique de vitraux. Créations originales autour du vitrail suivant les méthodes traditionnelles et contemporaines. Ouvert toute l'année. Ouvert le lundi, mardi, jeudi, vendredi et samedi."
        ],
        "es": [
          "Taller de vidrieras. Creaciones originales en torno a las vidrieras siguiendo métodos tradicionales y contemporáneos. Abierto todo el año. Abierto lunes, martes, jueves, viernes y sábado."
        ],
        "nl": [
          "Glas-in-lood atelier. Originele creaties rond glas in lood volgens traditionele en hedendaagse methodes. Het hele jaar geopend. Geopend op maandag, dinsdag, donderdag, vrijdag en zaterdag."
        ]
      },
