  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ced08d3a-0e1a-35c5-9603-112c1e54e04f",
      "dc:description": {
        "de": [
          "Das Gîte du Canal wurde 2017 renoviert, um Ihnen eine qualitativ hochwertige Unterkunft zu bieten, die sehr gut ausgestattet ist. Die Dekoration ist gepflegt, die Räume sind geräumig und hell."
        ],
        "en": [
          "The Gîte du Canal was renovated in 2017 to offer you a quality rental, very well equipped. The rooms are bright and spacious, and the decor has been carefully thought out."
        ],
        "it": [
          "Il Gîte du Canal è stato ristrutturato nel 2017 per offrirvi una sistemazione di alta qualità e ben attrezzata. È stato decorato con cura e le camere sono spaziose e luminose."
        ],
        "fr": [
          "Le Gîte du Canal a été rénové en 2017 pour vous offrir une location de qualité, très bien équipé. La décoration y est soignée, les pièces sont spacieuses et lumineuses."
        ],
        "es": [
          "El Gîte du Canal se renovó en 2017 para ofrecerle un alojamiento de gran calidad y bien equipado. Se ha decorado con esmero y las habitaciones son amplias y luminosas."
        ],
        "nl": [
          "De Gîte du Canal is in 2017 gerenoveerd om je een goed uitgeruste accommodatie van hoge kwaliteit te bieden. Het is met zorg ingericht en de kamers zijn ruim en licht."
        ]
      },
