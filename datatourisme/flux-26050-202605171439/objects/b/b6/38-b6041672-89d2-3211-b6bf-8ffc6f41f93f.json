  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/20f3f0f2-8e1f-3645-acbd-381e69077214",
      "dc:description": {
        "de": [
          "Kommen Sie an Bord eines Schnellbootes, das mit der hochwertigsten Ausrüstung ausgestattet ist, und entdecken Sie das moderne und sportliche Angeln auf Wolfsbarsch mit Ködern. Von der Küste bis zu den Inseln des Morbihan haben Sie die schönsten Landschaften um sich herum."
        ],
        "en": [
          "Embark on a speedboat, equipped with the highest quality material, come and discover the modern and sportive fishing of sea bass with lures. From the coast to the Morbihan islands, you will have the most beautiful landscapes around you."
        ],
        "it": [
          "Salite a bordo di un motoscafo e scoprite la pesca alla spigola moderna e sportiva con esche artificiali. Dalla costa alle isole del Morbihan, avrete intorno a voi i paesaggi più belli."
        ],
        "fr": [
          "Embarquez sur une vedette rapide.Equipé du matériel le plus haut de gamme, venez découvrir la pêche moderne et sportive du bar aux leurres. De la côte aux îles morbihannaises, vous aurez les plus beaux paysages autour de vous."
        ],
        "es": [
          "Suba a bordo de una lancha rápida y descubra la pesca moderna y deportiva de la lubina con señuelos. Desde la costa hasta las islas de Morbihan, tendrá los más bellos paisajes a su alrededor."
        ],
        "nl": [
          "Kom aan boord van een speedboot en ontdek het moderne en sportieve baarsvissen met kunstaas. Van de kust tot de eilanden van Morbihan heeft u de mooiste landschappen om u heen."
        ]
      },
