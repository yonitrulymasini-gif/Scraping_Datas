  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/06ae7ced-34f4-393d-a243-130c5ca68484",
      "dc:description": {
        "de": [
          "Allein in der Natur, auf dem Land bei Ploërdut, gegenüber der Sonne und einem kleinen Tal gelegen, wird Sie dieses Ferienhaus mit seiner gemütlichen Einrichtung begeistern. Ruhe garantiert."
        ],
        "en": [
          "Alone in the heart of nature, in the Ploërdut countryside, facing the sun and a small valley, this vacation home, with its cosy interior, will enchant you. Peace and quiet guaranteed."
        ],
        "it": [
          "Sola nel cuore della natura, nella campagna di Ploërdut, di fronte al sole e a una piccola valle, questa casa vacanze, con i suoi interni accoglienti, vi incanterà. Pace e tranquillità garantite."
        ],
        "fr": [
          "Seule en pleine nature, dans la campagne de Ploërdut, posée face au soleil et à une petite vallée, cette maison de vacances, avec son intérieur cosy, vous enchantera. Tranquillité assurée."
        ],
        "es": [
          "Sola en plena naturaleza, en el campo de Ploërdut, frente al sol y un pequeño valle, esta casa de vacaciones, con su acogedor interior, le encantará. Paz y tranquilidad garantizadas."
        ],
        "nl": [
          "Alleen in het hart van de natuur, op het platteland van Ploërdut, met uitzicht op de zon en een kleine vallei, zal dit vakantiehuis, met zijn gezellige interieur, je verrukken. Rust en stilte gegarandeerd."
        ]
      },
      "@type": [
        "Description"
