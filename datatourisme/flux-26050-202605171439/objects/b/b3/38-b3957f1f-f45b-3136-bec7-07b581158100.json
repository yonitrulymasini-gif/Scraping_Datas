  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3f444c2a-9a36-388d-8545-d8cf33558ce1",
      "dc:description": {
        "de": [
          "Das Restaurant Le Charly's befindet sich auf einem hübschen Platz gegenüber der Kirche Notre-Dame in Kernascléden. Es verfügt über eine Innenterrasse mit Blick auf die umliegende Landschaft und eine angenehme Außenterrasse. Das Restaurant bietet Ihnen 2 Räume-2 Stimmungen: eine Formel Buffet oder à la carte, alles hausgemacht. Vegetarische, vegane oder glutenfreie Gerichte auf vorherige Anfrage."
        ],
        "en": [
          "Le Charly's restaurant is located on a pretty square in front of the Notre-Dame church in Kernascléden. It has an indoor terrace overlooking the surrounding countryside and a pleasant outdoor terrace. The restaurant offers 2 dining rooms-2 atmospheres: buffet or à la carte, all homemade. Vegetarian, vegan and gluten-free dishes available on request."
        ],
        "it": [
          "Il ristorante Le Charly's si trova in una graziosa piazza di fronte alla chiesa di Notre-Dame a Kernascléden. Dispone di una terrazza interna con vista sulla campagna circostante e di una piacevole terrazza esterna. Il ristorante offre 2 sale da pranzo e 2 atmosfere: buffet o menu à la carte, tutti fatti in casa. Su richiesta sono disponibili piatti vegetariani, vegani e senza glutine."
        ],
        "fr": [
          "Le restaurant Le Charly's est situé sur une jolie place face à l'église Notre-Dame de Kernascléden. Il possède une terrasse intérieure avec vue sur la campagne environnante et une agréable terrasse extérieure. Le  restaurant vous propose 2 salles-2 ambiances :  une formule buffet ou à la carte, le tout fait maison. Plat végétarien, végan ou sans gluten sur demande préalable."
        ],
        "nl": [
          "Restaurant Le Charly's ligt aan een mooi plein tegenover de kerk Notre-Dame in Kernascléden. Het heeft een overdekt terras met uitzicht over het omliggende platteland en een aangenaam buitenterras. Het restaurant biedt 2 eetzalen-2 sferen: een buffet of à la carte menu, alles huisgemaakt. Vegetarische, veganistische en glutenvrije gerechten op aanvraag."
        ],
        "es": [
          "El restaurante Le Charly's está situado en una bonita plaza frente a la iglesia de Notre-Dame, en Kernascléden. Dispone de una terraza interior con vistas a la campiña de los alrededores y de una agradable terraza exterior. El restaurante ofrece 2 comedores y 2 ambientes: bufé o menú a la carta, todo casero. Platos vegetarianos, veganos y sin gluten disponibles previa petición."
        ]
      },
