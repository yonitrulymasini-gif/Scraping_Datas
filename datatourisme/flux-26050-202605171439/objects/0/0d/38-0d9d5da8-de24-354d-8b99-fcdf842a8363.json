  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/db80eeee-b677-331d-9dfe-6169cae00485",
      "dc:description": {
        "de": [
          "Das Festkomitee von Crédin organisiert das Fest von Couëdic mit einer Ausstellung von Oldtimern, darunter Feuerwehrfahrzeuge, einem Volkskonzert, einem Tausch- und Flohmarkt im Freien im Schloss von Couëdic und einem Essen im Wald (Reservierung per E-Mail oder Telefon bis zum 15. Juni erforderlich).\nEintritt frei."
        ],
        "en": [
          "Crédin's Comité des Fêtes organizes the Fête du Couëdic with an exhibition of vintage vehicles, including fire engines, a popular concert, an outdoor barter and flea market at the Château du Couëdic, and a meal in the woods (reservation by e-mail or telephone until June 15).\nFree admission."
        ],
        "it": [
          "Il comitato del festival di Crédin organizza la festa di Couëdic con un'esposizione di veicoli d'epoca, compresi quelli dei vigili del fuoco, un concerto popolare, un mercatino del baratto e dell'usato all'aperto presso il castello di Couëdic e un pranzo nel bosco (prenotazioni via e-mail o telefono fino al 15 giugno).\nL'ingresso è gratuito."
        ],
        "fr": [
          "Le comité des fêtes de Crédin organise la fête du Couëdic avec une exposition de véhicules anciens dont des véhicules de pompiers, un concert populaire, un troc et puces en extérieur au château du Couëdic, et un repas dans le bois (sur réservation par mail ou téléphone jusqu'au 15 juin).\nEntrée gratuite."
        ],
        "nl": [
          "Het festivalcomité van Crédin organiseert het festival van Couëdic met een tentoonstelling van oldtimervoertuigen, waaronder brandweerauto's, een populair concert, een ruil- en vlooienmarkt in de openlucht bij het Château du Couëdic en een maaltijd in het bos (reserveren per e-mail of telefoon tot 15 juni).\nDe toegang is gratis."
        ],
        "es": [
          "El comité de fiestas de Crédin organiza la fiesta de Couëdic con una exposición de vehículos de época, incluidos vehículos de los bomberos, un concierto popular, un mercadillo y trueque al aire libre en el castillo de Couëdic y una comida en el bosque (reservas por correo electrónico o teléfono hasta el 15 de junio).\nLa entrada es gratuita."
        ]
      },
