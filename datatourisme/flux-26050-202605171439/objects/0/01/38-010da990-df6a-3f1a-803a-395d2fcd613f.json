      "dc:description": {
        "de": [
          "Die Mediathek lädt Sie ein, den Geschichten und Kinderreimen von Karin und Corine zu lauschen.\n\nLesungen für 0-3-Jährige.\n\nKostenlos mit Anmeldung: 02 97 55 41 80 oder mediatheque@mairiebelz.com"
        ],
        "en": [
          "The multimedia library invites you to listen to stories and rhymes by Karine and Corine.\n\nReadings for 0-3 year olds.\n\nFree with registration: 02 97 55 41 80 or mediatheque@mairiebelz.com"
        ],
        "it": [
          "La biblioteca multimediale invita ad ascoltare le storie e le filastrocche di Karine e Corine.\n\nLetture per bambini da 0 a 3 anni.\n\nGratuito con iscrizione: 02 97 55 41 80 o mediatheque@mairiebelz.com"
        ],
        "fr": [
          "La médiathèque vous invite à écouter les histoires et comptines de Karine et Corine.\n\nLectures pour les 0-3 ans.\n\nGratuit sur inscription : 02 97 55 41 80 ou mediatheque@mairiebelz.com"
        ],
        "es": [
          "La biblioteca multimedia le invita a escuchar cuentos y canciones infantiles de Karine y Corine.\n\nLecturas para niños de 0 a 3 años.\n\nGratuito previa inscripción: 02 97 55 41 80 o mediatheque@mairiebelz.com"
        ],
        "nl": [
          "De mediatheek nodigt je uit om te luisteren naar verhalen en kinderliedjes van Karine en Corine.\n\nVoorlezen voor kinderen van 0-3 jaar.\n\nGratis bij inschrijving: 02 97 55 41 80 of mediatheque@mairiebelz.com"
        ]
      },
