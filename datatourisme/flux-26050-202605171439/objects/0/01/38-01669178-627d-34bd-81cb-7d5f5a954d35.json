  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a71bfad8-767e-34c2-9b33-92c98137110e",
      "dc:description": {
        "de": [
          "Bretonisches Haus von 100 m² ganz für Sie in ruhiger Lage mit einem Garten mit Bäumen. Sie können sich in der Hängematte entspannen und im Schutz des Apfelbaums essen."
        ],
        "en": [
          "100 m² Breton house entirely for you, in a quiet, wooded garden. You can relax in the hammock and eat in the shade of the apple tree."
        ],
        "it": [
          "Casa bretone di 100 m² interamente per voi nella pace con un giardino rialzato. Potrete rilassarvi sull'amaca e mangiare al riparo del melo."
        ],
        "fr": [
          "Maison bretonne de 100 m² entièrement pour vous au calme avec un jardin arboré. Vous pourrez vous détendre dans le hamac et manger à l'abri du pommier."
        ],
        "es": [
          "Casa bretona de 100 m² enteramente para usted en la tranquilidad con un jardín enarbolado. Podrá relajarse en la hamaca y comer al abrigo del manzano."
        ],
        "nl": [
          "Bretons huis van 100 m² helemaal voor jou in de rust met een verhoogde tuin. Je kunt ontspannen in de hangmat en eten onder de beschutting van de appelboom."
        ]
      },
