  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/38bb6ab5-9979-3aee-8224-00416db1c314",
      "dc:description": {
        "de": [
          "Dieses große Bauernhaus aus Stein befindet sich auf dem Land auf einem Bio-Bauernhof und ist gemütlich wie ein Haus eingerichtet. Zahlreiche Naturaktivitäten sind von der Unterkunft aus oder in der Nähe möglich."
        ],
        "en": [
          "Located in the countryside, on an organic farm, this large stone farmhouse is warmly furnished like a home. Numerous nature activities are possible from the gîte or nearby."
        ],
        "it": [
          "Situato in campagna, in una fattoria biologica, questo grande casale in pietra è arredato con calore come una casa. Molte attività naturalistiche sono possibili dal gîte o nelle vicinanze."
        ],
        "fr": [
          "Situé à la campagne, sur une ferme bio, cette grande longère en pierre est aménagée chaleureusement comme une maison. De nombreuse activités nature sont possibles depuis le gîte ou à proximité."
        ],
        "es": [
          "Situada en el campo, en una granja ecológica, esta gran casa rural de piedra está cálidamente amueblada como un hogar. Desde la casa rural o en las inmediaciones se pueden practicar numerosas actividades en la naturaleza."
        ],
        "nl": [
          "Gelegen op het platteland, op een biologische boerderij, is deze grote stenen boerderij warm ingericht als een thuis. Veel natuuractiviteiten zijn mogelijk vanuit de gîte of in de buurt."
        ]
      },
      "@type": [
        "Description"
