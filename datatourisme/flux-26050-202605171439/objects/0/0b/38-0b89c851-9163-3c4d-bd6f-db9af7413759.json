  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/51ec2f45-81b9-3a56-94a8-9f96d820fd90",
      "dc:description": {
        "de": [
          "Gegenüber dem Fischereihafen. Warmer und geselliger Rahmen. Entspannte Atmosphäre. Verwendung von frischen Produkten. Desserts aus eigener Herstellung. Freundliches Personal. Das ganze Jahr über jeden Tag geöffnet.\n\nService von 12 bis 14 Uhr und von 19 bis 21.30 Uhr. Durchgehender Service in den Sommermonaten (Juli-August) von 12 bis 22 Uhr."
        ],
        "en": [
          "Facing the fishing port. Warm and friendly setting. Relaxed atmosphere. Use of fresh produce. Home-made desserts. Friendly staff. Open every day of the year.\n\nService from 12h to 14h and from 19h to 21h30. Continuous service in summer (July-August) from 12pm to 10pm."
        ],
        "it": [
          "Di fronte al porto di pesca. Ambiente caldo e accogliente. Atmosfera rilassata. Utilizzo di prodotti freschi. Dolci fatti in casa. Personale cordiale. Aperto tutti i giorni dell'anno.\n\nServizio dalle 12.00 alle 14.00 e dalle 19.00 alle 21.30. Servizio continuo in estate (luglio-agosto) dalle 12:00 alle 22:00."
        ],
        "fr": [
          "Face au port de pêche. Cadre chaleureux et convivial. Ambiance décontractée. Utilisation de produits frais. Desserts maison. Personnel accueillant. Ouvert tous les jours de l'année. \n\nService de 12h à 14h et de 19h à 21h30. Service continu en période estivale (juillet-août) de 12h à 22h."
        ],
        "nl": [
          "Tegenover de vissershaven. Warme en vriendelijke omgeving. Ontspannen sfeer. Gebruik van verse producten. Huisgemaakte desserts. Vriendelijk personeel. Elke dag van het jaar geopend.\n\nBediening van 12.00 tot 14.00 uur en van 19.00 tot 21.30 uur. Doorlopende service in de zomer (juli-augustus) van 12.00 tot 22.00 uur."
        ],
        "es": [
          "Frente al puerto pesquero. Entorno cálido y acogedor. Ambiente relajado. Utilización de productos frescos. Postres caseros. Personal amable. Abierto todos los días del año.\n\nServicio de 12h a 14h y de 19h a 21h30. Servicio continuo en verano (julio-agosto) de 12.00 a 22.00 h."
        ]
      },
