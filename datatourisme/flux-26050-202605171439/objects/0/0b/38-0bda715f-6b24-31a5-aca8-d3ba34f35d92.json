      "dc:description": {
        "de": [
          "Jeden Mittwochmorgen ab 10 Uhr sind Kinder herzlich willkommen, um die neuen Jugendbücher zu entdecken, die von Audrey vorgelesen werden."
        ],
        "en": [
          "Every Wednesday morning from 10am, children are welcome to discover new children's books read by Audrey."
        ],
        "it": [
          "Ogni mercoledì mattina, a partire dalle 10, i bambini sono invitati a scoprire nuovi libri per bambini letti da Audrey."
        ],
        "fr": [
          "Tous les Mercredis matins à partir de 10h, les enfants sont les bienvenues pour découvrir les nouveaux albums jeunesses lus par Audrey."
        ],
        "es": [
          "Todos los miércoles a partir de las 10 de la mañana, los niños pueden descubrir nuevos libros infantiles leídos por Audrey."
        ],
        "nl": [
          "Elke woensdagochtend vanaf 10 uur zijn kinderen welkom om nieuwe kinderboeken te ontdekken die worden voorgelezen door Audrey."
        ]
      },
