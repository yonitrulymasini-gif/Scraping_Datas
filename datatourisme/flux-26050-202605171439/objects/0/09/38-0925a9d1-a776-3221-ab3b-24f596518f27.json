  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/feed0fa1-127f-3897-b350-9fdcdfa7e036",
      "dc:description": {
        "de": [
          "Ferienhaus Wohlbefinden Entspannung. 30 Minuten von Vannes und dem Golf von Morbihan entfernt. Charakteristisches Herrenhaus inmitten eines 7 Hektar großen Parks. Entdecken Sie einen einzigartigen und geschichtsträchtigen Ort, an dem Eleganz und Wohlbefinden für einen unvergesslichen Aufenthalt zusammenkommen"
        ],
        "en": [
          "Well-being and relaxation gîte. 30 min from Vannes and the Golfe du Morbihan. A manor house with character set in 7 hectares of parkland. Discover a unique place steeped in history, where elegance and well-being come together for an unforgettable stay!"
        ],
        "it": [
          "Gîte di benessere e relax. A 30 minuti da Vannes e dal Golfo di Morbihan. Una casa padronale di carattere immersa in 7 ettari di parco. Scoprite un luogo unico e ricco di storia, dove eleganza e benessere si fondono per un soggiorno indimenticabile!"
        ],
        "fr": [
          "Gîte bien être détente. A 30 min de Vannes et du Golfe du Morbihan. Manoir de caractère au coeur d'un parc de 7 hectares. Découvrez un lieu unique et chargé d'histoire, où élégance et bien être se conjuguent pour un séjour inoubliable!"
        ],
        "nl": [
          "Gîte voor welzijn en ontspanning. Op 30 minuten van Vannes en de Golf van Morbihan. Een karaktervol landhuis in een park van 7 hectare. Ontdek een unieke plek met een rijke geschiedenis, waar elegantie en welzijn samenkomen voor een onvergetelijk verblijf!"
        ],
        "es": [
          "Casa rural de bienestar y relajación. A 30 minutos de Vannes y del golfo de Morbihan. Una casa solariega con carácter situada en un parque de 7 hectáreas. Descubra un lugar único cargado de historia, donde la elegancia y el bienestar se unen para una estancia inolvidable"
        ]
      },
      "@type": [
        "Description"
      ],
