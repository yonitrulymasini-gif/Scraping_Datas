      "dc:description": {
        "de": [
          "Entdecken Sie die verschiedenen Objekte, die in den Werkstätten des Institut médico - éducatif de Tréleau hergestellt werden: Nähen, Holz, Maschinenbau und Grünflächen."
        ],
        "en": [
          "Come and discover the different objects created in the workshops of the Institut médico - éducatif de Tréleau: sewing, wood, machinery and green spaces."
        ],
        "it": [
          "Venite a scoprire i diversi oggetti creati nei laboratori dell'Institut médico - éducatif de Tréleau: cucito, legno, macchinari e spazi verdi."
        ],
        "fr": [
          "Venez découvrir les différents objets créés lors des ateliers de l’Institut médico - éducatif de Tréleau : couture, bois, machinisme et espaces verts."
        ],
        "es": [
          "Venga a descubrir los diferentes objetos creados en los talleres del Institut médico - éducatif de Tréleau: costura, madera, maquinaria y espacios verdes."
        ],
        "nl": [
          "Kom de verschillende voorwerpen ontdekken die in de ateliers van het Institut médico - éducatif de Tréleau zijn gemaakt: naaiwerk, hout, machines en groen."
        ]
