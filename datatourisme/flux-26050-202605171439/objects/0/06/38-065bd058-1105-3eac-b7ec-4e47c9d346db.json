  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2ebb0695-3318-3fc2-8269-e757f305ec1c",
      "dc:description": {
        "de": [
          "Stellen Sie sich vor, Sie wären in dieser geräumigen Wohnung im Zentrum des charmanten bretonischen Dorfes La Gacilly, das für seine Kunsthandwerker und sein jährliches Fotofestival berühmt ist und die Wiege der Familie von Yves Rocher ist."
        ],
        "en": [
          "Imagine yourself in this spacious apartment, perched in the heart of the charming Breton village of La Gacilly, famous for its arts and crafts, its annual photo festival and the birthplace of the Yves Rocher family."
        ],
        "it": [
          "Immaginatevi in questo spazioso appartamento, situato nel centro dell'affascinante villaggio bretone di La Gacilly, un luogo vivace e autentico, famoso per le sue arti e mestieri e per il suo festival fotografico annuale, luogo di nascita della famiglia Yves Rocher."
        ],
        "fr": [
          "Imaginez vous dans ce grand appartement spacieux, perché en hypercentre du charmant village breton de La Gacilly, authentique et très vivant, célèbre pour ses artisans d’art et son festival photo annuel, berceau de la famille d’Yves Rocher."
        ],
        "nl": [
          "Waan je in dit ruime appartement in het centrum van het charmante Bretonse dorp La Gacilly, een levendige en authentieke plaats, beroemd om zijn kunst en ambachten en het jaarlijkse fotofestival, de geboorteplaats van de familie Yves Rocher."
        ],
        "es": [
          "Imagínese en este espacioso apartamento, situado en pleno centro del encantador pueblo bretón de La Gacilly, un lugar animado y auténtico, famoso por su artesanía y su festival anual de fotografía, cuna de la familia Yves Rocher."
        ]
      },
      "@type": [
        "Description"
      ],
