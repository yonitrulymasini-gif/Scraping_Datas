      "dc:description": {
        "de": [
          "Gemeinsam für den Kampf gegen den Krebs. 6, 9 und 12 km, freier Start ab 8 Uhr gegenüber der Mediathek, 9 Uhr Aufwärmen und gemeinsamer Start. Anmeldung vor Ort oder online 10 ? Crêpes und Galettes vor Ort."
        ],
        "en": [
          "Together in the fight against cancer. 6, 9 and 12 km, free start from 8 a.m. in front of the media library, 9 a.m. warm-up and collective start. Registration on site or online 10? Pancakes and galettes on site."
        ],
        "it": [
          "Insieme nella lotta contro il cancro. 6, 9 e 12 km, partenza libera dalle ore 8 davanti alla mediateca, ore 9 riscaldamento e partenza di massa. Iscrizione in loco o online 10? Pancake e galette sul posto."
        ],
        "fr": [
          "Ensemble pour la lutte contre le cancer. 6, 9 et 12 km, départ libre à partir de 8h en face de la médiathèque, 9h échauffement et départ collectif. Inscription sur place ou en ligne 10 €. Crêpes et galettes sur place."
        ],
        "nl": [
          "Samen in de strijd tegen kanker. 6, 9 en 12 km, vrije start vanaf 8 uur voor de mediatheek, 9 uur warming-up en massastart. Inschrijven ter plaatse of online 10? Pannenkoeken en galetten ter plaatse."
        ],
        "es": [
          "Juntos en la lucha contra el cáncer. 6, 9 y 12 km, salida libre a partir de las 8 h delante de la mediateca, 9 h calentamiento y salida en masa. Inscripción in situ o en línea 10? Tortitas y galletas in situ."
        ]
      },
