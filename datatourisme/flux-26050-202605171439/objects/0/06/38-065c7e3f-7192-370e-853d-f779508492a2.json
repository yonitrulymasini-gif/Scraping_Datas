  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/2c217a96-7d99-3da6-be08-07f79e1c7871",
      "dc:description": {
        "de": [
          "Wir stellen unser altes Haus im Zentrum von St Martin als ganze Unterkunft zur Verfügung. Die An- und Abreise erfolgt selbstständig, aber wir bleiben die ganze Zeit erreichbar, wenn es nötig ist."
        ],
        "en": [
          "Our old house in the center of St Martin is available as a whole apartment. Arrival and departure are on your own, but we can be contacted at any time if necessary."
        ],
        "it": [
          "Mettiamo a disposizione la nostra vecchia casa nel centro di St Martin come alloggio completo. L'arrivo e la partenza avvengono autonomamente, ma se necessario possiamo essere contattati in qualsiasi momento."
        ],
        "fr": [
          "Nous mettons à disposition notre maison ancienne au centre de St Martin en logement entier. L'arrivée et le départ se font en autonomie, mais nous resterons joignables tout le temps si besoin."
        ],
        "nl": [
          "We stellen ons oude huis in het centrum van Sint Maarten beschikbaar als complete accommodatie. Aankomst en vertrek zijn op eigen gelegenheid, maar je kunt altijd contact met ons opnemen als dat nodig is."
        ],
        "es": [
          "Ponemos a su disposición nuestra antigua casa en el centro de San Martín como alojamiento completo. La llegada y la salida corren de su cuenta, pero puede ponerse en contacto con nosotros en cualquier momento si es necesario."
        ]
      },
