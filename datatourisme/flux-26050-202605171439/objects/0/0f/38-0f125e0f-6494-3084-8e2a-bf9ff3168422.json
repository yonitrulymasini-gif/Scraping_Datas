      "@id": "https://data.datatourisme.fr/aa4c3b89-0d05-3994-8106-eaf114e41234",
      "dc:description": {
        "de": [
          "Restaurant, Bar, Pizzeria\nCocktails\nVon April bis Oktober\nBlick auf die Bucht von Quiberon\nGesellige und entspannte Atmosphäre\nDJ-Sets während der Sommermonate\nReservierungen unter 02 97 59 19 15 oder im Internet ."
        ],
        "en": [
          "Restaurant, bar, pizzeria\nCocktails\nApril to October\nView over Quiberon Bay\nFriendly, relaxed atmosphere\nDJ Sets in summer\nFor reservations call 02 97 59 19 15 or visit our website."
        ],
        "it": [
          "Ristorante, bar, pizzeria\nCocktail\nDa aprile a ottobre\nVista sulla baia di Quiberon\nAtmosfera amichevole e rilassata\nDJ Set in estate\nPrenotazioni al numero 02 97 59 19 15 o su internet."
        ],
        "fr": [
          "Restaurant, bar, pizzéria\nCocktails\nDe Avril à Octobre\nVue sur la baie de Quiberon\nAmbiance conviviale et décontractée\nDJ Sets en période estivale\nRéservations au 02 97 59 19 15 ou sur internet ."
        ],
        "es": [
          "Restaurante, bar, pizzería\nCócteles\nDe abril a octubre\nVista sobre la bahía de Quiberon\nAmbiente agradable y relajado\nDJ Sets en verano\nReservas en el 02 97 59 19 15 o en Internet ."
        ],
        "nl": [
          "Restaurant, bar, pizzeria\nCocktails\nVan april tot oktober\nUitzicht over de baai van Quiberon\nVriendelijke, ontspannen sfeer\nDJ-sets in de zomer\nReserveringen op 02 97 59 19 15 of via internet ."
        ]
      },
