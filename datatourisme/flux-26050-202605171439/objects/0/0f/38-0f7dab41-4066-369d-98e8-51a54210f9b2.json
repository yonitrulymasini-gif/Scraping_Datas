  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a756fbe0-ffb2-3e64-b98a-5eac09255b3f",
      "dc:description": {
        "de": [
          "Ferienhaus mit Pool in einem Ferienhausdorf, 1,2 km von Quelneuc und 11 km von La Gacilly entfernt. Ehemaliges renoviertes Bauernhaus, das von der Ruhe seiner Umgebung profitiert."
        ],
        "en": [
          "Adjoining gîte with swimming pool in a self-catering village 1.2 km from Quelneuc and 11 km from La Gacilly. Renovated farmhouse benefits from peaceful surroundings."
        ],
        "it": [
          "Gîte adiacente con piscina in un villaggio indipendente a 1,2 km da Quelneuc e a 11 km da La Gacilly. Casa colonica ristrutturata in un ambiente tranquillo."
        ],
        "fr": [
          "Gîte mitoyen à la piscine dans un village de gîtes à 1,2 km de Quelneuc et 11 km de la Gacilly. Ancien corps de ferme rénové bénéficiant du calme de son environnement."
        ],
        "es": [
          "Casa rural adosada con piscina en un pueblo independiente a 1,2 km de Quelneuc y a 11 km de La Gacilly. Granja reformada en un entorno tranquilo."
        ],
        "nl": [
          "Aangrenzende gîte met zwembad in een vakantiehuisdorp op 1,2 km van Quelneuc en 11 km van La Gacilly. Gerenoveerde boerderij in een rustige omgeving."
        ]
      },
