  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/3c519294-7964-3f6b-88cf-0497b16e61cb",
      "dc:description": {
        "de": [
          "Gastfreundschaft ist die Philosophie des Ortes, an dem der persönliche Empfang gefördert wird. Gruppen, Wanderer, Familien, Freunde auf Kurzurlaub, jeder findet hier das passende Angebot."
        ],
        "en": [
          "Hospitality is the philosophy of the place, where a personalized welcome is encouraged. Groups, hikers, families, friends on a short break - there's something here for everyone."
        ],
        "it": [
          "L'ospitalità è la filosofia del luogo, dove viene incoraggiata un'accoglienza personalizzata. Gruppi, escursionisti, famiglie, amici per una breve vacanza: qui ce n'è per tutti i gusti."
        ],
        "fr": [
          "L’hospitalité est la philosophie du lieu, où l'on y favorise l'accueil personnalisé. Groupes, randonneurs, familles, amis en court séjour, chacun trouvera ici la formule adaptée."
        ],
        "es": [
          "La hospitalidad es la filosofía del lugar, donde se fomenta una acogida personalizada. Grupos, excursionistas, familias, amigos en una escapada: aquí hay algo para todos."
        ],
        "nl": [
          "Gastvrijheid is de filosofie van deze plek, waar een persoonlijk welkom wordt aangemoedigd. Groepen, wandelaars, gezinnen, vrienden op een korte vakantie - hier is voor elk wat wils."
        ]
      },
