      "dc:description": {
        "de": [
          "Neu renoviertes, sehr helles Ferienhaus in einem kleinen, friedlichen Dorf mit Blick auf einen riesigen, 2000 m² großen, angelegten Garten mit Bäumen."
        ],
        "en": [
          "Bright, newly-renovated vacation home set in a small, peaceful village, overlooking a huge 2,000 m² landscaped garden planted with trees."
        ],
        "it": [
          "Luminosa casa per vacanze recentemente ristrutturata, situata in un piccolo e tranquillo villaggio e affacciata su un grande giardino alberato di 2.000 m²."
        ],
        "fr": [
          "Maison de vacances nouvellement rénovée, très lumineuse, située dans un petit village paisible, donne sur un immense jardin paysagé et arboré de 2 000 m²."
        ],
        "es": [
          "Luminosa casa de vacaciones recién reformada situada en un pequeño y tranquilo pueblo, con vistas a un enorme jardín de 2.000 m² plantado de árboles."
        ],
        "nl": [
          "Licht, pas gerenoveerd vakantiehuis in een klein, rustig dorp, met uitzicht op een enorme landschapstuin van 2.000 m² met bomen."
        ]
