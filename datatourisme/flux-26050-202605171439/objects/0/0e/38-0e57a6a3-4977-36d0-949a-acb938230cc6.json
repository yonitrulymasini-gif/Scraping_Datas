  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a874a5e9-789c-32e4-a0f4-0475d88fe79f",
      "dc:description": {
        "de": [
          "Entdecken Sie eine für alle zugängliche Korbflechterei mit Rattan, dieser leicht zu verarbeitenden, weichen und geschmeidigen Liane. Stellen Sie einen kleinen Korb aus Rattan her. Geeignet für Kinder ab 7 Jahren in Begleitung ihrer Eltern."
        ],
        "en": [
          "Discover wickerwork that's accessible to all, thanks to rattan, a soft, supple vine that's easy to work with. Make a small rattan basket. Suitable for children over 7 accompanied by their parents."
        ],
        "it": [
          "Scoprite i lavori in vimini accessibili a tutti, grazie al rattan, un vitigno morbido e flessibile, facile da lavorare. Realizzazione di un piccolo cestino in rattan. Adatto ai bambini dai 7 anni in su accompagnati dai genitori."
        ],
        "fr": [
          "Découvrez une vannerie accessible à tous, grâce au rotin, cette liane facile à travailler, douce et souple. Réalisez un petit panier en rotin. Adapté aux enfants de plus de 7 ans accompagnés de leurs parents."
        ],
        "nl": [
          "Ontdek vlechtwerk dat voor iedereen toegankelijk is dankzij rotan, een zachte en soepele liaan die gemakkelijk te bewerken is. Maak een klein rotan mandje. Geschikt voor kinderen vanaf 7 jaar onder begeleiding van hun ouders."
        ],
        "es": [
          "Descubra un trabajo de mimbre al alcance de todos, gracias al ratán, una liana suave y flexible fácil de trabajar. Realice una pequeña cesta de ratán. Para niños a partir de 7 años acompañados de sus padres."
        ]
      },
