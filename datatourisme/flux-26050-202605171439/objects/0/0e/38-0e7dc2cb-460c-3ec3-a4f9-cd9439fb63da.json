  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/bfadf7f3-ba2d-399d-aa3f-ac4cc03148a0",
      "dc:description": {
        "de": [
          "Unabhängiges Ferienhaus auf einer Ebene in einem Anwesen zwischen Pleucadeuc und Malestroit. Gemütliche Inneneinrichtung. Angenehmer und erholsamer Rahmen. Schöne Aussicht. Gut ausgerichtete Terrasse."
        ],
        "en": [
          "Detached single-storey gîte in a property between Pleucadeuc and Malestroit. Warm interior. Pleasant, restful setting. Nice view. Well-exposed terrace."
        ],
        "it": [
          "Gîte indipendente a un piano in una proprietà tra Pleucadeuc e Malestroit. Interni caldi. Ambiente piacevole e rilassante. Vista incantevole. Terrazza ben esposta."
        ],
        "fr": [
          "Gîte indépendant de plain-pied dans une propriété entre Pleucadeuc et Malestroit. Intérieur chaleureux. Cadre agréable et reposant. Jolie vue. Terrasse bien exposée."
        ],
        "nl": [
          "Vrijstaande gelijkvloerse gîte op een landgoed tussen Pleucadeuc en Malestroit. Warm interieur. Aangename en ontspannende omgeving. Mooi uitzicht. Goed belicht terras."
        ],
        "es": [
          "Casa rural independiente de una sola planta en una propiedad entre Pleucadeuc y Malestroit. Interior cálido. Entorno agradable y relajante. Bonitas vistas. Terraza bien expuesta."
        ]
      },
