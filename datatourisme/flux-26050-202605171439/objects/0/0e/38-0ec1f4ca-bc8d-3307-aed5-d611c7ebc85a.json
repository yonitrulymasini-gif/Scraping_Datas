      "@id": "https://data.datatourisme.fr/9ce26325-264f-36f8-91db-48285419faa9",
      "dc:description": {
        "de": [
          "Entdecken Sie diese außergewöhnliche Wohnung, die sich im Herzen des charmanten Dorfes La Gacilly befindet, das für seine Kunsthandwerker und sein jährliches Fotofestival bekannt ist."
        ],
        "en": [
          "Discover this exceptional apartment, nestled in the heart of the charming village of La Gacilly, famous for its arts and crafts and its annual photo festival."
        ],
        "it": [
          "Scoprite questo appartamento eccezionale, immerso nel cuore dell'incantevole villaggio di La Gacilly, famoso per le sue arti e mestieri e per il suo festival fotografico annuale."
        ],
        "fr": [
          "Découvrez cet appartement d'exception, niché au coeur du charmant village de La Gacilly, célèbre pour ses artisans d'art et son festival photo annuel."
        ],
        "nl": [
          "Ontdek dit uitzonderlijke appartement, genesteld in het hart van het charmante dorpje La Gacilly, beroemd om zijn kunst en ambachten en het jaarlijkse fotofestival."
        ],
        "es": [
          "Descubra este piso excepcional, situado en el corazón del encantador pueblo de La Gacilly, famoso por su artesanía y su festival anual de fotografía."
        ]
      },
