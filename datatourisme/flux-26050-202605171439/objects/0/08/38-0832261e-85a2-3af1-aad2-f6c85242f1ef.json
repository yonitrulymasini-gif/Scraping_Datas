  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/b2bb0681-691f-3efc-9e08-59c146aaf582",
      "dc:description": {
        "de": [
          "Das Bar-Restaurant La Terrasse liegt in der Nähe des Kanals von Nantes nach Brest und bietet Ihnen jeden Tag ein einzigartiges Menü, traditionelle Küche mit hausgemachten Gerichten. Restauration nur mittags von Montag bis Freitag. Am Wochenende und an Feiertagen geschlossen. Die Bar ist von 9:00 bis 14:30 Uhr und von 16:00 bis 18:30 Uhr geöffnet."
        ],
        "en": [
          "Located near the Nantes-Brest canal, the bar-restaurant La Terrasse offers a unique menu every day, featuring traditional cuisine and homemade dishes. Lunchtime only, Monday to Friday. Closed on weekends and public holidays. The bar is open from 9am to 2.30pm and from 4pm to 6.30pm."
        ],
        "it": [
          "Situato vicino al canale di Nantes-Brest, il bar-ristorante La Terrasse propone ogni giorno un menu unico, con cucina tradizionale e piatti fatti in casa. Pranzo solo dal lunedì al venerdì. Chiuso nei fine settimana e nei giorni festivi. Il bar è aperto dalle 9.00 alle 14.30 e dalle 16.00 alle 18.30."
        ],
        "fr": [
          "Situé près du canal de Nantes à Brest, le bar-restaurant La Terrasse vous propose chaque jour un menu unique, cuisine traditionnelle avec des plats faits maison. Restauration seulement le midi du lundi au vendredi. Fermé le week-end et les jours fériés. Le bar est ouvert de 9h à 14h30 et de 16h à 18h30."
        ],
        "es": [
          "Situado cerca del canal Nantes-Brest, el bar-restaurante La Terrasse ofrece cada día un menú único, con cocina tradicional y platos caseros. Sólo almuerzo de lunes a viernes. Cerrado los fines de semana y los días festivos. El bar está abierto de 9:00 a 14:30 y de 16:00 a 18:30."
        ],
        "nl": [
          "Bar-restaurant La Terrasse ligt vlak bij het kanaal Nantes-Brest en biedt elke dag een uniek menu met traditionele gerechten en huisgemaakte gerechten. Alleen lunch van maandag tot vrijdag. Gesloten in het weekend en op feestdagen. De bar is geopend van 9.00 tot 14.30 uur en van 16.00 tot 18.30 uur."
        ]
      },
