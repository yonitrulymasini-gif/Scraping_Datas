  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/0bb5a695-7b39-3653-b6d9-970e106d7124",
      "dc:description": {
        "de": [
          "Von Wurzeln und \"L\",\nAls Kind des Landes lag mir ein Projekt sehr am Herzen: die Renovierung eines alten Gebäudes aus dem 17."
        ],
        "en": [
          "Des Racines Et Des \"L\",\nAs a local child, I had a project close to my heart: to renovate an old building dating from the 17th century, made of stones and earth that had belonged to my ancestors."
        ],
        "it": [
          "Des Racines Et Des \"L\",\nDa bambino del posto, avevo un progetto che mi stava a cuore: ristrutturare un vecchio edificio del XVII secolo, fatto di pietra e terra, appartenuto ai miei antenati."
        ],
        "fr": [
          "Des Racines Et Des \"L\",\nEnfant du Pays, un projet me tenait à coeur: rénover une vieille bâtisse datant du XVIIème faite de pierres et de terre ayant appartenu à mes aïeux."
        ],
        "es": [
          "Des Racines Et Des \"L\",\nTenía un proyecto muy cercano: renovar un antiguo edificio del siglo XVII, de piedra y tierra, que perteneció a mis antepasados."
        ],
        "nl": [
          "Des Racines Et Des \"L\",\nAls kind uit de buurt lag een project me na aan het hart: het renoveren van een oud gebouw uit de 17e eeuw, gemaakt van steen en aarde, dat toebehoorde aan mijn voorouders."
        ]
      },
