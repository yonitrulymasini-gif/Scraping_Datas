      "dc:description": {
        "de": [
          "Segelkurse, Meeresgarten, Ausflüge aufs Meer, Kurse auf Gruppenbooten, Wing Foil und E-Foils, Kitesurfen, Raids, Regatten. Vermietung von Booten, Katamaranen, Surfbrettern, Kajaks, Paddles."
        ],
        "en": [
          "Sailing courses, sea garden, sea outings, group boat courses, Wing Foil and e-foils, Kite Surf, raids, regattas. Rental of boats, catamarans, windsurfers, kayaks, paddles."
        ],
        "it": [
          "Corsi di vela, sea garden, uscite in mare, lezioni di gruppo in barca, Wing Foil ed e-foil, Kite Surf, raid, regate. Noleggio di barche, catamarani, windsurf, kayak e pagaie."
        ],
        "fr": [
          "Stages de voile, jardin des mers, sorties en mer, cours sur bateau collectif, Wing Foil et e-foils, Kite Surf, raids, régates. Location de bateaux, catamarans, planches à voile, kayaks, paddles."
        ],
        "nl": [
          "Zeilcursussen, zeetuin, uitstapjes op zee, bootlessen voor groepen, Wing Foil en e-foils, kitesurfen, raids, regatta's. Verhuur van boten, catamarans, windsurfers, kajaks en peddels."
        ],
        "es": [
          "Cursos de vela, jardín marino, salidas al mar, clases de barco en grupo, Wing Foil y e-foils, Kite Surf, raids, regatas. Alquiler de embarcaciones, catamaranes, windsurf, kayaks y remos."
        ]
      },
