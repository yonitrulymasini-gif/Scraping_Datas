  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6193de0d-6789-38d8-8d27-09588e00172c",
      "dc:description": {
        "de": [
          "Breizh Go Ile d'Arz fährt jeden Tag im Jahr zwischen Vannes, Séné und der Île d'Arz. Nutzen Sie diese Kreuzfahrt, um die Schönheit der Kapitänsinsel im Herzen des Golfs von Morbihan zu entdecken."
        ],
        "en": [
          "Every day of the year, Breizh Go Ile d'Arz operates between Vannes, Séné and Ile d'Arz. Take advantage of this cruise to discover the beauty of l'île aux capitaines in the heart of the Golfe du Morbihan."
        ],
        "it": [
          "Ogni giorno dell'anno, Breizh Go Ile d'Arz offre collegamenti tra Vannes, Séné e Ile d'Arz. Approfittate di questa crociera per scoprire la bellezza dell'île aux capitaines nel cuore del Golfe du Morbihan."
        ],
        "fr": [
          "Tous les jours de l'année, Breizh Go Ile d'Arz assure les liaisons entre Vannes, Séné et l'île d'Arz. Profitez de cette croisière pour découvrir la beauté de l'île aux capitaines au cœur du Golfe du Morbihan."
        ],
        "es": [
          "Todos los días del año, Breizh Go Ile d'Arz ofrece conexiones entre Vannes, Séné e Ile d'Arz. Aproveche este crucero para descubrir la belleza de l'île aux capitaines en el corazón del Golfe du Morbihan."
        ],
        "nl": [
          "Elke dag van het jaar verzorgt Breizh Go Ile d'Arz verbindingen tussen Vannes, Séné en Ile d'Arz. Profiteer van deze boottocht om de schoonheid van l'île aux capitaines in het hart van de Golfe du Morbihan te ontdekken."
        ]
      },
