  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/6070b1df-16e9-30bb-9a51-62eb3251a165",
      "dc:description": {
        "de": [
          "Meeresfrüchte-Restaurant mit Panoramablick auf die Barre d'Étel. Auf der Speisekarte: Meeresfrüchte, geräucherter BIO-Fisch, hausgemachte Desserts, Cocktails, Weinauswahl, Vorschläge der Woche mit einem vegetarischen Gericht und einem Fleischgericht. Retro-Ambiente, entspannt und herzlich."
        ],
        "en": [
          "Seafood restaurant with panoramic view of the Étel bar. Menu: seafood, organic smoked fish, homemade desserts, cocktails, wine selection, weekly suggestions with one vegetarian and one meat dish. A warm, relaxed, retro atmosphere."
        ],
        "it": [
          "Ristorante di pesce con vista panoramica sul bar Etel. In menu: frutti di mare, pesce affumicato biologico, dessert fatti in casa, cocktail, selezione di vini, proposte settimanali con un piatto vegetariano e uno di carne. Atmosfera calda, rilassata e retrò."
        ],
        "fr": [
          "Restaurant de fruits de mer avec vue panoramique sur la barre d'Étel. Au menu : fruits de mer, poissons fumés BIO, desserts maison, cocktails, sélection de vins, suggestions de la semaine avec un plat végétarien et un plat de viande. Ambiance rétro, décontractée et chaleureuse."
        ],
        "nl": [
          "Visrestaurant met panoramisch uitzicht op de Etel bar. Op het menu: zeevruchten, biologisch gerookte vis, huisgemaakte desserts, cocktails, wijnselectie, wekelijkse suggesties met een vegetarisch en een vleesgerecht. Een warme, ontspannen, retro sfeer."
        ],
        "es": [
          "Restaurante de marisco con vistas panorámicas al bar Etel. En el menú: marisco, pescado ahumado ecológico, postres caseros, cócteles, selección de vinos, sugerencias semanales con un plato vegetariano y otro de carne. Ambiente cálido, relajado y retro."
        ]
      },
      "@type": [
        "Description"
