  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/ad394488-9c9d-372d-b855-ef6e880f364c",
      "dc:description": {
        "de": [
          "Typisch bretonisches Familienhaus von ca. 185 m² auf 6000 m² bewaldetem Grundstück in ruhiger Lage in einem kleinen Dorf. Es verfügt über 2 Terrassen auf beiden Seiten des Hauses und eine schöne Veranda mit Wintergarten."
        ],
        "en": [
          "Typical Breton family home of approx. 185 m² on 6000 m² of wooded grounds in a quiet, small village. It has 2 terraces on both sides of the house and a pretty veranda-winter garden."
        ],
        "it": [
          "Tipica casa familiare bretone di circa 185 m² su 6000 m² di terreno alberato in una posizione tranquilla in un piccolo villaggio. Dispone di 2 terrazze su entrambi i lati della casa e di un grazioso giardino d'inverno-veranda."
        ],
        "fr": [
          "Maison familiale typique bretonne d'environ 185 m²  sur 6000 m² de terrain arboré et boisé au calme dans un petit village. Elle compte 2 terrasses sur les deux expositions de la maison et une jolie véranda-jardin d'hiver."
        ],
        "nl": [
          "Typisch Bretons familiehuis van ongeveer 185 m² op 6000 m² bebost terrein op een rustige locatie in een klein dorp. Het heeft 2 terrassen aan weerszijden van het huis en een mooie serre-wintertuin."
        ],
        "es": [
          "Típica casa familiar bretona de unos 185 m² situada en 6000 m² de terreno arbolado en una zona tranquila de un pequeño pueblo. Tiene 2 terrazas a cada lado de la casa y un bonito jardín de invierno."
        ]
      },
      "@type": [
        "Description"
      ],
