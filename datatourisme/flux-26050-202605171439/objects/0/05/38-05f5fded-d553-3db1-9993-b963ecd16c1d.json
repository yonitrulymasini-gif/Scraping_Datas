  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/644c952d-405b-3500-8cbc-3a09d0a12142",
      "dc:description": {
        "de": [
          "Wir servieren viel mehr als nur Galettes und Crêpes. Wenn Sie vom Strand zurückkehren, einen Snack oder eine Mahlzeit zu sich nehmen, bieten wir Ihnen einen Moment der Entspannung in einem schönen Gebäude aus den 30er Jahren mit Terrasse."
        ],
        "en": [
          "We serve much more than galettes and crêpes. On your return from the beach, for a snack or a meal, we offer you a moment of relaxation in a beautiful 1930s building with terrace."
        ],
        "it": [
          "Non serviamo solo galette e crêpes. Al ritorno dalla spiaggia, per uno spuntino o un pasto, vi offriamo un momento di relax in uno splendido edificio degli anni '30 con terrazza."
        ],
        "fr": [
          "Nous servons bien plus que des galettes et crêpes. Au retour de la plage, le temps d'un goûter ou d'un repas, nous vous proposons un moment de détente dans une belle bâtisse des années 30 avec terrasse."
        ],
        "nl": [
          "We serveren veel meer dan galettes en crêpes. Bij terugkomst van het strand, voor een snack of een maaltijd, bieden we je een moment van ontspanning in een prachtig jaren 30 gebouw met terras."
        ],
        "es": [
          "Servimos mucho más que galettes y crêpes. A la vuelta de la playa, para merendar o comer, le ofrecemos un momento de relax en un bonito edificio de los años 30 con terraza."
        ]
      },
      "@type": [
        "Description"
