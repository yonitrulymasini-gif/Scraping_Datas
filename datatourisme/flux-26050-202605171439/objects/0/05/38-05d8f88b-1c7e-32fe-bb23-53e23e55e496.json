  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/cd2d68ed-34d5-3e32-88e5-5b9ecadb4682",
      "dc:description": {
        "de": [
          "Dieses Ferienhaus im Herzen der Bretagne empfängt Sie für die Zeit Ihres Aufenthalts in der Region... An der Kreuzung zahlreicher historischer Stätten gelegen: Menhire von Monteneuf, mittelalterliche Stadt Malestroit, La Gacilly, Rochefort en Terre..."
        ],
        "en": [
          "Gîte in the heart of Brittany, welcoming you for the time of your stay in the region...Located at the crossroads of many historical sites: Menhirs of Monteneuf, medieval city of Malestroit, La Gacilly, Rochefort en Terre..."
        ],
        "it": [
          "Gîte nel cuore della Bretagna, vi accoglie per tutta la durata del vostro soggiorno nella regione...Situato al crocevia di numerosi siti storici: i Menhir di Monteneuf, la città medievale di Malestroit, La Gacilly, Rochefort en Terre..."
        ],
        "fr": [
          "Gîte au coeur de la Bretagne, vous accueillant le temps de votre passage dans la région...Situé au carrefour de nombreux sites historiques: Menhirs de Monteneuf, cité médiévale de Malestroit, La Gacilly, Rochefort en Terre..."
        ],
        "nl": [
          "Gîte in het hart van Bretagne, verwelkomt u voor de duur van uw verblijf in de regio...Gelegen op het kruispunt van vele historische plaatsen: de Menhirs van Monteneuf, de middeleeuwse stad Malestroit, La Gacilly, Rochefort en Terre..."
        ],
        "es": [
          "Casa rural en el corazón de Bretaña, le da la bienvenida durante su estancia en la región...Situada en la encrucijada de numerosos lugares históricos: los Menhires de Monteneuf, la ciudad medieval de Malestroit, La Gacilly, Rochefort en Terre..."
        ]
      },
