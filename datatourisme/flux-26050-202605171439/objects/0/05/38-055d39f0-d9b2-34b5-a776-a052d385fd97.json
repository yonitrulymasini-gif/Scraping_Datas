      "@id": "https://data.datatourisme.fr/cfe0830f-4e65-37f4-8aa7-bb3859460a11",
      "dc:description": {
        "de": [
          "Geführte Tour durch die Ausstellung\n\nEin Blick hinter die Kulissen der Ausstellung mit einem Fremdenführer.\n\nTreffpunkt in der Galerie des Klosters\n\nPreis: In der Eintrittsgebühr für die Ausstellung enthalten."
        ],
        "en": [
          "Guided tour of the exhibition\n\nBehind-the-scenes guided tour of the exhibition.\n\nRDV in the Galerie du Cloître\n\nPrice: Presentation included with exhibition admission."
        ],
        "it": [
          "Visita guidata alla mostra\n\nUna guida vi accompagnerà dietro le quinte della mostra.\n\nAppuntamento alla Galerie du Cloître\n\nPrezzo: Presentazione inclusa nel biglietto d'ingresso alla mostra."
        ],
        "fr": [
          "Visite guidée de l’exposition \n\nDécouverte des coulisses de l’exposition par un guide.\n\nRDV dans la Galerie du Cloître\n\nTarif : Présentation inclue dans le paiement de l’entrée de l’exposition."
        ],
        "es": [
          "Visita guiada a la exposición\n\nUn guía le llevará entre bastidores de la exposición.\n\nEncuentro en la Galerie du Cloître\n\nPrecio: Presentación incluida en el precio de entrada a la exposición."
        ],
        "nl": [
          "Rondleiding door de tentoonstelling\n\nEen gids neemt je mee achter de schermen van de tentoonstelling.\n\nAfspraak in de Galerie du Cloître\n\nPrijs: Presentatie inbegrepen in de toegangsprijs voor de tentoonstelling."
        ]
      },
