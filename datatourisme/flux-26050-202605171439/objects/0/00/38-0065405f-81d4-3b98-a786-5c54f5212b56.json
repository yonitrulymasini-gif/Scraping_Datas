  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/4fb87908-a86a-35a5-9870-5030aecdaa1c",
      "dc:description": {
        "de": [
          "Zwischen den beiden.\nGenießen Sie die Schönheit und den Luxus unseres einzigartig gestalteten Ferienhauses, umgeben von einem Gemüsegarten und dem Tal. Und nur 8 Minuten von der kleinen charaktervollen Stadt Guémené-sur-Scorff entfernt."
        ],
        "en": [
          "Entre Deux.\nEnjoy the beauty and luxury of our uniquely designed gîte, surrounded by the vegetable garden and the valley. And only 8 minutes from the small town of Guémené-sur-Scorff."
        ],
        "it": [
          "Entre Deux.\nGodetevi la bellezza e il lusso del nostro gîte dal design unico, circondato dall'orto e dalla valle. A soli 8 minuti dalla cittadina di Guémené-sur-Scorff."
        ],
        "fr": [
          "Entre Deux.\nProfitez de la beauté et du luxe de notre gîte au design unique, entouré du jardin potager et de la vallée. Et à seulement 8 min de la petite cité de caractère de Guémené-sur-Scorff."
        ],
        "nl": [
          "Entre Deux.\nGeniet van de schoonheid en luxe van onze uniek ontworpen gîte, omgeven door de moestuin en de vallei. En op slechts 8 minuten van het stadje Guémené-sur-Scorff."
        ],
        "es": [
          "Entre Deux.\nDisfrute de la belleza y el lujo de nuestra casa rural de diseño exclusivo, rodeada por el huerto y el valle. Y a sólo 8 minutos de la pequeña ciudad de Guémené-sur-Scorff."
        ]
      },
      "@type": [
        "Description"
      ],
