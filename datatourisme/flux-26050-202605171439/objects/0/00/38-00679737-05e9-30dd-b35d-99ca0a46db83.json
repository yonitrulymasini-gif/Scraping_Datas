      "dc:description": {
        "de": [
          "2 Rundgänge, 14 km, 14 ?, komplettes Menü (Aperitif, Zwiebelsuppe, Pastetenbrot, Galette saucisse, Dessert+Kaffee); 10 km, 11 ?, Menü mit Suppe ODER Pastete. Ermäßigter Preis für Kinder: 9? Start zwischen 11 Uhr und 12.30 Uhr. Anmeldungen bis zum 6. Oktober. Organisiert von der Schule Ste Barbe.  Becher mitbringen."
        ],
        "en": [
          "2 circuits, 14 km, 14?, full menu (aperitif, onion soup, pâté tartine, galette saucisse, dessert+coffee); 10 km, 11?, menu with soup OR pâté. Reduced price for children: 9? Departure between 11 a.m. and 12:30 p.m. Registration by October 6. Organized by Ecole Ste Barbe.  Please bring a cup."
        ],
        "it": [
          "2 circuiti, 14 km, ? 14, menu completo (aperitivo, zuppa di cipolle, tartina di paté, galette di salsiccia, dessert + caffè); 10 km, ? 11, menu con zuppa O paté. Prezzo ridotto per i bambini: 9 €. Partenza tra le 11.00 e le 12.30. Iscrizioni entro il 6 ottobre. Organizzata dalla scuola Ste Barbe.  Si prega di portare una tazza."
        ],
        "fr": [
          "2 circuits, 14 km, 14 €, menu complet (apéritif, soupe à l'oignon, tartine pâté, galette saucisse, dessert+café) ; 10 km, 11€, menu avec soupe OU pâté. Tarif réduit enfants : 9€. Départ entre 11h et 12h30. Inscriptions avant le 6 octobre. Organisé par l'école Ste Barbe.  Prévoir gobelet."
        ],
        "nl": [
          "2 circuits, 14 km, ? 14, volledig menu (aperitief, uiensoep, paté tartine, worst galette, dessert + koffie); 10 km, ? 11, menu met soep OF paté. Gereduceerde prijs voor kinderen: €9. Vertrek tussen 11u en 12u30. Inschrijven voor 6 oktober. Georganiseerd door Ste Barbe school.  Gelieve een beker mee te brengen."
        ],
        "es": [
          "2 circuitos, 14 km, 14 €, menú completo (aperitivo, sopa de cebolla, tartine de paté, galette de salchichas, postre + café); 10 km, 11 €, menú con sopa O paté. Precio reducido para niños: 9 €. Salida entre las 11.00 y las 12.30 horas. Inscripciones antes del 6 de octubre. Organizado por el colegio Ste Barbe.  Se ruega traer una taza."
        ]
      },
