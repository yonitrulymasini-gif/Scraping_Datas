      "dc:description": {
        "de": [
          "Trail-Herausforderungen: 25 km Start um 20 Uhr, 14 km Start um 20:30 Uhr, 7,5 km Start um 21 Uhr.\nMarsch-Challenges: 8 und 15 km Abfahrt von 16 bis 18 Uhr möglich.\nVerkostung von handwerklich gebrauten Bieren, begleitet von Galettes saucisses.\nAnmeldung www.klikego.com / Veranstalter: amicale du personnel de Baud Communauté"
        ],
        "en": [
          "Trail challenges: 25 km start at 8pm, 14 km start at 8:30pm, 7.5 km start at 9pm.\nWalking challenges: 8 and 15 km departures possible from 4 to 6 pm.\nArtisanal beer tasting with galettes saucisses.\nRegistration www.klikego.com / organizer: amicale du personnel de Baud Communauté"
        ],
        "it": [
          "Sfide di trail: 25 km con partenza alle 20.00, 14 km con partenza alle 20.30, 7,5 km con partenza alle 21.00.\nSfide a piedi: 8 e 15 km con partenza dalle 16.00 alle 18.00.\nDegustazione di birra artigianale accompagnata da galette di salsiccia.\nIscrizioni www.klikego.com / organizzatore: amicale du personnel de Baud Communauté"
        ],
        "fr": [
          "Défis trail : 25 km départ à 20h, 14 km départ à 20h30, 7,5 km départ à 21.\nDéfis marches : 8 et 15 km départ possible de 16h à 18h.\nDégustation de bières artisanales accompagnées de galettes saucisses.\nInscription www.klikego.com / organisateur : amicale du personnel de Baud Communauté"
        ],
        "nl": [
          "Trail uitdagingen: 25 km start om 20.00 uur, 14 km start om 20.30 uur, 7,5 km start om 21.00 uur.\nWandeluitdagingen: vertrek van 8 en 15 km mogelijk van 16 tot 18 uur.\nProeverij van ambachtelijk bier en galetten met worst.\nInschrijving www.klikego.com / organisator: amicale du personnel de Baud Communauté"
        ],
        "es": [
          "Desafíos de senderismo: 25 km con salida a las 20.00 h, 14 km con salida a las 20.30 h, 7,5 km con salida a las 21.00 h.\nDesafíos a pie: salidas de 8 y 15 km posibles de 16.00 a 18.00 h.\nDegustación de cerveza artesanal acompañada de galette saucisses.\nInscripción www.klikego.com / organizador: amicale du personnel de Baud Communauté"
        ]
      },
