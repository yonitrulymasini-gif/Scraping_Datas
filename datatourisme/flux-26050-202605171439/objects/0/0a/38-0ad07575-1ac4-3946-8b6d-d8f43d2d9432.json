      "@id": "https://data.datatourisme.fr/76bcd485-67ee-39a6-a179-1709dd7edcc8",
      "dc:description": {
        "de": [
          "Wanderungen, um die Gemeinde Saint-Barthélemy zu entdecken.\nEmpfang Kaffee, Sandwich, kostenloser Verzehr, Verpflegung.\nAbfahrt zwischen 7:30 und 10:00 Uhr. Teilnahmegebühr 5 ? zugunsten eines Vereins"
        ],
        "en": [
          "Walking tours to discover the commune of Saint-Barthélemy.\nWelcome coffee, sandwiches, free drinks, refreshments.\nDeparture between 7.30am and 10am. 5? donation to charity"
        ],
        "it": [
          "Visite a piedi alla scoperta del comune di Saint-Barthélemy.\nA disposizione caffè, panini, bevande gratuite e rinfreschi.\nPartenza tra le 7.30 e le 10.00. Partecipazione 5? a favore di un ente di beneficenza"
        ],
        "fr": [
          "Randonnées pédestres pour découvrir la commune de Saint-Barthélemy.\nAccueil café, sandwich, consommation offerte, ravitaillement.\nDépart entre 7h30 et 10h. Participation 5€ au profit d'une association"
        ],
        "nl": [
          "Wandelingen om de gemeente Saint-Barthélemy te ontdekken.\nKoffie, broodjes, gratis drankjes en versnaperingen zijn beschikbaar.\nVertrek tussen 7.30 en 10.00 uur. Deelname 5? ten voordele van een goed doel"
        ],
        "es": [
          "Paseos para descubrir el municipio de Saint-Barthélemy.\nCafé, bocadillos, bebidas y refrescos gratuitos.\nSalidas entre las 7h30 y las 10h00. Participación 5? a beneficio de una organización benéfica"
        ]
      },
