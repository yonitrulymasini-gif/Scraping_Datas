  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/a0b93fe9-44af-308b-a921-6cec1c4ce6b1",
      "dc:description": {
        "de": [
          "Direktverkauf an Privatpersonen von Geflügel, Foie Gras, Confits, Wurstwaren oder Panés, gefüllte Körbe mit lokalen Körben.\nGeöffnet montags bis freitags von 10 bis 18 Uhr und samstags von 9 bis 12.30 Uhr."
        ],
        "en": [
          "Direct sales to individuals of poultry, foie gras, confits, charcuterie or baskets filled with local baskets.\nOpen Monday to Friday from 10am to 6pm and Saturday from 9am to 12:30pm."
        ],
        "it": [
          "Vendita diretta ai privati di pollame, foie gras, confit, salumi o cesti pieni di prodotti locali.\nAperto dal lunedì al venerdì dalle 10.00 alle 18.00 e il sabato dalle 9.00 alle 12.30."
        ],
        "fr": [
          "Vente directe aux particuliers de volailles, foie gras, confits, charcuteries ou panés, paniers garnis de paniers locaux.\nOuvert du lundi au vendredi de 10h à 18h et le samedi de 9h à 12h30."
        ],
        "es": [
          "Venta directa a particulares de aves de corral, foie gras, confits, charcutería o cestas rellenas de productos locales.\nAbierto de lunes a viernes de 10.00 a 18.00 horas y los sábados de 9.00 a 12.30 horas."
        ],
        "nl": [
          "Directe verkoop aan particulieren van gevogelte, foie gras, confits, charcuterie of manden gevuld met lokale manden.\nGeopend van maandag tot vrijdag van 10.00 tot 18.00 uur en zaterdag van 9.00 tot 12.30 uur."
        ]
      },
