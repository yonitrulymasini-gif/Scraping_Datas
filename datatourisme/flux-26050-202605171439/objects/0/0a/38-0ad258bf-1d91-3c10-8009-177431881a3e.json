  "hasDescription": [
    {
      "@id": "https://data.datatourisme.fr/7df0ba99-b06f-3e53-9a06-5e1eb7ac35e4",
      "dc:description": {
        "de": [
          "Dieses gemütliche Haus bietet Platz für bis zu 4 Personen. Das Ambiente dieses Cottages bietet einen geselligen und komfortablen Raum, der sich perfekt für einen Aufenthalt mit der Familie oder mit Freunden eignet."
        ],
        "en": [
          "This cosy cottage can accommodate up to 4 people. The ambience of this cottage offers a friendly and comfortable space, perfect for stays with family or friends."
        ],
        "it": [
          "Questo accogliente cottage può ospitare fino a 4 persone. L'atmosfera di questo cottage offre uno spazio accogliente e confortevole, perfetto per un soggiorno in famiglia o con gli amici."
        ],
        "fr": [
          "Cette maison chaleureuse peut accueillir jusqu'à 4 personnes. L'ambiance de ce cottage offre un espace convivial et confortable, parfait pour les séjours en famille ou entre amis."
        ],
        "es": [
          "Esta acogedora casa de campo tiene capacidad para 4 personas. El ambiente de esta casa de campo ofrece un espacio acogedor y confortable, perfecto para una estancia en familia o con amigos."
        ],
        "nl": [
          "Deze gezellige cottage is geschikt voor maximaal 4 personen. De sfeer van deze cottage biedt een vriendelijke en comfortabele ruimte, perfect voor een verblijf met familie of vrienden."
        ]
      },
